<Window x:Class="ProjectStarkSemi.ConoscopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ProjectStarkSemi.Properties"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        Title="Conoscope" Height="750" Width="1582" Background="{DynamicResource GlobalBackground}">
    <Window.Resources>
        <DataTemplate x:Key="DocumentHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource GlobalBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" WindowChrome.IsHitTestVisibleInChrome="True">
            <DockPanel Margin="6,2">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding EditConoscopeConfigCommand}" Padding="2" Height="32" Width="32" Margin="0,0,8,0" ToolTip="设置">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="rotateTransformWindowSettings" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <TextBlock Text="&#xE713;" HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource GlobalTextBrush}">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="rotateTransformWindowSettings" CenterX="9" CenterY="9"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Menu x:Name="menu" Padding="2" Background="Transparent" VerticalAlignment="Center" />
                    <Separator Margin="8,0" />
                    <Button Content="打开" Click="OpenFile_Click" Padding="10,4" Margin="0,0,6,0"/>
                    <Button Content="方位角导出" Click="btnExportAngleMode_Click" Padding="10,4" Margin="0,0,6,0"/>
                    <Button Content="极角导出" Click="btnExportCircleMode_Click" Padding="10,4" Margin="0,0,6,0"/>
                    <Button Content="高级导出" Click="btnAdvancedExport_Click" Padding="10,4" Margin="0,0,10,0"/>
                    <TextBlock Text="型号" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="cbModelType" Width="100" SelectionChanged="cbModelType_SelectionChanged" Margin="0,0,10,0"/>
                    <Button x:Name="btnOpenObservationCamera" Content="{x:Static properties:Resources.OpenObservationCamera}" Click="btnOpenObservationCamera_Click" Padding="10,4"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <xcad:DockingManager x:Name="DockingManager" Grid.Row="1" Margin="-6,-6" Padding="0" Background="Transparent" BorderThickness="0" DocumentHeaderTemplate="{StaticResource DocumentHeaderTemplate}">
            <xcad:LayoutRoot>
                <xcad:LayoutPanel Orientation="Horizontal">
                    <xcad:LayoutDocumentPane x:Name="ViewDocumentPane" />
                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>

        <StatusBar Grid.Row="2" Height="25">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static properties:Resources.CurrentModel}" Margin="0,0,5,0"/>
                    <TextBlock x:Name="tbCurrentModel" Text="VA60" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem x:Name="ObservationCameraStatusItem">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static properties:Resources.ObservationCameraStatus}" Margin="0,0,5,0"/>
                    <TextBlock x:Name="tbObservationCameraStatus" Text="{x:Static properties:Resources.NotOpened}" Foreground="Gray"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>