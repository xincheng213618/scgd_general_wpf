<Window x:Class="ProjectARVRPro.ThunderbirdSerialDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="雷鸟切图调试" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Receive + Send Areas -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <!-- Receive Label -->
            <TextBlock Grid.Row="0" Text="接收区" FontWeight="Bold" Margin="0,0,0,5"/>

            <!-- Receive Area -->
            <TextBox Grid.Row="1" x:Name="ReceiveTextBox" 
                     IsReadOnly="True" 
                     TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Courier New"
                     Background="White"
                     Margin="0,0,5,5"/>

            <!-- Send Label + Tabs -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="发送区" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,5">
                    <Button Content="写亮度" Click="WriteBrightnessPreset_Click" Margin="0,0,5,0" Padding="8,2"/>
                    <Button Content="读亮度" Click="ReadBrightnessPreset_Click" Margin="0,0,5,0" Padding="8,2"/>
                    <Button Content="向上切图" Click="SwitchUpPreset_Click" Margin="0,0,5,0" Padding="8,2"/>
                    <Button Content="向下切图" Click="SwitchDownPreset_Click" Margin="0,0,5,0" Padding="8,2"/>
                </StackPanel>
            </Grid>

            <!-- Send Area -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="SendTextBox"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Courier New"
                         Margin="0,0,5,0"/>
                <StackPanel Grid.Column="1">
                    <Button Content="发送" x:Name="SendButton" Click="Send_Click" 
                            Height="40" Margin="0,0,0,5"
                            Background="#FF4CAF50" Foreground="White" FontWeight="Bold"/>
                    <Button Content="清除发送" Click="ClearSend_Click" Margin="0,0,0,5"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Right: Serial Port Config -->
        <Border Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5,0,0,0">
            <StackPanel>
                <TextBlock Text="串口选择" FontWeight="Bold" Margin="0,0,0,10"/>

                <!-- COM Port -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="串口" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="ComPortComboBox"/>
                </Grid>

                <!-- Baud Rate -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="波特率" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="BaudRateComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="115200"/>
                        <ComboBoxItem Content="9600"/>
                        <ComboBoxItem Content="19200"/>
                        <ComboBoxItem Content="38400"/>
                        <ComboBoxItem Content="57600"/>
                    </ComboBox>
                </Grid>

                <!-- Stop Bits -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="停止位" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="StopBitsComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="1.5"/>
                        <ComboBoxItem Content="2"/>
                    </ComboBox>
                </Grid>

                <!-- Data Bits -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="数据位" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="DataBitsComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="8"/>
                        <ComboBoxItem Content="7"/>
                        <ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="5"/>
                    </ComboBox>
                </Grid>

                <!-- Parity -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="校验位" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="ParityComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="None"/>
                        <ComboBoxItem Content="Odd"/>
                        <ComboBoxItem Content="Even"/>
                        <ComboBoxItem Content="Mark"/>
                        <ComboBoxItem Content="Space"/>
                    </ComboBox>
                </Grid>

                <!-- Open/Close Port -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="串口操作" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="TogglePortButton" Content="打开串口" Click="TogglePort_Click"/>
                </Grid>

                <Separator Margin="0,5"/>

                <Button Content="刷新串口" Click="RefreshPorts_Click" Margin="0,5,0,5"/>
                <Button Content="清除接收" Click="ClearReceive_Click" Margin="0,0,0,5"/>

                <Separator Margin="0,5"/>

                <!-- Brightness Control -->
                <TextBlock Text="亮度控制" FontWeight="Bold" Margin="0,5,0,5"/>
                <TextBlock Text="PWM: 0x20(最小) ~ 0x30(最大)" FontSize="11" Margin="0,0,0,5" Foreground="Gray"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="亮度档位" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="BrightnessComboBox"/>
                </Grid>

                <Separator Margin="0,5"/>

                <!-- Status -->
                <TextBlock Text="状态" FontWeight="Bold" Margin="0,5,0,5"/>
                <TextBlock x:Name="StatusText" Text="串口未打开" Foreground="Gray" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
