<Window x:Class="ProjectARVRPro.ThunderbirdSerialDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="雷鸟切图调试" Height="520" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Serial Port Connection -->
        <GroupBox Grid.Row="0" Header="串口连接" Margin="0,0,0,5" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="串口" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="ComPortComboBox" Margin="0,0,5,0"/>
                    <Button Grid.Column="2" Content="刷新" Click="RefreshPorts_Click" Padding="8,2" Margin="0,0,5,0"/>
                    <TextBlock Grid.Column="3" Text="波特率" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="4" x:Name="BaudRateComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="115200"/>
                        <ComboBoxItem Content="9600"/>
                    </ComboBox>
                </Grid>
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ConnectionStatusText" Text="● 未连接" Foreground="Gray" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="超时(ms):" VerticalAlignment="Center" Margin="5,0,3,0"/>
                    <TextBox Grid.Column="2" x:Name="TimeoutTextBox" Text="1000" Width="55" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Grid.Column="4" x:Name="TogglePortButton" Content="连接" Click="TogglePort_Click"
                            Width="100" Height="28" Background="#FF4CAF50" Foreground="White" FontWeight="Bold"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Row 1: Image Switching -->
        <GroupBox Grid.Row="1" Header="切图操作" Margin="0,0,0,5" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="SwitchUpButton" Content="▲ 向上切图" Click="SwitchUp_Click"
                        Height="40" FontSize="14" FontWeight="Bold" IsEnabled="False"/>
                <Button Grid.Column="2" x:Name="SwitchDownButton" Content="▼ 向下切图" Click="SwitchDown_Click"
                        Height="40" FontSize="14" FontWeight="Bold" IsEnabled="False"/>
            </Grid>
        </GroupBox>

        <!-- Row 2: Brightness Control -->
        <GroupBox Grid.Row="2" Header="亮度控制 (PWM 0x20~0x30, 共17档)" Margin="0,0,0,5" Padding="8">
            <StackPanel>
                <!-- Current brightness status -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="当前亮度:" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" x:Name="CurrentBrightnessText" Text="未知" VerticalAlignment="Center"
                               FontSize="16" FontWeight="Bold" Foreground="#FF2196F3" Margin="8,0,0,0"/>
                    <Button Grid.Column="2" x:Name="QueryBrightnessButton" Content="查询亮度" Click="QueryBrightness_Click"
                            Padding="10,3" IsEnabled="False"/>
                </Grid>

                <!-- Brightness +/- controls -->
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="BrightnessDownButton" Content="- 减" Click="BrightnessDown_Click"
                            Height="32" FontWeight="Bold" IsEnabled="False"/>
                    <Slider Grid.Column="1" x:Name="BrightnessSlider" Minimum="0" Maximum="16"
                            IsSnapToTickEnabled="True" TickFrequency="1" TickPlacement="BottomRight"
                            ValueChanged="BrightnessSlider_ValueChanged" Margin="8,0" VerticalAlignment="Center" IsEnabled="False"/>
                    <Button Grid.Column="2" x:Name="BrightnessUpButton" Content="+ 加" Click="BrightnessUp_Click"
                            Height="32" FontWeight="Bold" IsEnabled="False"/>
                </Grid>

                <!-- Brightness level display -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="最小 0x20" Foreground="Gray" FontSize="11"/>
                    <TextBlock Grid.Column="1" x:Name="SliderValueText" Text="档位 0 (0x20)" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Grid.Column="2" Text="最大 0x30" Foreground="Gray" FontSize="11"/>
                </Grid>

                <!-- Direct set -->
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="指定档位:" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="BrightnessComboBox" Margin="5,0" IsEnabled="False"/>
                    <Button Grid.Column="2" x:Name="SetBrightnessButton" Content="设置亮度" Click="SetBrightness_Click"
                            Padding="10,3" IsEnabled="False"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- Row 3: Status -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="8,4" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="操作状态: " VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="StatusText" Text="请先连接串口" Foreground="Gray" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Row 4: Log -->
        <GroupBox Grid.Row="4" Header="通信日志" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" x:Name="ReceiveTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Courier New" FontSize="11"
                         Background="White"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                    <Button Content="清除日志" Click="ClearReceive_Click" Padding="8,2"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Window>
