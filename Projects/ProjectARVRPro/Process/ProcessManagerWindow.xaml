<Window x:Class="ProjectARVRPro.Process.ProcessManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectARVRPro.Process"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:ProcessManager}"
        Title="流程处理配置" Height="720" Width="1280" MinHeight="640" MinWidth="1040" Background="{DynamicResource GlobalBackground}" Initialized="Window_Initialized">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="520"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0 0 0 8" Padding="8">
            <DockPanel>
                <TextBlock Text="流程组管理" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0 0 12 0"/>
                <TextBlock Text="当前组:" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <ComboBox ItemsSource="{Binding ProcessGroups}" DisplayMemberPath="Name"
                          SelectedIndex="{Binding ActiveGroupIndex}" Width="150" VerticalAlignment="Center" Margin="0 0 12 0"
                          x:Name="GroupComboBox" SelectionChanged="GroupComboBox_SelectionChanged"/>
                <TextBox Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}" Width="120" VerticalAlignment="Center" Margin="0 0 5 0"/>
                <Button Content="添加组" Padding="8 3" Margin="0 0 5 0" Command="{Binding AddGroupCommand}"/>
                <Button Content="重命名" Padding="8 3" Margin="0 0 5 0" Command="{Binding RenameGroupCommand}"/>
                <Button Content="复制组" Padding="8 3" Margin="0 0 5 0" Command="{Binding DuplicateGroupCommand}"/>
                <Button Content="删除组" Padding="8 3" Margin="0 0 5 0" Command="{Binding RemoveGroupCommand}" Foreground="Red"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="470" MinWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0 0 0 8">
                        <TextBlock Text="流程列表" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="新增" Padding="10 4" Margin="4 0 0 0" Command="{Binding AddMetaCommand}"/>
                            <Button Content="编辑" Padding="10 4" Margin="4 0 0 0" Command="{Binding UpdateMetaCommand}"/>
                            <Button Content="删除" Padding="10 4" Margin="4 0 0 0" Command="{Binding RemoveMetaCommand}"/>
                            <Button Content="上移" Padding="10 4" Margin="4 0 0 0" Command="{Binding MoveUpCommand}"/>
                            <Button Content="下移" Padding="10 4" Margin="4 0 0 0" Command="{Binding MoveDownCommand}"/>
                        </StackPanel>
                    </DockPanel>

                    <ListView Grid.Row="1" ItemsSource="{Binding ProcessMetas}" SelectedItem="{Binding SelectedProcessMeta}" x:Name="lvMetas" SelectionChanged="ListView_SelectionChanged" MouseDoubleClick="ListView_MouseDoubleClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource ListViewItemBaseStyle.Small}"/>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridView.ColumnHeaderContainerStyle>
                                    <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource GridViewColumnHeaderBase}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </GridView.ColumnHeaderContainerStyle>
                                <GridViewColumn Header="名称" Width="120" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="流程模板" Width="140" DisplayMemberBinding="{Binding FlowTemplate}"/>
                                <GridViewColumn Header="处理类" Width="150" DisplayMemberBinding="{Binding ProcessTypeName}"/>
                                <GridViewColumn Header="启用" Width="50">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsEnabled}" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0 0 0 8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedProcessMeta.Name, TargetNullValue=未选择流程}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Foreground="Gray" Margin="0 4 0 0">
                                <Run Text="模板: "/><Run Text="{Binding SelectedProcessMeta.FlowTemplate}"/>
                                <Run Text="    处理类: "/><Run Text="{Binding SelectedProcessMeta.ProcessTypeName}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="启用" IsChecked="{Binding SelectedProcessMeta.IsEnabled}" VerticalAlignment="Center" Margin="0 0 12 0"/>
                            <Button Content="编辑流程" Padding="12 4" Command="{Binding UpdateMetaCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TabControl Grid.Row="1">
                    <TabItem Header="Recipe">
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource GlobalBorderBrush}" CornerRadius="4,4,0,0" Padding="10,6">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                                Command="{Binding SelectedProcessMeta.EditRecipeConfigCommand}"
                                                Visibility="{Binding SelectedProcessMeta.HasRecipeConfig, Converter={StaticResource BoolToVisibilityConverter}}"
                                                ToolTip="独立编辑 Recipe"
                                                Padding="6,4" Margin="8,0,0,0"/>
                                        <TextBlock Text="Recipe 配置" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                                    <StackPanel x:Name="RecipePanel">
                                        <TextBlock Text="请选择一个处理项" Foreground="Gray" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </TabItem>

                    <TabItem Header="Process">
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource GlobalBorderBrush}" CornerRadius="4,4,0,0" Padding="10,6">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                                Command="{Binding SelectedProcessMeta.EditProcessConfigCommand}"
                                                Visibility="{Binding SelectedProcessMeta.HasProcessConfig, Converter={StaticResource BoolToVisibilityConverter}}"
                                                ToolTip="独立编辑 Process"
                                                Padding="6,4" Margin="8,0,0,0"/>
                                        <TextBlock Text="Process 配置" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                                    <StackPanel x:Name="ProcessPanel">
                                        <TextBlock Text="请选择一个处理项" Foreground="Gray" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </TabItem>

                    <TabItem Header="切图">
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource GlobalBorderBrush}" CornerRadius="4,4,0,0" Padding="10,6">
                                    <TextBlock Text="切图配置" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                                    <StackPanel x:Name="PictureSwitchPanel">
                                        <TextBlock Text="请选择一个处理项" Foreground="Gray" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Grid>
</Window>