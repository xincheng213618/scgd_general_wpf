<Window x:Class="ProjectARVRPro.DeviceChannel.DeviceChannelEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectARVRPro.DeviceChannel"
        mc:Ignorable="d"
        Title="设备通道配置" Height="520" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:ChannelTypeToSerialVisibilityConverter x:Key="SerialVisConverter"/>
        <local:ChannelTypeToSocketVisibilityConverter x:Key="SocketVisConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：通道列表 -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="通道列表" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <ListBox Grid.Row="1" x:Name="ChannelListBox"
                         SelectionChanged="ChannelListBox_SelectionChanged"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Gray"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Fill" Value="#FF4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding ChannelType}" Foreground="Gray" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Button Content=" ＋ 添加" Click="AddChannel_Click" Padding="12,4" Margin="0,0,5,0"
                            Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                    <Button Content=" － 删除" Click="RemoveChannel_Click" Padding="12,4"
                            Background="#FFE53935" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 右侧：通道详情编辑 -->
        <Border Grid.Column="1" Margin="10,0,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10">
            <Grid x:Name="DetailPanel" DataContext="{Binding ElementName=ChannelListBox, Path=SelectedItem}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=ChannelListBox, Path=SelectedItem}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 未选中时的占位提示 -->
                <TextBlock x:Name="PlaceholderText" Text="← 请选择或添加一个通道"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="14"/>
                <!-- 基本信息 -->
                <GroupBox Grid.Row="0" Header="基本信息" Padding="8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="通道名称" Grid.Row="0"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>

                        <TextBlock Text="通道类型" Grid.Row="1"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ChannelTypeComboBox"
                                  SelectedItem="{Binding ChannelType}" Margin="0,2"/>

                        <TextBlock Text="启用" Grid.Row="2"/>
                        <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding IsEnabled}" Margin="0,4" VerticalAlignment="Center"/>
                    </Grid>
                </GroupBox>

                <!-- 串口参数 -->
                <GroupBox Grid.Row="1" Header="串口参数" Padding="8" Margin="0,0,0,8"
                          Visibility="{Binding ChannelType, Converter={StaticResource SerialVisConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="串口名称" Grid.Row="0"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="SerialPortComboBox"
                                  Text="{Binding SerialPortName, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" Margin="0,2"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="刷新" Click="RefreshPorts_Click" Padding="8,2" Margin="5,2,0,2"/>

                        <TextBlock Text="波特率" Grid.Row="1"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="BaudRateComboBox"
                                  Text="{Binding BaudRate, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" Margin="0,2" Grid.ColumnSpan="2">
                            <ComboBoxItem Content="9600"/>
                            <ComboBoxItem Content="19200"/>
                            <ComboBoxItem Content="38400"/>
                            <ComboBoxItem Content="57600"/>
                            <ComboBoxItem Content="115200"/>
                        </ComboBox>

                        <TextBlock Text="超时(ms)" Grid.Row="2"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}" Margin="0,2" Grid.ColumnSpan="2"/>
                    </Grid>
                </GroupBox>

                <!-- Socket 参数 -->
                <GroupBox Grid.Row="2" Header="Socket 参数" Padding="8" Margin="0,0,0,8"
                          Visibility="{Binding ChannelType, Converter={StaticResource SocketVisConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="地址" Grid.Row="0"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>

                        <TextBlock Text="端口" Grid.Row="1"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>

                        <TextBlock Text="超时(ms)" Grid.Row="2"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
                    </Grid>
                </GroupBox>

                <!-- 连接测试 -->
                <GroupBox Grid.Row="3" Header="连接测试" Padding="8" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="测试连接" Click="TestConnect_Click" Padding="12,4"
                                Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
                        <TextBlock x:Name="TestResultText" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </GroupBox>
            </Grid>

        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,0,-5">
            <Button Content="保存" Click="Save_Click" Padding="16,6" Margin="0,0,8,0"
                    Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
            <Button Content="关闭" Click="Close_Click" Padding="16,6"
                    Background="{DynamicResource PrimaryBrush}" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
