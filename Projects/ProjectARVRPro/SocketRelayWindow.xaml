<Window x:Class="ProjectARVRPro.SocketRelayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Socket中转服务器" Height="620" Width="780"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Server Config + Status -->
        <GroupBox Grid.Row="0" Header="中转服务器 (Flow作为Client连接此服务器)" Margin="0,0,0,5" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="监听IP" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="ListenIPTextBox" Text="127.0.0.1" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="端口" VerticalAlignment="Center" Margin="5,0,3,0"/>
                    <TextBox Grid.Column="3" x:Name="ListenPortTextBox" Text="9200" VerticalAlignment="Center"/>
                </Grid>
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Vertical">
                        <TextBlock x:Name="ServerStatusText" Text="● 服务器未启动" Foreground="Gray" VerticalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock x:Name="FlowStatusText" Text="● Flow未连接" Foreground="Gray" VerticalAlignment="Center" Margin="0,2,0,0"/>
                        <TextBlock x:Name="ClientStatusText" Text="● 外部Client未连接" Foreground="Gray" VerticalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="StartButton" Content="启动服务器" Click="StartServer_Click"
                            Width="100" Height="28" Background="#FF4CAF50" Foreground="White" FontWeight="Bold" Margin="0,0,5,0"/>
                    <Button Grid.Column="2" x:Name="StopButton" Content="停止服务器" Click="StopServer_Click"
                            Width="100" Height="28" Background="#FFF44336" Foreground="White" FontWeight="Bold" IsEnabled="False"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Row 1: Architecture Diagram -->
        <GroupBox Grid.Row="1" Header="消息流向" Margin="0,0,0,5" Padding="8">
            <TextBlock FontFamily="Courier New" FontSize="11" Foreground="{DynamicResource PrimaryTextBrush}">
                <Run Text="Flow(Client) → [AOITestSwitchImage] → 中转Server → SocketControl.Current.Stream → 外部Client"/>
                <LineBreak/>
                <Run Text="外部Client  → [AOITestSwitchImageComplete] → SocketManager → Handler → 中转Server → Flow"/>
            </TextBlock>
        </GroupBox>

        <!-- Row 2: Manual Send -->
        <GroupBox Grid.Row="2" Header="手动发送 (调试用)" Margin="0,0,0,5" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SendToFlowTextBox" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="SendToFlowButton" Content="发送到Flow" Click="SendToFlow_Click" 
                            Padding="10,3" Margin="5,0,0,0" IsEnabled="False"/>
                </Grid>
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SendToClientTextBox" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="SendToClientButton" Content="发送到外部Client" Click="SendToClient_Click" 
                            Padding="10,3" Margin="5,0,0,0" IsEnabled="False"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- Row 3: Message Log -->
        <GroupBox Grid.Row="3" Header="消息日志" Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ListView x:Name="MessageListView" FontFamily="Courier New" FontSize="11">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="时间" Width="100" DisplayMemberBinding="{Binding Time, StringFormat=HH:mm:ss.fff}"/>
                            <GridViewColumn Header="方向" Width="130" DisplayMemberBinding="{Binding DirectionText}"/>
                            <GridViewColumn Header="EventName" Width="160" DisplayMemberBinding="{Binding EventName}"/>
                            <GridViewColumn Header="内容" Width="350" DisplayMemberBinding="{Binding Content}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </GroupBox>

        <!-- Row 4: Bottom Bar -->
        <Grid Grid.Row="4" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" Text="就绪" VerticalAlignment="Center" Foreground="Gray"/>
            <Button Grid.Column="2" Content="清除日志" Click="ClearLog_Click" Padding="8,2"/>
        </Grid>
    </Grid>
</Window>
