<Window x:Class="ProjectKB.EditRecipeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectKB"
        mc:Ignorable="d"
        Title="Recipe参数设定" Height="620" Width="980" MinHeight="520" MinWidth="860" Background="{StaticResource GlobalBackground}" PreviewKeyDown="Window_PreviewKeyDown" Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="ToolTip" Value="{ Binding Text,RelativeSource={RelativeSource Self}}"/>
        </Style>
        <Style x:Key="PrimaryRecipeButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
        <Style x:Key="RecipeButton" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Background="{DynamicResource  SecondaryRegionBrush}" Grid.RowSpan="2" BorderBrush="{DynamicResource BorderBrush}"  BorderThickness="1" />
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="模板设定集" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <DataGrid x:Name="RecipeDataGrid" Grid.Row="1" AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow" SelectionChanged="RecipeDataGrid_SelectionChanged" CanUserAddRows="False" CanUserDeleteRows="False" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="模板" Binding="{Binding TemplateName}" Width="*"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="72"/>
                        <DataGridTextColumn Header="当前" Binding="{Binding CurrentText}" Width="54"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="刷新" Style="{StaticResource RecipeButton}" Click="RefreshTemplates_Click"/>
                    <Button Content="目录" Style="{StaticResource RecipeButton}" Click="OpenRecipeFolder_Click"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="SelectedTemplateTextBlock" FontSize="18" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock x:Name="RecipeStatusTextBlock"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,10,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="复制自" Margin="0,0,8,0"/>
                    <ComboBox x:Name="CopySourceComboBox" Grid.Column="1" DisplayMemberPath="TemplateName" MinWidth="200"/>
                    <Button Grid.Column="2" Content="复制到选中" Style="{StaticResource RecipeButton}" Click="CopyFrom_Click"/>
                    <Button Grid.Column="3" Content="应用初始值" Style="{StaticResource RecipeButton}" Click="ApplyDefault_Click"/>
                    <Button Grid.Column="4" Content="选中设为初始值" Style="{StaticResource RecipeButton}" Click="SetDefault_Click"/>
                    <Button Grid.Column="5" Content="编辑初始值" Style="{StaticResource RecipeButton}" Click="EditDefault_Click"/>
                </Grid>

                <Border Grid.Row="2" Background="{DynamicResource  SecondaryRegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <StackPanel x:Name="EditStackPanel" Margin="8"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
        <Grid Grid.Row="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                <Button Content="保存" Style="{StaticResource PrimaryRecipeButton}" Click="Save_Click"/>
                <Button Content="恢复初始值" Style="{StaticResource PrimaryRecipeButton}" Click="Reset_Click"/>
                <Button Content="关闭" Style="{StaticResource PrimaryRecipeButton}" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
