<Window x:Class="ProjectKB.Auth.KBChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="修改管理员密码" Height="300" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="修改管理员密码" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource GlobalTextBrush}" Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="原始密码" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}"/>
            <PasswordBox x:Name="OldPasswordBox" Grid.Column="1" hc:InfoElement.Placeholder="请输入原始密码"
                         FontSize="14" Padding="8,6" PasswordChanged="PasswordBox_PasswordChanged"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="新密码" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}"/>
            <PasswordBox x:Name="NewPasswordBox" Grid.Column="1" hc:InfoElement.Placeholder="请输入新密码"
                         FontSize="14" Padding="8,6" PasswordChanged="PasswordBox_PasswordChanged"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="确认密码" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}"/>
            <PasswordBox x:Name="ConfirmPasswordBox" Grid.Column="1" hc:InfoElement.Placeholder="请再次输入新密码"
                         FontSize="14" Padding="8,6" PasswordChanged="PasswordBox_PasswordChanged"/>
        </Grid>

        <TextBlock x:Name="ErrorText" Grid.Row="4" Foreground="Red" FontSize="12"
                   Visibility="Collapsed" Margin="0,0,0,5"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="80" Margin="0,0,10,0" Click="Confirm_Click"
                    IsDefault="True" Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0" Padding="12,5"/>
            <Button Content="取消" Width="80" Click="Cancel_Click"
                    IsCancel="True" Padding="12,5"/>
        </StackPanel>
    </Grid>
</Window>
