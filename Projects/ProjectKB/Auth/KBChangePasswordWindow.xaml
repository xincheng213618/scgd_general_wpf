<Window x:Class="ProjectKB.Auth.KBChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="修改管理员密码" Height="300" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="修改管理员密码" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource GlobalTextBrush}" Margin="0,0,0,15"/>

        <PasswordBox x:Name="OldPasswordBox" Grid.Row="1" hc:InfoElement.Placeholder="旧密码"
                     FontSize="14" Padding="8,6" Margin="0,0,0,8"
                     PasswordChanged="PasswordBox_PasswordChanged"/>

        <PasswordBox x:Name="NewPasswordBox" Grid.Row="2" hc:InfoElement.Placeholder="新密码"
                     FontSize="14" Padding="8,6" Margin="0,0,0,8"
                     PasswordChanged="PasswordBox_PasswordChanged"/>

        <PasswordBox x:Name="ConfirmPasswordBox" Grid.Row="3" hc:InfoElement.Placeholder="确认新密码"
                     FontSize="14" Padding="8,6" Margin="0,0,0,5"
                     PasswordChanged="PasswordBox_PasswordChanged"/>

        <TextBlock x:Name="ErrorText" Grid.Row="4" Foreground="Red" FontSize="12"
                   Visibility="Collapsed" Margin="0,0,0,5"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="80" Margin="0,0,10,0" Click="Confirm_Click"
                    IsDefault="True" Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0" Padding="12,5"/>
            <Button Content="取消" Width="80" Click="Cancel_Click"
                    IsCancel="True" Padding="12,5"/>
        </StackPanel>
    </Grid>
</Window>
