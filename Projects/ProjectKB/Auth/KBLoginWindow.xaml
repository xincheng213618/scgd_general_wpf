<Window x:Class="ProjectKB.Auth.KBLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="管理员登录" Height="220" Width="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="请输入管理员密码" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource GlobalTextBrush}" Margin="0,0,0,15"/>

        <PasswordBox x:Name="PasswordBox" Grid.Row="1" hc:InfoElement.Placeholder="输入密码"
                     FontSize="14" Padding="8,6" Margin="0,0,0,5"
                     PasswordChanged="PasswordBox_PasswordChanged"/>

        <TextBlock x:Name="ErrorText" Grid.Row="2" Foreground="Red" FontSize="12"
                   Visibility="Collapsed" Margin="0,0,0,5"/>

        <TextBlock x:Name="AttemptText" Grid.Row="3" Foreground="Orange" FontSize="12"
                   Visibility="Collapsed" Margin="0,0,0,5"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="80" Margin="0,0,10,0" Click="Login_Click"
                    IsDefault="True" Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0" Padding="12,5"/>
            <Button Content="取消" Width="80" Click="Cancel_Click"
                    IsCancel="True" Padding="12,5"/>
        </StackPanel>
    </Grid>
</Window>
