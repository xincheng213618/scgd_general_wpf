<Window x:Class="ColorVision.Engine.Media.CVRawManualCieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.CalcCIE}"
        Height="560"
        Width="720"
        MinHeight="480"
        MinWidth="640"
        Background="{DynamicResource GlobalBackground}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="2"
                Background="{DynamicResource SecondaryRegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" />

        <Grid Grid.Row="0" Margin="5,5,5,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,5"
                    Background="{DynamicResource GlobalBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="5">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{x:Static properties:Resources.CameraFourColorCalFile}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource GlobalTextBrush}"
                               Margin="0,0,0,6"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ListBox x:Name="CalibrationFileList"
                                 Grid.Column="0"
                                 Height="110"
                                 DisplayMemberPath="DisplayName"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Background="{DynamicResource SecondaryRegionBrush}"/>

                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top">
                            <Button Content="{x:Static properties:Resources.ImportSelected}"
                                    Foreground="White"
                                    Background="{StaticResource PrimaryBrush}"
                                    BorderThickness="0"
                                    Click="ImportSelected_Click"
                                    Margin="0,0,0,5"/>
                            <TextBlock Text="{x:Static properties:Resources.DefaultUseInitialMatrix}"
                                       Width="150"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource GlobalTextBrush}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{DynamicResource GlobalBackground}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="5">
                <ScrollViewer Margin="5"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="PropertyPanelHost" />
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="5">
            <DockPanel>
                <Button Content="{x:Static properties:Resources.Reset}"
                        Foreground="White"
                        Background="{StaticResource PrimaryBrush}"
                        BorderThickness="0"
                        Click="Reset_Click"
                        Margin="5,0,0,0" />
                <Button Content="{x:Static properties:Resources.ResetToDefault}"
                        Foreground="White"
                        Background="{StaticResource PrimaryBrush}"
                        BorderThickness="0"
                        Click="ResetToFactory_Click"
                        ToolTip="{x:Static properties:Resources.ResetToClassDefault}"
                        Margin="5,0,0,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{x:Static properties:Resources.OK}"
                            Foreground="White"
                            Background="{StaticResource PrimaryBrush}"
                            BorderThickness="0"
                            Click="OK_Click"
                            Margin="5,0,0,0"/>
                    <Button Content="{x:Static properties:Resources.Cancel}"
                            Foreground="White"
                            Background="{StaticResource PrimaryBrush}"
                            BorderThickness="0"
                            Click="Cancel_Click"
                            Margin="5,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</Window>