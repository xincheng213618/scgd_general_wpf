<Window x:Class="ColorVision.Engine.Services.PhyCameras.CameraSearchResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:CameraSearchResultViewModel}"
        Title="相机搜索结果" Height="680" Width="1040" Background="{DynamicResource GlobalBackground}" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="{Binding SummaryText}" FontSize="16" FontWeight="SemiBold" Margin="0,0,20,0"/>
            <TextBlock Text="{Binding ElapsedText}" FontSize="16"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Models}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MaxHeight="170" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="类型" Binding="{Binding CameraModel}" Width="160"/>
                <DataGridTextColumn Header="耗时" Binding="{Binding ElapsedText}" Width="120"/>
                <DataGridTextColumn Header="数量" Binding="{Binding CameraCount}" Width="80"/>
                <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Cameras}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="类型" Binding="{Binding CameraModel}" Width="130"/>
                <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="90"/>
                <DataGridTextColumn Header="MD5" Binding="{Binding MD5Id}" Width="260"/>
                <DataGridTextColumn Header="CameraId" Binding="{Binding CameraId}" Width="*"/>
                <DataGridTextColumn Header="类型耗时" Binding="{Binding SearchElapsedText}" Width="110"/>
                <DataGridTemplateColumn Header="操作" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding ActionText}" Command="{Binding CreateCommand}" IsEnabled="{Binding CanCreate}" MinWidth="76" Padding="6,2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3" Content="关闭" MinWidth="90" Height="30" HorizontalAlignment="Right" Margin="0,10,0,0" Click="Close_Click"/>
    </Grid>
</Window>