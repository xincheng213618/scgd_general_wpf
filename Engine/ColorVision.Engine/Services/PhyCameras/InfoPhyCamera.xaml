<UserControl x:Class="ColorVision.Engine.Services.PhyCameras.InfoPhyCamera"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:PhyCamera}"
             d:DesignHeight="620" d:DesignWidth="940">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ColorVision.Engine;component/Services/PhyCameras/PhyCameraConsoleStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <local:StatusToTextConverter x:Key="StatusToTextConverter"/>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </Style>

            <Style x:Key="HeaderBadgeLabelStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Opacity" Value="0.72"/>
                <Setter Property="Margin" Value="0,0,6,0"/>
            </Style>

            <Style x:Key="HeaderBadgeValueStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="ConnectionBadgeStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource StatusBadgeBorderStyle}">
                <Setter Property="Background" Value="#1F2EAD4F"/>
                <Setter Property="BorderBrush" Value="#662EAD4F"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SysResourceModel.Remark}" Value="Offline">
                        <Setter Property="Background" Value="#1FE53935"/>
                        <Setter Property="BorderBrush" Value="#66E53935"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ConnectionBadgeValueTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderBadgeValueStyle}">
                <Setter Property="Foreground" Value="#FF2EAD4F"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SysResourceModel.Remark}" Value="Offline">
                        <Setter Property="Foreground" Value="#FFE53935"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="AlertBorderStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource PanelBorderStyle}">
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
                <Setter Property="Background" Value="{Binding LicenseStatusBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{Binding LicenseStatusBrush}"/>
            </Style>

            <Style x:Key="CommandButtonTextStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource PanelBorderStyle}"/>
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionPanelStyle}">
                <Grid>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBox Text="{Binding Code, Mode=OneWay}" Style="{StaticResource CopyableTitleTextBoxStyle}"/>
                        <TextBox Style="{StaticResource CopyableSubtleTextBoxStyle}">
                            <TextBox.Text>
                                <MultiBinding StringFormat="{}{0} / {1}">
                                    <Binding Path="Config.CameraModel" Mode="OneWay"/>
                                    <Binding Path="Config.CameraMode" Mode="OneWay"/>
                                </MultiBinding>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Right">
                        <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,10">
                            <Border Style="{StaticResource ConnectionBadgeStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="连接状态" Style="{StaticResource HeaderBadgeLabelStyle}"/>
                                    <TextBlock Text="{Binding SysResourceModel.Remark, Mode=OneWay, Converter={StaticResource StatusToTextConverter}}"
                                               Style="{StaticResource ConnectionBadgeValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatusBadgeBorderStyle}"
                                    Background="{Binding LicenseStatusBackgroundBrush}"
                                    BorderBrush="{Binding LicenseStatusBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="许可证状态" Style="{StaticResource HeaderBadgeLabelStyle}"/>
                                    <TextBlock Text="{Binding LicenseStatusText}" Style="{StaticResource HeaderBadgeValueStyle}"
                                               Foreground="{Binding LicenseStatusBrush}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Button Command="{Binding EditCommand}" Style="{StaticResource ToolbarButtonStyle}"
                                HorizontalAlignment="Right" Margin="0"
                                ToolTip="修改当前相机配置">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                                <TextBlock Text="编辑配置"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource AlertBorderStyle}"
                    Visibility="{Binding HasLicenseAlert, Converter={StaticResource BooleanToVisibilityConverter}}">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="许可证提醒" FontWeight="SemiBold" Margin="0,0,10,0"
                                   Foreground="{Binding LicenseStatusBrush}"/>
                        <TextBlock Text="{Binding LicenseAlertText}" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button DockPanel.Dock="Right" Command="{Binding UploadLicenseCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" Margin="12,0,0,0"
                            Content="更新许可证"/>
                </DockPanel>
            </Border>

            <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,12">
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="ID" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Id, Mode=OneWay}" Style="{StaticResource CopyableMetricTextBoxStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="型号" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding Config.CameraModel, Mode=OneWay}" Style="{StaticResource CopyableMetricTextBoxStyle}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <StackPanel>
                        <TextBlock Text="连接状态" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding SysResourceModel.Remark, Mode=OneWay, Converter={StaticResource StatusToTextConverter}}">
                            <TextBox.Style>
                                <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource CopyableMetricTextBoxStyle}">
                                    <Setter Property="Foreground" Value="#FF2EAD4F"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SysResourceModel.Remark}" Value="Offline">
                                            <Setter Property="Foreground" Value="#FFE53935"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="许可证状态" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Text="{Binding LicenseStatusText, Mode=OneWay}"
                                 Foreground="{Binding LicenseStatusBrush}"
                                 Style="{StaticResource CopyableMetricTextBoxStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource SectionPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="配置" Style="{StaticResource SectionTitleStyle}"/>
                                <UniformGrid Columns="3">
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding EditCommand}">
                                        <TextBlock Text="修改配置" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding OpenSettingDirectoryCommand}">
                                        <TextBlock Text="打开配置文件" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding FilterWheelEditCommand}">
                                        <TextBlock Text="编辑滤光轮配置" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="许可证" Style="{StaticResource SectionTitleStyle}"/>
                                <UniformGrid Columns="4">
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding UploadLicenseCommand}">
                                        <TextBlock Text="修改许可证" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding UploadLicenseNetCommand}">
                                        <TextBlock Text="在线下载许可证" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding CopyLicenseCommand}">
                                        <TextBlock Text="复制许可证" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding ExportLicenseCommand}">
                                        <TextBlock Text="导出许可证" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="校正" Style="{StaticResource SectionTitleStyle}"/>
                                <UniformGrid Columns="3">
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding UploadCalibrationCommand}">
                                        <TextBlock Text="上传校正文件" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding CalibrationTemplateOpenCommand}">
                                        <TextBlock Text="校正模板设置" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding CalibrationEditCommand}">
                                        <TextBlock Text="校正编辑" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="备份与恢复" Style="{StaticResource SectionTitleStyle}"/>
                                <UniformGrid Columns="2">
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding CreatResotreCommand}">
                                        <TextBlock Text="创建还原点" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                    <Button Style="{StaticResource CommandActionButtonStyle}" Command="{Binding LoadResotreCommand}">
                                        <TextBlock Text="加载还原点" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionPanelStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="危险操作" Style="{StaticResource SectionTitleStyle}"/>
                                <UniformGrid Columns="2">
                                    <Button Style="{StaticResource DangerCommandButtonStyle}" Command="{Binding ResetCommand}">
                                        <TextBlock Text="重置" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                    <Button Style="{StaticResource DangerCommandButtonStyle}" Command="{Binding DeleteCommand}">
                                        <TextBlock Text="删除" Style="{StaticResource CommandButtonTextStyle}"/>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="配置信息" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="CameraMode" Style="{StaticResource DetailLabelStyle}"/>
                                <TextBox Grid.Column="1" Text="{Binding Config.CameraMode, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}"/>

                                <TextBlock Grid.Row="1" Text="Channel" Style="{StaticResource DetailLabelStyle}" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Config.Channel, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,8,0,0"/>

                                <TextBlock Grid.Row="2" Text="ImageBpp" Style="{StaticResource DetailLabelStyle}" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Config.ImageBpp, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,8,0,0"/>

                                <TextBlock Grid.Row="3" Text="Endpoint" Style="{StaticResource DetailLabelStyle}" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,8,0,0">
                                    <TextBox.Text>
                                        <MultiBinding StringFormat="{}{0}  {1}">
                                            <Binding Path="Config.FileServerCfg.Endpoint" Mode="OneWay"/>
                                            <Binding Path="Config.FileServerCfg.PortRange" Mode="OneWay"/>
                                        </MultiBinding>
                                    </TextBox.Text>
                                </TextBox>

                                <TextBlock Grid.Row="4" Text="Path" Style="{StaticResource DetailLabelStyle}" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Config.FileServerCfg.FileBasePath, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,8,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="许可证" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="DeviceMode" Style="{StaticResource DetailLabelStyle}"/>
                                <TextBox Grid.Column="1" Text="{Binding CameraLicenseModel.ColorVisionLicense.DeviceMode, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}"/>

                                <TextBlock Grid.Row="1" Text="IssueDate" Style="{StaticResource DetailLabelStyle}" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CameraLicenseModel.ColorVisionLicense.IssueDate, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,8,0,0"/>

                                <TextBlock Grid.Row="2" Text="ExpiryDate" Style="{StaticResource DetailLabelStyle}" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CameraLicenseModel.ExpiryDate, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,8,0,0"/>

                                <TextBlock Grid.Row="3" Text="Licensee" Style="{StaticResource DetailLabelStyle}" Margin="0,8,10,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CameraLicenseModel.ColorVisionLicense.Licensee, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,8,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionPanelStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="校正文件管理" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Resources" Style="{StaticResource DetailLabelStyle}"/>
                                <TextBox Grid.Column="1" Text="{Binding VisualChildren.Count, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
