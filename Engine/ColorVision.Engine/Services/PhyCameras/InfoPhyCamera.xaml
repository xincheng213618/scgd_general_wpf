<UserControl x:Class="ColorVision.Engine.Services.PhyCameras.InfoPhyCamera"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:PhyCamera}"
             d:DesignHeight="620" d:DesignWidth="940">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ColorVision.Engine;component/Services/PhyCameras/PhyCameraConsoleStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <local:StatusToTextConverter x:Key="StatusToTextConverter"/>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </Style>

            <Style x:Key="HeaderTitleTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource CopyableTextBoxStyle}">
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="TextAlignment" Value="Left"/>
                <Setter Property="TextWrapping" Value="NoWrap"/>
            </Style>

            <Style x:Key="HeaderMetaTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource CopyableTextBoxStyle}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Opacity" Value="0.64"/>
                <Setter Property="TextAlignment" Value="Left"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
            </Style>

            <Style x:Key="HeaderStatusTextStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,6,0,0"/>
            </Style>

            <Style x:Key="ConnectionStatusTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderStatusTextStyle}">
                <Setter Property="Foreground" Value="#FF2EAD4F"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SysResourceModel.Remark}" Value="Offline">
                        <Setter Property="Foreground" Value="#FFE53935"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="LicenseStatusTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HeaderStatusTextStyle}">
                <Setter Property="Foreground" Value="{Binding LicenseStatusBrush}"/>
                <Setter Property="Margin" Value="6,6,0,0"/>
            </Style>

            <Style x:Key="AlertBorderStyle" TargetType="{x:Type Border}">
                <Setter Property="CornerRadius" Value="0"/>
                <Setter Property="Padding" Value="0,2,0,8"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style x:Key="CommandButtonTextStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="CompactCommandButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource CommandActionButtonStyle}">
                <Setter Property="MinHeight" Value="36"/>
                <Setter Property="Margin" Value="0,0,6,6"/>
                <Setter Property="Padding" Value="10,6"/>
            </Style>

            <Style x:Key="WarningCommandButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource CompactCommandButtonStyle}">
                <Setter Property="Foreground" Value="#FFB7791F"/>
                <Setter Property="BorderBrush" Value="#FFB7791F"/>
                <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            </Style>

            <Style x:Key="CompactDangerCommandButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource DangerCommandButtonStyle}">
                <Setter Property="MinHeight" Value="40"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Padding" Value="12,8"/>
            </Style>

            <Style x:Key="ActionSectionTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <Style x:Key="SectionDividerStyle" TargetType="{x:Type Border}">
                <Setter Property="Height" Value="1"/>
                <Setter Property="Margin" Value="0,2,0,8"/>
                <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush1}"/>
                <Setter Property="Opacity" Value="0.45"/>
            </Style>

            <Style x:Key="InfoSectionPanelStyle" TargetType="{x:Type StackPanel}">
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource PanelBorderStyle}"/>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionPanelStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBox Text="{Binding Code, Mode=OneWay}" Style="{StaticResource HeaderTitleTextBoxStyle}"/>
                        <TextBox Style="{StaticResource HeaderMetaTextBoxStyle}">
                            <TextBox.Text>
                                <MultiBinding StringFormat="{}{0} · {1}">
                                    <Binding Path="Config.CameraModel" Mode="OneWay"/>
                                    <Binding Path="Config.CameraMode" Mode="OneWay"/>
                                </MultiBinding>
                            </TextBox.Text>
                        </TextBox>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SysResourceModel.Remark, Mode=OneWay, Converter={StaticResource StatusToTextConverter}}"
                                       Style="{StaticResource ConnectionStatusTextStyle}"/>
                            <TextBlock Text="·" Style="{StaticResource HeaderStatusTextStyle}" Opacity="0.45" Margin="6,6,0,0"/>
                            <TextBlock Text="{Binding LicenseStatusBadgeText}"
                                       Style="{StaticResource LicenseStatusTextStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1" Command="{Binding EditCommand}" Style="{StaticResource ToolbarButtonStyle}"
                            VerticalAlignment="Center" Margin="16,0,0,0"
                                ToolTip="{x:Static properties:Resources.ToolTipEditCameraConfig}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="{x:Static properties:Resources.ButtonEditConfig}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource AlertBorderStyle}"
                    Visibility="{Binding HasLicenseAlert, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding LicenseAlertText}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Foreground="{Binding LicenseStatusBrush}"
                               Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Command="{Binding UploadLicenseCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" Margin="8,0,0,0"
                            Content="{x:Static properties:Resources.ButtonUpdateLicense}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.58*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.18*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionPanelStyle}" Margin="0">
                    <StackPanel>
                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.Configuration}" Style="{StaticResource ActionSectionTitleStyle}"/>
                            <UniformGrid Columns="3">
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding EditCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.ModifyConfiguration}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding PropertyEditorEditCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.PropertyEdit}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding CfwPortEditCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.LabelCFWConfig}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding OpenSettingDirectoryCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.ButtonOpenConfigFile}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding FilterWheelEditCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.EditFilterWheelConfig}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                            </UniformGrid>
                        </StackPanel>

                        <Border Style="{StaticResource SectionDividerStyle}"/>

                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.License}" Style="{StaticResource ActionSectionTitleStyle}"/>
                            <UniformGrid Columns="4">
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding UploadLicenseCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.ModifyLicense}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding UploadLicenseNetCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.DownLicOnline}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding CopyLicenseCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.CopyLicense}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding ExportLicenseCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.ExportLicense}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                            </UniformGrid>
                        </StackPanel>

                        <Border Style="{StaticResource SectionDividerStyle}"/>

                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.Calibration}" Style="{StaticResource ActionSectionTitleStyle}"/>
                            <UniformGrid Columns="3">
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding UploadCalibrationCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.UploadCalibrationFiles}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding CalibrationTemplateOpenCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.CaliTemplateSet}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding CalibrationEditCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.ButtonCalibrationEdit}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                            </UniformGrid>
                        </StackPanel>

                        <Border Style="{StaticResource SectionDividerStyle}"/>

                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.SectionBackupRestore}" Style="{StaticResource ActionSectionTitleStyle}"/>
                            <UniformGrid Columns="2">
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding CreatResotreCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.CreateRestorePoint}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactCommandButtonStyle}" Command="{Binding LoadResotreCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.LoadRestorePoint}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                            </UniformGrid>
                        </StackPanel>

                        <Border Style="{StaticResource SectionDividerStyle}"/>

                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.SectionDangerousOperations}" Style="{StaticResource ActionSectionTitleStyle}"/>
                            <UniformGrid Columns="2">
                                <Button Style="{StaticResource WarningCommandButtonStyle}" Command="{Binding ResetCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.Reset}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                                <Button Style="{StaticResource CompactDangerCommandButtonStyle}" Command="{Binding DeleteCommand}">
                                    <TextBlock Text="{x:Static properties:Resources.Delete}" Style="{StaticResource CommandButtonTextStyle}"/>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SectionPanelStyle}" Margin="0">
                    <StackPanel>
                        <StackPanel Style="{StaticResource InfoSectionPanelStyle}">
                            <TextBlock Text="{x:Static properties:Resources.ConfigerInfo}" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="118"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="CameraID" Style="{StaticResource DetailLabelStyle}"/>
                                <TextBox Grid.Column="1" Text="{Binding Config.CameraID, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}"/>

                                <TextBlock Grid.Row="1" Text="CameraModel" Style="{StaticResource DetailLabelStyle}" Margin="0,6,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Config.CameraModel, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,6,0,0"/>

                                <TextBlock Grid.Row="2" Text="CameraMode" Style="{StaticResource DetailLabelStyle}" Margin="0,6,8,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Config.CameraMode, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,6,0,0"/>

                                <TextBlock Grid.Row="3" Text="Channel" Style="{StaticResource DetailLabelStyle}" Margin="0,6,8,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Config.Channel, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,6,0,0"/>

                                <TextBlock Grid.Row="4" Text="ImageBpp" Style="{StaticResource DetailLabelStyle}" Margin="0,6,8,0"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Config.ImageBpp, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,6,0,0"/>
                            </Grid>
                        </StackPanel>

                        <Border Style="{StaticResource SectionDividerStyle}"/>

                        <StackPanel Style="{StaticResource InfoSectionPanelStyle}">
                            <TextBlock Text="{x:Static properties:Resources.License}" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="118"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="DeviceMode" Style="{StaticResource DetailLabelStyle}"/>
                                <TextBox Grid.Column="1" Text="{Binding CameraLicenseModel.ColorVisionLicense.DeviceMode, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}"/>

                                <TextBlock Grid.Row="1" Text="IssueDate" Style="{StaticResource DetailLabelStyle}" Margin="0,6,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CameraLicenseModel.ColorVisionLicense.IssueDate, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,6,0,0"/>

                                <TextBlock Grid.Row="2" Text="ExpiryDate" Style="{StaticResource DetailLabelStyle}" Margin="0,6,8,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CameraLicenseModel.ExpiryDate, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,6,0,0"/>

                                <TextBlock Grid.Row="3" Text="Licensee" Style="{StaticResource DetailLabelStyle}" Margin="0,6,8,0"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CameraLicenseModel.ColorVisionLicense.Licensee, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}" Margin="0,6,0,0"/>
                            </Grid>
                        </StackPanel>

                        <Border Style="{StaticResource SectionDividerStyle}"/>

                        <StackPanel Margin="0">
                            <TextBlock Text="{x:Static properties:Resources.CalibrationFileManagement}" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="118"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Static properties:Resources.LabelResourceCount}" Style="{StaticResource DetailLabelStyle}"/>
                                <TextBox Grid.Column="1" Text="{Binding VisualChildren.Count, Mode=OneWay}"
                                         Style="{StaticResource CopyableValueTextBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
