<UserControl x:Class="ColorVision.Engine.Services.PhyCameras.Group.CalibrationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras.Group"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:phy="clr-namespace:ColorVision.Engine.Services.PhyCameras"
             xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:CalibrationParam}"
             d:DesignHeight="520" d:DesignWidth="560"
             MinWidth="420"
             Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="TextBox"/>
        <Style BasedOn="{StaticResource ComboBox.Small}" TargetType="hc:ComboBox">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsEditable" Value="True"/>
        </Style>
        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="CalibrationRowStyle" TargetType="{x:Type DockPanel}">
            <Setter Property="Margin" Value="0,0,0,7"/>
            <Setter Property="LastChildFill" Value="True"/>
        </Style>
        <Style x:Key="StatusDotStyle" TargetType="{x:Type Ellipse}">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="10,0,4,0"/>
            <Setter Property="Fill" Value="{DynamicResource GlobalBorderBrush1}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Fill" Value="#FF2EAD4F"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource PanelBorderStyle}"/>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <Border Style="{StaticResource PanelBorderStyle}" Padding="12" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.CalibrationFileManagement}"
                                       FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Static properties:Resources.DescriptionCalibrationControl}"
                                       FontSize="12" Opacity="0.62" Margin="0,4,0,0"/>
                        </StackPanel>
                        <WrapPanel x:Name="uploadbutton"
                                   d:DataContext="{d:DesignInstance phy:PhyCamera}"
                                   Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center">
                            <Button Margin="6,0,0,0"
                                    Command="{Binding UploadCalibrationCommand}"
                                    Content="{x:Static properties:Resources.UploadCalibrationGroup}"/>
                            <Button Margin="6,0,0,0"
                                    Click="Button_Click"
                                    Content="{x:Static properties:Resources.CalibrationGroupManagement}"/>
                            <Button Margin="6,0,0,0"
                                    Command="{Binding OpenSettingDirectoryCommand}"
                                    Content="{x:Static properties:Resources.OpenConfigFolder}"/>
                        </WrapPanel>
                        <hc:ComboBox x:Name="ComboBoxList"
                                     Grid.Row="1"
                                     Grid.ColumnSpan="2"
                                     DisplayMemberPath="Name"
                                     Text="{Binding CalibrationMode}"
                                     Margin="0,12,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.SectionBasicCalibration}" Style="{StaticResource SectionTitleStyle}"/>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipDarkNoise}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Normal.DarkNoise.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Normal.DarkNoise.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.DarkNoise}"/>
                            <TextBox IsEnabled="False" Text="{Binding Normal.DarkNoise.FilePath}"/>
                        </DockPanel>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipDSNU}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Normal.DSNU.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Normal.DSNU.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.DSNU}"/>
                            <TextBox IsEnabled="False" Text="{Binding Normal.DSNU.FilePath}"/>
                        </DockPanel>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipDefectPoint}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Normal.DefectPoint.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Normal.DefectPoint.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.DefectPoint}"/>
                            <TextBox IsEnabled="False" Text="{Binding Normal.DefectPoint.FilePath}"/>
                        </DockPanel>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipColorShift}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Normal.ColorShift.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Normal.ColorShift.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.ColorShift}"/>
                            <TextBox IsEnabled="False" Text="{Binding Normal.ColorShift.FilePath}"/>
                        </DockPanel>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipDistortion}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Normal.Distortion.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Normal.Distortion.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.Distortion}"/>
                            <TextBox IsEnabled="False" Text="{Binding Normal.Distortion.FilePath}"/>
                        </DockPanel>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipUniformity}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Normal.Uniformity.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Normal.Uniformity.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.Uniformity}"/>
                            <TextBox IsEnabled="False" Text="{Binding Normal.Uniformity.FilePath}"/>
                        </DockPanel>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipLineArity}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Normal.LineArity.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Normal.LineArity.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.LineArity}"/>
                            <TextBox IsEnabled="False" Text="{Binding Normal.LineArity.FilePath}"/>
                        </DockPanel>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipColorDiff}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Normal.ColorDiff.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Normal.ColorDiff.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.ColorDiff}"/>
                            <TextBox IsEnabled="False" Text="{Binding Normal.ColorDiff.FilePath}"/>
                        </DockPanel>

                        <DockPanel ToolTip="{x:Static properties:Resources.ToolTipAngleShift}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Normal.AngleShift.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Normal.AngleShift.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.AngleShift}"/>
                            <TextBox IsEnabled="False" Text="{Binding Normal.AngleShift.FilePath}"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}" Padding="12">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.SectionColorCalibration}" Style="{StaticResource SectionTitleStyle}"/>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipLuminance}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Color.Luminance.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Color.Luminance.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.Brightness}"/>
                            <TextBox IsEnabled="False" Text="{Binding Color.Luminance.FilePath}"/>
                        </DockPanel>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipOneColor}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Color.LumOneColor.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Color.LumOneColor.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.OneColor}"/>
                            <TextBox IsEnabled="False" Text="{Binding Color.LumOneColor.FilePath}"/>
                        </DockPanel>

                        <DockPanel Style="{StaticResource CalibrationRowStyle}" ToolTip="{x:Static properties:Resources.ToolTipFourColor}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Color.LumFourColor.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Color.LumFourColor.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.FourColor}"/>
                            <TextBox IsEnabled="False" Text="{Binding Color.LumFourColor.FilePath}"/>
                        </DockPanel>

                        <DockPanel ToolTip="{x:Static properties:Resources.ToolTipMultiColor}">
                            <Ellipse DockPanel.Dock="Right" Style="{StaticResource StatusDotStyle}" Tag="{Binding Color.LumMultiColor.IsExitFile, Mode=OneWay}"/>
                            <CheckBox DockPanel.Dock="Right" Width="22" IsChecked="{Binding Color.LumMultiColor.IsSelected}"/>
                            <TextBlock DockPanel.Dock="Left" Width="88" Text="{x:Static properties:Resources.MultiColor}"/>
                            <TextBox IsEnabled="False" Text="{Binding Color.LumMultiColor.FilePath}"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
