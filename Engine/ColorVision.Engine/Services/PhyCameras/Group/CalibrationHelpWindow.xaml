<Window x:Class="ColorVision.Engine.Services.PhyCameras.Group.CalibrationHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="校正系统参考手册" Background="{DynamicResource GlobalBackground}" Height="780" Width="900" WindowStartupLocation="CenterScreen" >
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
        <Style x:Key="SubHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
        <Style x:Key="Formula" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="16,4,16,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="FileFormat" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="16,2,16,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="PipelineBox" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,6,0,10"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" Padding="16,12">
            <StackPanel>
                <TextBlock Text="图像校正系统（Calibration System）参考手册" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                <TextBlock Text="本系统提供从原始图像采集到 CIE 色彩空间（XYZ/xy/uv/CCT）转换的完整校正流水线" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.7" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,10,20,20">
            <StackPanel>

                <!-- ===== 1. 校正流水线总览 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="1. 校正流水线总览"/>
                <TextBlock Style="{StaticResource Body}" Text="校正按以下固定顺序依次执行。每一步的输出作为下一步的输入，跳过未启用的步骤。"/>
                <Border Style="{StaticResource PipelineBox}">
                    <TextBlock FontFamily="Consolas" FontSize="13" Foreground="{DynamicResource GlobalTextBrush}" TextWrapping="Wrap" TextAlignment="Center">
                        <Run FontWeight="Bold" Text="原始图像"/>
                        <Run Text="  →  DarkNoise(暗电流)  →  DefectPoint(坏点)  →  DSNU(暗信号非均匀性)"/>
                        <LineBreak/>
                        <Run Text="  →  Uniformity(均匀性)  →  ColorShift(色偏)  →  Distortion(畸变)"/>
                        <LineBreak/>
                        <Run Text="  →  "/>
                        <Run FontWeight="Bold" Text="校正后图像"/>
                        <Run Text="  →  [亮度 / 单色 / 四色 / 多色] 色彩转换  →  "/>
                        <Run FontWeight="Bold" Text="CIE XYZ / Lv"/>
                    </TextBlock>
                </Border>

                <!-- ===== 2. 基础校正项详解 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="2. 基础校正项详解"/>

                <!-- DarkNoise -->
                <TextBlock Style="{StaticResource SubHeader}" Text="2.1 暗电流校正（DarkNoise）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：在无光照条件下，传感器会产生暗电流信号。通过预先标定的暗电流比率对每个像素进行乘法补偿，消除暗电流噪声。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法公式："/>
                <TextBlock Style="{StaticResource Formula}" Text="pixel_out = min(pixel_in × DarkNoiseRatio, MaxValue)&#x0a;&#x0a;MaxValue:  8-bit → 255,  16-bit → 65535"/>
                <TextBlock Style="{StaticResource Body}" Text="配置文件格式：JSON"/>
                <TextBlock Style="{StaticResource FileFormat}" Text='{}{  "bpp": 16, "DarkNoiseRatio": 0.95 }'/>
                <TextBlock Style="{StaticResource Body}" Text="说明：在 ROI 区域内逐像素乘以暗电流系数，结果上溢截断至最大值。"/>

                <!-- DSNU -->
                <TextBlock Style="{StaticResource SubHeader}" Text="2.2 暗信号非均匀性校正（DSNU）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：暗信号非均匀性（Dark Signal Non-Uniformity）是传感器固有的像素级暗电流差异。通过预采集的暗帧基准图，逐像素做减法补偿。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法公式："/>
                <TextBlock Style="{StaticResource Formula}" Text="pixel_out = max(pixel_in - DSNU_ref[i], 0)&#x0a;&#x0a;支持单通道和多通道（R/G/B 分别减对应通道的 DSNU 基准值）&#x0a;下溢截断至 0"/>
                <TextBlock Style="{StaticResource Body}" Text="配置文件格式：二进制"/>
                <TextBlock Style="{StaticResource FileFormat}" Text="V0：[8字节头: height, width] + [ushort数据: height × width]&#x0a;V1：[20字节头: height, width, databpp, channels, typebpp] + [ushort数据: height × width × channels]"/>

                <!-- DefectPoint -->
                <TextBlock Style="{StaticResource SubHeader}" Text="2.3 坏点校正（DefectPoint）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：预先标定坏点坐标列表，对每个坏点用其 7×7 邻域的中值滤波值替代。多通道独立处理。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法步骤："/>
                <TextBlock Style="{StaticResource Formula}" Text="1. 读取坏点列表 (row, col)&#x0a;2. 对每个坏点取中心 ±3 范围内的邻域像素&#x0a;3. 对邻域像素排序，取中值作为修复值&#x0a;4. 多通道独立处理&#x0a;&#x0a;中值滤波窗口：7×7，边界处自动裁剪到图像边界"/>
                <TextBlock Style="{StaticResource Body}" Text="配置文件格式：二进制"/>
                <TextBlock Style="{StaticResource FileFormat}" Text="[4字节: 坏点数量 N]&#x0a;[4字节: y坐标][4字节: x坐标] × N"/>

                <!-- Uniformity -->
                <TextBlock Style="{StaticResource SubHeader}" Text="2.4 均匀性校正（Uniformity）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：补偿镜头渐晕（Vignetting）和传感器灵敏度的空间差异。使用预标定的乘法因子矩阵，对每个像素乘以对应的校正系数。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法公式："/>
                <TextBlock Style="{StaticResource Formula}" Text="pixel_out = min(pixel_in × Uniformity_factor[i], MaxValue)&#x0a;&#x0a;上溢截断至最大值（8-bit: 255, 16-bit: 65535）&#x0a;支持单通道和 RGB 三通道独立校正&#x0a;支持 BGR 交错和通道分离两种内存布局"/>
                <TextBlock Style="{StaticResource Body}" Text="配置文件格式：二进制"/>
                <TextBlock Style="{StaticResource FileFormat}" Text="V0：[8字节头: height, width] + [float数据: height × width]&#x0a;V1：[20字节头: height, width, databpp, channels, typebpp] + [float数据: height × width × channels]"/>

                <!-- ColorShift -->
                <TextBlock Style="{StaticResource SubHeader}" Text="2.5 色偏校正（ColorShift）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：在多通道光学系统中，不同色彩通道可能存在空间偏移。通过 OpenCV 仿射变换进行通道级平移补偿。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法公式："/>
                <TextBlock Style="{StaticResource Formula}" Text="构造 2×3 仿射变换矩阵：&#x0a;M = | 1  0  dx |&#x0a;    | 0  1  dy |&#x0a;&#x0a;调用 cv::warpAffine 执行亚像素级平移&#x0a;fillOffset=true 时，用边缘镜像数据填充平移后的空白区域"/>
                <TextBlock Style="{StaticResource Body}" Text="配置文件格式：JSON"/>
                <TextBlock Style="{StaticResource FileFormat}" Text='统一偏移：{ "fillOffset": true, "offset": { "X": 2, "Y": -1 } }&#x0a;多通道独立偏移：{ "fillOffset": false, "offsets": [{"X":1,"Y":0}, {"X":0,"Y":-1}, ...] }'/>

                <!-- Distortion -->
                <TextBlock Style="{StaticResource SubHeader}" Text="2.6 畸变校正（Distortion）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：使用 OpenCV 的相机标定模型，支持标准针孔模型和鱼眼模型。预计算重映射表后通过 cv::remap 执行像素重映射。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法步骤："/>
                <TextBlock Style="{StaticResource Formula}" Text="1. 加载标定参数 (fx, fy, cx, cy, k1-k3, p1-p2)&#x0a;2. 后台线程预计算重映射表：&#x0a;   标准模型 → cv::initUndistortRectifyMap&#x0a;   鱼眼模型 → cv::fisheye::initUndistortRectifyMap&#x0a;3. 校正时使用 cv::remap 执行像素重映射&#x0a;4. alpha 参数控制缩放（0=无黑边，1=保留所有像素）&#x0a;&#x0a;畸变模型：&#x0a;  标准：k1, k2, p1, p2, k3（径向 + 切向）&#x0a;  鱼眼：4 个畸变系数"/>
                <TextBlock Style="{StaticResource Body}" Text="配置文件格式：JSON"/>
                <TextBlock Style="{StaticResource FileFormat}" Text='{}{  "w": 1920, "h": 1080, "fx": 1200.0, "fy": 1200.0,&#x0a;  "cx": 960.0, "cy": 540.0,&#x0a;  "k1": -0.1, "k2": 0.01, "p1": 0.0, "p2": 0.0, "k3": 0.0,&#x0a;  "alpha": 0.0 }'/>

                <!-- LineArity -->
                <TextBlock Style="{StaticResource SubHeader}" Text="2.7 线性度校正（LineArity）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：校正传感器输出灰度值与实际光照强度之间的非线性响应关系，确保线性映射。"/>

                <!-- ColorDiff -->
                <TextBlock Style="{StaticResource SubHeader}" Text="2.8 色差校正（ColorDiff）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：校正不同色彩通道间的色差偏移，消除由光学系统引起的通道间色彩误差。"/>

                <!-- ===== 3. 色彩校正项详解 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="3. 色彩校正项详解（四选一，互斥）"/>
                <TextBlock Style="{StaticResource Body}" Text="四种色彩校正模式互斥，每次只能启用其中一种。它们将传感器的灰度/RGB 值转换为 CIE XYZ 三刺激值或绝对亮度值。"/>

                <!-- Luminance -->
                <TextBlock Style="{StaticResource SubHeader}" Text="3.1 亮度校正（Luminance）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：将单通道灰度值转换为绝对亮度值 Lv（cd/m²），输出 32 位浮点 CIE-Y 通道。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法公式："/>
                <TextBlock Style="{StaticResource Formula}" Text="Lv[i] = (a / Texp) × pixel[i]&#x0a;&#x0a;线性转换，系数 a 经曝光时间归一化&#x0a;仅处理光学黑区（OB）外的有效像素&#x0a;输出：单通道 32 位浮点亮度图（cd/m²）"/>
                <TextBlock Style="{StaticResource Body}" Text="配置文件格式：JSON"/>
                <TextBlock Style="{StaticResource FileFormat}" Text='{}{  "bpp": 16, "Texp": 100.0, "Gain": 1.0,&#x0a;  "a": 0.0123, "b": 0.0, "c": 0.0, "d": 0.0 }'/>

                <!-- LumOneColor -->
                <TextBlock Style="{StaticResource SubHeader}" Text="3.2 单色校正（LumOneColor）— 4 系数模型"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：使用 4 系数模型，将 3 通道（RGB）灰度图像转换为 CIE XYZ 三刺激值。假设 X 由 R 和 B 通道线性组合，Y 仅来自 G，Z 仅来自 B。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法公式："/>
                <TextBlock Style="{StaticResource Formula}" Text="X[i] = (a / Tx·Gx) × R[i] + (d / Tz·Gz) × B[i]&#x0a;Y[i] = (b / Ty·Gy) × G[i]&#x0a;Z[i] = (c / Tz·Gz) × B[i]&#x0a;&#x0a;其中 Tx/Ty/Tz = 各通道曝光时间，Gx/Gy/Gz = 各通道增益&#x0a;支持 BGR 交错和通道分离两种输入布局&#x0a;多线程加速：图像按行分为 4 个线程块并行计算&#x0a;输出：3 个 32 位浮点通道 [CIE_X][CIE_Y][CIE_Z]"/>

                <!-- LumFourColor -->
                <TextBlock Style="{StaticResource SubHeader}" Text="3.3 四色校正（LumFourColor）— 3×3 矩阵（9 系数）"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：使用完整的 3×3 矩阵（9 个系数 a-i）实现通道混合色彩转换。每个输出通道由全部 3 个输入通道加权求和，精度高于单色校正。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法公式："/>
                <TextBlock Style="{StaticResource Formula}" Text="| X |   | a/(Tx·Gx)  b/(Ty·Gy)  c/(Tz·Gz) |   | R |&#x0a;| Y | = | d/(Tx·Gx)  e/(Ty·Gy)  f/(Tz·Gz) | × | G |&#x0a;| Z |   | g/(Tx·Gx)  h/(Ty·Gy)  i/(Tz·Gz) |   | B |&#x0a;&#x0a;配置文件含 a-i 共 9 个系数，以及各通道曝光时间和增益&#x0a;同样支持多线程并行计算"/>

                <!-- LumMultiColor -->
                <TextBlock Style="{StaticResource SubHeader}" Text="3.4 多色校正（LumMultiColor）— 动态高阶矩阵"/>
                <TextBlock Style="{StaticResource Body}" Text="原理：使用动态大小的系数矩阵（N 个系数），支持更高阶的色彩转换模型。系数数组长度 N，增益数组长度 N/3，按每 3 个系数为一组对 RGB 做线性组合。"/>
                <TextBlock Style="{StaticResource Body}" Text="算法说明："/>
                <TextBlock Style="{StaticResource Formula}" Text="系数数组 pa[N]，增益数组 Gain[N/3]&#x0a;每 3 个系数为一组 (pa[3k], pa[3k+1], pa[3k+2])：&#x0a;  output[k] = pa[3k]×R + pa[3k+1]×G + pa[3k+2]×B&#x0a;&#x0a;适用于需要更高精度的特殊光学系统"/>
                <TextBlock Style="{StaticResource Body}" Text="配置文件格式：JSON"/>
                <TextBlock Style="{StaticResource FileFormat}" Text='{}{  "bpp": 16,&#x0a;  "pa": [c0, c1, c2, c3, c4, c5, ...],&#x0a;  "Gain": [g0, g1, g2, ...] }'/>

                <!-- ===== 4. XYZ 数据提取 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="4. CIE 色度数据提取"/>
                <TextBlock Style="{StaticResource Body}" Text="校正完成后，可在 CIE XYZ 浮点图像上提取色度数据。支持圆形和矩形 ROI 区域。"/>
                <Border Style="{StaticResource PipelineBox}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Body}" FontWeight="SemiBold" Text="支持的色度参数："/>
                        <TextBlock Style="{StaticResource Formula}" Text="CIE xy 色度坐标：  x = X/(X+Y+Z),   y = Y/(X+Y+Z)&#x0a;CIE u'v' 色度坐标：u' = 4X/(X+15Y+3Z), v' = 9Y/(X+15Y+3Z)&#x0a;CCT（相关色温）和主波长"/>
                        <TextBlock Style="{StaticResource Body}" Margin="0,8,0,0" Text="滤波功能：支持阈值滤波、区域外滤波、XYZ 通道滤波、百分比滤波等多种异常像素排除机制。"/>
                    </StackPanel>
                </Border>

                <!-- ===== 5. 文件状态指示说明 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="5. 界面指示说明"/>
                <Border Style="{StaticResource PipelineBox}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Body}" Text="● 绿色指示灯（亮）：校正文件已就绪，文件存在于服务器上且可用"/>
                        <TextBlock Style="{StaticResource Body}" Text="● 灰色指示灯（灭）：校正文件未找到或无效，该校正步骤将被跳过"/>
                        <TextBlock Style="{StaticResource Body}" Text="● 复选框（勾选）：启用该校正步骤，执行校正时将应用此校正"/>
                        <TextBlock Style="{StaticResource Body}" Text="● 复选框（未勾选）：禁用该校正步骤，即使文件存在也不会应用"/>
                        <TextBlock Style="{StaticResource Body}" Margin="0,6,0,0" FontStyle="Italic" Text="提示：色彩校正（亮度/单色/四色/多色）四选一互斥，选中一个会自动取消其他三个。"/>
                    </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource Body}" Opacity="0.5" Margin="0,20,0,10" TextAlignment="Center" Text="— 基于 C++ DLL 校正引擎（CVCommCore.dll）—"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
