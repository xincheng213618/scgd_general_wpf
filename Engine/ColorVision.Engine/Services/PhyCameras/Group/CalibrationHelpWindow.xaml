<Window x:Class="ColorVision.Engine.Services.PhyCameras.Group.CalibrationHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.TitleCalibrationHelp}" Background="{DynamicResource GlobalBackground}" Height="780" Width="900" WindowStartupLocation="CenterScreen" >
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>
        <Style x:Key="SubHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="Body" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
        <Style x:Key="Formula" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="16,4,16,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="FileFormat" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="16,2,16,4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="PipelineBox" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource RegionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,6,0,10"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" Padding="16,12">
            <StackPanel>
                <TextBlock Text="{x:Static properties:Resources.HelpCalibrationSystemTitle}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                <TextBlock Text="{x:Static properties:Resources.HelpCalibrationSystemDesc}" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.7" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,10,20,20">
            <StackPanel>

                <!-- ===== 1. 校正流水线总览 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static properties:Resources.HelpSection1Title}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpSection1Desc}"/>
                <Border Style="{StaticResource PipelineBox}">
                    <TextBlock FontFamily="Consolas" FontSize="13" Foreground="{DynamicResource GlobalTextBrush}" TextWrapping="Wrap" TextAlignment="Center">
                        <Run FontWeight="Bold" Text="{x:Static properties:Resources.HelpPipelineRawImage}"/>
                        <Run Text="{x:Static properties:Resources.HelpPipelineBasic}"/>
                        <LineBreak/>
                        <Run Text="{x:Static properties:Resources.HelpPipelineAdvanced}"/>
                        <LineBreak/>
                        <Run Text="  →  "/>
                        <Run FontWeight="Bold" Text="{x:Static properties:Resources.HelpPipelineCorrectedImage}"/>
                        <Run Text="{x:Static properties:Resources.HelpPipelineColorConversion}"/>
                        <Run FontWeight="Bold" Text="{x:Static properties:Resources.HelpPipelineOutputLabel}"/>
                    </TextBlock>
                </Border>

                <!-- ===== 2. 基础校正项详解 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static properties:Resources.HelpSection2Title}"/>

                <!-- DarkNoise -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpDarkNoiseTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpDarkNoiseDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFormulaLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaDarkNoiseText}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFileFormatJSON}"/>
                <TextBlock Style="{StaticResource FileFormat}" Text='{}{  "bpp": 16, "DarkNoiseRatio": 0.95 }'/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpDarkNoiseNote}"/>

                <!-- DSNU -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpDSNUTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpDSNUDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFormulaLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaDSNU}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFileFormatBinary}"/>
                <TextBlock Style="{StaticResource FileFormat}" Text="{x:Static properties:Resources.HelpFileFormatDSNU}"/>

                <!-- DefectPoint -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpDefectPointTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpDefectPointDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpAlgorithmStepsLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaDefectPoint}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFileFormatBinary}"/>
                <TextBlock Style="{StaticResource FileFormat}" Text="{x:Static properties:Resources.HelpFileFormatDefectPoint}"/>

                <!-- Uniformity -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpUniformityTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpUniformityDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFormulaLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaUniformity}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFileFormatBinary}"/>
                <TextBlock Style="{StaticResource FileFormat}" Text="{x:Static properties:Resources.HelpFileFormatUniformity}"/>

                <!-- ColorShift -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpColorShiftTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpColorShiftDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFormulaLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaColorShift}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFileFormatJSON}"/>
                <TextBlock Style="{StaticResource FileFormat}" Text="{x:Static properties:Resources.HelpFileFormatColorShift}"/>

                <!-- Distortion -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpDistortionTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpDistortionDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpAlgorithmStepsLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaDistortion}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFileFormatJSON}"/>
                <TextBlock Style="{StaticResource FileFormat}" Text='{}{  "w": 1920, "h": 1080, "fx": 1200.0, "fy": 1200.0,&#x0a;  "cx": 960.0, "cy": 540.0,&#x0a;  "k1": -0.1, "k2": 0.01, "p1": 0.0, "p2": 0.0, "k3": 0.0,&#x0a;  "alpha": 0.0 }'/>

                <!-- LineArity -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpLineArityTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpLineArityDesc}"/>

                <!-- ColorDiff -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpColorDiffTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpColorDiffDesc}"/>

                <!-- ===== 3. 色彩校正项详解 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static properties:Resources.HelpSection3Title}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpSection3Desc}"/>

                <!-- Luminance -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpLuminanceTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpLuminanceDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFormulaLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaLuminance}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFileFormatJSON}"/>
                <TextBlock Style="{StaticResource FileFormat}" Text='{}{  "bpp": 16, "Texp": 100.0, "Gain": 1.0,&#x0a;  "a": 0.0123, "b": 0.0, "c": 0.0, "d": 0.0 }'/>

                <!-- LumOneColor -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpOneColorTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpOneColorDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFormulaLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaOneColor}"/>

                <!-- LumFourColor -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpFourColorTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFourColorDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFormulaLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaFourColor}"/>

                <!-- LumMultiColor -->
                <TextBlock Style="{StaticResource SubHeader}" Text="{x:Static properties:Resources.HelpMultiColorTitle}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpMultiColorDesc}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpAlgorithmDescLabel}"/>
                <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaMultiColor}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpFileFormatJSON}"/>
                <TextBlock Style="{StaticResource FileFormat}" Text='{}{  "bpp": 16,&#x0a;  "pa": [c0, c1, c2, c3, c4, c5, ...],&#x0a;  "Gain": [g0, g1, g2, ...] }'/>

                <!-- ===== 4. XYZ 数据提取 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static properties:Resources.HelpSection4Title}"/>
                <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpSection4Desc}"/>
                <Border Style="{StaticResource PipelineBox}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Body}" FontWeight="SemiBold" Text="{x:Static properties:Resources.HelpChromaticParamsLabel}"/>
                        <TextBlock Style="{StaticResource Formula}" Text="{x:Static properties:Resources.HelpFormulaChromatic}"/>
                        <TextBlock Style="{StaticResource Body}" Margin="0,8,0,0" Text="{x:Static properties:Resources.HelpFilterDesc}"/>
                    </StackPanel>
                </Border>

                <!-- ===== 5. 文件状态指示说明 ===== -->
                <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static properties:Resources.HelpSection5Title}"/>
                <Border Style="{StaticResource PipelineBox}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpIndicatorGreen}"/>
                        <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpIndicatorGray}"/>
                        <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpIndicatorChecked}"/>
                        <TextBlock Style="{StaticResource Body}" Text="{x:Static properties:Resources.HelpIndicatorUnchecked}"/>
                        <TextBlock Style="{StaticResource Body}" Margin="0,6,0,0" FontStyle="Italic" Text="{x:Static properties:Resources.HelpColorCalibrationTip}"/>
                    </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource Body}" Opacity="0.5" Margin="0,20,0,10" TextAlignment="Center" Text="{x:Static properties:Resources.HelpEngineFooter}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
