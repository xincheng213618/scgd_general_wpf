<Window x:Class="ColorVision.Engine.Services.PhyCameras.CameraSearchTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:CameraSearchTypeWindow}"
        Title="搜索相机类型" Height="480" Width="420" Background="{DynamicResource GlobalBackground}" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="相机类型" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <ListBox ItemsSource="{Binding CameraModels}" BorderThickness="0" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="6,4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button Content="默认" MinWidth="64" Margin="0,0,6,0" Click="Default_Click"/>
                <Button Content="全选" MinWidth="64" Margin="0,0,6,0" Click="SelectAll_Click"/>
                <Button Content="清空" MinWidth="64" Click="Clear_Click"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="搜索" MinWidth="80" Margin="0,0,8,0" Background="{StaticResource PrimaryBrush}" Foreground="White" Click="Search_Click"/>
                <Button Content="取消" MinWidth="80" Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>