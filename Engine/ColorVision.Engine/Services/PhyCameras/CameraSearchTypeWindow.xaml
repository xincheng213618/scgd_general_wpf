<Window x:Class="ColorVision.Engine.Services.PhyCameras.CameraSearchTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:CameraSearchTypeWindow}"
        Title="{x:Static properties:Resources.TitleSearchCameraType}" Height="520" Width="460" MinHeight="420" MinWidth="380"
        Background="{DynamicResource GlobalBackground}" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="2,0,2,12">
            <TextBlock Text="{x:Static properties:Resources.LabelCameraType}" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="{x:Static properties:Resources.DescriptionSelectCameraType}" FontSize="12"
                       Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.62"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="6">
            <ListBox ItemsSource="{Binding CameraModels}" BorderThickness="0" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  Margin="8,5" Padding="6,4"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button Content="{x:Static properties:Resources.ButtonDefault}" MinWidth="68" Margin="0,0,6,0" Click="Default_Click"/>
                <Button Content="{x:Static properties:Resources.ButtonSelectAll}" MinWidth="68" Margin="0,0,6,0" Click="SelectAll_Click"/>
                <Button Content="{x:Static properties:Resources.Clear}" MinWidth="68" Click="Clear_Click"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{x:Static properties:Resources.Search}" MinWidth="86" Height="32"
                        Margin="0,0,8,0" Background="{StaticResource PrimaryBrush}" Foreground="White"
                        Click="Search_Click"/>
                <Button Content="{x:Static properties:Resources.Cancel}" MinWidth="86" Height="32"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
