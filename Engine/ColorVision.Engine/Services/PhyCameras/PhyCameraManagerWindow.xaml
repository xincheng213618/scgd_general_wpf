<Window x:Class="ColorVision.Engine.Services.PhyCameras.PhyCameraManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:PhyCameraManager}"
        Title="{x:Static properties:Resources.PhysicalCameraManager}"
        Height="760" Width="1320" MinHeight="620" MinWidth="980"
        Background="{DynamicResource GlobalBackground}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <ResourceDictionary>
            <local:StatusToTextConverter x:Key="StatusToTextConverter"/>

            <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>

            <Style x:Key="ToolbarButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="MinHeight" Value="34"/>
                <Setter Property="Padding" Value="12,5"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="SmallIconButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Width" Value="36"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            </Style>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Padding="12,10" Margin="0,0,0,12">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right" Style="{StaticResource SmallIconButtonStyle}"
                        Command="{Binding EditCofigCommand}" ToolTip="{x:Static properties:Resources.ModifyConfiguration}">
                    <TextBlock Text="&#xE713;" HorizontalAlignment="Center"
                               FontFamily="Segoe MDL2 Assets" FontSize="19"
                               Foreground="{DynamicResource GlobalTextBrush}">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="rotateTransform21"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.Click">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="rotateTransform21"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:0.5"
                                                     FillBehavior="Stop"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>

                <WrapPanel VerticalAlignment="Center">
                    <hc:Badge Value="{Binding Count}" BadgeMargin="0,-12,-8,0"
                              Style="{StaticResource BadgeDanger}" Margin="0,0,8,0">
                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                Content="{x:Static properties:Resources.AddUncreatedCamera}"
                                Command="{Binding CreateCommand}"/>
                    </hc:Badge>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="{x:Static properties:Resources.Search}"
                            Command="{Binding SearchCameraCommand}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="{x:Static properties:Resources.LicenseImport}"
                            Command="{Binding ImportCommand}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="{x:Static properties:Resources.LicenseManager}"
                            Command="{Binding OpenLicenseManagerCommand}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="{x:Static properties:Resources.OpenDeviceManager}"
                            Command="{Binding OpenDeviceManagerCommand}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="MVS Log"
                            Command="{Binding OpenMVSLogViewerCommand}"/>
                    <Button Style="{StaticResource ToolbarButtonStyle}" Content="License Notice"
                            Command="{Binding EditLicenseNotificationConfigCommand}"/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="2,0,2,10">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding PhyCameras.Count, StringFormat={}{0}}"
                                   FontSize="13" FontWeight="SemiBold" Opacity="0.75"/>
                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.Camera}" FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Static properties:Resources.PhysicalCameraManager}"
                                       FontSize="12" Opacity="0.58" Margin="0,3,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <TreeView x:Name="TreeView1" Grid.Row="1"
                              ItemsSource="{Binding PhyCameras}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              SelectedItemChanged="TreeView1_SelectedItemChanged"
                              Background="Transparent" BorderThickness="0">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type local:PhyCamera}">
                                <Border Margin="0,3" Padding="10" CornerRadius="7"
                                        BorderBrush="{DynamicResource GlobalBorderBrush1}"
                                        BorderThickness="1"
                                        Background="{DynamicResource ButtonBackground}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Id}" FontWeight="SemiBold"/>
                                            <TextBlock Text="  "/>
                                            <TextBlock Text="{Binding CameraLicenseModel.ColorVisionLicense.DeviceMode}"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                            <Ellipse Width="9" Height="9" Margin="0,0,5,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="{x:Type Ellipse}">
                                                        <Setter Property="Fill" Value="#FF28A745"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SysResourceModel.Remark}" Value="Offline">
                                                                <Setter Property="Fill" Value="#FFE53935"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding SysResourceModel.Remark,Converter={StaticResource StatusToTextConverter}}"
                                                       FontSize="12" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SysResourceModel.Remark}" Value="Offline">
                                                                <Setter Property="Foreground" Value="#FFE53935"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Code}"
                                                   FontSize="12" Opacity="0.72" Margin="0,7,0,0"/>
                                        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,7,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="12" Opacity="0.72">
                                                <Run Text="{Binding Config.CameraModel}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding Config.CameraMode}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding Config.Channel}"/>
                                                <Run Text=" / "/>
                                                <Run Text="{Binding Config.ImageBpp}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding LicenseExpiryText}"
                                                       Foreground="{Binding LicenseExpiryColor}"
                                                       FontSize="11" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource TreeViewItemBaseStyle}">
                                <Setter Property="ContextMenu" Value="{Binding ContextMenu}"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch"
                          Background="Transparent"/>

            <Grid x:Name="StackPanelShow" Grid.Column="2">
                <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static properties:Resources.Camera}" FontSize="22"
                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Static properties:Resources.Selected}" FontSize="13"
                                   Opacity="0.6" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
