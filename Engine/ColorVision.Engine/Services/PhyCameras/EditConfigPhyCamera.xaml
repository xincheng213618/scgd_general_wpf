<Window x:Class="ColorVision.Engine.Services.PhyCameras.EditConfigPhyCamera"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:EditConfigPhyCamera}"
        Title="{x:Static properties:Resources.TitleEditCameraConfig}"
        Height="720" Width="1040"
        MinHeight="640" MinWidth="920"
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ColorVision.Engine;component/Services/PhyCameras/PhyCameraConsoleStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </Style>

            <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Opacity" Value="0.62"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>

            <Style x:Key="FieldBoxStyle" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="7"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Margin" Value="0,0,10,10"/>
            </Style>

            <Style x:Key="ChannelHeaderStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="6,0,0,6"/>
            </Style>

            <Style x:Key="ExpanderHeaderStyle" TargetType="{x:Type Expander}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="Margin" Value="0,8,0,0"/>
            </Style>

            <Style x:Key="SectionDividerStyle" TargetType="{x:Type Border}">
                <Setter Property="Height" Value="1"/>
                <Setter Property="Margin" Value="0,2,0,8"/>
                <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush1}"/>
                <Setter Property="Opacity" Value="0.45"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource SectionPanelStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource FieldBoxStyle}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.CameraType}" Style="{StaticResource FieldLabelStyle}"/>
                                    <hc:ComboBox x:Name="ComboxCameraModel"
                                                 SelectedValue="{Binding EditConfig.CameraModel}"
                                                 SelectedValuePath="Key"
                                                 DisplayMemberPath="Value"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource FieldBoxStyle}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.CamreaMode}" Style="{StaticResource FieldLabelStyle}"/>
                                    <hc:ComboBox x:Name="ComboxCameraMode"
                                                 SelectedValue="{Binding EditConfig.CameraMode}"
                                                 SelectedValuePath="Key"
                                                 DisplayMemberPath="Value"
                                                 SelectionChanged="ComboxCameraMode_SelectionChanged"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource FieldBoxStyle}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.DefaultImageBits}" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="ComboxCameraImageBpp"
                                              SelectedValue="{Binding EditConfig.ImageBpp}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Value"/>
                                </StackPanel>
                            </Border>
                            <Border x:Name="ChannelField" Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.DefaultChannelCount}" Style="{StaticResource FieldLabelStyle}"/>
                                    <hc:ComboBox x:Name="ComboxCameraChannel"
                                                 SelectedValue="{Binding EditConfig.Channel}"
                                                 SelectedValuePath="Key"
                                                 DisplayMemberPath="Value"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionPanelStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.LabelFrameCropROI}" Style="{StaticResource SectionTitleStyle}"/>
                        <Expander Header="PhyCameraCfg" Style="{StaticResource ExpanderHeaderStyle}">
                            <StackPanel x:Name="CameraCfgPanel" Margin="0,8,0,0"/>
                        </Expander>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionPanelStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,12">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Click="ResetChannels_Click"
                                    Visibility="{Binding EditConfig.CFW.IsUseCFW, Converter={StaticResource bool2VisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                                    <TextBlock Text="{x:Static properties:Resources.ButtonResetChannels}"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="{x:Static properties:Resources.LabelCFWConfig}" Style="{StaticResource SectionTitleStyle}"/>
                        </DockPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="330"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,10">
                                    <DockPanel LastChildFill="True">
                                        <ui:ToggleSwitch DockPanel.Dock="Right"
                                                         IsChecked="{Binding EditConfig.CFW.IsUseCFW}"/>
                                        <StackPanel>
                                            <TextBlock Text="{x:Static properties:Resources.LabelEnableCFW}" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBlock Text="{x:Static properties:Resources.DescriptionCFWDisableNote}"
                                                       FontSize="11" Opacity="0.55"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <StackPanel Visibility="{Binding EditConfig.CFW.IsUseCFW, Converter={StaticResource bool2VisibilityConverter}}">
                                    <Border Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{x:Static properties:Resources.LabelFilterWheelCount}" Style="{StaticResource FieldLabelStyle}"/>
                                            <hc:NumericUpDown Value="{Binding EditConfig.CFW.CFWNum}"
                                                              Minimum="1"
                                                              Maximum="3"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,10">
                                        <DockPanel LastChildFill="True">
                                            <ui:ToggleSwitch DockPanel.Dock="Right"
                                                             IsChecked="{Binding EditConfig.CFW.IsBingNDDevice}"/>
                                            <StackPanel>
                                                <TextBlock Text="{x:Static properties:Resources.LabelBindNDDevice}" Style="{StaticResource FieldLabelStyle}"/>
                                                <TextBlock Text="{x:Static properties:Resources.DescriptionBindNDNote}"
                                                           FontSize="11" Opacity="0.55"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                    <Border Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,10">
                                        <DockPanel LastChildFill="True">
                                            <ui:ToggleSwitch DockPanel.Dock="Right"
                                                             IsChecked="{Binding EditConfig.CFW.IsCOM}"/>
                                            <StackPanel>
                                                <TextBlock Text="{x:Static properties:Resources.EnableSerialPort}" Style="{StaticResource FieldLabelStyle}"/>
                                                <TextBlock Text="{x:Static properties:Resources.DescriptionSerialPortNote}"
                                                           FontSize="11" Opacity="0.55"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>

                                    <Border Style="{StaticResource SectionDividerStyle}"/>
                                    <StackPanel x:Name="CfwConnectionFieldsPanel"/>

                                    <Expander Header="{x:Static properties:Resources.HeaderCFWAdvancedParams}" Style="{StaticResource ExpanderHeaderStyle}">
                                        <StackPanel x:Name="CfwAdvancedFieldsPanel" Margin="0,8,0,0"/>
                                    </Expander>
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{x:Static properties:Resources.DescriptionCFWChannelMapping}"
                                           FontSize="12"
                                           Opacity="0.62"
                                           Margin="0,0,0,10"
                                           Visibility="{Binding EditConfig.CFW.IsUseCFW, Converter={StaticResource bool2VisibilityConverter}}"/>

                                <Grid Grid.Row="1"
                                      Visibility="{Binding EditConfig.CFW.IsUseCFW, Converter={StaticResource bool2VisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="74"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="1" Text="{x:Static properties:Resources.HeaderChannel1}" Style="{StaticResource ChannelHeaderStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{x:Static properties:Resources.HeaderChannel2}" Style="{StaticResource ChannelHeaderStyle}"/>
                                    <TextBlock Grid.Column="3" Text="{x:Static properties:Resources.HeaderChannel3}" Style="{StaticResource ChannelHeaderStyle}"/>

                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              x:Name="chType1"
                                              Margin="6,0,0,8"
                                              SelectedValue="{Binding EditConfig.CFW.ChannelCfgs[0].Chtype}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Value"/>
                                    <ComboBox Grid.Row="1" Grid.Column="2"
                                              x:Name="chType2"
                                              Margin="6,0,0,8"
                                              SelectedValue="{Binding EditConfig.CFW.ChannelCfgs[1].Chtype}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Value"/>
                                    <ComboBox Grid.Row="1" Grid.Column="3"
                                              x:Name="chType3"
                                              Margin="6,0,0,8"
                                              SelectedValue="{Binding EditConfig.CFW.ChannelCfgs[2].Chtype}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Value"/>

                                    <TextBlock Grid.Row="2" Text="{x:Static properties:Resources.HeaderFilterWheel1}" Style="{StaticResource DetailLabelStyle}" Margin="0,0,0,8"/>
                                    <hc:NumericUpDown Grid.Row="2" Grid.Column="1"
                                                      Margin="6,0,0,8"
                                                      MinHeight="30"
                                                      Value="{Binding EditConfig.CFW.ChannelCfgs[0].Cfwport}"
                                                      Minimum="0"/>
                                    <hc:NumericUpDown Grid.Row="2" Grid.Column="2"
                                                      Margin="6,0,0,8"
                                                      MinHeight="30"
                                                      Value="{Binding EditConfig.CFW.ChannelCfgs[1].Cfwport}"
                                                      Minimum="0"/>
                                    <hc:NumericUpDown Grid.Row="2" Grid.Column="3"
                                                      Margin="6,0,0,8"
                                                      MinHeight="30"
                                                      Value="{Binding EditConfig.CFW.ChannelCfgs[2].Cfwport}"
                                                      Minimum="0"/>

                                    <TextBlock Grid.Row="3" Text="{x:Static properties:Resources.HeaderFilterWheel2}" Style="{StaticResource DetailLabelStyle}" Margin="0,0,0,8"
                                               Visibility="{Binding EditConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    <hc:NumericUpDown Grid.Row="3" Grid.Column="1"
                                                      Margin="6,0,0,8"
                                                      MinHeight="30"
                                                      Value="{Binding EditConfig.CFW.ChannelCfgs[3].Cfwport}"
                                                      Minimum="0"
                                                      Visibility="{Binding EditConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    <hc:NumericUpDown Grid.Row="3" Grid.Column="2"
                                                      Margin="6,0,0,8"
                                                      MinHeight="30"
                                                      Value="{Binding EditConfig.CFW.ChannelCfgs[4].Cfwport}"
                                                      Minimum="0"
                                                      Visibility="{Binding EditConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    <hc:NumericUpDown Grid.Row="3" Grid.Column="3"
                                                      Margin="6,0,0,8"
                                                      MinHeight="30"
                                                      Value="{Binding EditConfig.CFW.ChannelCfgs[5].Cfwport}"
                                                      Minimum="0"
                                                      Visibility="{Binding EditConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>

                                    <TextBlock Grid.Row="4" Text="{x:Static properties:Resources.HeaderFilterWheel3}" Style="{StaticResource DetailLabelStyle}" Margin="0,0,0,8"
                                               Visibility="{Binding EditConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    <hc:NumericUpDown Grid.Row="4" Grid.Column="1"
                                                      Margin="6,0,0,8"
                                                      MinHeight="30"
                                                      Value="{Binding EditConfig.CFW.ChannelCfgs[6].Cfwport}"
                                                      Minimum="0"
                                                      Visibility="{Binding EditConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    <hc:NumericUpDown Grid.Row="4" Grid.Column="2"
                                                      Margin="6,0,0,8"
                                                      MinHeight="30"
                                                      Value="{Binding EditConfig.CFW.ChannelCfgs[7].Cfwport}"
                                                      Minimum="0"
                                                      Visibility="{Binding EditConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    <hc:NumericUpDown Grid.Row="4" Grid.Column="3"
                                                      Margin="6,0,0,8"
                                                      MinHeight="30"
                                                      Value="{Binding EditConfig.CFW.ChannelCfgs[8].Cfwport}"
                                                      Minimum="0"
                                                      Visibility="{Binding EditConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                </Grid>

                                <Border Grid.Row="1" Background="Transparent">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EditConfig.CFW.IsUseCFW}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{x:Static properties:Resources.LabelCFWDisabled}"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"
                                               FontSize="13"
                                               Opacity="0.45"
                                               Margin="0,10,0,0"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.92*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="1.28*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SectionPanelStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.SectionFileService}" Style="{StaticResource SectionTitleStyle}"/>
                            <StackPanel x:Name="FileServerPanel"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource SectionPanelStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{x:Static properties:Resources.SectionMotorParams}" Style="{StaticResource SectionTitleStyle}"/>
                                <Expander Header="MotorConfig" IsExpanded="True" Style="{StaticResource ExpanderHeaderStyle}">
                                    <StackPanel x:Name="MotorConfigPanel" Margin="0,8,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionPanelStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="{x:Static properties:Resources.SectionParamLimits}" Style="{StaticResource SectionTitleStyle}"/>
                                <Expander Header="CameraParameterLimit" Style="{StaticResource ExpanderHeaderStyle}">
                                    <StackPanel x:Name="CameraParameterLimitPanel" Margin="0,8,0,0"/>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Button Content="{x:Static properties:Resources.PropertyEdit}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    MinWidth="120"
                    HorizontalAlignment="Left"
                    Click="OpenPropertyEditor_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{x:Static properties:Resources.OK}"
                        Style="{StaticResource PrimaryToolbarButtonStyle}"
                        MinWidth="120"
                        Margin="0,0,8,0"
                        Click="OkButton_Click"/>
                <Button Content="{x:Static properties:Resources.Cancel}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        MinWidth="120"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
