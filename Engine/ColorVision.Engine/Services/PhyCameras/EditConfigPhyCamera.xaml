<Window x:Class="ColorVision.Engine.Services.PhyCameras.EditConfigPhyCamera"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:EditConfigPhyCamera}"
        Title="{x:Static properties:Resources.TitleEditCameraConfig}"
        Height="650" Width="920"
        MinHeight="560" MinWidth="860"
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterOwner"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ColorVision.Engine;component/Services/PhyCameras/PhyCameraConsoleStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="CardStyle" TargetType="{x:Type Border}">
                <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>

            <Style x:Key="NestedCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardStyle}">
                <Setter Property="Background" Value="{DynamicResource GlobalBackground}"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="12"/>
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
            </Style>

            <Style x:Key="SectionHintStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="Opacity" Value="0.64"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
            </Style>

            <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Opacity" Value="0.64"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <Style x:Key="GroupCaptionStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="Opacity" Value="0.78"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <Style x:Key="ChannelHeaderStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Normal"/>
                <Setter Property="Margin" Value="8,0,0,8"/>
            </Style>

            <Style x:Key="InlineSummaryStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Opacity" Value="0.74"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="ConfigNavStyle" TargetType="{x:Type ListBox}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            </Style>

            <Style x:Key="ConfigNavItemStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="MinHeight" Value="34"/>
                <Setter Property="Padding" Value="10,7"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Chrome"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="SelectionBar"
                                            Width="3"
                                            CornerRadius="2"
                                            Background="{DynamicResource PrimaryBrush}"
                                            Opacity="0"/>
                                    <ContentPresenter x:Name="HeaderContent"
                                                      Grid.Column="2"
                                                      Content="{TemplateBinding Content}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ButtonBackground}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource ButtonBackground}"/>
                                    <Setter TargetName="SelectionBar" Property="Opacity" Value="1"/>
                                    <Setter TargetName="HeaderContent" Property="TextElement.Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Chrome" Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16,14,16,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="{x:Static properties:Resources.EditCameraConfigBasicConfig}"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{x:Static properties:Resources.CameraType}" Style="{StaticResource FieldLabelStyle}"/>
                        <hc:ComboBox x:Name="ComboxCameraModel"
                                     Height="32"
                                     SelectedValue="{Binding EditConfig.CameraModel}"
                                     SelectedValuePath="Key"
                                     DisplayMemberPath="Value"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{x:Static properties:Resources.CamreaMode}" Style="{StaticResource FieldLabelStyle}"/>
                        <hc:ComboBox x:Name="ComboxCameraMode"
                                     Height="32"
                                     SelectedValue="{Binding EditConfig.CameraMode}"
                                     SelectedValuePath="Key"
                                     DisplayMemberPath="Value"
                                     SelectionChanged="ComboxCameraMode_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="{x:Static properties:Resources.DefaultImageBits}" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox x:Name="ComboxCameraImageBpp"
                                  Height="32"
                                  SelectedValue="{Binding EditConfig.ImageBpp}"
                                  SelectedValuePath="Key"
                                  DisplayMemberPath="Value"/>
                    </StackPanel>

                    <Border x:Name="ChannelField"
                            Grid.Column="6"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                        <StackPanel>
                            <TextBlock Text="{x:Static properties:Resources.DefaultChannelCount}" Style="{StaticResource FieldLabelStyle}"/>
                            <hc:ComboBox x:Name="ComboxCameraChannel"
                                         Height="32"
                                         SelectedValue="{Binding EditConfig.Channel}"
                                         SelectedValuePath="Key"
                                         DisplayMemberPath="Value"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="178"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ConfigTabs"
                     Grid.Column="0"
                     Margin="0,8,0,0"
                     Style="{StaticResource ConfigNavStyle}"
                     ItemContainerStyle="{StaticResource ConfigNavItemStyle}">
                <ListBoxItem x:Name="CfwTab"
                             Visibility="{Binding EditConfig.CameraMode, Converter={StaticResource enum2VisibilityConverter}, ConverterParameter=CV_MODE}">
                    <TextBlock Text="CFW" TextWrapping="Wrap"/>
                </ListBoxItem>
                <ListBoxItem x:Name="CameraTab" IsSelected="True">
                    <TextBlock Text="{x:Static properties:Resources.CameraParam}" TextWrapping="Wrap"/>
                </ListBoxItem>
                <ListBoxItem x:Name="MotorTab">
                    <TextBlock Text="{x:Static properties:Resources.MotorConfig}" TextWrapping="Wrap"/>
                </ListBoxItem>
                <ListBoxItem x:Name="LimitTab">
                    <TextBlock Text="{x:Static properties:Resources.SectionParamLimits}" TextWrapping="Wrap"/>
                </ListBoxItem>
                <ListBoxItem x:Name="FileTab">
                    <TextBlock Text="{x:Static properties:Resources.SectionFileService}" TextWrapping="Wrap"/>
                </ListBoxItem>
            </ListBox>

            <Border Grid.Column="2"
                    Margin="0,8,0,0"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsSelected, ElementName=CfwTab, Converter={StaticResource bool2VisibilityConverter}}">
                        <StackPanel>
                            <StackPanel x:Name="CfwConfigPanel"/>

                            <Border Style="{StaticResource NestedCardStyle}"
                                    Margin="0,8,0,0"
                                    Visibility="{Binding EditConfig.CFW.IsUseCFW, Converter={StaticResource bool2VisibilityConverter}}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,6">
                                        <Button DockPanel.Dock="Right"
                                                MinWidth="72"
                                                Height="30"
                                                Style="{StaticResource ToolbarButtonStyle}"
                                                Click="ResetChannels_Click">
                                            <TextBlock Text="{x:Static properties:Resources.ButtonResetChannels}"/>
                                        </Button>
                                        <TextBlock Text="{x:Static properties:Resources.EditCameraConfigCfwMappingTitle}"
                                                   Style="{StaticResource GroupCaptionStyle}"
                                                   Margin="0,6,0,0"/>
                                    </DockPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Column="1" Text="R" Style="{StaticResource ChannelHeaderStyle}"/>
                                        <TextBlock Grid.Column="2" Text="G" Style="{StaticResource ChannelHeaderStyle}"/>
                                        <TextBlock Grid.Column="3" Text="B" Style="{StaticResource ChannelHeaderStyle}"/>

                                        <TextBlock Grid.Row="1" Text="通道" Style="{StaticResource DetailLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,8"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="chType1" Height="30" Margin="8,0,0,8" SelectedValue="{Binding EditConfig.CFW.ChannelCfgs[0].Chtype}" SelectedValuePath="Key" DisplayMemberPath="Value"/>
                                        <ComboBox Grid.Row="1" Grid.Column="2" x:Name="chType2" Height="30" Margin="8,0,0,8" SelectedValue="{Binding EditConfig.CFW.ChannelCfgs[1].Chtype}" SelectedValuePath="Key" DisplayMemberPath="Value"/>
                                        <ComboBox Grid.Row="1" Grid.Column="3" x:Name="chType3" Height="30" Margin="8,0,0,8" SelectedValue="{Binding EditConfig.CFW.ChannelCfgs[2].Chtype}" SelectedValuePath="Key" DisplayMemberPath="Value"/>

                                        <TextBlock Grid.Row="2" Text="{x:Static properties:Resources.HeaderFilterWheel1}" Style="{StaticResource DetailLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,8"/>
                                        <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Height="30" Margin="8,0,0,8" Minimum="0" Value="{Binding EditConfig.CFW.ChannelCfgs[0].Cfwport}"/>
                                        <hc:NumericUpDown Grid.Row="2" Grid.Column="2" Height="30" Margin="8,0,0,8" Minimum="0" Value="{Binding EditConfig.CFW.ChannelCfgs[1].Cfwport}"/>
                                        <hc:NumericUpDown Grid.Row="2" Grid.Column="3" Height="30" Margin="8,0,0,8" Minimum="0" Value="{Binding EditConfig.CFW.ChannelCfgs[2].Cfwport}"/>

                                        <TextBlock Grid.Row="3"
                                                   Text="{x:Static properties:Resources.HeaderFilterWheel2}"
                                                   Style="{StaticResource DetailLabelStyle}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,8"
                                                   Visibility="{Binding EditConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>
                                        <hc:NumericUpDown Grid.Row="3" Grid.Column="1" Height="30" Margin="8,0,0,8" Minimum="0" Value="{Binding EditConfig.CFW.ChannelCfgs[3].Cfwport}" Visibility="{Binding EditConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>
                                        <hc:NumericUpDown Grid.Row="3" Grid.Column="2" Height="30" Margin="8,0,0,8" Minimum="0" Value="{Binding EditConfig.CFW.ChannelCfgs[4].Cfwport}" Visibility="{Binding EditConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>
                                        <hc:NumericUpDown Grid.Row="3" Grid.Column="3" Height="30" Margin="8,0,0,8" Minimum="0" Value="{Binding EditConfig.CFW.ChannelCfgs[5].Cfwport}" Visibility="{Binding EditConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>

                                        <TextBlock Grid.Row="4"
                                                   Text="{x:Static properties:Resources.HeaderFilterWheel3}"
                                                   Style="{StaticResource DetailLabelStyle}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0"
                                                   Visibility="{Binding EditConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                        <hc:NumericUpDown Grid.Row="4" Grid.Column="1" Height="30" Margin="8,0,0,0" Minimum="0" Value="{Binding EditConfig.CFW.ChannelCfgs[6].Cfwport}" Visibility="{Binding EditConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                        <hc:NumericUpDown Grid.Row="4" Grid.Column="2" Height="30" Margin="8,0,0,0" Minimum="0" Value="{Binding EditConfig.CFW.ChannelCfgs[7].Cfwport}" Visibility="{Binding EditConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                        <hc:NumericUpDown Grid.Row="4" Grid.Column="3" Height="30" Margin="8,0,0,0" Minimum="0" Value="{Binding EditConfig.CFW.ChannelCfgs[8].Cfwport}" Visibility="{Binding EditConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsSelected, ElementName=CameraTab, Converter={StaticResource bool2VisibilityConverter}}">
                        <StackPanel x:Name="CameraCfgPanel"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"/>
                    </ScrollViewer>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsSelected, ElementName=MotorTab, Converter={StaticResource bool2VisibilityConverter}}">
                        <StackPanel x:Name="MotorConfigPanel"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"/>
                    </ScrollViewer>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsSelected, ElementName=LimitTab, Converter={StaticResource bool2VisibilityConverter}}">
                        <StackPanel x:Name="CameraParameterLimitPanel"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"/>
                    </ScrollViewer>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding IsSelected, ElementName=FileTab, Converter={StaticResource bool2VisibilityConverter}}">
                        <StackPanel x:Name="FileServerPanel"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource GlobalBorderBrush1}" Opacity="0.64"/>

        <Grid Grid.Row="3" Margin="0,14,0,14" MinHeight="52">
                <Button Content="{x:Static properties:Resources.PropertyEdit}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        MinWidth="120"
                        Height="36"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Click="OpenPropertyEditor_Click"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="{x:Static properties:Resources.OK}"
                            Style="{StaticResource PrimaryToolbarButtonStyle}"
                            MinWidth="120"
                            Height="36"
                            Click="OkButton_Click"/>
                    <Button Content="{x:Static properties:Resources.Cancel}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            MinWidth="120"
                            Height="36"
                            Click="CancelButton_Click"/>
                </StackPanel>
        </Grid>
    </Grid>
</Window>
