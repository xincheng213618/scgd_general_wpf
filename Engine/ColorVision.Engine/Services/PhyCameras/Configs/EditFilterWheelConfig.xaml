<Window x:Class="ColorVision.Engine.Services.PhyCameras.Configs.EditFilterWheelConfig"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras.Configs"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.EditFilterWheelConfig}"
        Background="{DynamicResource GlobalBackground}"
        Height="520" Width="640" MinHeight="420" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Padding="14,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static properties:Resources.FilterWheel}" FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Static properties:Resources.FilterWheelHoleMapping}" FontSize="12" Opacity="0.6" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{x:Static properties:Resources.Add}" Click="Button_Add_Click"
                            Margin="0,0,6,0" MinWidth="80"/>
                    <Button Content="{x:Static properties:Resources.Delete}" Click="Button_Delete_Click"
                            MinWidth="80"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="8">
            <DataGrid x:Name="DataGridHoleMapping"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static properties:Resources.FilterWheelHoleIndex}" Binding="{Binding HoleIndex}" Width="160" IsReadOnly="False"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.FilterWheelHoleName}" Binding="{Binding HoleName}" Width="*" IsReadOnly="False"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static properties:Resources.Submit}"
                    Foreground="White"
                    Background="{StaticResource PrimaryBrush}"
                    Click="Button_Save_Click"
                    Width="100"
                    Height="32"
                    Margin="0,0,8,0"/>
            <Button Content="{x:Static properties:Resources.Cancel}"
                    Click="Button_Cancel_Click"
                    Width="100"
                    Height="32"/>
        </StackPanel>
    </Grid>
</Window>
