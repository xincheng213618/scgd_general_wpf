<Window x:Class="ColorVision.Engine.Services.PhyCameras.Configs.EditFilterWheelConfig"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras.Configs"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.EditFilterWheelConfig}"
        Background="{DynamicResource GlobalBackground}"
        Height="500" Width="620" MinHeight="420" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style x:Key="CellEditorStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource TextBoxBaseStyle}">
            <Setter Property="Margin" Value="8,5"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Padding="16,13" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{x:Static properties:Resources.FilterWheel}" FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Static properties:Resources.FilterWheelHoleMapping}" FontSize="12" Opacity="0.6" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{x:Static properties:Resources.Add}"
                        Click="Button_Add_Click"
                        VerticalAlignment="Center"
                        MinWidth="84"
                        Height="34"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="8,8,8,4">
            <DataGrid x:Name="DataGridHoleMapping"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      CanUserSortColumns="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      RowHeight="44"
                      ColumnHeaderHeight="38"
                      HorizontalGridLinesBrush="{DynamicResource GlobalBorderBrush1}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{x:Static properties:Resources.FilterWheelHoleIndex}" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding HoleIndex, UpdateSourceTrigger=PropertyChanged, ValidatesOnExceptions=True}"
                                         Style="{StaticResource CellEditorStyle}"
                                         HorizontalContentAlignment="Center"
                                         ToolTip="{x:Static properties:Resources.FilterWheelHoleIndex}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{x:Static properties:Resources.FilterWheelHoleName}" Width="*" MinWidth="240">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding HoleName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource CellEditorStyle}"
                                         ToolTip="{x:Static properties:Resources.FilterWheelHoleName}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{x:Static properties:Resources.Delete}" Width="92" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{x:Static properties:Resources.Delete}"
                                        Click="Button_DeleteRow_Click"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MinWidth="68"
                                        Height="30"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static properties:Resources.Submit}"
                    Foreground="White"
                    Background="{StaticResource PrimaryBrush}"
                    Click="Button_Save_Click"
                    Width="96"
                    Height="36"
                    Margin="0,0,8,0"/>
            <Button Content="{x:Static properties:Resources.Cancel}"
                    Click="Button_Cancel_Click"
                    IsCancel="True"
                    Width="96"
                    Height="36"/>
        </StackPanel>
    </Grid>
</Window>
