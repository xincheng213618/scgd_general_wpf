<Window x:Class="ColorVision.Engine.Services.PhyCameras.Configs.RoiEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:imageEditor="clr-namespace:ColorVision.ImageEditor;assembly=ColorVision.ImageEditor"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ROI 设置"
        Height="640"
        Width="880"
        MinHeight="560"
        MinWidth="760"
        Background="{DynamicResource GlobalBackground}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <DrawingBrush x:Key="ImageViewBackgroundBrush"
                      TileMode="Tile"
                      Viewport="0,0,24,24"
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#202020" Geometry="M0,0 L24,0 24,24 0,24 Z"/>
                    <GeometryDrawing Brush="#262626" Geometry="M0,0 L12,0 12,12 0,12 Z"/>
                    <GeometryDrawing Brush="#262626" Geometry="M12,12 L24,12 24,24 12,24 Z"/>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="RoiButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="82"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="10,2"/>
        </Style>

        <Style x:Key="TransparentThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ResizeThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="White"
                                BorderThickness="1"
                                CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding Summary}"
                       Foreground="{DynamicResource GlobalTextBrush}"
                       Opacity="0.74"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="ROI 设置"
                       Foreground="{DynamicResource GlobalTextBrush}"
                       FontSize="16"
                       FontWeight="SemiBold"/>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="相机 Width" Style="{StaticResource FieldLabelStyle}"/>
                <hc:NumericUpDown Height="30"
                                  Minimum="1"
                                  Maximum="2147483647"
                                  Value="{Binding SensorWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="相机 Height" Style="{StaticResource FieldLabelStyle}"/>
                <hc:NumericUpDown Height="30"
                                  Minimum="1"
                                  Maximum="2147483647"
                                  Value="{Binding SensorHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <TextBlock Text="X" Style="{StaticResource FieldLabelStyle}"/>
                <hc:NumericUpDown Height="30"
                                  Minimum="0"
                                  Maximum="2147483647"
                                  Value="{Binding PointX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Column="6">
                <TextBlock Text="Y" Style="{StaticResource FieldLabelStyle}"/>
                <hc:NumericUpDown Height="30"
                                  Minimum="0"
                                  Maximum="2147483647"
                                  Value="{Binding PointY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Column="8">
                <TextBlock Text="ROI Width" Style="{StaticResource FieldLabelStyle}"/>
                <hc:NumericUpDown Height="30"
                                  Minimum="0"
                                  Maximum="2147483647"
                                  Value="{Binding RoiWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Column="10">
                <TextBlock Text="ROI Height" Style="{StaticResource FieldLabelStyle}"/>
                <hc:NumericUpDown Height="30"
                                  Minimum="0"
                                  Maximum="2147483647"
                                  Value="{Binding RoiHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Grid>

        <WrapPanel Grid.Row="2" Margin="0,14,0,12">
            <Button Content="居中 1/2" Style="{StaticResource RoiButtonStyle}" Click="HalfButton_Click"/>
            <Button Content="居中 1/4" Style="{StaticResource RoiButtonStyle}" Click="QuarterButton_Click"/>
            <Button Content="居中 2/3" Style="{StaticResource RoiButtonStyle}" Click="TwoThirdButton_Click"/>
            <Button Content="居中当前" Style="{StaticResource RoiButtonStyle}" Click="CenterButton_Click"/>
            <Button Content="全幅" Style="{StaticResource RoiButtonStyle}" Click="FullButton_Click"/>
        </WrapPanel>

        <Border Grid.Row="3"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                ClipToBounds="True"
                Background="{StaticResource ImageViewBackgroundBrush}">
            <Grid>
                <imageEditor:ImageView x:Name="PreviewImageView"
                                       EnableEditorImageServices="False"
                                       IsHitTestVisible="False"
                                       Opacity="0.5"/>
                <Canvas x:Name="PreviewCanvas"
                        Background="Transparent"
                        ClipToBounds="True"
                        MouseLeftButtonDown="PreviewCanvas_MouseLeftButtonDown"
                        SizeChanged="PreviewCanvas_SizeChanged">
                    <Rectangle x:Name="SensorRect"
                               Stroke="#707070"
                               StrokeThickness="1"
                               Fill="#242424"/>
                    <Rectangle x:Name="RoiRect"
                               Stroke="{DynamicResource PrimaryBrush}"
                               StrokeThickness="2"
                               Fill="#3087CEFA"/>
                    <Thumb x:Name="MoveThumb"
                           Background="Transparent"
                           Cursor="SizeAll"
                           DragDelta="MoveThumb_DragDelta"
                           Style="{StaticResource TransparentThumbStyle}"/>
                    <Thumb x:Name="ResizeThumb"
                           Width="14"
                           Height="14"
                           Background="{DynamicResource PrimaryBrush}"
                           Cursor="SizeNWSE"
                           DragDelta="ResizeThumb_DragDelta"
                           Style="{StaticResource ResizeThumbStyle}"/>
                </Canvas>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="确定"
                        IsDefault="True"
                        MinWidth="108"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OkButton_Click"/>
                <Button Content="取消"
                        IsCancel="True"
                        MinWidth="108"
                        Height="34"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
