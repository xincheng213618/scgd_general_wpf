<Window x:Class="ColorVision.Engine.Services.PhyCameras.Licenses.LicenseExpiryNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.TitleLicenseExpiryNotification}" Height="440" Width="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource GlobalBackground}"
        ShowInTaskbar="True">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelBorderStyle}" Padding="14,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="34" Height="34" CornerRadius="17" Background="#FFFF8A00">
                    <TextBlock Text="!" Foreground="White" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="{x:Static properties:Resources.TitleLicenseExpiryNotification}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="TextBlockSummary" FontSize="12" Opacity="0.65"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CameraListControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource ButtonBackground}"
                                    BorderBrush="{DynamicResource GlobalBorderBrush1}"
                                    BorderThickness="1"
                                    Margin="0,0,0,8" Padding="12" CornerRadius="7">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Ellipse Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                                             Width="34" Height="34"
                                             Fill="{Binding StatusColor}"
                                             Margin="0,0,12,0" VerticalAlignment="Top"/>
                                    <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                                               Text="!" FontSize="19" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding CameraName}"
                                               FontSize="14" FontWeight="SemiBold"/>

                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding StatusMessage}"
                                               FontSize="12"
                                               Foreground="{Binding StatusTextColor}"
                                               Margin="0,5,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding LicenseInfo}"
                                               FontSize="11"
                                               Opacity="0.68"
                                               TextWrapping="Wrap"
                                               Margin="0,5,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <CheckBox x:Name="CheckBoxDontShowAgain"
                  Grid.Row="2"
                  Content="{x:Static properties:Resources.CheckBoxDoNotShowAgain}"
                  Foreground="{DynamicResource GlobalTextBrush}"
                  Margin="2,12,0,10"
                  VerticalAlignment="Center"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ButtonGoToManager"
                    Content="{x:Static properties:Resources.ButtonGoToCameraManager}"
                    Width="130" Height="32"
                    Margin="0,0,8,0"
                    Click="ButtonGoToManager_Click"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontWeight="SemiBold"/>
            <Button x:Name="ButtonClose"
                    Content="{x:Static properties:Resources.Close}"
                    Width="86" Height="32"
                    Click="ButtonClose_Click"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
