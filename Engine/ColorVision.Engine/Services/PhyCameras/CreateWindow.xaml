<Window x:Class="ColorVision.Engine.Services.PhyCameras.CreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.PhyCameras"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:CreateWindow}"
        Title="创建设备"
        Height="660" Width="760" MinHeight="560" MinWidth="680"
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterOwner"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldBoxStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,10,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Padding="14,12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="创建设备" FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="选择待登记相机后补全基础参数与滤光轮配置。"
                               FontSize="12" Opacity="0.62" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Camera Code" Style="{StaticResource FieldLabelStyle}"/>
                    <hc:ComboBox x:Name="CameraCode"
                                 IsEditable="True"
                                 SelectedIndex="0"
                                 SelectedValue="{Binding CreateConfig.CameraID}"
                                 Text="{Binding CreateConfig.Code}"
                                 hc:InfoElement.ShowClearButton="True"/>
                    <TextBlock x:Name="DeviceName"
                               FontSize="12"
                               Opacity="0.68"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="StackPanelInfo">
                <Border Style="{StaticResource PanelBorderStyle}" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.ConfigerInfo}" Style="{StaticResource SectionTitleStyle}"/>
                        <UniformGrid Columns="2">
                            <Border Style="{StaticResource FieldBoxStyle}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.CameraType}" Style="{StaticResource FieldLabelStyle}"/>
                                    <hc:ComboBox x:Name="ComboxCameraModel"
                                                 SelectedValue="{Binding CreateConfig.CameraModel}"
                                                 SelectedValuePath="Key"
                                                 DisplayMemberPath="Value"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.CamreaMode}" Style="{StaticResource FieldLabelStyle}"/>
                                    <hc:ComboBox x:Name="ComboxCameraMode"
                                                 SelectedValue="{Binding CreateConfig.CameraMode}"
                                                 SelectedValuePath="Key"
                                                 DisplayMemberPath="Value"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource FieldBoxStyle}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.DefaultCaptureMode}" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="ComboxCameraTakeImageMode"
                                              SelectedValue="{Binding CreateConfig.TakeImageMode}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Value"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.DefaultChannelCount}" Style="{StaticResource FieldLabelStyle}"/>
                                    <hc:ComboBox x:Name="ComboxCameraChannel"
                                                 SelectedValue="{Binding CreateConfig.Channel}"
                                                 SelectedValuePath="Key"
                                                 DisplayMemberPath="Value"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource FieldBoxStyle}">
                                <StackPanel>
                                    <TextBlock Text="{x:Static properties:Resources.DefaultImageBits}" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox x:Name="ComboxCameraImageBpp"
                                              SelectedValue="{Binding CreateConfig.ImageBpp}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Value"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <ui:ToggleSwitch DockPanel.Dock="Right"
                                             IsChecked="{Binding CreateConfig.CFW.IsUseCFW}"/>
                            <StackPanel>
                                <TextBlock Text="{x:Static properties:Resources.FilterWheel}" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="启用后配置串口、轮盘数量与通道位置映射。"
                                           FontSize="12" Opacity="0.62"/>
                            </StackPanel>
                        </DockPanel>

                        <Grid Visibility="{Binding CreateConfig.CFW.IsUseCFW, Converter={StaticResource bool2VisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource FieldBoxStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static properties:Resources.EnableSerialPort}" Style="{StaticResource FieldLabelStyle}"/>
                                        <ui:ToggleSwitch IsChecked="{Binding CreateConfig.CFW.IsCOM}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FieldBoxStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static properties:Resources.FilterWheelNum}" Style="{StaticResource FieldLabelStyle}"/>
                                        <hc:NumericUpDown Value="{Binding CreateConfig.CFW.CFWNum}" Minimum="0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <UniformGrid Grid.Row="1" Columns="2"
                                         Visibility="{Binding CreateConfig.CFW.IsCOM, Converter={StaticResource bool2VisibilityConverter}}">
                                <Border Style="{StaticResource FieldBoxStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static properties:Resources.Serial}" Style="{StaticResource FieldLabelStyle}"/>
                                        <hc:ComboBox x:Name="TextSerial1"
                                                     IsEditable="True"
                                                     Text="{Binding CreateConfig.CFW.SzComName}"
                                                     hc:InfoElement.ShowClearButton="True"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="{x:Static properties:Resources.BaudRate}" Style="{StaticResource FieldLabelStyle}"/>
                                        <hc:ComboBox x:Name="TextBaudRate1"
                                                     IsEditable="True"
                                                     Text="{Binding CreateConfig.CFW.BaudRate}"
                                                     hc:InfoElement.ShowClearButton="True"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <UniformGrid Grid.Row="2" Columns="3">
                                <Border Style="{StaticResource FieldBoxStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Channel X" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox x:Name="chType1"
                                                  SelectedValue="{Binding CreateConfig.CFW.ChannelCfgs[0].Chtype}"
                                                  SelectedValuePath="Key"
                                                  DisplayMemberPath="Value"/>
                                        <hc:NumericUpDown Margin="0,6,0,0"
                                                          Value="{Binding CreateConfig.CFW.ChannelCfgs[0].Cfwport}"
                                                          Minimum="0"/>
                                        <hc:NumericUpDown Margin="0,6,0,0"
                                                          Value="{Binding CreateConfig.CFW.ChannelCfgs[3].Cfwport}"
                                                          Minimum="0"
                                                          Visibility="{Binding CreateConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>
                                        <hc:NumericUpDown Margin="0,6,0,0"
                                                          Value="{Binding CreateConfig.CFW.ChannelCfgs[6].Cfwport}"
                                                          Minimum="0"
                                                          Visibility="{Binding CreateConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FieldBoxStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Channel Y" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox x:Name="chType2"
                                                  SelectedValue="{Binding CreateConfig.CFW.ChannelCfgs[1].Chtype}"
                                                  SelectedValuePath="Key"
                                                  DisplayMemberPath="Value"/>
                                        <hc:NumericUpDown Margin="0,6,0,0"
                                                          Value="{Binding CreateConfig.CFW.ChannelCfgs[1].Cfwport}"
                                                          Minimum="0"/>
                                        <hc:NumericUpDown Margin="0,6,0,0"
                                                          Value="{Binding CreateConfig.CFW.ChannelCfgs[4].Cfwport}"
                                                          Minimum="0"
                                                          Visibility="{Binding CreateConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>
                                        <hc:NumericUpDown Margin="0,6,0,0"
                                                          Value="{Binding CreateConfig.CFW.ChannelCfgs[7].Cfwport}"
                                                          Minimum="0"
                                                          Visibility="{Binding CreateConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FieldBoxStyle}" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Channel Z" Style="{StaticResource FieldLabelStyle}"/>
                                        <ComboBox x:Name="chType3"
                                                  SelectedValue="{Binding CreateConfig.CFW.ChannelCfgs[2].Chtype}"
                                                  SelectedValuePath="Key"
                                                  DisplayMemberPath="Value"/>
                                        <hc:NumericUpDown Margin="0,6,0,0"
                                                          Value="{Binding CreateConfig.CFW.ChannelCfgs[2].Cfwport}"
                                                          Minimum="0"/>
                                        <hc:NumericUpDown Margin="0,6,0,0"
                                                          Value="{Binding CreateConfig.CFW.ChannelCfgs[5].Cfwport}"
                                                          Minimum="0"
                                                          Visibility="{Binding CreateConfig.CFW.IsCFWNum2, Converter={StaticResource bool2VisibilityConverter}}"/>
                                        <hc:NumericUpDown Margin="0,6,0,0"
                                                          Value="{Binding CreateConfig.CFW.ChannelCfgs[8].Cfwport}"
                                                          Minimum="0"
                                                          Visibility="{Binding CreateConfig.CFW.IsCFWNum3, Converter={StaticResource bool2VisibilityConverter}}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource PanelBorderStyle}" Padding="10" Margin="0,12,0,0">
            <Button Content="{x:Static properties:Resources.Submit}"
                    Height="36"
                    MinWidth="130"
                    HorizontalAlignment="Right"
                    Foreground="White"
                    Background="{StaticResource PrimaryBrush}"
                    Click="Button_Click"/>
        </Border>
    </Grid>
</Window>
