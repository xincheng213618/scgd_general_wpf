<Window x:Class="ColorVision.Engine.Services.WindowService"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Services"
        xmlns:type="clr-namespace:ColorVision.Engine.Services.Types"
        xmlns:devices="clr-namespace:ColorVision.Engine.Services"
        xmlns:core ="clr-namespace:ColorVision.Engine.Services.PhyCameras.Group"
        xmlns:terminal ="clr-namespace:ColorVision.Engine.Services.Terminal"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        Title="WindowService" Height="600" Width="900" Background="{DynamicResource GlobalBackground}" Initialized="Window_Initialized" >
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Margin="5,5,5,0" Padding="5,4" CornerRadius="5">
            <WrapPanel HorizontalAlignment="Center">
                <Button Style="{StaticResource NavButton}" Click="ButtonLicenseManager_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static properties:Resources.LicenseManagement}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource NavButton}" Click="ButtonPhyCameraManager_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static properties:Resources.PhysicalCameraManager}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource NavButton}" Click="ButtonArchiveManager_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static properties:Resources.Archive}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource NavButton}" Click="ButtonFlowManager_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static properties:Resources.FlowEditor}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource NavButton}" Click="ButtonCacheSetting_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9D5;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="{x:Static properties:Resources.CacheManagement}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Content="{x:Static properties:Resources.ToggleList}" Margin="3,0" FontSize="12" Click="Button_Click_2" />
                <Button Command="{Binding WindowServiceConfig.EditCommand}" Padding="2" Height="40" Width="40" Margin="2,0" DockPanel.Dock="Right">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.Click">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="rotateTransform2" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                    <TextBlock Text="&#xE713;" HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="25" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="rotateTransform2" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Button>
            </WrapPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
  
                <TreeView x:Name="TreeView1" Grid.Row="1" Style="{StaticResource TreeView.Small}" Loaded="TreeView1_Loaded" 
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectedItemChanged="TreeView1_SelectedItemChanged" 
                          Margin="3,2,3,3" Padding="0" FontSize="12">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type type:TypeService}" ItemsSource="{Binding VisualChildren}">
                            <TextBlock Text="{Binding Name}" Margin="0,1"/>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type terminal:TerminalService}" ItemsSource="{Binding VisualChildren}">
                            <DockPanel Margin="0,1">
                                <Image Source="{Binding Icon}" Height="16" HorizontalAlignment="Left" Margin="0,0,3,0"/>
                                <TextBlock Text="{Binding Config.Name}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type devices:DeviceService}">
                            <DockPanel Margin="0,1">
                                <Image Source="{Binding Icon}" Height="16" HorizontalAlignment="Left" Margin="0,0,3,0"/>
                                <TextBlock Text="{Binding Config.Name}" VerticalAlignment="Center"/>
                            </DockPanel>
                        </HierarchicalDataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type core:GroupResource}" ItemsSource="{Binding VisualChildren}">
                            <TextBlock Text="{Binding Name}" Margin="0,1"/>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource TreeViewItemBaseStyle}">
                            <Setter Property="ContextMenu" Value="{Binding ContextMenu}"/>
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
                            <Setter Property="Padding" Value="2,1"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>
            <Border CornerRadius="5" Grid.Column="1" Margin="2,3,5,3">
                <Grid x:Name="StackPanelShow"/>
            </Border>
        </Grid>

        <!-- Bottom Button -->
        <Border Margin="5,2,5,5" Grid.Row="2">
            <Button x:Name="ButtonOK" Height="32" Content="{x:Static properties:Resources.EnterAcquisitionWindow}" 
                    Background="{StaticResource PrimaryBrush}" Foreground="White" FontSize="16" Click="Button_Click"/>
        </Border>
    </Grid>

</Window>
