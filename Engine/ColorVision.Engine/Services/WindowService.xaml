<Window x:Class="ColorVision.Engine.Services.WindowService"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:type="clr-namespace:ColorVision.Engine.Services.Types"
        xmlns:devices="clr-namespace:ColorVision.Engine.Services"
        xmlns:core="clr-namespace:ColorVision.Engine.Services.PhyCameras.Group"
        xmlns:terminal="clr-namespace:ColorVision.Engine.Services.Terminal"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        Title="WindowService"
        Height="600"
        Width="900"
        MinHeight="520"
        MinWidth="780"
        Background="{DynamicResource GlobalBackground}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <Style x:Key="ToolIconButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PaneBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>

        <Style x:Key="PaneHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style x:Key="ButtonText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="ListToggleButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource PaneBorder}"
                Padding="8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                    <Button Style="{StaticResource NavButton}" Click="ButtonPhyCameraManager_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE722;"/>
                            <TextBlock Style="{StaticResource ButtonText}" Text="{x:Static properties:Resources.PhysicalCameraManager}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ButtonArchiveManager_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE7B8;"/>
                            <TextBlock Style="{StaticResource ButtonText}" Text="{x:Static properties:Resources.Archive}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ButtonCacheSetting_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconText}" Text="&#xE9D5;"/>
                            <TextBlock Style="{StaticResource ButtonText}" Text="{x:Static properties:Resources.CacheManagement}"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource ToolIconButton}"
                        Command="{Binding WindowServiceConfig.EditCommand}"
                        ToolTip="{x:Static properties:Resources.ServiceRegistryCenterConfig}">
                    <Button.Triggers>
                        <EventTrigger RoutedEvent="Button.Click">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="rotateTransform2"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0"
                                                     To="360"
                                                     Duration="0:0:0.5"
                                                     FillBehavior="Stop"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                    <TextBlock Text="&#xE713;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="20"
                               Foreground="{DynamicResource GlobalTextBrush}"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="rotateTransform2"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="180"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PaneBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="10,8"
                            Background="{DynamicResource RegionBrush}"
                            CornerRadius="5,5,0,0">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource ListToggleButton}"
                                    Click="ButtonToggleList_Click"
                                    ToolTip="{x:Static properties:Resources.ToggleList}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconText}" Text="&#xE8AB;"/>
                                    <TextBlock Style="{StaticResource ButtonText}" Text="{x:Static properties:Resources.ToggleList}"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:Name="ListModeText"
                                       Style="{StaticResource PaneHeaderText}"
                                       Text="{x:Static properties:Resources.Service}"/>
                        </DockPanel>
                    </Border>

                    <TreeView x:Name="TreeView1"
                              Grid.Row="1"
                              Style="{StaticResource TreeView.Small}"
                              Loaded="TreeView1_Loaded"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              SelectedItemChanged="TreeView1_SelectedItemChanged"
                              Margin="5"
                              Padding="0"
                              FontSize="12">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type type:TypeService}" ItemsSource="{Binding VisualChildren}">
                                <TextBlock Text="{Binding Name}" Margin="0,1"/>
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type terminal:TerminalService}" ItemsSource="{Binding VisualChildren}">
                                <DockPanel Margin="0,1">
                                    <Image Source="{Binding Icon}" Height="16" HorizontalAlignment="Left" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding Config.Name}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type devices:DeviceService}">
                                <DockPanel Margin="0,1">
                                    <Image Source="{Binding Icon}" Height="16" HorizontalAlignment="Left" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding Config.Name}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type core:GroupResource}" ItemsSource="{Binding VisualChildren}">
                                <TextBlock Text="{Binding Name}" Margin="0,1"/>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}" BasedOn="{StaticResource TreeViewItemBaseStyle}">
                                <Setter Property="ContextMenu" Value="{Binding ContextMenu}"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
                                <Setter Property="Padding" Value="2,1"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource PaneBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="10,8"
                            Background="{DynamicResource RegionBrush}"
                            CornerRadius="5,5,0,0">
                        <TextBlock Style="{StaticResource PaneHeaderText}"
                                   Text="{x:Static properties:Resources.Property}"/>
                    </Border>

                    <Grid x:Name="StackPanelShow" Grid.Row="1" Margin="8"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="0,8,0,0">
            <Button x:Name="ButtonOK"
                    Style="{StaticResource PrimaryActionButton}"
                    Content="{x:Static properties:Resources.EnterAcquisitionWindow}"
                    Click="Button_Click"/>
        </Border>
    </Grid>
</Window>
