<Window x:Class="ColorVision.Engine.Services.Devices.Spectrum.Calibration.SpectrumCalibrationGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.SpectrumCalibrationGroups_Title}"
        Width="680"
        Height="460"
        Background="{DynamicResource GlobalBackground}">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="{x:Type TextBox}" />
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
            <Button x:Name="BtnRemoveGroup" DockPanel.Dock="Right" Margin="6,0,0,0" Padding="12,4" Click="BtnRemoveGroup_Click" Content="{x:Static properties:Resources.SpectrumCalibrationGroups_RemoveGroup}" />
            <Button x:Name="BtnAddGroup" DockPanel.Dock="Right" Margin="6,0,0,0" Padding="12,4" Click="BtnAddGroup_Click" Content="{x:Static properties:Resources.SpectrumCalibrationGroups_AddGroup}" />
            <TextBlock Width="76" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_CurrentGroup}" />
            <ComboBox x:Name="ComboBoxGroups" DisplayMemberPath="GroupName" SelectionChanged="ComboBoxGroups_SelectionChanged" />
        </DockPanel>

        <GroupBox Grid.Row="1" Header="{x:Static properties:Resources.SpectrumCalibrationGroups_GroupDetails}">
            <Grid x:Name="DetailGrid" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,8">
                    <TextBlock Width="90" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_GroupName}" />
                    <TextBox Text="{Binding GroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>

                <DockPanel Grid.Row="1" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right" Margin="6,0,0,0" Padding="10,3" Click="BtnSelectWavelength_Click" Content="{x:Static properties:Resources.SelectWithEllipsis}" />
                    <TextBlock Width="90" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_WavelengthCalibration}" />
                    <TextBox IsReadOnly="True" Text="{Binding WavelengthFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                </DockPanel>

                <DockPanel Grid.Row="2" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right" Margin="6,0,0,0" Padding="10,3" Click="BtnSelectMaguide_Click" Content="{x:Static properties:Resources.SelectWithEllipsis}" />
                    <TextBlock Width="90" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_AmplitudeCalibration}" />
                    <TextBox IsReadOnly="True" Text="{Binding MaguideFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                </DockPanel>

                <DockPanel Grid.Row="3" Margin="0,0,0,8">
                    <TextBlock Width="90" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_FilterWheelService}" />
                    <ComboBox x:Name="ComboBoxCfwService"
                              Width="260"
                              HorizontalAlignment="Left"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Code"
                              SelectionChanged="ComboBoxCfwService_SelectionChanged" />
                </DockPanel>

                <DockPanel Grid.Row="4" Margin="0,0,0,8">
                    <TextBlock Width="90" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_FilterWheelPosition}" />
                    <ComboBox x:Name="ComboBoxNDHole"
                              Width="180"
                              HorizontalAlignment="Left"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="HoleIndex"
                              SelectedValue="{Binding NDHoleIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="8,0,0,0" FontSize="11" Foreground="Gray" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_AutoApplyNdHint}" />
                </DockPanel>

                <Border Grid.Row="5" Padding="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Width="90" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_CurrentWavelength}" />
                            <TextBlock Text="{Binding DataContext.Config.WavelengthFile, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Width="90" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_CurrentAmplitude}" />
                            <TextBlock Text="{Binding DataContext.Config.MaguideFile, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock Foreground="Gray" FontSize="11" Text="{x:Static properties:Resources.SpectrumCalibrationGroups_SaveHint}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button MinWidth="80" Margin="0,0,8,0" Padding="16,5" Click="BtnSave_Click" Content="{x:Static properties:Resources.Save}" />
                <Button MinWidth="80" Padding="16,5" Click="BtnClose_Click" Content="{x:Static properties:Resources.Close}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
