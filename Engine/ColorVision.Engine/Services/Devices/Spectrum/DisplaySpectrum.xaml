<UserControl x:Class="ColorVision.Engine.Services.Devices.Spectrum.DisplaySpectrum"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:ColorVision.Engine.Services.Devices.Spectrum"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:DeviceSpectrum}"
             d:DesignWidth="300"
             ContextMenu="{Binding ContextMenu}"
             Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="{x:Type TextBox}" />
    </UserControl.Resources>
    <StackPanel>
        <DockPanel Margin="0,0,5,0">
            <Grid DockPanel.Dock="Right">
                <ToggleButton Width="10" Height="10" HorizontalAlignment="Center" IsChecked="True" IsEnabled="False" Style="{StaticResource ButtonMQTTConnect}" />
                <Image Height="18" Margin="0,0,0,0" Source="{DynamicResource DrawingImageProperty}" />
                <Button Background="Transparent" BorderThickness="0" Command="{Binding PropertyCommand}" />
            </Grid>
            <Button Padding="3" Background="Transparent" BorderThickness="0" Command="{Binding RefreshCommand}" DockPanel.Dock="Right">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform1" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE72C;" ToolTip="{x:Static properties:Resources.Refresh}">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="rotateTransform1" CenterX="6" CenterY="6" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Button>
            <ToggleButton Content="{Binding Config.Name}" FontSize="15" IsChecked="{Binding DisplayConfig.IsDisplayOpen}" Style="{StaticResource ButtonPageControl1}" ToolTip="{Binding DService.DeviceStatus}" />
        </DockPanel>
        <Border x:Name="DisPlayBorder" Style="{DynamicResource BorderModuleArea}" Visibility="{Binding DisplayConfig.IsDisplayOpen, Converter={StaticResource bool2VisibilityConverter}}">
            <StackPanel Margin="5">
                <TextBlock x:Name="TextBlockUnknow" HorizontalAlignment="Center" Text="{x:Static properties:Resources.UnknownStatus}" />
                <Button x:Name="TextBlockOffLine" Margin="0,0,0,3" Click="Button_Click_Open" Content="OffLine" />
                <Button x:Name="ButtonUnauthorized" Margin="0,0,0,3" Command="{Binding EditCommand}" Content="{x:Static properties:Resources.UnauthorizedOrLicenseExpired}" />
                <StackPanel x:Name="StackPanelContent">
                    <DockPanel Margin="0,0,0,2">
                        <Button x:Name="btn_connect" Margin="0,0,0,2" Click="Button_Click_Open" Content="{x:Static properties:Resources.Open}" />
                    </DockPanel>
                    <DockPanel Margin="0,0,0,5">
                        <Button Width="24" Height="24" Margin="5,0,0,0" Padding="2" DockPanel.Dock="Right" Command="{Binding OpenCalibrationGroupWindowCommand}" ToolTip="标定文件分组">
                            <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE713;" />
                        </Button>
                        <ComboBox x:Name="ComboBoxCalibrationGroups"
                                  DisplayMemberPath="GroupName"
                                  ItemsSource="{Binding Config.CalibrationGroups}"
                                  SelectedValue="{Binding Config.ActiveCalibrationGroupName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="GroupName"
                                  SelectionChanged="CalibrationGroup_SelectionChanged"
                                  Style="{StaticResource ComboBox.Small}" />
                    </DockPanel>
                    <StackPanel x:Name="StackPanelOpen">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.AverageTimes}" />
                            <TextBox Width="50" DockPanel.Dock="Right" Text="{Binding ElementName=SpectrumSliderAveNum, Path=Value}" />
                            <hc:PreviewSlider x:Name="SpectrumSliderAveNum" IsSnapToTickEnabled="True" LargeChange="1" Maximum="{Binding DisplayConfig.MaxAveNum}" SmallChange="1" TickFrequency="1" Value="{Binding DisplayConfig.AveNum}">
                                <hc:PreviewSlider.PreviewContent>
                                    <Label Content="{Binding Path=(hc:PreviewSlider.PreviewPosition), RelativeSource={RelativeSource Self}}" ContentStringFormat="#0" Style="{StaticResource LabelPrimary}" />
                                </hc:PreviewSlider.PreviewContent>
                            </hc:PreviewSlider>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.IntegrationTime}" />
                            <TextBox Width="50" DockPanel.Dock="Right" Text="{Binding ElementName=SpectrumSliderIntTime, Path=Value}" />
                            <hc:PreviewSlider x:Name="SpectrumSliderIntTime" IsSnapToTickEnabled="True" LargeChange="1" Maximum="{Binding DisplayConfig.MaxIntTime}" SmallChange="1" TickFrequency="1" Value="{Binding DisplayConfig.IntTime}">
                                <hc:PreviewSlider.PreviewContent>
                                    <Label Content="{Binding Path=(hc:PreviewSlider.PreviewPosition), RelativeSource={RelativeSource Self}}" ContentStringFormat="#0" Style="{StaticResource LabelPrimary}" />
                                </hc:PreviewSlider.PreviewContent>
                            </hc:PreviewSlider>
                        </DockPanel>
                        <StackPanel Margin="0,0,0,5">
                            <UniformGrid Columns="2">
                                <DockPanel Margin="0,0,0,2">
                                    <CheckBox Margin="0,0,5,0" IsChecked="{Binding DisplayConfig.IsAutoIntTime}" />
                                    <TextBlock Text="{x:Static properties:Resources.AutoIntegra}" />
                                </DockPanel>
                                <DockPanel Margin="0,0,0,2">
                                    <CheckBox Margin="0,0,5,0" IsChecked="{Binding DisplayConfig.IsWithND}" />
                                    <TextBlock Text="ND" />
                                </DockPanel>
                                <DockPanel Margin="0,0,0,2">
                                    <CheckBox Margin="0,0,5,0" IsChecked="{Binding DisplayConfig.IsAutoDark}" />
                                    <TextBlock Text="{x:Static properties:Resources.AutoZeroCalibration}" />
                                </DockPanel>
                                <DockPanel Margin="0,0,0,2">
                                    <CheckBox Margin="0,0,5,0" IsChecked="{Binding DisplayConfig.IsShutter}" />
                                    <TextBlock Text="{x:Static properties:Resources.AdaptiveZeroCalibration}" />
                                </DockPanel>
                            </UniformGrid>
                        </StackPanel>
                        <DockPanel Visibility="{Binding DisplayConfig.IsLuminousFluxMode, Converter={StaticResource bool2VisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <DockPanel>
                                    <TextBlock Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.V}" />
                                    <TextBlock Width="30" Block.TextAlignment="Center" DockPanel.Dock="Right" Text="V" />
                                    <TextBox Width="50" BorderThickness="0,0,0,1" Text="{Binding DisplayConfig.V, StringFormat={}{0:F1}}" />
                                </DockPanel>
                                <DockPanel>
                                    <TextBlock Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.I}" />
                                    <TextBlock Width="30" Block.TextAlignment="Center" DockPanel.Dock="Right" Text="mA" />
                                    <TextBox Width="50" BorderThickness="0,0,0,1" Text="{Binding DisplayConfig.I, StringFormat={}{0:F1}}" />

                                </DockPanel>
                            </StackPanel>
                        </DockPanel>
                        <StackPanel Margin="0,0,0,5">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btn_oneTest" Margin="2" Click="Button_Click_OneTest" Content="{x:Static properties:Resources.SingleTest}" />
                                <Button x:Name="btn_autoTest" Margin="2" Click="Button_Click_AutoTest" Content="{x:Static properties:Resources.ContinuousMeasurement}" />
                            </StackPanel>
                            <DockPanel>
                                <Button x:Name="btn_oneInitDark" Margin="2" Click="Button_Click_Init_Dark" Content="{x:Static properties:Resources.SingleZeroCalibration}" />
                                <!--  半透明遮罩层  -->
                                <Rectangle x:Name="Overlay" Fill="#7F000000" Visibility="Collapsed" />
                                <Border x:Name="LoadingPanel" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" CornerRadius="5" Visibility="Collapsed">
                                    <StackPanel Orientation="Vertical">
                                        <ProgressBar Width="200" Height="20" IsIndeterminate="True" />
                                        <TextBlock Margin="0,10,0,0" HorizontalAlignment="Center" Text="{x:Static properties:Resources.Processing}" />
                                    </StackPanel>
                                </Border>
                                <Button Margin="2" Command="{Binding SelfAdaptionInitDarkCommand}" Content="{x:Static properties:Resources.AdaptiveZeroCalibration}" />
                                <Button Grid.Column="1" Width="21" Height="21" Margin="5,0,5,0" Padding="2" HorizontalAlignment="Left" Command="{Binding SelfAdaptionInitDarkSettingCommand}">
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="Button.Click">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform21" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>
                                    <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform x:Name="rotateTransform21" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Button>

                            </DockPanel>

                            <DockPanel Margin="0,2" Visibility="{Binding DisplayConfig.IsWithND, Converter={StaticResource bool2VisibilityConverter}}">
                                <Button Click="GetNDport_Click" Content="Get" DockPanel.Dock="Right" />
                                <Button Click="NDport_Click" Content="{x:Static properties:Resources.ChangeNDPort}" DockPanel.Dock="Right" />
                                <TextBlock Text="NDPort" />
                                <ComboBox x:Name="ComboBoxNDPort"
                                          MinWidth="96"
                                          Margin="5,0"
                                          DisplayMemberPath="HoleName"
                                          SelectedValue="{Binding DisplayConfig.PortNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="HoleIndex" />
                            </DockPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,5" Orientation="Horizontal" Visibility="{Binding Config.IsShutterEnable, Converter={StaticResource bool2VisibilityConverter}}">
                            <Button Click="Button_Click_Shutter_Doopen" Content="Open Shutter" />
                            <Button Margin="5,0,0,0" Click="Button_Click_Shutter_Doclose" Content="Close Shutter" />
                        </StackPanel>

                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>

</UserControl>
