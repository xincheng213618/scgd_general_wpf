<UserControl x:Class="ColorVision.Engine.Services.Devices.CfwPort.DisplayCfwPort"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:ColorVision.Engine.Services.Devices.CfwPort"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:DeviceCfwPort}"
             d:DesignWidth="300"
             ContextMenu="{Binding ContextMenu}"
             Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="{x:Type TextBox}" />
    </UserControl.Resources>
    <StackPanel>
        <DockPanel Margin="0,0,5,0">
            <Grid DockPanel.Dock="Right">
                <ToggleButton Width="10" Height="10" HorizontalAlignment="Center" IsChecked="True" IsEnabled="False" Style="{StaticResource ButtonMQTTConnect}" />
                <Image Height="18" Margin="0,0,0,0" Source="{DynamicResource DrawingImageProperty}" />
                <Button Background="Transparent" BorderThickness="0" Command="{Binding PropertyCommand}" />
            </Grid>

            <ToggleButton Content="{Binding Config.Name}" FontSize="15" IsChecked="{Binding DisplayConfig.IsDisplayOpen}" Style="{StaticResource ButtonPageControl1}" ToolTip="{Binding DService.DeviceStatus}" />
        </DockPanel>
        <Border x:Name="DisPlayBorder" Style="{DynamicResource BorderModuleArea}" Visibility="{Binding DisplayConfig.IsDisplayOpen, Converter={StaticResource bool2VisibilityConverter}}">
            <StackPanel Margin="5">
                <DockPanel x:Name="TextBlockUnknow" HorizontalAlignment="Left"  Margin="0,0,0,3">
                    <TextBlock HorizontalAlignment="Center" Text="{x:Static properties:Resources.UnknownStatus}" />
                </DockPanel>

                <DockPanel x:Name="ButtonUnauthorized" HorizontalAlignment="Left"  Margin="0,0,0,3">
                    <Button Command="{Binding EditCommand}" Content="{x:Static properties:Resources.UnauthorizedOrLicenseExpired}" />
                </DockPanel>
                <DockPanel x:Name="ButtonInit" HorizontalAlignment="Left"  Margin="0,0,0,3">
                    <Button Command="{Binding EditCommand}" Content="{x:Static properties:Resources.SetSnFirst}" />
                </DockPanel>
                <Button x:Name="ButtonOffline" HorizontalAlignment="Left"  Margin="0,0,0,3" Background="Red" Click="CameraOffline_Click" Content="{x:Static properties:Resources.DeviceOffline}" Foreground="White" Visibility="Collapsed" />
                <Button x:Name="ButtonOpen" HorizontalAlignment="Left"  Margin="0,2" Click="Open_Click" Content="{x:Static properties:Resources.Connect}" />
                <Button x:Name="ButtonClose" HorizontalAlignment="Left"  Margin="0,2" Click="Close_Click" Content="{x:Static properties:Resources.Close}" Visibility="Collapsed" />
                <StackPanel x:Name="StackPanelOpen" Margin="0,0,0,3">
                    <DockPanel Margin="0,2">
                        <Button Click="GetPort_Click" Content="GetPort" DockPanel.Dock="Right" />
                        <Button Click="SetPort_Click" Content="SetPort" DockPanel.Dock="Right" />
                        <hc:ComboBox x:Name="CombPort" Width="150" HorizontalAlignment="Left" hc:InfoElement.ShowClearButton="True" AutoComplete="True" IsEditable="True" Style="{StaticResource ComboBox.Small}" />
                    </DockPanel>
                </StackPanel>

            </StackPanel>
        </Border>
    </StackPanel>

</UserControl>
