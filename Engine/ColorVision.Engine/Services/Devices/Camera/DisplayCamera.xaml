<UserControl x:Class="ColorVision.Engine.Services.Devices.Camera.DisplayCamera"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:ColorVision.Engine.Services.Devices.Camera"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
             xmlns:winf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:DeviceCamera}"
             d:DesignWidth="300"
             ContextMenu="{Binding ContextMenu}"
             Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="TextBox">
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown" />
        </Style>
    </UserControl.Resources>
    <StackPanel>
        <DockPanel>
            <Grid DockPanel.Dock="Right">
                <ToggleButton Width="10" Height="10" HorizontalAlignment="Center" Command="{Binding PropertyCommand}" IsChecked="True" IsEnabled="False" Style="{StaticResource ButtonMQTTConnect}" />
                <Image Height="18" Source="{DynamicResource DrawingImageProperty}" />
                <Button Background="Transparent" BorderThickness="0" Command="{Binding PropertyCommand}" />
            </Grid>
            <Button Padding="3" Background="Transparent" BorderThickness="0" Command="{Binding RefreshCommand}" DockPanel.Dock="Right">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform1" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE72C;" ToolTip="{x:Static properties:Resources.Refresh}">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="rotateTransform1" CenterX="6" CenterY="6" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Button>
            <ToggleButton Content="{Binding Config.Name}" FontSize="15" IsChecked="{Binding DisplayConfig.IsDisplayOpen}" Style="{StaticResource ButtonPageControl1}" ToolTip="{Binding DService.DeviceStatus}" />
        </DockPanel>
        <Border x:Name="DisPlayBorder" Style="{DynamicResource BorderModuleArea}" Visibility="{Binding DisplayConfig.IsDisplayOpen, Converter={StaticResource bool2VisibilityConverter}}">
            <StackPanel Margin="3">
                <DockPanel x:Name="TextBlockUnknow" Margin="0,0,0,3">
                    <Button Margin="0,0,3,0" Command="{Binding RefreshDeviceIdCommand}" Content="{x:Static properties:Resources.RefreshDeviceList}" />
                    <TextBlock HorizontalAlignment="Center" Text="{x:Static properties:Resources.UnknownStatus}" />
                </DockPanel>

                <DockPanel x:Name="ButtonUnauthorized" Margin="0,0,0,3">
                    <Button Margin="0,0,3,0" Command="{Binding RefreshDeviceIdCommand}" Content="{x:Static properties:Resources.RefreshDeviceList}" />
                    <Button Command="{Binding PhyCamera.UploadLicenseCommand}" Content="{x:Static properties:Resources.UnauthorizedOrCameraLicenseExpiredz}" />
                </DockPanel>
                <DockPanel x:Name="ButtonInit" Margin="0,0,0,3">
                    <Button Margin="0,0,3,0" Command="{Binding RefreshDeviceIdCommand}" Content="{x:Static properties:Resources.RefreshDeviceList}" />
                    <Button Command="{Binding EditCommand}" Content="{x:Static properties:Resources.PleaseConfigureCameraIDFirst}" />
                </DockPanel>
                <Button x:Name="ButtonOffline" Margin="0,0,0,3" Background="Red" Click="CameraOffline_Click" Content="{x:Static properties:Resources.DeviceOffline}" Foreground="White" Visibility="Collapsed" />
                <DockPanel x:Name="ButtonOpen" Margin="0,0,0,3">
                    <Button x:Name="VideoButton" Grid.Column="1" Margin="5,0,0,0" Click="Video_Click" Content="{x:Static properties:Resources.Video}" DockPanel.Dock="Right" />
                    <Grid>
                        <Button x:Name="OpenButton" Grid.Column="0" Click="Open_Click" Content="{x:Static properties:Resources.Open}" />
                    </Grid>

                </DockPanel>
                <DockPanel x:Name="ButtonClose" Margin="0,0,0,3" Visibility="Visible">
                    <Button Width="21" Height="21" Margin="5,0,0,0" Padding="2" HorizontalAlignment="Left" Command="{Binding CameraVideoControl.EditConfigCommand}" DockPanel.Dock="Right" Visibility="{Binding DService.IsVideoOpen, Converter={StaticResource bool2VisibilityConverter}}">
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform255" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="rotateTransform255" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>
                    <Grid>
                        <Button x:Name="CloseButton" Grid.Column="0" Background="Red" Click="Close_Click" Content="{x:Static properties:Resources.Close}" Foreground="White" />
                    </Grid>
                </DockPanel>
                <StackPanel x:Name="StackPanelOpen" Margin="0,0,0,2">
                    <StackPanel Visibility="{Binding DService.IsVideoOpen, Converter={StaticResource bool2VisibilityConverter}}">
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.Flip}" />
                            <ComboBox x:Name="CBFilp1" DisplayMemberPath="Key" SelectedValue="{Binding DisplayConfig.FlipMode}" SelectedValuePath="Value" SelectionChanged="CBFilp1_SelectionChanged" Style="{StaticResource ComboBox.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.Gain}" />
                            <TextBox MinWidth="50" DockPanel.Dock="Right" Text="{Binding DisplayConfig.Gain, StringFormat=F2}" />
                            <hc:PreviewSlider IsSnapToTickEnabled="True" LargeChange="10" Maximum="{Binding Config.GainMax}" Minimum="{Binding Config.GainMin}" SmallChange="1" TickFrequency="1" ValueChanged="PreviewSlider_ValueChanged1" Value="{Binding DisplayConfig.Gain}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.Exposure}" />
                            <TextBox MinWidth="50" DockPanel.Dock="Right" Text="{Binding DisplayConfig.ExpTime, StringFormat=F2}" />
                            <hc:PreviewSlider IsSnapToTickEnabled="True" LargeChange="0.01" Maximum="{Binding Config.ExpTimeMaxLog}" Minimum="{Binding Config.ExpTimeMinLog}" SmallChange="0.001" TickFrequency="0.001" ValueChanged="PreviewSlider_ValueChanged" Value="{Binding DisplayConfig.ExpTimeLog}" />
                        </DockPanel>

                    </StackPanel>

                    <StackPanel x:Name="StackPanelImage" Visibility="{Binding DService.IsVideoOpen, Converter={StaticResource bool2VisibilityConverter1}}">
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.Gain}" />
                            <TextBox MinWidth="50" DockPanel.Dock="Right" Text="{Binding DisplayConfig.Gain, StringFormat=F2}" />
                            <hc:PreviewSlider IsSnapToTickEnabled="True" LargeChange="10" Maximum="{Binding Config.GainMax}" Minimum="{Binding Config.GainMin}" SmallChange="1" TickFrequency="1" ValueChanged="PreviewSlider_ValueChanged1" Value="{Binding DisplayConfig.Gain}" />
                        </DockPanel>
                        <StackPanel Visibility="{Binding Config.IsAutoExpose, Converter={StaticResource bool2VisibilityConverter1}}">
                            <StackPanel Visibility="{Binding Config.IsExpThree, Converter={StaticResource bool2VisibilityConverter1}}">
                                <DockPanel Margin="0,0,0,3">
                                    <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.Exposure}" />
                                    <TextBox Width="50" DockPanel.Dock="Right" Text="{Binding DisplayConfig.ExpTime, StringFormat=F2}" />
                                    <hc:PreviewSlider IsSnapToTickEnabled="True" LargeChange="0.01" Maximum="{Binding Config.ExpTimeMaxLog}" Minimum="{Binding Config.ExpTimeMinLog}" SmallChange="0.001" TickFrequency="0.001" ValueChanged="PreviewSlider_ValueChanged" Value="{Binding DisplayConfig.ExpTimeLog}" />
                                </DockPanel>
                            </StackPanel>
                            <StackPanel Visibility="{Binding Config.IsExpThree, Converter={StaticResource bool2VisibilityConverter}}">
                                <DockPanel Margin="0,0,0,3">
                                    <TextBlock MinWidth="60" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.ExposureR}" />
                                    <TextBox Width="50" DockPanel.Dock="Right" Text="{Binding DisplayConfig.ExpTimeR, StringFormat=F2}" />
                                    <hc:PreviewSlider IsSnapToTickEnabled="True" LargeChange="0.01" Maximum="{Binding Config.ExpTimeMaxLog}" Minimum="{Binding Config.ExpTimeMinLog}" SmallChange="0.001" TickFrequency="0.001" ValueChanged="PreviewSlider_ValueChanged" Value="{Binding DisplayConfig.ExpTimeRLog}" />
                                </DockPanel>
                                <DockPanel Margin="0,0,0,3">
                                    <TextBlock MinWidth="60" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.ExposureG}" />
                                    <TextBox Width="50" DockPanel.Dock="Right" Text="{Binding DisplayConfig.ExpTimeG, StringFormat=F2}" />
                                    <hc:PreviewSlider IsSnapToTickEnabled="True" LargeChange="0.01" Maximum="{Binding Config.ExpTimeMaxLog}" Minimum="{Binding Config.ExpTimeMinLog}" SmallChange="0.001" TickFrequency="0.001" ValueChanged="PreviewSlider_ValueChanged" Value="{Binding DisplayConfig.ExpTimeGLog}" />
                                </DockPanel>
                                <DockPanel Margin="0,0,0,3">
                                    <TextBlock MinWidth="60" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.ExposureB}" />
                                    <TextBox Width="50" DockPanel.Dock="Right" Text="{Binding DisplayConfig.ExpTimeB, StringFormat=F2}" />
                                    <hc:PreviewSlider IsSnapToTickEnabled="True" LargeChange="0.001" Maximum="{Binding Config.ExpTimeMaxLog}" Minimum="{Binding Config.ExpTimeMinLog}" SmallChange="0.001" TickFrequency="0.001" ValueChanged="PreviewSlider_ValueChanged" Value="{Binding DisplayConfig.ExpTimeBLog}" />
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,3" Orientation="Horizontal">
                            <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.AverageTimes}" />
                            <TextBox Width="100" Margin="0,0,10,0" HorizontalAlignment="Left" DockPanel.Dock="Right" Text="{Binding DisplayConfig.AvgCount}" />
                            <TextBlock MinWidth="30" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.Flip}" />
                            <ComboBox x:Name="CBFilp" Width="70" DisplayMemberPath="Key" SelectedValue="{Binding DisplayConfig.FlipMode}" SelectedValuePath="Value" Style="{StaticResource ComboBox.Small}" />
                        </StackPanel>

                        <DockPanel Margin="0,0,0,3">
                            <Grid Width="20" Margin="5,0" HorizontalAlignment="Left" DockPanel.Dock="Right">
                                <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE713;">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="rotateTransform43" CenterX="8" CenterY="8" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <Button Width="20" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="EditHDRTemplate">
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="Button.Click">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform43" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>
                                </Button>
                            </Grid>
                            <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.UseHDR}" />
                            <ComboBox d:DataContext="{d:DesignInstance local:DisplayCameraConfig}" x:Name="ComboBoxHDRTemplate" DisplayMemberPath="Key" SelectedIndex="{Binding HDRTemplateIndex}" SelectedValuePath="Value" Style="{StaticResource ComboBox.Small}" />

                        </DockPanel>

                        <StackPanel Margin="0,0,0,3" Visibility="{Binding Config.IsAutoExpose, Converter={StaticResource bool2VisibilityConverter1}}">
                            <DockPanel>
                                <Button HorizontalAlignment="Left" Click="AutoExplose_Click" Content="{x:Static properties:Resources.AutoExposure}" DockPanel.Dock="Right" />
                                <CheckBox Margin="0,0,5,0" Padding="2,0,0,0" Content="ND" DockPanel.Dock="Right" IsChecked="{Binding Config.IsAutoExpWithND}" Visibility="{Binding Config.CFW.IsNDPort, Converter={StaticResource bool2VisibilityConverter}}" />
                                <Grid Width="20" Margin="5,0" HorizontalAlignment="Left" DockPanel.Dock="Right">
                                    <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE713;">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform x:Name="rotateTransform2" CenterX="8" CenterY="8" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <Button Width="20" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="EditAutoExpTime">
                                        <Button.Triggers>
                                            <EventTrigger RoutedEvent="Button.Click">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform2" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </Grid>
                                <ComboBox d:DataContext="{d:DesignInstance local:DisplayCameraConfig}" x:Name="ComboxAutoExpTimeParamTemplate" DisplayMemberPath="Key" SelectedIndex="{Binding ExpTimeParamTemplateIndex}" SelectedValuePath="Value" Style="{StaticResource ComboBox.Small}" />
                            </DockPanel>
                        </StackPanel>


                        <StackPanel Margin="0,0,0,2" Visibility="{Binding DService.IsVideoOpen, Converter={StaticResource bool2VisibilityConverter1}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,3">
                                        <StackPanel VerticalAlignment="Center" DockPanel.Dock="Right">
                                            <CheckBox Margin="0,0,5,0" Padding="2,0,0,0" Content="ND" IsChecked="{Binding Config.IsAutoExpWithND}" Visibility="{Binding Config.CFW.IsNDPort, Converter={StaticResource bool2VisibilityConverter}}" />
                                        </StackPanel>
                                        <Grid Width="20" Margin="5,0" HorizontalAlignment="Left" DockPanel.Dock="Right">
                                            <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE713;">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform x:Name="rotateTransform3" CenterX="8" CenterY="8" />
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                            <Button Width="20" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="EditAutoExpTime1">
                                                <Button.Triggers>
                                                    <EventTrigger RoutedEvent="Button.Click">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform3" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Button.Triggers>
                                            </Button>
                                        </Grid>
                                        <ComboBox d:DataContext="{d:DesignInstance local:DisplayCameraConfig}" x:Name="ComboxAutoExpTimeParamTemplate1" DisplayMemberPath="Key" SelectedIndex="{Binding ExpTimeParamTemplate1Index}" SelectedValuePath="Value" SelectionChanged="ComboxAutoExpTimeParamTemplate1_SelectionChanged" Style="{StaticResource ComboBox.Small}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0">
                                        <Grid Width="20" Margin="5,0" HorizontalAlignment="Left" DockPanel.Dock="Right">
                                            <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE713;">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform x:Name="rotateTransform4" CenterX="8" CenterY="8" />
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                            <Button Width="20" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="MenuItem_Template">
                                                <Button.Triggers>
                                                    <EventTrigger RoutedEvent="Button.Click">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform4" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Button.Triggers>
                                            </Button>
                                        </Grid>
                                        <ComboBox d:DataContext="{d:DesignInstance local:DisplayCameraConfig}" x:Name="ComboxCalibrationTemplate" DisplayMemberPath="Key" SelectedIndex="{Binding CalibrationTemplateIndex}" SelectedValuePath="Value" Style="{StaticResource ComboBox.Small}" />
                                    </DockPanel>
                                </StackPanel>
                                <Button x:Name="TakePhotoButton" Grid.Column="1" Click="GetData_Click" Content="{x:Static properties:Resources.Capture}" FontSize="15" FontWeight="Bold" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <DockPanel Margin="0,2" Visibility="{Binding Config.CFW.IsNDPort, Converter={StaticResource bool2VisibilityConverter}}">
                        <Button Click="GetNDport_Click" Content="Get" DockPanel.Dock="Right" />
                        <Button Click="NDport_Click" Content="{x:Static properties:Resources.ChangeNDPort}" DockPanel.Dock="Right" />
                        <TextBlock Text="NDPort" />
                        <TextBox Margin="5,0" BorderThickness="0,0,0,1" Text="{Binding Config.NDPort}" />
                    </DockPanel>

                    <StackPanel Margin="2" Visibility="{Binding Config.MotorConfig.IsUseMotor, Converter={StaticResource bool2VisibilityConverter}}">
                        <DockPanel>
                            <Button Click="AutoFocus_Click" Content="{x:Static properties:Resources.AutoFocus}" DockPanel.Dock="Right" />
                            <Grid Width="20" Margin="5,0" HorizontalAlignment="Left" DockPanel.Dock="Right">
                                <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="rotateTransform10" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <Button Width="20" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="EditAutoFocus">
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="Button.Click">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform10" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>
                                </Button>
                            </Grid>
                            <ComboBox d:DataContext="{d:DesignInstance local:DisplayCameraConfig}" x:Name="ComboxAutoFocus" DisplayMemberPath="Key" SelectedIndex="{Binding AutoFocusTemplateIndex}" SelectedValuePath="Value" Style="{StaticResource ComboBox.Small}" />
                        </DockPanel>

                        <DockPanel Margin="0,2">
                            <Button Click="Move_Click" Content="{x:Static properties:Resources.Move}" DockPanel.Dock="Right" />
                            <CheckBox x:Name="CheckBoxIsAbs" Content="{x:Static properties:Resources.AbsolutePosition}" />
                            <TextBox x:Name="TextPos" Margin="5,0" BorderThickness="0,0,0,1" Text="0" />
                        </DockPanel>
                        <DockPanel Margin="0,2">
                            <Button Click="Move1_Click" Content="{x:Static properties:Resources.AdjustAperture}" DockPanel.Dock="Right" />
                            <TextBlock Width="40" Text="{x:Static properties:Resources.ApertureF}" />
                            <TextBox x:Name="TextDiaphragm" Margin="5,0" BorderThickness="0,0,0,1" Text="0" />
                        </DockPanel>


                        <Button Margin="0,2" Click="GoHome_Click" Content="{x:Static properties:Resources.HomePosition}" />
                        <DockPanel>
                            <Button Click="GetPosition_Click" Content="{x:Static properties:Resources.AcquirePosition}" DockPanel.Dock="Right" />
                            <TextBlock Width="60" Text="{x:Static properties:Resources.CurrentPosition}" />
                            <TextBox Width="60" Margin="5,0" Background="Transparent" BorderThickness="0,0,0,0" IsReadOnly="True" Text="{Binding Config.MotorConfig.Position}" />
                            <TextBox Margin="5,0" Background="Transparent" BorderThickness="0,0,0,0" IsReadOnly="True" Text="{Binding Config.MotorConfig.VIDPosition}" />
                        </DockPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="LocalVideo" Margin="0,0,0,3">
                    <DockPanel Margin="0,0,0,3">
                        <Button Width="21" Height="21" Margin="5,0,0,0" Padding="2" HorizontalAlignment="Left" Command="{Binding CameraVideoControl.EditConfigCommand}" DockPanel.Dock="Right">
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.Click">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform256" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                            <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="rotateTransform256" />
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Button>
                        <Button x:Name="LocalVideoButton" Click="Video1_Click" Content="LocalVideo" />

                    </DockPanel>
                    <StackPanel Visibility="{Binding DisplayConfig.IsLocalVideoOpen, Converter={StaticResource bool2VisibilityConverter}}">
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.Flip}" />
                            <ComboBox x:Name="CBFilp2" DisplayMemberPath="Value" SelectedValue="{Binding DisplayConfig.LocalVideoTransform}" SelectedValuePath="Key" SelectionChanged="CBFilp2_SelectionChanged" Style="{StaticResource ComboBox.Small}" />
                        </DockPanel>
                        <StackPanel Margin="0,0,0,3">
                            <CheckBox Margin="0,0,0,3" Content="十字导引" IsChecked="{Binding DisplayConfig.IsCrossGuideEnabled}" />
                            <StackPanel Visibility="{Binding DisplayConfig.IsCrossGuideEnabled, Converter={StaticResource bool2VisibilityConverter}}">
                                <UniformGrid Margin="0,0,0,3" Columns="2">
                                    <DockPanel Margin="0,0,3,0">
                                        <TextBlock MinWidth="38" Margin="0,0,5,0" Text="中心X" />
                                        <TextBox Text="{Binding DisplayConfig.CrossGuideStandardCenterX}" />
                                    </DockPanel>
                                    <DockPanel Margin="3,0,0,0">
                                        <TextBlock MinWidth="38" Margin="0,0,5,0" Text="中心Y" />
                                        <TextBox Text="{Binding DisplayConfig.CrossGuideStandardCenterY}" />
                                    </DockPanel>
                                </UniformGrid>
                                <UniformGrid Margin="0,0,0,3" Columns="2">
                                    <DockPanel Margin="0,0,3,0">
                                        <TextBlock MinWidth="38" Margin="0,0,5,0" Text="阈值" />
                                        <TextBox Text="{Binding DisplayConfig.CrossGuideTolerancePx}" />
                                    </DockPanel>
                                    <DockPanel Margin="3,0,0,0">
                                        <TextBlock MinWidth="38" Margin="0,0,5,0" Text="间隔" />
                                        <TextBox Text="{Binding DisplayConfig.CrossGuideIntervalMs}" />
                                    </DockPanel>
                                </UniformGrid>
                                <UniformGrid Margin="0,0,0,3" Columns="2">
                                    <DockPanel Margin="0,0,3,0">
                                        <TextBlock MinWidth="38" Margin="0,0,5,0" Text="亮度" />
                                        <TextBox Text="{Binding DisplayConfig.CrossGuideThresholdRatio}" />
                                    </DockPanel>
                                    <DockPanel Margin="3,0,0,0">
                                        <TextBlock MinWidth="38" Margin="0,0,5,0" Text="覆盖" />
                                        <TextBox Text="{Binding DisplayConfig.CrossGuideMinCoverageRatio}" />
                                    </DockPanel>
                                </UniformGrid>
                                <StackPanel x:Name="LocalVideoCrossGuideRoiEditorHost" Margin="0,0,0,3" />
                                <TextBlock Text="{Binding DisplayConfig.CrossGuideStatus}" Foreground="{DynamicResource GlobalTextBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Visibility="{Binding CameraVideoControl.Config.IsCalArtculation, Converter={StaticResource bool2VisibilityConverter}}">
                            <StackPanel x:Name="LocalVideoRoiEditorHost" Margin="0,0,0,3" />
                            <UniformGrid Margin="0,0,0,3" Columns="2">
                                <Button Margin="0,0,3,0" Click="LocalVideoRoiDefault_Click" Content="默认区域" />
                                <Button Margin="3,0,0,0" Click="LocalVideoRoiFull_Click" Content="全幅" />
                            </UniformGrid>
                        </StackPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.Gain}" />
                            <TextBox MinWidth="50" DockPanel.Dock="Right" Text="{Binding DisplayConfig.Gain, StringFormat=F2}" />
                            <hc:PreviewSlider IsSnapToTickEnabled="True" LargeChange="10" Maximum="{Binding Config.GainMax}" Minimum="{Binding Config.GainMin}" SmallChange="1" TickFrequency="1" ValueChanged="PreviewSliderLocalGain_ValueChanged1" Value="{Binding DisplayConfig.Gain}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock MinWidth="50" Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.Exposure}" />
                            <TextBox MinWidth="50" DockPanel.Dock="Right" Text="{Binding DisplayConfig.ExpTime, StringFormat=F2}" />
                            <hc:PreviewSlider IsSnapToTickEnabled="True" LargeChange="0.01" Maximum="{Binding Config.ExpTimeMaxLog}" Minimum="{Binding Config.ExpTimeMinLog}" SmallChange="0.001" TickFrequency="0.001" ValueChanged="PreviewSliderLocalExp_ValueChanged" Value="{Binding DisplayConfig.ExpTimeLog}" />
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>

</UserControl>
