<Window x:Class="ColorVision.Engine.Services.Devices.Camera.CameraLocalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:im="clr-namespace:ColorVision.ImageEditor;assembly=ColorVision.ImageEditor"
        xmlns:local="clr-namespace:ColorVision.Engine.Services.Devices.Camera"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Title="COLOR VISION" Width="1400" Height="900" Closing="Window_Closing"
        Loaded="Window_Loaded" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Menu Bar  -->
        <Menu Grid.Row="0">
            <MenuItem Header="显示设置">
                <MenuItem x:Name="MenuItem_ShowCenterLine" Header="显示中心线" IsCheckable="True" />
            </MenuItem>
            <MenuItem Header="基本参数设置">
                <MenuItem Click="Camera_MenuItem_Click" Header="相机参数设置" />
                <MenuItem Click="Channels_MenuItem_Click" Header="通道参数设置" />
                <MenuItem Click="Calibration_MenuItem_Click" Header="校正参数设置" />
                <MenuItem Click="ExpTime_MenuItem_Click" Header="自动曝光参数设置" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Left Panel - Controls  -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,5">
                    <!--  Camera Model  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="90" Text="相机型号：" />
                        <ComboBox x:Name="cb_CM_TYPE" SelectionChanged="cb_CM_TYPE_SelectionChanged">
                            <ComboBoxItem Content="QHY_USB" />
                            <ComboBoxItem Content="HK_USB" />
                            <ComboBoxItem Content="HK_CARD" />
                            <ComboBoxItem Content="MIL_CL_CARD" />
                            <ComboBoxItem Content="MIL_CXP_CARD" />
                            <ComboBoxItem Content="NN_USB" />
                            <ComboBoxItem Content="TOUP_USB" />
                            <ComboBoxItem Content="HK_FG_CARD" />
                            <ComboBoxItem Content="IKAP_CARD" />
                        </ComboBox>
                    </DockPanel>

                    <!--  Camera Mode  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="90" Text="相机模式：" />
                        <ComboBox x:Name="cb_CM_MODE" SelectionChanged="cb_CM_MODE_SelectionChanged">
                            <ComboBoxItem Content="CV_MODE" />
                            <ComboBoxItem Content="BV_MODE" />
                            <ComboBoxItem Content="LV_MODE" />
                            <ComboBoxItem Content="LVTOBV_MODE" />
                        </ComboBox>
                    </DockPanel>

                    <!--  Camera ID  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="90" Text="相机ID：" />
                        <ComboBox x:Name="cb_CM_ID" SelectionChanged="cb_CM_ID_SelectionChanged" />
                    </DockPanel>

                    <!--  Channels  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="90" Text="通道数：" />
                        <ComboBox x:Name="cb_Channels" IsEnabled="False" SelectionChanged="cb_Channels_SelectionChanged">
                            <ComboBoxItem Content="1" />
                            <ComboBoxItem Content="3" />
                        </ComboBox>
                    </DockPanel>

                    <!--  Take Image Mode  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="90" Text="取图模式：" />
                        <ComboBox x:Name="cb_get_mode" SelectionChanged="cb_get_mode_SelectionChanged">
                            <ComboBoxItem Content="Measure_Normal" />
                            <ComboBoxItem Content="Live" />
                            <ComboBoxItem Content="Measure_Fast" />
                            <ComboBoxItem Content="Measure_FastEx" />
                        </ComboBox>
                    </DockPanel>

                    <!--  BPP  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="90" Text="像素位数：" />
                        <ComboBox x:Name="cb_bpp" SelectionChanged="cb_bpp_SelectionChanged">
                            <ComboBoxItem Content="8" />
                            <ComboBoxItem Content="16" />
                        </ComboBox>
                    </DockPanel>

                    <Separator Margin="0,5" />

                    <!--  Buttons: Connect / Reset / Close  -->
                    <UniformGrid Margin="0,3" Columns="3">
                        <Button x:Name="btn_Connect" Margin="0,0,3,0" Padding="5" Click="btn_Connect_Click" Content="连接" />
                        <Button x:Name="btn_reset" Margin="3,0,0,0" Padding="5" Click="btn_reset_Click" Content="复位" />

                        <Button  Margin="3,0,0,0" Padding="5" Click="GetID_Click" Content="复位" />


                    </UniformGrid>
                    <Button x:Name="btn_close" Margin="0,3" Padding="5" Click="btn_close_Click" Content="关闭" IsEnabled="False" />

                    <Separator Margin="0,5" />

                    <!--  Measure buttons  -->
                    <Button x:Name="btn_Meas" Margin="0,3" Padding="5" Click="btn_Meas_Click" Content="测量" IsEnabled="False" />
                    <Button x:Name="btn_MeasTif" Margin="0,3" Padding="5" Click="btn_MeasTif_Click" Content="测量tif" IsEnabled="False" />
                    <Button x:Name="btn_CalAutoExp" Margin="0,3" Padding="5" Click="btn_CalAutoExp_Click" Content="计算自动曝光" />

                    <!--  Calculate Position  -->
                    <DockPanel Margin="0,3">
                        <Button x:Name="button1" Width="100" Padding="5" Click="button1_Click" Content="计算位置" DockPanel.Dock="Left" IsEnabled="False" />
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Right" Text="阈值(0-255)" />
                        <TextBox x:Name="textBox1" Margin="5,0" Text="30" />
                    </DockPanel>

                    <Separator Margin="0,5" />

                    <!--  S/E/P fields  -->
                    <DockPanel Margin="0,3">
                        <TextBox x:Name="tb_s" Width="60" Margin="0,0,5,0" Text="1" />
                        <TextBox x:Name="tb_e" Width="60" Margin="0,0,5,0" Text="3" />
                        <TextBox x:Name="tb_p" Width="60" Text="0" />
                    </DockPanel>

                    <!--  TIF Name  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="70" Text="TIF名称" />
                        <TextBox x:Name="tb_TiffName" Text="ceshi001" />
                    </DockPanel>

                    <!--  Count  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="70" Text="次数" />
                        <TextBox x:Name="tb_Count" Text="1" />
                    </DockPanel>

                    <!--  Gain  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="70" Text="增益" />
                        <TextBox x:Name="tb_Gain" Width="80" Margin="0,0,5,0" Text="10" />
                        <TextBlock Width="30" Text="dB" />
                        <Button x:Name="btn_SetGain" Padding="5,2" Click="btn_SetGain_Click" Content="设置" />
                    </DockPanel>

                    <!--  Exposure Time  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="70" Text="时间" />
                        <TextBox x:Name="tb_Exp" Width="80" Margin="0,0,5,0" Text="100" />
                        <TextBlock Width="30" Text="ms" />
                        <Button x:Name="btn_SetExp" Padding="5,2" Click="btn_SetExp_Click" Content="设置" />
                    </DockPanel>

                    <!--  Exposure 2  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="70" Text="" />
                        <TextBox x:Name="tb_Exp2" Width="80" Margin="0,0,5,0" Text="100" />
                        <TextBlock Width="30" Text="ms" />
                    </DockPanel>

                    <!--  Exposure 3  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="70" Text="" />
                        <TextBox x:Name="tb_Exp3" Width="80" Margin="0,0,5,0" Text="100" />
                        <TextBlock Width="30" Text="ms" />
                    </DockPanel>

                    <Separator Margin="0,5" />

                    <!--  Calibration Checkboxes  -->
                    <TextBlock Margin="0,3" FontWeight="Bold" Text="校正选项" />
                    <CheckBox x:Name="cb_DSNU" Margin="0,3" Content="DSNU" />
                    <CheckBox x:Name="cb_DarkNoiseCorrect" Margin="0,3" Content="暗噪声校正" />
                    <CheckBox x:Name="cb_AutoExp" Margin="0,3" Content="自动曝光" />
                    <CheckBox x:Name="cb_LumCorrect" Margin="0,3" Content="Luminance校正" />
                    <CheckBox x:Name="cb_MonoCorrect" Margin="0,3" Checked="cb_MonoCorrect_Checked" Content="单色校正" />
                    <CheckBox x:Name="cb_FourColorCorrect" Margin="0,3" Checked="cb_FourColorCorrect_Checked" Content="四色校正" />
                    <CheckBox x:Name="cb_MulColorCorrect" Margin="0,3" Checked="cb_MulColorCorrect_Checked" Content="多色校正" />
                    <CheckBox x:Name="cb_BadPixelCorrect" Margin="0,3" Content="坏点校正" />
                    <CheckBox x:Name="cb_UniformFieldCorrect" Margin="0,3" Content="均匀场校正" />
                    <CheckBox x:Name="cb_DistortCorrect" Margin="0,3" Content="畸变校正" />

                    <Separator Margin="0,5" />

                    <!--  Additional controls  -->
                    <CheckBox x:Name="checkBox1" Margin="0,3" Checked="checkBox1_CheckedChanged" Content="框选" />
                    <UniformGrid Margin="0,3" Columns="2">
                        <Button Margin="0,0,3,0" Padding="5" Click="btn_FOV_Click" Content="执行FOV" />
                        <Button Margin="3,0,0,0" Padding="5" Click="btn_SFR_Click" Content="执行 SFR" />
                    </UniformGrid>
                    <UniformGrid Margin="0,3" Columns="2">
                        <Button Margin="0,0,3,0" Padding="5" Click="btn_Distortion_Click" Content="执行Disto" />
                        <Button Margin="3,0,0,0" Padding="5" Click="button2_Click" Content="显示设置" />
                    </UniformGrid>

                    <Button x:Name="btn_Test" Margin="0,3" Padding="5" Click="btn_Test_Click" Content="自动对焦测试" />
                    <Button x:Name="btn_ConfigFile" Margin="0,3" Padding="5" Click="btn_ConfigFile_Click" Content="配置文件" />

                    <!--  TIF Path  -->
                    <DockPanel Margin="0,3">
                        <TextBlock Width="70" Text="TIF路径" />
                        <TextBox x:Name="tb_TiffPath" />
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>

            <!--  Right Panel - ImageView  -->
            <im:ImageView x:Name="ImageView" Grid.Column="1" />
        </Grid>
    </Grid>
</Window>
