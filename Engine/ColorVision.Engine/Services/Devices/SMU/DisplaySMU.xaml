<UserControl x:Class="ColorVision.Engine.Services.Devices.SMU.DisplaySMU"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.Engine.Services.Devices.SMU"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:DeviceSMU}"
             d:DesignWidth="300"
             ContextMenu="{Binding ContextMenu}"
             Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="{x:Type TextBox}" />
    </UserControl.Resources>
    <StackPanel>
        <DockPanel Margin="0,0,5,0">
            <ToggleButton Content="{Binding Config.Name}" FontSize="15" IsChecked="{Binding DisplayConfig.IsDisplayOpen}" Style="{StaticResource ButtonPageControl1}" ToolTip="{Binding DService.DeviceStatus}" />
        </DockPanel>
        <Border x:Name="DisPlayBorder" Style="{DynamicResource BorderModuleArea}" Visibility="{Binding DisplayConfig.IsDisplayOpen, Converter={StaticResource bool2VisibilityConverter}}">
            <StackPanel Margin="5">
                <TextBlock x:Name="TextBlockUnknow" HorizontalAlignment="Center" Text="{x:Static properties:Resources.UnknownStatus}" />
                <Button x:Name="ButtonUnauthorized" Margin="0,0,0,3" Command="{Binding EditCommand}" Content="{x:Static properties:Resources.UnauthorizedOrLicenseExpired}" />
                <TextBlock x:Name="TextBlockOffLine" HorizontalAlignment="Center" Text="{x:Static properties:Resources.offline}" />
                <DockPanel x:Name="StackPanelContent" Margin="0,0,0,3">
                    <Button x:Name="ButtonSourceMeter1" Click="ButtonSourceMeter1_Click" Content="{x:Static properties:Resources.Open}" />
                </DockPanel>
                <StackPanel x:Name="StackPanelOpen">

                    <DockPanel Margin="0,0,0,3">
                        <ComboBox Name="CbChannel" Width="80" SelectedValue="{Binding DisplayConfig.Channel}" Style="{StaticResource ComboBox.Small}" />
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <RadioButton Margin="0,0,3,0" Content="{x:Static properties:Resources.V}" IsChecked="{Binding DisplayConfig.IsSourceV}" />
                            <RadioButton Content="{x:Static properties:Resources.I}" IsChecked="{Binding DisplayConfig.IsSourceV, Converter={StaticResource inverseBooleanConverter}}" />
                        </StackPanel>

                    </DockPanel>

                    <StackPanel Margin="0,0,0,3">
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock Width="60" Margin="0,0,3,0" Text="{x:Static properties:Resources.SourceValue}" />
                            <TextBlock DockPanel.Dock="Right" Text="V" Visibility="{Binding DisplayConfig.IsSourceV, Converter={StaticResource bool2VisibilityConverter}}" />
                            <TextBlock DockPanel.Dock="Right" Text="mA" Visibility="{Binding DisplayConfig.IsSourceV, Converter={StaticResource bool2VisibilityConverter1}}" />
                            <TextBox BorderThickness="0,0,0,1" Text="{Binding DisplayConfig.CurrentSourceConfig.MeasureVal}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,3">
                            <TextBlock Width="60" Margin="0,0,3,0" Text="{x:Static properties:Resources.LimitValue}" />
                            <TextBlock DockPanel.Dock="Right" Text="V" Visibility="{Binding DisplayConfig.IsSourceV, Converter={StaticResource bool2VisibilityConverter1}}" />
                            <TextBlock DockPanel.Dock="Right" Text="mA" Visibility="{Binding DisplayConfig.IsSourceV, Converter={StaticResource bool2VisibilityConverter}}" />
                            <TextBox BorderThickness="0,0,0,1" Text="{Binding DisplayConfig.CurrentSourceConfig.LmtVal}" />
                        </DockPanel>

                        <UniformGrid Margin="0,0,0,3" Columns="3">
                            <Button x:Name="MeasureDataButton" Click="MeasureData_Click" Content="{x:Static properties:Resources.Ignite}" />
                            <Button x:Name="StepMeasureDataButton" Click="StepMeasureData_Click" Content="{x:Static properties:Resources.Settings}" />
                            <Button Click="MeasureDataClose_Click" Content="{x:Static properties:Resources.Extinguish}" />
                        </UniformGrid>
                        <UniformGrid Margin="0,0,0,3" Columns="2">
                            <DockPanel Margin="0,0,5,0">
                                <TextBlock Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.CurrentVoltageV}" />
                                <TextBox x:Name="TextSourceMeterV" BorderThickness="0,0,0,1" IsEnabled="False" Text="{Binding DisplayConfig.CurrentChannelConfig.V, StringFormat={}{0:F4}}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,5,0">
                                <TextBlock Margin="0,0,5,0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{x:Static properties:Resources.CurrentCurrentMA}" />
                                <TextBox x:Name="TextSourceMeterI" BorderThickness="0,0,0,1" IsEnabled="False" Text="{Binding DisplayConfig.CurrentChannelConfig.I, StringFormat={}{0:F4}}" />
                            </DockPanel>
                        </UniformGrid>
                    </StackPanel>


                    <StackPanel x:Name="StackPanelVITemplate">
                        <DockPanel>
                            <Button x:Name="VIScanButton" Margin="5,0,0,0" Click="VIScan_Click" Content="{x:Static properties:Resources.Scan}" DockPanel.Dock="Right" />
                            <Grid Width="20" Margin="5,0,0,0" HorizontalAlignment="Left" DockPanel.Dock="Right">
                                <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE713;" />
                                <Button Width="20" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="MenuItem_Template" Tag="SMUParam" />
                            </Grid>
                            <ComboBox x:Name="ComboxVITemplate" Margin="0,0,0,0" DisplayMemberPath="Key" SelectedValuePath="Value" Style="{StaticResource ComboBox.Small}" />
                        </DockPanel>
                    </StackPanel>

                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>

</UserControl>
