<UserControl x:Class="ColorVision.Engine.Services.Devices.PG.DisplayPG"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:ColorVision.Engine.Services.Devices.PG"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mqtt="clr-namespace:ColorVision.Engine.MQTT"
             xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:DevicePG}"
             d:DesignWidth="300"
             ContextMenu="{Binding ContextMenu}"
             Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="{x:Type TextBox}" />
    </UserControl.Resources>
    <StackPanel>
        <DockPanel Margin="0,0,5,0" ToolTip="{Binding DService.DeviceStatus}">
            <Grid DockPanel.Dock="Right">
                <ToggleButton Width="10" Height="10" HorizontalAlignment="Center" IsChecked="True" IsEnabled="False" Style="{StaticResource ButtonMQTTConnect}" />
                <Image Height="18" Margin="0,0,0,0" Source="{DynamicResource DrawingImageProperty}" />
                <Button Background="Transparent" BorderThickness="0" Command="{Binding PropertyCommand}" />
            </Grid>
            <Button Padding="3" Background="Transparent" BorderThickness="0" Command="{Binding RefreshCommand}" DockPanel.Dock="Right">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform1" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE72C;" ToolTip="{x:Static properties:Resources.Refresh}">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="rotateTransform1" CenterX="6" CenterY="6" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Button>
            <ToggleButton Content="{Binding Config.Name}" FontSize="15" IsChecked="{Binding DisplayConfig.IsDisplayOpen}" Style="{StaticResource ButtonPageControl1}" ToolTip="{Binding DService.DeviceStatus}" />

        </DockPanel>
        <Border x:Name="DisPlayBorder" Style="{DynamicResource BorderModuleArea}" Visibility="{Binding DisplayConfig.IsDisplayOpen, Converter={StaticResource bool2VisibilityConverter}}">
            <StackPanel Margin="5">
                <TextBlock x:Name="TextBlockUnknow" HorizontalAlignment="Center" Text="{x:Static properties:Resources.UnknownStatus}" />
                <TextBlock x:Name="TextBlockOffLine" HorizontalAlignment="Center" Text="{x:Static properties:Resources.offline}" />
                <Button x:Name="ButtonUnauthorized" Margin="0,0,0,3" Command="{Binding EditCommand}" Content="{x:Static properties:Resources.Unregistered}" />
                <StackPanel x:Name="StackPanelContent">
                    <DockPanel x:Name="ButtonOpen" Margin="0,0,0,3">
                        <Grid>
                            <Button x:Name="OpenButton" Click="PGOpen" Content="{x:Static properties:Resources.Open}" />
                        </Grid>
                    </DockPanel>
                    <DockPanel x:Name="ButtonClose" Margin="0,0,0,3">
                        <Grid>
                            <Button x:Name="CloseButton" Background="Red" Click="PGClose" Content="{x:Static properties:Resources.Close}" Foreground="White" />
                        </Grid>
                    </DockPanel>
                    <Grid x:Name="PGOperationPanel">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Margin="2" Click="PGStartPG" Content="{x:Static properties:Resources.PowerOn}" />
                        <Button Grid.Row="0" Grid.Column="1" Margin="2" Click="PGStopPG" Content="{x:Static properties:Resources.PowerOff}" />
                        <Button Grid.Row="1" Grid.Column="0" Margin="2" Click="PGSwitchUpPG" Content="{x:Static properties:Resources.PG_PreviousImage}" ToolTip="{x:Static properties:Resources.PG_PreviousImageTooltip}" />
                        <Button Grid.Row="1" Grid.Column="1" Margin="2" Click="PGSwitchDownPG" Content="{x:Static properties:Resources.PG_NextImage}" ToolTip="{x:Static properties:Resources.PG_NextImageTooltip}" />
                        <TextBox x:Name="PGFrameText" Grid.Row="2" Grid.Column="0" Margin="2" VerticalContentAlignment="Center" BorderThickness="0,0,0,1" Text="0" ToolTip="{x:Static properties:Resources.PG_ImageNumberTooltip}" />
                        <Button Grid.Row="2" Grid.Column="1" Margin="2" Click="PGSwitchFramePG" Content="{x:Static properties:Resources.Switch}" ToolTip="{x:Static properties:Resources.PG_SwitchImageTooltip}" />
                        <Button Grid.Row="3" Grid.ColumnSpan="2" Margin="2" Click="PGReSetPG" Content="ReSet" />
                    </Grid>

                    <StackPanel>
                        <DockPanel Margin="0,0,0,5">
                            <Button Width="60" Margin="2,0" Click="PGSendCmd" Content="{x:Static properties:Resources.Send}" DockPanel.Dock="Right" />
                            <TextBlock Margin="0,0,5,0" Text="{x:Static properties:Resources.PGCommand}" />
                            <TextBox x:Name="PGCmdMsg" BorderThickness="0,0,0,1" />
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
