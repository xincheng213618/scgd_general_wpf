<Window x:Class="ColorVision.Engine.Templates.Flow.FlowNodeAnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:local="clr-namespace:ColorVision.Engine.Templates.Flow"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.Flow_NodeAnalysis_Title}" Height="720" Width="1280"
        Background="{DynamicResource GlobalBackground}" Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top: Batch selection controls -->
        <Grid Grid.Row="0" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Static properties:Resources.Flow_NodeAnalysis_BatchSelection}" Margin="0,0,5,0"/>
            <ListView x:Name="BatchListView" Grid.Column="1" Height="60"
                      SelectionMode="Extended"
                      Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource ListViewItemBaseStyle.Small}"/>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource GridViewColumnHeaderBase}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Margin="4,2"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>

                </ListView.View>
            </ListView>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="{x:Static properties:Resources.Flow_NodeAnalysis_Load}" Click="LoadButton_Click" Margin="5,0,0,0" Width="60" Height="30"/>
                <Button Content="{x:Static properties:Resources.Flow_NodeAnalysis_Compare}" Click="CompareButton_Click" Margin="5,0,0,0" Width="60" Height="30"/>
                <Button Content="{x:Static properties:Resources.Flow_NodeAnalysis_Export}" Click="ExportButton_Click" Margin="5,0,0,0" Width="60" Height="30"/>
            </StackPanel>
        </Grid>

        <!-- Main content: chart (primary) + list (secondary) -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" MinHeight="200"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*" MinHeight="120"/>
            </Grid.RowDefinitions>

            <!-- Top: Gantt chart (primary) -->
            <ScottPlot:WpfPlot x:Name="GanttPlot" Grid.Row="0"/>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Middle: Node records list -->
            <ListView x:Name="NodeRecordListView" Grid.Row="2"
                      Background="Transparent" BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource ListViewItemBaseStyle.Small}"/>
                </ListView.ItemContainerStyle>
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource GridViewColumnHeaderBase}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>
                        <GridViewColumn Header="BatchId" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding BatchId}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_NodeName}" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NodeName}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_NodeType}" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding NodeType}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_StartTime}" Width="170">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StartTime, StringFormat=yyyy/MM/dd HH:mm:ss.fff}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_EndTime}" Width="170">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding EndTime, StringFormat=yyyy/MM/dd HH:mm:ss.fff}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_ElapsedMs}" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ElapsedMs}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="SN" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SerialNumber}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Bottom: MQTT Message records (master-detail like MessagesListWindow) -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,2,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static properties:Resources.Flow_NodeAnalysis_MqttMessageTrace}" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="2" Text="{x:Static properties:Resources.Flow_NodeAnalysis_NodeFilter}" Margin="10,0,5,0"/>
                    <ComboBox x:Name="MessageNodeFilter" Grid.Column="3" SelectionChanged="MessageNodeFilter_SelectionChanged">
                        <ComboBoxItem Content="{x:Static properties:Resources.Flow_NodeAnalysis_All}" Tag="All" IsSelected="True"/>
                    </ComboBox>
                    <TextBlock Grid.Column="4" Text="{x:Static properties:Resources.Flow_NodeAnalysis_StateFilter}" Margin="10,0,5,0"/>
                    <ComboBox x:Name="MessageStateFilter" Grid.Column="5" SelectionChanged="MessageStateFilter_SelectionChanged">
                        <ComboBoxItem Content="{x:Static properties:Resources.Flow_NodeAnalysis_All}" Tag="All" IsSelected="True"/>
                        <ComboBoxItem Content="Sended"/>
                        <ComboBoxItem Content="Success"/>
                        <ComboBoxItem Content="Fail"/>
                        <ComboBoxItem Content="Timeout"/>
                    </ComboBox>
                    <Button Grid.Column="7" Content="{x:Static properties:Resources.Flow_NodeAnalysis_MessageQueryWindow}" Click="OpenMessageListWindow_Click" Margin="5,0,0,0" Width="100" Height="24"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Message list -->
                    <ListView x:Name="MessageListView" Grid.Column="0"
                              Background="Transparent" BorderThickness="0"
                              SelectionChanged="MessageListView_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource ListViewItemBaseStyle.Small}"/>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridView.ColumnHeaderContainerStyle>
                                    <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource GridViewColumnHeaderBase}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </GridView.ColumnHeaderContainerStyle>
                                <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_Node}" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding NodeName}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="EventName" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding EventName}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_SendTime}" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SendTime, StringFormat=HH:mm:ss.fff}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_RecvTime}" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding RecvTime, StringFormat=HH:mm:ss.fff}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_ElapsedMs}" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ElapsedMs}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static properties:Resources.Flow_NodeAnalysis_State}" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding State}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

                    <!-- Right: Send/Recv detail panels -->
                    <Grid x:Name="MessageDetailGrid" Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{x:Static properties:Resources.Flow_NodeAnalysis_SendData}" FontWeight="Bold" Margin="2"/>
                        <TextBox x:Name="SendPayloadTextBox" Grid.Row="1" IsReadOnly="True"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="12"/>

                        <TextBlock Grid.Row="2" Text="{x:Static properties:Resources.Flow_NodeAnalysis_RecvData}" FontWeight="Bold" Margin="2"/>
                        <TextBox x:Name="RecvPayloadTextBox" Grid.Row="3" IsReadOnly="True"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="12"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
