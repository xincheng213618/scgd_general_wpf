<Window x:Class="ColorVision.Engine.Templates.Flow.TemplateSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        Title="{x:Static properties:Resources.SelectTemplateAsModule}" Height="400" Width="350"
        ResizeMode="NoResize"
        Background="{DynamicResource GlobalBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{x:Static properties:Resources.SelectFlowTemplateToImport}" Margin="0,0,0,8" Foreground="{DynamicResource GlobalTextBrush}"/>
        <ListBox x:Name="TemplateList" Grid.Row="1" 
                 DisplayMemberPath="Key"
                 MouseDoubleClick="TemplateList_MouseDoubleClick"
                 Background="{DynamicResource GlobalBackground}"
                 Foreground="{DynamicResource GlobalTextBrush}"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{x:Static properties:Resources.Import}" Width="80" Margin="0,0,8,0" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="{x:Static properties:Resources.Cancel}" Width="80" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
