<UserControl x:Class="ColorVision.Engine.Templates.Matching.DisplayMatching"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             Foreground="{DynamicResource GlobalTextBrush}"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ColorVision.Engine.Templates.Matching"
             xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance local:AlgorithmMatching}"
             d:DesignHeight="200" d:DesignWidth="280" Initialized="UserControl_Initialized">
    <Grid>
        <StackPanel>
            <DockPanel Margin="0,2">
                <Button  Content="{x:Static properties:Resources.Calculate}" DockPanel.Dock="Right"  HorizontalAlignment="Right" Click="RunTemplate_Click" />
                <TextBlock Text="{x:Static properties:Resources.ParameterTemplate}" Width="80"/>
                <ComboBox  x:Name="ComboxTemplate"  Width="130" HorizontalAlignment="Left" SelectedIndex="{Binding TemplatePoiSelectedIndex}" Style="{StaticResource ComboBox.Small}" SelectedValuePath="Value"  DisplayMemberPath="Key" />
                <Grid Width="20" Margin="5,0" HorizontalAlignment="Left">
                    <TextBlock Text="&#xE713;"  HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="15"  Foreground="{DynamicResource GlobalTextBrush}"/>
                    <Button  Width="20" BorderBrush="Transparent" Background="Transparent" BorderThickness="0" Command="{Binding OpenTemplateCommand}"/>
                </Grid>
            </DockPanel>
            <DockPanel Margin="0,2">
                <TextBlock Text="TemplateFile" Width="80"/>
                <TextBox  Style="{StaticResource TextBox.Small}" Text="{Binding TemplateFile}" Width="140" HorizontalAlignment="Left"  Margin="0,0,5,0"/>
                <Button Content="..." Command="{Binding SetTemplateFileCommand}"  HorizontalAlignment="Left"/>
            </DockPanel>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Width="60" VerticalAlignment="Center" Text="{x:Static properties:Resources.Image}" />
                <TextBox x:Name="ImageFile" Grid.Column="1" Style="{StaticResource TextBox.Small}" Text="{Binding ImageFilePath}" Margin="0,0,2,0" HorizontalAlignment="Stretch" />
                <Button Grid.Column="2" Content="..." Click="Open_File" />
            </Grid>
        
        </StackPanel>
    </Grid>
</UserControl>
