<Window x:Class="ColorVision.Engine.Templates.TemplateCreate"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Templates"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:winf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.Create}" Background="{DynamicResource GlobalBackground}" Height="620" Width="900" MinWidth="620" Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="ToolTip" Value="{ Binding Text,RelativeSource={RelativeSource Self}}"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxBaseBaseStyle}">
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown"/>
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid" Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="PropertyColumn" Width="400"/>
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border x:Name="TemplateSourcePanel" Grid.Row="0" Background ="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="10,8,10,4">
                        <TextBlock Text="{x:Static properties:Resources.CreateSource}" FontWeight="Bold" FontSize="14" />
                        <TextBlock x:Name="TemplateSourceCountText" DockPanel.Dock="Right" Foreground="{DynamicResource ThirdlyTextBrush}" />
                    </DockPanel>
                    <DockPanel x:Name="GroupFilterPanel" Grid.Row="1" Margin="10,0,10,6">
                        <TextBlock Text="{x:Static properties:Resources.Group}" Margin="0,0,8,0" Foreground="{DynamicResource ThirdlyTextBrush}" />
                        <hc:ComboBox x:Name="SourceGroupComboBox" Width="180" Height="28" IsTextSearchEnabled="False" SelectionChanged="SourceGroupComboBox_SelectionChanged" />
                    </DockPanel>
                    <ScrollViewer Grid.Row="2" Margin="8,0,8,8" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <WrapPanel x:Name="TemplateStackPanels" Orientation="Horizontal" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="0,8,0,0" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
                <StackPanel>
                    <TextBlock Text="{x:Static properties:Resources.NewTemplateName}" Margin="0,0,0,5" Foreground="{DynamicResource ThirdlyTextBrush}" />
                    <DockPanel Grid.Row="1">
                        <hc:ComboBox x:Name="CreateCode" IsEditable="True" SelectedIndex="0"  hc:InfoElement.ShowClearButton="True"   />
                    </DockPanel>
                    <Button Content="{x:Static properties:Resources.Create}" Foreground="White" Background="{StaticResource PrimaryBrush}" Margin="0,8,0,0" Height="32" Click="Button_Click" />
                </StackPanel>
            </Border>
        </Grid>
        <Grid Grid.Column="1" Width="400">
            <Grid  x:Name="GridProperty" Margin="3,5">
                <WindowsFormsHost>
                    <winf:PropertyGrid x:Name="PropertyGrid1" />
                </WindowsFormsHost>
            </Grid>
        </Grid>
       
    </Grid>
</Window>
