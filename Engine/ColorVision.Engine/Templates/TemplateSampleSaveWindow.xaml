<Window x:Class="ColorVision.Engine.Templates.TemplateSampleSaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="保存为样例" Height="260" Width="420" MinWidth="380"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="InfoText" Grid.Row="0" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="组别" VerticalAlignment="Center"/>
            <hc:ComboBox x:Name="GroupComboBox" Grid.Column="1" IsEditable="True" Height="30"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="样例名" VerticalAlignment="Center"/>
            <TextBox x:Name="NameTextBox" Grid.Column="1" Height="30" VerticalContentAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="说明" VerticalAlignment="Top" Margin="0,5,0,0"/>
            <TextBox x:Name="DescriptionTextBox" Grid.Column="1" Height="56" AcceptsReturn="True" TextWrapping="Wrap"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Width="72" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="保存" Width="72" Foreground="White" Background="{StaticResource PrimaryBrush}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>