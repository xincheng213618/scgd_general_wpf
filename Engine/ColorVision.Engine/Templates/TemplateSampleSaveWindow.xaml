<Window x:Class="ColorVision.Engine.Templates.TemplateSampleSaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        Title="{x:Static properties:Resources.CreateSample}" Height="280" Width="440" MinWidth="400"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="InfoText" Grid.Row="0" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Static properties:Resources.SampleGroup}" VerticalAlignment="Center"/>
            <hc:ComboBox x:Name="GroupComboBox" Grid.Column="1" IsEditable="True" Height="30" hc:InfoElement.Placeholder="{x:Static properties:Resources.SampleGroupPlaceholder}"/>
        </Grid>

        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Static properties:Resources.AutoCreateGroupHint}" Foreground="{DynamicResource ThirdlyTextBrush}" FontSize="11" Margin="72,32,0,0"/>

        <Grid Grid.Row="2" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Static properties:Resources.SampleName}" VerticalAlignment="Center"/>
            <TextBox x:Name="NameTextBox" Grid.Column="1" Height="30" VerticalContentAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Static properties:Resources.Description}" VerticalAlignment="Top" Margin="0,5,0,0"/>
            <TextBox x:Name="DescriptionTextBox" Grid.Column="1" Height="56" AcceptsReturn="True" TextWrapping="Wrap"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static properties:Resources.Cancel}" Width="72" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="{x:Static properties:Resources.Save}" Width="72" Foreground="White" Background="{StaticResource PrimaryBrush}" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>