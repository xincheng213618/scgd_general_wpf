<UserControl x:Class="ColorVision.Engine.Templates.POI.POIOutput.EditPoiOutput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.Engine.Templates.POI.POIOutput"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:PoiOutputParam}"
             d:DesignHeight="450" d:DesignWidth="500" Width="500" Height="450"
             Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="{x:Type TextBox}">
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Border Background="{DynamicResource SecondaryRegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5" />
        <ScrollViewer>
            <StackPanel Margin="5">
                <DockPanel Margin="5,0,0,5">
                    <TextBlock MinWidth="100" HorizontalAlignment="Left" Text="Heigth" />
                    <TextBox Width="100" HorizontalAlignment="Left" Text="{Binding Height}" />
                </DockPanel>
                <DockPanel Margin="5,0,0,5">
                    <TextBlock MinWidth="100" HorizontalAlignment="Left" Text="Width" />
                    <TextBox Width="100" HorizontalAlignment="Left" Text="{Binding Width}" />
                </DockPanel>
                <DockPanel Margin="5,0,0,5">
                    <TextBlock MinWidth="100" HorizontalAlignment="Left" Text="MaskFileName" />
                    <TextBox Width="100" HorizontalAlignment="Left" Text="{Binding MaskFileName}" />
                </DockPanel>
                <DockPanel Margin="5,0,0,5">
                    <TextBlock MinWidth="100" HorizontalAlignment="Left" Text="{x:Static properties:Resources.BenchmarkParams}" />
                </DockPanel>
                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseX}" />
                            <ToggleButton IsChecked="{Binding XIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding XFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>
                <!--  Y Configuration  -->
                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseY}" />
                            <ToggleButton IsChecked="{Binding YIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding YFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!--  Z Configuration  -->
                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseZ}" />
                            <ToggleButton IsChecked="{Binding ZIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding ZFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!--  x Configuration  -->
                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseXLower}" />
                            <ToggleButton IsChecked="{Binding xIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding xFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!--  y Configuration  -->
                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseYLower}" />
                            <ToggleButton IsChecked="{Binding yIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding yFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>
                <!--  u Configuration  -->
                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseU}" />
                            <ToggleButton IsChecked="{Binding uIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding uFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!--  v Configuration  -->
                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseV}" />
                            <ToggleButton IsChecked="{Binding vIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding vFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>


                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseCCT}" />
                            <ToggleButton IsChecked="{Binding CCTIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding CCTFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseXYZ}" />
                            <ToggleButton IsChecked="{Binding XYZIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding XYZFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Margin="0,0,0,5" CornerRadius="5" Style="{StaticResource BorderModuleArea}">
                    <StackPanel Margin="5,5,5,0">
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.UseWave}" />
                            <ToggleButton IsChecked="{Binding WaveIsEnable}" Style="{StaticResource ToggleButtonSwitch.Small}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock MinWidth="100" Text="{x:Static properties:Resources.FileName_Poi}" />
                            <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding WaveFileName}" />
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
