<Window x:Class="ColorVision.Engine.Templates.Jsons.SFR2.Sfr2PlotWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ColorVision.Engine.Templates.Jsons.SFR2"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        Title="SFR2 Plot" Height="900" Width="1400">
    <DockPanel>
        <StackPanel DockPanel.Dock="Right" Width="320" Margin="8">
            <TextBlock Text="POIs" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
            <ListBox x:Name="PoiList" Height="180" SelectionChanged="PoiList_SelectionChanged"/>
            <CheckBox x:Name="ChkAll" Margin="0,8,0,0" Checked="ChkAll_Checked" Unchecked="ChkAll_Unchecked"><TextBlock><Run Text="{x:Static properties:Resources.ShowAll}"/><Run Text=" POI"/></TextBlock></CheckBox>

            <Separator Margin="0,8,0,8"/>

            <TextBlock Text="{x:Static properties:Resources.DisplayType}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
            <ComboBox x:Name="CmbShowType" SelectionChanged="CmbShowType_SelectionChanged">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="Left"/>
                <ComboBoxItem Content="Top"/>
                <ComboBoxItem Content="Right"/>
                <ComboBoxItem Content="Bottom"/>
                <ComboBoxItem Content="HorAverage"/>
                <ComboBoxItem Content="VerAverage"/>
            </ComboBox>

            <Separator Margin="0,8,0,8"/>

            <TextBlock Text="{x:Static properties:Resources.Inquire}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock VerticalAlignment="Center" Width="60"><Run Text="{x:Static properties:Resources.CurveName}"/><Run Text=":"/></TextBlock>
                <TextBox x:Name="TxtSeries" Width="220" ToolTip="{x:Static properties:Resources.SfrPlot_SeriesExample}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock VerticalAlignment="Center" Width="60"><Run Text="{x:Static properties:Resources.Frequency}"/><Run Text=":"/></TextBlock>
                <TextBox x:Name="TxtFreq" Width="120" Text="0.5"/>
                <Button Content="MTF@Freq" Width="100" Margin="8,0,0,0" Click="BtnMtfAtFreq_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="MTF:" VerticalAlignment="Center" Width="60"/>
                <TextBox x:Name="TxtMtf" Width="120" Text="0.5"/>
                <Button Content="Freq@MTF" Width="100" Margin="8,0,0,0" Click="BtnFreqAtMtf_Click"/>
            </StackPanel>

            <TextBlock x:Name="TxtResult" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <local:Sfr2PlotControl x:Name="Plot" Margin="8"/>
    </DockPanel>
</Window>
