<Window x:Class="ColorVision.Engine.Batch.PreProcessManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Batch"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:PreProcessManager}"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        Title="预处理配置" Height="720" Width="1120" MinHeight="520" MinWidth="900" Background="{DynamicResource GlobalBackground}">
    <Window.Resources>
        <local:PreTypeNameConverter x:Key="TypeNameConverter"/>
        <local:PreProcessTooltipConverter x:Key="ProcessTooltipConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LastSaveStatus}" VerticalAlignment="Center" Foreground="Gray" ToolTip="{Binding PersistPath}"/>
                    <Button Content="立即保存" Padding="12,4" Margin="12,0,0,0" Command="{Binding SaveCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="预处理配置" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ProcessCount, StringFormat={}{0} 个处理器}" Margin="16,0,0,0" Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EnabledCount, StringFormat=已启用 {0} 个}" Margin="12,0,0,0" Foreground="Gray" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="360"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="460" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                <Button Content="上移" Padding="12,4" Command="{Binding MoveUpCommand}"/>
                <Button Content="下移" Padding="12,4" Margin="8,0,0,0" Command="{Binding MoveDownCommand}"/>
            </StackPanel>

            <ListView Grid.Row="1" ItemsSource="{Binding Processes}" SelectedItem="{Binding SelectedProcess}" x:Name="lvProcesses" SelectionChanged="ListView_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="序号" Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Converter={StaticResource TypeNameConverter}, ConverterParameter=Index}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="状态" Width="64">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource TypeNameConverter}, ConverterParameter=Enabled}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="处理器" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource TypeNameConverter}}" 
                                              ToolTip="{Binding Converter={StaticResource ProcessTooltipConverter}}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="应用模板" Width="130">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource TypeNameConverter}, ConverterParameter=Templates}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Converter={StaticResource TypeNameConverter}, ConverterParameter=Templates}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="描述" Width="260">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource TypeNameConverter}, ConverterParameter=Description}" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource GlobalBorderBrush}" CornerRadius="4,4,0,0" Padding="12,8">
                    <TextBlock Text="属性" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel x:Name="PropertyPanel">
                        <TextBlock Text="请选择一个预处理器查看配置" Foreground="Gray" HorizontalAlignment="Center" Margin="0,20,0,0"
                                   x:Name="PlaceholderText"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭" Padding="18,5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
