<Window x:Class="ColorVision.Engine.Batch.BatchProcessManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Engine.Batch"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:BatchManager}"
        xmlns:properties="clr-namespace:ColorVision.Engine.Properties"
        Title="{x:Static properties:Resources.ProcessHandlingConfig}" Height="720" Width="1280"  Background="{DynamicResource GlobalBackground}" Initialized="Window_Initialized">
    <Window.Resources>
        <local:TypeNameConverter x:Key="TypeNameConverter"/>
        <local:ProcessTooltipConverter x:Key="ProcessTooltipConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="600"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="350" MinWidth="250"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel: List and Controls -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Header="{x:Static properties:Resources.CreateProcessMeta}" Padding="8" Margin="0 0 0 8" Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{x:Static properties:Resources.Name}" VerticalAlignment="Center" Margin="0 0 4 0"/>
                    <TextBox Grid.Column="1" Text="{Binding NewMetaName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Column="2" Text="{x:Static properties:Resources.FlowTemplate}" VerticalAlignment="Center" Margin="12 0 4 0"/>
                    <ComboBox Grid.Column="3" ItemsSource="{Binding templateModels}" DisplayMemberPath="Key" SelectedItem="{Binding SelectedTemplate}"/>

                    <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="12 0 4 0"><Run Text="{x:Static properties:Resources.ProcessClass}"/><Run Text=":"/></TextBlock>
                    <ComboBox Grid.Column="5" ItemsSource="{Binding Processes}" SelectedItem="{Binding SelectedProcess}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource TypeNameConverter}}" 
                                          ToolTip="{Binding Converter={StaticResource ProcessTooltipConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Grid.Column="6">
                        <Button  Content="{x:Static properties:Resources.Add}" Margin="12 0 0 0" Padding="12 4" Command="{Binding AddMetaCommand}"/>
                        <Button Grid.Column="1" Margin="5,1,5,0" HorizontalAlignment="Left" Command="{Binding BatchConfig.EditCommand}" Padding="2" Height="30" Width="30" >
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.Click">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="rotateTransform2" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                            <TextBlock Text="&#xE713;"  HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" RenderTransformOrigin="0.5,0.5" FontSize="20" Foreground="{DynamicResource GlobalTextBrush}">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="rotateTransform2"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Button>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="{x:Static properties:Resources.UpdateProcessMeta}" Padding="8" Margin="0 0 0 8" Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center" Margin="0 0 4 0"><Run Text="{x:Static properties:Resources.FlowTemplate}"/><Run Text=":"/></TextBlock>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding templateModels}" DisplayMemberPath="Key" SelectedItem="{Binding UpdateTemplate}"/>

                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="12 0 4 0"><Run Text="{x:Static properties:Resources.ProcessClass}"/><Run Text=":"/></TextBlock>
                    <ComboBox Grid.Column="3" ItemsSource="{Binding Processes}" SelectedItem="{Binding UpdateProcess}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource TypeNameConverter}}" 
                                          ToolTip="{Binding Converter={StaticResource ProcessTooltipConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Grid.Column="4" Content="{x:Static properties:Resources.Update}" Margin="12 0 0 0" Padding="12 4" Command="{Binding UpdateMetaCommand}"/>
                </Grid>
            </GroupBox>

            <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0 0 0 8">
                <Button Content="{x:Static properties:Resources.DeleteSelected}" Padding="12 4" Command="{Binding RemoveMetaCommand}"/>
                <Button Content="{x:Static properties:Resources.MoveUp}" Padding="12 4" Margin="8 0 0 0" Command="{Binding MoveUpCommand}"/>
                <Button Content="{x:Static properties:Resources.MoveDown}" Padding="12 4" Margin="8 0 0 0" Command="{Binding MoveDownCommand}"/>
                <TextBlock Text="  ({x:Static properties:Resources.ProcessOrderHint})" VerticalAlignment="Center" Margin="12 0 0 0" Foreground="Gray"/>
            </StackPanel>

            <ListView Grid.Row="3" ItemsSource="{Binding ProcessMetas}" SelectedItem="{Binding SelectedProcessMeta}" x:Name="lvMetas" SelectionChanged="ListView_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{x:Static properties:Resources.SerialNumber1}" Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ExecutionOrder}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Name}" Width="100" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="{x:Static properties:Resources.FlowTemplate}" Width="120" DisplayMemberBinding="{Binding TemplateName}"/>
                        <GridViewColumn Header="{x:Static properties:Resources.ProcessClass}" Width="140" DisplayMemberBinding="{Binding ProcessDisplayName}"/>
                        <GridViewColumn Header="{x:Static properties:Resources.Tag_Column}" Width="80" DisplayMemberBinding="{Binding Tag}"/>
                        <GridViewColumn Header="{x:Static properties:Resources.Description}" Width="150" DisplayMemberBinding="{Binding ProcessDescription}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
        
        <!-- GridSplitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>
        
        <!-- Right Panel: Properties -->
        <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <Border Grid.Row="0" Background="{DynamicResource GlobalBorderBrush}" CornerRadius="4,4,0,0" Padding="12,8">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="&#xE713;" FontFamily="Segoe MDL2 Assets" 
                                Command="{Binding SelectedProcessMeta.EditConfigCommand}"
                                Visibility="{Binding SelectedProcessMeta.HasConfig, Converter={StaticResource BoolToVisibilityConverter}}"
                                ToolTip="{x:Static properties:Resources.EditConfigInWindow}"
                                Padding="6,4" Margin="8,0,0,0"/>
                        <TextBlock Text="{x:Static properties:Resources.PropertyConfig}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
                
                <!-- Properties Content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel x:Name="PropertyPanel">
                        <TextBlock Text="{x:Static properties:Resources.SelectProcessToViewConfig}" Foreground="Gray" HorizontalAlignment="Center" Margin="0,20,0,0"
                                   x:Name="PlaceholderText"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
