<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ColorVisionRepoRoot Condition="'$(ColorVisionRepoRoot)' == '' and '$(SolutionDir)' != '' and Exists('$(SolutionDir)ColorVision\ColorVision.csproj')">$(SolutionDir)</ColorVisionRepoRoot>
    <ColorVisionRepoRoot Condition="'$(ColorVisionRepoRoot)' == '' and '$(ColorVisionNativePropsDir)' != '' and Exists('$(ColorVisionNativePropsDir)..\ColorVision\ColorVision.csproj')">$(ColorVisionNativePropsDir)..\</ColorVisionRepoRoot>
    <ColorVisionRepoRoot Condition="'$(ColorVisionRepoRoot)' == '' and Exists('$(MSBuildProjectDirectory)\..\..\ColorVision\ColorVision.csproj')">$(MSBuildProjectDirectory)\..\..\</ColorVisionRepoRoot>
    <ColorVisionNativeAppTargetFramework Condition="'$(ColorVisionNativeAppTargetFramework)' == ''">net10.0-windows</ColorVisionNativeAppTargetFramework>
    <ColorVisionNativeAppOutputRoot>$(ColorVisionRepoRoot)ColorVision\bin\$(Platform)\$(Configuration)\$(ColorVisionNativeAppTargetFramework)\</ColorVisionNativeAppOutputRoot>
  </PropertyGroup>

  <Target Name="CopyColorVisionNativeToAppRoot" AfterTargets="Build" Condition="'$(Platform)' == 'x64' and '$(TargetPath)' != '' and Exists('$(TargetPath)')">
    <ItemGroup>
      <ColorVisionNativeRootFile Include="$(TargetPath)" />
    </ItemGroup>
    <MakeDir Directories="$(ColorVisionNativeAppOutputRoot)" />
    <Copy SourceFiles="@(ColorVisionNativeRootFile)" DestinationFolder="$(ColorVisionNativeAppOutputRoot)" SkipUnchangedFiles="true" Condition="'@(ColorVisionNativeRootFile)' != ''" />
  </Target>
</Project>
