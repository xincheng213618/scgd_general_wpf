<Window x:Class="ColorVision.UI.Desktop.Marketplace.PluginManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.UI.Desktop.Marketplace"
        xmlns:properties="clr-namespace:ColorVision.UI.Desktop.Properties"
        xmlns:hc ="https://handyorg.github.io/handycontrol"
        d:DataContext="{d:DesignInstance local:PluginManager}"
        xmlns:pl="clr-namespace:ColorVision.UI;assembly=ColorVision.UI"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Plugin Marketplace" Background="{DynamicResource GlobalBackground}" Height="720" Width="1280" Initialized="Window_Initialized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid>
                <StackPanel Margin="5,5,0,0">
                    <WrapPanel Margin="0,0,0,5">
                        <Button Command="{Binding InstallPackageCommand}" Margin="0,0,3,0" Padding="6,2" ToolTip="{x:Static properties:Resources.InstallPackage}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{x:Static properties:Resources.InstallPackage}" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenViewDllViersionCommand}" Margin="0,0,3,0" Padding="6,2" ToolTip="{x:Static properties:Resources.OpenViewDllViersion}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{x:Static properties:Resources.OpenViewDllViersion}" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RestartCommand}" Margin="0,0,3,0" Padding="6,2" ToolTip="{x:Static properties:Resources.Restart}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{x:Static properties:Resources.Restart}" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Click="RefreshVersionsButton_Click" Margin="0,0,3,0" Padding="6,2" ToolTip="{x:Static properties:Resources.Refresh}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{x:Static properties:Resources.Refresh}" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding UpdateAllCommand}" Margin="0,0,3,0" Padding="6,2" ToolTip="{x:Static properties:Resources.UpdateAll}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="{x:Static properties:Resources.UpdateAll}" VerticalAlignment="Center" FontSize="12"/>
                                <Border Background="#FF5252" CornerRadius="8" Padding="4,0" Margin="5,0,0,0" MinWidth="16" Visibility="{Binding UpdateAvailableCount, Converter={StaticResource int2VisibilityConverter}}">
                                    <TextBlock Text="{Binding UpdateAvailableCount}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Grid>
                            <hc:ComboBox x:Name="DefalutSearchComboBox" Width="250" Padding="25,1,2,1"   IsEditable="True" Text="{Binding SearchName, UpdateSourceTrigger=PropertyChanged}" BorderThickness="1" hc:InfoElement.Placeholder="{x:Static properties:Resources.Search}" hc:InfoElement.ShowClearButton="True" BorderBrush="#CCCEDB"   VerticalContentAlignment="Center" TextBoxBase.TextChanged="SearchComboBox_TextChanged" />
                            <Viewbox Width="20 " Height="20" HorizontalAlignment="Left" Margin="4,0,0,0">
                                <Rectangle Width="25 " Height="25" >
                                    <Rectangle.Resources>
                                        <SolidColorBrush x:Key="canvas" Opacity="0" />
                                        <SolidColorBrush x:Key="light-defaultgrey-10" Color="{DynamicResource defaultgreyColor}" Opacity=" 0.1" />
                                        <SolidColorBrush x:Key="light-defaultgrey" Color="{DynamicResource defaultgreyColor}" Opacity="1" />
                                    </Rectangle.Resources>
                                    <Rectangle.Fill>
                                        <DrawingBrush Stretch="None">
                                            <DrawingBrush.Drawing>
                                                <DrawingGroup>
                                                    <DrawingGroup x:Name="canvas">
                                                        <GeometryDrawing Brush="{DynamicResource canvas}" Geometry="F1M0,0H16V16H0Z" />
                                                    </DrawingGroup>
                                                    <DrawingGroup x:Name="level_1">
                                                        <GeometryDrawing Brush="{DynamicResource light-defaultgrey-10}" Geometry="F1M11.5,6.5a5,5,0,1,1-5-5A5,5,0,0,1,11.5,6.5Z" />
                                                        <GeometryDrawing Brush="{DynamicResource light-defaultgrey}" Geometry="F1M1,6.5a5.5,5.5,0,0,0,9.017,4.224l5.129,5.13.708-.708-5.13-5.129A5.5,5.5,0,1,0,1,6.5Zm1,0A4.5,4.5,0,1,1,6.5,11,4.505,4.505,0,0,1,2,6.5Z" />
                                                    </DrawingGroup>
                                                </DrawingGroup>
                                            </DrawingBrush.Drawing>
                                        </DrawingBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </Viewbox>
                        </Grid>
                        <Button Content="{x:Static properties:Resources.Install}" Command="{Binding DownloadPackageCommand}" Margin="5,0,5,0"/>
                        <Button  Command="{Binding EditConfigCommand}" Padding="2" Height="27" Width="27" >
                            <TextBlock Text="&#xE713;"  HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" RenderTransformOrigin="0.5,0.5"  FontSize="20" Foreground="{DynamicResource GlobalTextBrush}">
                                <TextBlock.RenderTransform>
                                    <RotateTransform x:Name="rotateTransform21"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="Button.Click">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="rotateTransform21" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>
                        </Button>
                    </StackPanel>


                </StackPanel>

            </Grid>

            <!-- Tabbed panel: Installed / Marketplace -->
            <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="5,0,5,5" SelectionChanged="MainTabControl_SelectionChanged">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static properties:Resources.Installed}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ListBox x:Name="ListViewPlugins" Background="Transparent" ItemsSource="{Binding Plugins}" SelectionChanged="ListViewPlugins_SelectionChanged" Padding="2">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}">
                                <Setter Property="ContextMenu" Value="{Binding ContextMenu}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,1,0,1"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#145A8DEE"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0A5A8DEE"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasUpdate}" Value="True">
                                        <Setter Property="BorderBrush" Value="#FFA726"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            
                            <DataTemplate DataType="{x:Type local:PluginInfoVM}">
                                <Border Padding="10,8" CornerRadius="6" Background="#08000000" BorderBrush="#12000000" BorderThickness="1" Margin="2,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                            <ui:ToggleSwitch IsChecked="{Binding PluginInfo.Enabled}" Margin="0,0,8,0"/>
                                            <Image Source="{Binding Icon}" Width="24" Height="24" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Name,Mode=OneWay}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource GlobalTextBrush}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}" Foreground="Gray" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Background="#1A2E7D32" CornerRadius="8" Padding="6,2" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding AssemblyVersion}" FontSize="10" Foreground="#2E7D32" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Background="#1A2E5CB8" CornerRadius="8" Padding="6,2" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding LastVersion}" FontSize="10" Foreground="#2E5CB8" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Background="#FFA726" CornerRadius="10" Width="20" Height="20" Margin="0,0,4,0" ToolTip="有可用更新" Visibility="{Binding HasUpdate, Converter={StaticResource bool2VisibilityConverter}}">
                                                <TextBlock Text="⬆" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                            </Border>
                                            <Button Content="{x:Static properties:Resources.Update}" Command="{Binding UpdateCommand}" Visibility="{Binding HasUpdate,Converter={StaticResource bool2VisibilityConverter}}" MinWidth="50" Padding="6,2"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{x:Static properties:Resources.Marketplace}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="MarketplaceStatus" Text="" Margin="5,2" FontStyle="Italic" Foreground="Gray"/>
                        <ListBox x:Name="ListViewMarketplace" Background="Transparent" Grid.Row="1" SelectionChanged="ListViewMarketplace_SelectionChanged" Padding="2">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,1,0,1"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#145A8DEE"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#0A5A8DEE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" CornerRadius="6" Background="#08000000" BorderBrush="#12000000" BorderThickness="1" Margin="2,2">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                            <Border Grid.Row="0" Grid.Column="1" Margin="8,0,0,0"
                                                    Background="#1A5A8DEE" CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding LatestVersion, StringFormat=v{0}}"
                                                           Foreground="#2E5CB8" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>

                                            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,4,0,0"
                                                       Text="{Binding Description}" Foreground="Gray" FontSize="11"
                                                       MaxHeight="34" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>

                                            <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,6,0,0">
                                                <Border Background="#1A888888" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="9" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="#666"/>
                                                        <TextBlock Text="{Binding Author}" FontSize="10" Foreground="#666"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="#1A5A8DEE" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="9" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="#2E5CB8"/>
                                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#2E5CB8"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border Background="#1A43A047" CornerRadius="4" Padding="6,2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="9" VerticalAlignment="Center" Margin="0,0,3,0" Foreground="#2E7D32"/>
                                                        <TextBlock Text="{Binding TotalDownloads}" FontSize="10" Foreground="#2E7D32"/>
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <Border x:Name="BorderContent" CornerRadius="5" Margin="0,0,5,5" d:DataContext="{d:DesignInstance local:PluginInfoVM}" Grid.Column="1">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1 " Margin="0,0,0,2">
                    <Grid>
                        <DockPanel>
                            <Border Width="68" Height="68" Margin="10" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="#0D000000">
                                <Image Source="{Binding Icon}" Width="50" Height="50" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent" Text="{Binding Name}" FontWeight="Bold" FontSize="20"  />
                                <StackPanel Orientation="Horizontal">
                                    <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent" Text="{Binding HeaderMetaText,Mode=OneWay}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Border Background="#2E7D32" CornerRadius="10" Padding="8,2" Margin="0,0,6,0" Visibility="{Binding InstalledBadgeVisibility,Mode=OneWay}">
                                        <TextBlock Text="{Binding InstalledBadgeText,Mode=OneWay}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Background="#F57C00" CornerRadius="10" Padding="8,2" Margin="0,0,6,0" Visibility="{Binding UpdateBadgeVisibility ,Mode=OneWay}">
                                        <TextBlock Text="{Binding UpdateBadgeText,Mode=OneWay}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="Gray" MaxWidth="620" Margin="2,2,0,0" />
                            </StackPanel>
                        </DockPanel>
                        <StackPanel  HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent" Text="{Binding HeaderRightPrimary,Mode=OneWay}" HorizontalAlignment="Right" Padding="3"/>
                            <StackPanel Orientation="Horizontal"  HorizontalAlignment="Right">
                                <TextBox IsReadOnly="True" BorderThickness="0" Background="Transparent" Text="{Binding HeaderRightSecondary,Mode=OneWay}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="OpenLocalPath" Background="Transparent" BorderThickness="0" Command="{Binding OpenLocalPathCommand}" Margin="0,0,5,0" Visibility="{Binding OpenLocalPathVisibility, FallbackValue=Visible}"/>
                                <Button Content="{x:Static properties:Resources.ExtractPlugin}" Background="Transparent" BorderThickness="0" Command="{Binding ExtractPluginCommand}" Margin="0,0,5,0" Visibility="{Binding ExtractPluginVisibility, FallbackValue=Visible}"/>
                                <Button Content="{Binding PrimaryActionText, FallbackValue={x:Static properties:Resources.Install}}" Background="Transparent" BorderThickness="0" Command="{Binding InstallCommand}" Margin="0,0,5,0" Visibility="{Binding PrimaryActionVisibility, FallbackValue=Collapsed}"/>
                                <Button Content="{x:Static properties:Resources.Download}" Background="Transparent" BorderThickness="0" Command="{Binding DownloadCommand}" Margin="0,0,5,0" Visibility="{Binding DownloadLatestVisibility, FallbackValue=Collapsed}"/>
                                <Button Content="OpenUrl" Background="Transparent" BorderThickness="0" Command="{Binding OpenProjectUrlCommand}" Visibility="{Binding OpenProjectUrlVisibility, FallbackValue=Collapsed}"/>
                            </StackPanel>

                        </StackPanel>
                    </Grid>

                </Border>
                <TabControl x:Name="TabControl1" Grid.Row="1" SelectionChanged="TabControl_SelectionChanged">
                    <TabItem Header="README">
                        <wv2:WebView2 Name="webViewReadMe"  Grid.Row="1" />
                    </TabItem>
                    <TabItem Header="CHANGELOG" > 
                        <wv2:WebView2 Name="webViewChangeLog"  Grid.Row="1" />
                    </TabItem>
                    <TabItem Header="DetailInfo">
                        <ScrollViewer>
                            <StackPanel  x:Name="DetailInfo">
                                
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Dependents">
                        <ScrollViewer>
                            <StackPanel  x:Name="Dependents">
                                <ListView  x:Name="DependentsListView">
                                    <ListView.View>
                                        <GridView >
                                            <GridViewColumn Header="Package">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate >
                                                        <TextBlock  Text="{Binding Key}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Version">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate >
                                                        <TextBlock  Text="{Binding Value}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
  
                
            </Grid>
        </Border>

    </Grid>

</Window>
