<Window x:Class="ColorVision.UI.Desktop.ThirdPartyApps.Treemap.TreemapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ColorVision.UI.Controls;assembly=ColorVision.UI"
        xmlns:properties="clr-namespace:ColorVision.UI.Properties;assembly=ColorVision.UI"
        Title="{x:Static properties:Resources.Treemap_Title}"
        Width="1100" Height="720"
        MinWidth="500" MinHeight="400">
    <DockPanel>
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Height="36" Padding="2,0">

            <!-- Drive selection -->
            <TextBlock VerticalAlignment="Center" Margin="4,0,2,0" Text="{x:Static properties:Resources.Treemap_DriveLabel}"/>
            <ComboBox x:Name="CmbDrives" Width="72" VerticalAlignment="Center"
                      SelectionChanged="CmbDrives_SelectionChanged"
                      DisplayMemberPath="Name" Margin="0,0,4,0"/>

            <!-- Manual path browse -->
            <Button x:Name="BtnBrowse" Content="{x:Static properties:Resources.Treemap_BrowseDirectory}" Padding="8,3"
                    Click="BtnBrowse_Click" ToolTip="{x:Static properties:Resources.Treemap_BrowseDirectoryTooltip}"/>

            <!-- Current path display -->
            <TextBlock x:Name="TxtPath" VerticalAlignment="Center"
                       Margin="6,0" FontSize="11" Foreground="#ccc"
                       MaxWidth="320" TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

            <Separator/>

            <!-- Scan / cancel -->
            <Button x:Name="BtnScan" Content="{x:Static properties:Resources.Treemap_Scan}" Padding="10,3"
                    Click="BtnScan_Click" IsEnabled="False"
                    ToolTip="{x:Static properties:Resources.Treemap_ScanTooltip}"/>
            <Button x:Name="BtnCancel" Content="{x:Static properties:Resources.Treemap_Cancel}" Padding="8,3"
                    Click="BtnCancel_Click" IsEnabled="False"
                    ToolTip="{x:Static properties:Resources.Treemap_CancelTooltip}"/>

            <Separator/>

            <!-- Save / Load scan results -->
            <Button x:Name="BtnSave" Content="{x:Static properties:Resources.Treemap_Save}" Padding="8,3"
                    Click="BtnSave_Click" IsEnabled="False"
                    ToolTip="{x:Static properties:Resources.Treemap_SaveTooltip}"/>
            <Button x:Name="BtnLoad" Content="{x:Static properties:Resources.Treemap_Load}" Padding="8,3"
                    Click="BtnLoad_Click"
                    ToolTip="{x:Static properties:Resources.Treemap_LoadTooltip}"/>

            <Separator/>

            <!-- Navigation -->
            <Button x:Name="BtnUp" Content="{x:Static properties:Resources.Treemap_Up}" Padding="8,3"
                    Click="BtnUp_Click" IsEnabled="False"
                    ToolTip="{x:Static properties:Resources.Treemap_UpTooltip}"/>

            <Separator/>

            <!-- Labels toggle -->
            <CheckBox x:Name="ChkLabels" Content="{x:Static properties:Resources.Treemap_ShowLabels}" IsChecked="True"
                      Checked="ChkLabels_Changed" Unchecked="ChkLabels_Changed"
                      VerticalAlignment="Center" Margin="4,0"/>

            <Separator/>

            <!-- Node count -->
            <TextBlock VerticalAlignment="Center" Text="{x:Static properties:Resources.Treemap_NodeCount}" Margin="4,0,0,0"/>
            <TextBlock x:Name="TxtNodeCount" VerticalAlignment="Center" MinWidth="50"
                       Margin="0,0,4,0"/>
        </ToolBar>

        <!-- Scan progress -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Height="20"
                    Background="#1a1a1a">
            <ProgressBar x:Name="ProgressBar" Width="200" Height="8"
                         VerticalAlignment="Center" Margin="8,0"
                         IsIndeterminate="True" Visibility="Collapsed"/>
            <TextBlock x:Name="TxtProgress" VerticalAlignment="Center"
                       Foreground="#aaa" FontSize="11" Margin="4,0"/>
        </StackPanel>

        <!-- Treemap canvas -->
        <Border Background="#1e1e1e" Padding="4">
            <local:TreemapControl x:Name="TreemapCtrl" ShowLabels="True"
                                  NodeRightClicked="TreemapCtrl_NodeRightClicked"
                                  NodeClicked="TreemapCtrl_NodeClicked"/>
        </Border>
    </DockPanel>
</Window>
