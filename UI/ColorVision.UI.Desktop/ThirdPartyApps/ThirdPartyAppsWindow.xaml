<Window x:Class="ColorVision.UI.Desktop.ThirdPartyApps.ThirdPartyAppsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.UI.Desktop.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.ThirdPartyApps}" Height="760" Width="1280"
        MinHeight="620" MinWidth="980"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6F8"
        Initialized="Window_Initialized"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <SolidColorBrush x:Key="LauncherWindowBackgroundBrush" Color="#F5F6F8"/>
        <SolidColorBrush x:Key="LauncherPanelBrush" Color="#FBFBFC"/>
        <SolidColorBrush x:Key="LauncherSurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LauncherSoftBrush" Color="#F0F1F4"/>
        <SolidColorBrush x:Key="LauncherHoverBrush" Color="#F4F5F7"/>
        <SolidColorBrush x:Key="LauncherBorderBrush" Color="#E5E7EC"/>
        <SolidColorBrush x:Key="LauncherStrongBorderBrush" Color="#D4DAE4"/>
        <SolidColorBrush x:Key="LauncherTextBrush" Color="#17191D"/>
        <SolidColorBrush x:Key="LauncherMutedTextBrush" Color="#777D88"/>
        <SolidColorBrush x:Key="LauncherFaintTextBrush" Color="#A7ADB6"/>
        <SolidColorBrush x:Key="LauncherWarningBrush" Color="#FFB020"/>

        <DropShadowEffect x:Key="LauncherPanelShadow"
                          BlurRadius="28"
                          ShadowDepth="8"
                          Direction="270"
                          Opacity="0.10"
                          Color="#1C2430"/>

        <Style x:Key="SidebarPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource LauncherPanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LauncherBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Effect" Value="{StaticResource LauncherPanelShadow}"/>
        </Style>

        <Style x:Key="IconRoundButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource LauncherTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="19">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource LauncherHoverBrush}"/>
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource LauncherBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#E8EBF1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ActionChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ActionChrome" Property="Background" Value="{StaticResource LauncherHoverBrush}"/>
                                <Setter TargetName="ActionChrome" Property="BorderBrush" Value="{StaticResource LauncherBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ActionChrome" Property="Background" Value="#E9ECF2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource LauncherMutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CategoryTabItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="TabChrome"
                                Padding="0,8,0,9"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TabText"
                                           Text="{Binding DisplayName}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource LauncherMutedTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding DisplayName}"/>
                                <Border x:Name="TabCountBadge"
                                        Height="18"
                                        MinWidth="22"
                                        Margin="7,1,0,0"
                                        Padding="6,0"
                                        CornerRadius="9"
                                        Background="#EEF0F4">
                                    <TextBlock Text="{Binding Count}"
                                               FontSize="11"
                                               Foreground="{StaticResource LauncherMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabText" Property="Foreground" Value="{StaticResource LauncherTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="TabText" Property="Foreground" Value="{StaticResource LauncherTextBrush}"/>
                                <Setter TargetName="TabCountBadge" Property="Background" Value="#E9F0FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppTileItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="TileChrome"
                                Width="118"
                                Height="132"
                                Margin="8,8,8,14"
                                Padding="8"
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="Transparent"
                                Background="Transparent"
                                Cursor="Hand">
                            <Grid ToolTip="{Binding Name}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Grid Width="64" Height="64" Margin="0,2,0,10">
                                        <Border x:Name="IconFallback"
                                                Width="56"
                                                Height="56"
                                                CornerRadius="14"
                                                Background="{StaticResource LauncherSurfaceBrush}"
                                                BorderBrush="{StaticResource LauncherBorderBrush}"
                                                BorderThickness="1"
                                                Visibility="Collapsed"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="&#xE71D;"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="24"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <Image x:Name="AppIcon"
                                               Source="{Binding IconSource}"
                                               Width="56"
                                               Height="56"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                        <Border x:Name="UnavailableDot"
                                                Width="13"
                                                Height="13"
                                                CornerRadius="7"
                                                Background="{StaticResource LauncherWarningBrush}"
                                                BorderBrush="{StaticResource LauncherPanelBrush}"
                                                BorderThickness="2"
                                                Visibility="Collapsed"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,5,5"/>
                                    </Grid>

                                    <TextBlock x:Name="AppNameText"
                                               Text="{Binding Name}"
                                               Width="102"
                                               MaxHeight="42"
                                               FontSize="13"
                                               LineHeight="18"
                                               Foreground="{StaticResource LauncherTextBrush}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                <Setter TargetName="AppIcon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="IconFallback" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                <Setter TargetName="UnavailableDot" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="AppIcon" Property="Opacity" Value="0.52"/>
                                <Setter TargetName="IconFallback" Property="Opacity" Value="0.62"/>
                                <Setter TargetName="AppNameText" Property="Foreground" Value="{StaticResource LauncherMutedTextBrush}"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileChrome" Property="Background" Value="{StaticResource LauncherSurfaceBrush}"/>
                                <Setter TargetName="TileChrome" Property="BorderBrush" Value="{StaticResource LauncherBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TileChrome" Property="Background" Value="{StaticResource LauncherSurfaceBrush}"/>
                                <Setter TargetName="TileChrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="188"/>
            <ColumnDefinition Width="28"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource SidebarPanelStyle}" Padding="18,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="ColorVision"
                               FontSize="23"
                               FontWeight="Bold"
                               Foreground="{StaticResource LauncherTextBrush}"/>
                    <TextBlock Text="{x:Static properties:Resources.ThirdPartyApps}"
                               Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="{StaticResource LauncherMutedTextBrush}"/>
                    <TextBlock x:Name="AppCountText"
                               Margin="0,3,0,0"
                               FontSize="12"
                               Foreground="{StaticResource LauncherFaintTextBrush}"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Height="40"
                        Margin="0,24,0,0"
                        CornerRadius="10"
                        Background="{StaticResource LauncherSurfaceBrush}"
                        BorderBrush="{StaticResource LauncherBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="38"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   Foreground="{StaticResource LauncherMutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Grid Grid.Column="1">
                            <TextBlock Text="{x:Static properties:Resources.Search}"
                                       Margin="0,0,8,0"
                                       FontSize="12"
                                       Foreground="{StaticResource LauncherFaintTextBrush}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="SearchBox"
                                     Margin="0,0,10,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{StaticResource LauncherTextBrush}"
                                     CaretBrush="{StaticResource LauncherTextBrush}"
                                     VerticalContentAlignment="Center"
                                     FontSize="13"
                                     TextChanged="SearchBox_TextChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2"
                           Text="{x:Static properties:Resources.CustomApp_QuickActions}"
                           Margin="0,26,0,10"
                           Style="{StaticResource SectionLabelStyle}"/>

                <StackPanel Grid.Row="3">
                    <Button x:Name="BtnAddScript"
                            Style="{StaticResource SidebarActionButtonStyle}"
                            Click="BtnAddScript_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE756;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Foreground="{StaticResource LauncherTextBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Static properties:Resources.ThirdPartyAppsAddQuickScript}"
                                       FontSize="13"
                                       Foreground="{StaticResource LauncherTextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Button>

                    <Button x:Name="BtnRefresh"
                            Style="{StaticResource SidebarActionButtonStyle}"
                            Click="BtnRefresh_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE72C;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Foreground="{StaticResource LauncherTextBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Static properties:Resources.Refresh}"
                                       FontSize="13"
                                       Foreground="{StaticResource LauncherTextBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <Border Grid.Row="5"
                        Height="38"
                        CornerRadius="12"
                        Background="{StaticResource LauncherSurfaceBrush}"
                        BorderBrush="{StaticResource LauncherBorderBrush}"
                        BorderThickness="1"
                        Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{DynamicResource PrimaryBrush}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{x:Static properties:Resources.ThirdPartyApps}"
                                   FontSize="12"
                                   Foreground="{StaticResource LauncherMutedTextBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="&#xE72B;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           Foreground="{StaticResource LauncherFaintTextBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <Border Grid.Column="1"
                        MinWidth="176"
                        Height="38"
                        CornerRadius="19"
                        Background="{StaticResource LauncherSurfaceBrush}"
                        BorderBrush="{StaticResource LauncherBorderBrush}"
                        BorderThickness="1"
                        Padding="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE71D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock x:Name="CurrentGroupText"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource LauncherTextBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Button x:Name="BtnAddApp"
                        Grid.Column="2"
                        Style="{StaticResource IconRoundButtonStyle}"
                        Content="&#xE710;"
                        Click="BtnAddApp_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,26,0,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="GroupsLabelText"
                           Style="{StaticResource SectionLabelStyle}"
                           Margin="0,0,0,6"/>

                <ListBox x:Name="GroupListBox"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource CategoryTabItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         SelectionChanged="GroupListBox_SelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Grid>

            <ListBox x:Name="AppsListBox"
                     Grid.Row="2"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0"
                     ItemContainerStyle="{StaticResource AppTileItemStyle}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MouseDoubleClick="AppsListBox_MouseDoubleClick"
                     PreviewMouseRightButtonUp="AppsListBox_PreviewMouseRightButtonUp">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
        </Grid>
    </Grid>
</Window>
