<Window x:Class="ColorVision.UI.Desktop.Settings.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.UI.Properties;assembly=ColorVision.UI"
        mc:Ignorable="d"
        Height="720" Width="1180" MinHeight="620" MinWidth="980"
        Title="{x:Static properties:Resources.Options}"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource GlobalBorderBrush1}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource TextBox.Small}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
        </Style>

        <Style x:Key="SettingsEditorComboBoxStyle" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource ComboBoxBaseStyle}">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource GlobalBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource SettingsEditorComboBoxStyle}">
            <Setter Property="Width" Value="220"/>
        </Style>

        <Style x:Key="SettingsSearchTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource TextBox.Small}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource GlobalBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
        </Style>

        <Style x:Key="SettingsNavigationListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="SettingsNavigationItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource GlobalBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource GlobalBackground}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource GlobalBorderBrush1}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="272" MinWidth="248"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource GlobalBorderBrush1}">
            <Grid Margin="22,24,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{x:Static properties:Resources.Options}"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           TextTrimming="CharacterEllipsis"/>

                <Grid Grid.Row="1" Margin="0,22,0,18">
                    <TextBox x:Name="SearchTextBox"
                             Style="{StaticResource SettingsSearchTextBoxStyle}"
                             TextChanged="SearchTextBox_TextChanged"
                             ToolTip="{x:Static properties:Resources.SearchSettingsTitle}"/>
                    <TextBlock Margin="13,0,8,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"
                               FontSize="12"
                               Opacity="0.58"
                               Foreground="{DynamicResource GlobalTextBrush}"
                               Text="{x:Static properties:Resources.Search}">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <ListBox x:Name="NavigationListBox"
                         Grid.Row="2"
                         Style="{StaticResource SettingsNavigationListBoxStyle}"
                         ItemContainerStyle="{StaticResource SettingsNavigationItemStyle}"
                         SelectionChanged="NavigationListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           Opacity="0.82"
                                           Text="{Binding IconGlyph}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource GlobalTextBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource GlobalTextBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="12"
                Background="{DynamicResource ButtonBackground}"
                BorderBrush="{DynamicResource GlobalBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="44,32,44,10">
                    <TextBlock x:Name="CurrentGroupTitle"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource GlobalTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="CurrentGroupDescription"
                               Margin="0,10,0,0"
                               FontSize="13"
                               Opacity="0.68"
                               Foreground="{DynamicResource GlobalTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Grid HorizontalAlignment="Stretch"
                          MaxWidth="1280"
                          Margin="44,18,44,34">
                        <StackPanel x:Name="SettingsContentPanel"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
