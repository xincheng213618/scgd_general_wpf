<UserControl x:Class="ColorVision.UI.Desktop.LanRemote.LanRemoteControlSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="420">
    <StackPanel HorizontalAlignment="Stretch">
        <Border CornerRadius="8"
                BorderThickness="1"
                Padding="24"
                Background="{DynamicResource GlobalBackground}"
                BorderBrush="{DynamicResource ButtonBorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,28,0">
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="现场运维伴侣"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource GlobalTextBrush}"/>
                            <TextBlock Text="启用后，通过短时二维码与设备密钥安全配对；高风险操作仍需桌面确认。"
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Opacity="0.68"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource GlobalTextBrush}"/>
                        </StackPanel>
                        <CheckBox x:Name="EnableCheckBox"
                                  Grid.Column="1"
                                  Content="启用"
                                  VerticalAlignment="Center"
                                  Checked="EnableCheckBox_Changed"
                                  Unchecked="EnableCheckBox_Changed"/>
                    </Grid>

                    <Border CornerRadius="8"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,18"
                            Background="{DynamicResource GlobalBackground}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="132"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,16,0">
                                <TextBlock Text="1. 手机先安装 ColorVision 移动版"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource GlobalTextBrush}"/>
                                <TextBlock Text="没有安装 App 的手机，先扫描右侧下载二维码；安装完成后，再用 App 扫描连接二维码。"
                                           Margin="0,6,0,10"
                                           FontSize="12"
                                           Opacity="0.68"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource GlobalTextBrush}"/>
                                <TextBox x:Name="AppDownloadUrlTextBox"
                                         IsReadOnly="True"
                                         MinHeight="30"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Center"/>
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Padding="12,5"
                                            Content="打开下载页"
                                            Click="OpenAppDownloadPageButton_Click"/>
                                    <Button Margin="8,0,0,0"
                                            Padding="12,5"
                                            Content="复制下载地址"
                                            Click="CopyAppDownloadUrlButton_Click"/>
                                </WrapPanel>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Width="124"
                                    Height="124"
                                    CornerRadius="8"
                                    Padding="6"
                                    Background="White"
                                    BorderBrush="#D7DEE8"
                                    BorderThickness="1">
                                <Image x:Name="AppDownloadQrImage"
                                       Stretch="Uniform"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="监听端口"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource GlobalTextBrush}"/>
                        <TextBox x:Name="PortTextBox"
                                 Grid.Column="1"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 LostFocus="PortTextBox_LostFocus"
                                 KeyDown="PortTextBox_KeyDown"/>
                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                Padding="14,5"
                                Content="应用"
                                Click="ApplyPortButton_Click"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="安全 HTTPS 端口"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource GlobalTextBrush}"/>
                        <TextBlock x:Name="SecurePortTextBlock"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource GlobalTextBrush}"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="二维码地址"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource GlobalTextBrush}"/>
                        <ComboBox x:Name="IpAddressComboBox"
                                  Grid.Column="1"
                                  Height="32"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="IpAddressComboBox_SelectionChanged"/>
                    </Grid>

                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,2,0,14"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource GlobalTextBrush}"/>

                    <TextBlock Text="安全运维地址"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <TextBlock Text="2. 用移动版扫描右侧短时配对码，再在下方批准这台设备。配对码两分钟失效且只能提交一次。"
                               Margin="0,0,0,6"
                               FontSize="12"
                               Opacity="0.68"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <TextBox x:Name="ConnectionUrlTextBox"
                             IsReadOnly="True"
                             MinHeight="34"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"/>

                    <WrapPanel Margin="0,14,0,0">
                        <Button Padding="14,6"
                                Content="复制安全地址"
                                Click="CopyUrlButton_Click"/>
                        <Button Margin="8,0,0,0"
                                Padding="14,6"
                                Content="刷新状态"
                                Click="RefreshButton_Click"/>
                        <Button Margin="8,0,0,0"
                                Padding="14,6"
                                Content="刷新配对码"
                                Click="ResetTokenButton_Click"/>
                    </WrapPanel>

                    <TextBlock x:Name="IpListTextBlock"
                               Margin="0,18,0,0"
                               FontSize="12"
                               Opacity="0.68"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right">
                    <Border x:Name="QrCard"
                            Width="240"
                            Height="240"
                            CornerRadius="8"
                            Padding="10"
                            Background="White"
                            BorderBrush="#D7DEE8"
                            BorderThickness="1">
                        <Image x:Name="QrImage"
                               Stretch="Uniform"/>
                    </Border>
                    <Border Margin="0,12,0,0"
                            CornerRadius="999"
                            Padding="10,5"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource ButtonBackground}">
                        <TextBlock x:Name="ServiceStateTextBlock"
                                   FontSize="12"
                                   Foreground="{DynamicResource GlobalTextBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" CornerRadius="8" BorderThickness="1" Padding="16"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" Background="{DynamicResource GlobalBackground}">
                <StackPanel>
                    <TextBlock Text="待批准设备" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <TextBlock Text="核对手机显示的设备名称后再批准。未批准设备不能读取任何运维数据。"
                               Margin="0,5,0,10" FontSize="12" Opacity="0.68" TextWrapping="Wrap"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <ListBox x:Name="PendingDevicesListBox" MinHeight="64">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DeviceId}" FontSize="11" Opacity="0.65"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <WrapPanel Margin="0,10,0,0">
                        <Button Padding="12,5" Content="批准只读运维权限" Click="ApproveDeviceButton_Click"/>
                        <Button Margin="8,0,0,0" Padding="12,5" Content="拒绝" Click="RejectDeviceButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" CornerRadius="8" BorderThickness="1" Padding="16"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" Background="{DynamicResource GlobalBackground}">
                <StackPanel>
                    <TextBlock Text="已配对设备" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <TextBlock Text="撤销后，该设备的所有签名请求会立即失效。"
                               Margin="0,5,0,10" FontSize="12" Opacity="0.68"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <ListBox x:Name="PairedDevicesListBox" MinHeight="64">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DeviceId}" FontSize="11" Opacity="0.65"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Margin="0,10,0,0" HorizontalAlignment="Left" Padding="12,5"
                            Content="撤销所选设备" Click="RevokeDeviceButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
        <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" CornerRadius="8" BorderThickness="1" Padding="16"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" Background="{DynamicResource GlobalBackground}">
                <StackPanel>
                    <TextBlock Text="等待本机共签的作业" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <TextBlock Text="移动端批准只记录意图；必须在本机再次确认。特权作业还需通过 ServiceHost 票据闸门。"
                               Margin="0,5,0,10" FontSize="12" Opacity="0.68" TextWrapping="Wrap"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <ListBox x:Name="LocalCoSignJobsListBox" MinHeight="72">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding CapabilityId}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Reason}" FontSize="11" Opacity="0.65" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <WrapPanel Margin="0,10,0,0">
                        <Button Padding="12,5" Content="本机确认" Click="LocalCoSignJobButton_Click"/>
                        <Button Margin="8,0,0,0" Padding="12,5" Content="本机拒绝" Click="LocalRejectJobButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" CornerRadius="8" BorderThickness="1" Padding="16"
                    BorderBrush="{DynamicResource ButtonBorderBrush}" Background="{DynamicResource GlobalBackground}">
                <StackPanel>
                    <TextBlock Text="远程支持请求" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <TextBlock Text="仅允许诊断或引导模式，最长 30 分钟；不开放任意远程桌面或命令。"
                               Margin="0,5,0,10" FontSize="12" Opacity="0.68" TextWrapping="Wrap"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <ListBox x:Name="SupportRequestsListBox" MinHeight="72">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Mode}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Reason}" FontSize="11" Opacity="0.65" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <WrapPanel Margin="0,10,0,0">
                        <Button Padding="12,5" Content="允许限时支持" Click="ConsentSupportButton_Click"/>
                        <Button Margin="8,0,0,0" Padding="12,5" Content="拒绝" Click="RejectSupportButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
