<UserControl x:Class="ColorVision.UI.Desktop.LanRemote.LanRemoteControlSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="420">
    <StackPanel HorizontalAlignment="Stretch">
        <Border CornerRadius="8"
                BorderThickness="1"
                Padding="24"
                Background="{DynamicResource GlobalBackground}"
                BorderBrush="{DynamicResource ButtonBorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,0,28,0">
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="局域网控制"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource GlobalTextBrush}"/>
                            <TextBlock Text="启用后，手机扫描二维码即可连接这台电脑上的 ColorVision。"
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Opacity="0.68"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource GlobalTextBrush}"/>
                        </StackPanel>
                        <CheckBox x:Name="EnableCheckBox"
                                  Grid.Column="1"
                                  Content="启用"
                                  VerticalAlignment="Center"
                                  Checked="EnableCheckBox_Changed"
                                  Unchecked="EnableCheckBox_Changed"/>
                    </Grid>

                    <Border CornerRadius="8"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,18"
                            Background="{DynamicResource GlobalBackground}"
                            BorderBrush="{DynamicResource ButtonBorderBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="132"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,16,0">
                                <TextBlock Text="1. 手机先安装 ColorVision 移动版"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource GlobalTextBrush}"/>
                                <TextBlock Text="没有安装 App 的手机，先扫描右侧下载二维码；安装完成后，再用 App 扫描连接二维码。"
                                           Margin="0,6,0,10"
                                           FontSize="12"
                                           Opacity="0.68"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource GlobalTextBrush}"/>
                                <TextBox x:Name="AppDownloadUrlTextBox"
                                         IsReadOnly="True"
                                         MinHeight="30"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Center"/>
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Padding="12,5"
                                            Content="打开下载页"
                                            Click="OpenAppDownloadPageButton_Click"/>
                                    <Button Margin="8,0,0,0"
                                            Padding="12,5"
                                            Content="复制下载地址"
                                            Click="CopyAppDownloadUrlButton_Click"/>
                                </WrapPanel>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Width="124"
                                    Height="124"
                                    CornerRadius="8"
                                    Padding="6"
                                    Background="White"
                                    BorderBrush="#D7DEE8"
                                    BorderThickness="1">
                                <Image x:Name="AppDownloadQrImage"
                                       Stretch="Uniform"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="监听端口"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource GlobalTextBrush}"/>
                        <TextBox x:Name="PortTextBox"
                                 Grid.Column="1"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 LostFocus="PortTextBox_LostFocus"
                                 KeyDown="PortTextBox_KeyDown"/>
                        <Button Grid.Column="2"
                                Margin="10,0,0,0"
                                Padding="14,5"
                                Content="应用"
                                Click="ApplyPortButton_Click"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="二维码地址"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource GlobalTextBrush}"/>
                        <ComboBox x:Name="IpAddressComboBox"
                                  Grid.Column="1"
                                  Height="32"
                                  VerticalContentAlignment="Center"
                                  SelectionChanged="IpAddressComboBox_SelectionChanged"/>
                    </Grid>

                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,2,0,14"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource GlobalTextBrush}"/>

                    <TextBlock Text="连接地址"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <TextBlock Text="2. 安装完成后，用移动版扫描右侧二维码连接这台电脑。"
                               Margin="0,0,0,6"
                               FontSize="12"
                               Opacity="0.68"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                    <TextBox x:Name="ConnectionUrlTextBox"
                             IsReadOnly="True"
                             MinHeight="34"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Center"/>

                    <WrapPanel Margin="0,14,0,0">
                        <Button Padding="14,6"
                                Content="复制地址"
                                Click="CopyUrlButton_Click"/>
                        <Button Margin="8,0,0,0"
                                Padding="14,6"
                                Content="刷新"
                                Click="RefreshButton_Click"/>
                        <Button Margin="8,0,0,0"
                                Padding="14,6"
                                Content="重置二维码"
                                Click="ResetTokenButton_Click"/>
                    </WrapPanel>

                    <TextBlock x:Name="IpListTextBlock"
                               Margin="0,18,0,0"
                               FontSize="12"
                               Opacity="0.68"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource GlobalTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right">
                    <Border x:Name="QrCard"
                            Width="240"
                            Height="240"
                            CornerRadius="8"
                            Padding="10"
                            Background="White"
                            BorderBrush="#D7DEE8"
                            BorderThickness="1">
                        <Image x:Name="QrImage"
                               Stretch="Uniform"/>
                    </Border>
                    <Border Margin="0,12,0,0"
                            CornerRadius="999"
                            Padding="10,5"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource ButtonBackground}">
                        <TextBlock x:Name="ServiceStateTextBlock"
                                   FontSize="12"
                                   Foreground="{DynamicResource GlobalTextBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
