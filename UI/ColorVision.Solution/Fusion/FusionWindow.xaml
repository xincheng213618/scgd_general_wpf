<Window x:Class="ColorVision.Solution.Fusion.FusionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="景深融合 (Fusion)" Height="620" Width="780" 
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="景深融合" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- File List -->
        <GroupBox Grid.Row="1" Header="图像文件列表（按顺序排列）" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ListBox x:Name="FileListBox" Grid.Column="0" AllowDrop="True" 
                         Drop="FileListBox_Drop" DragOver="FileListBox_DragOver"
                         SelectionMode="Extended">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" ToolTip="{Binding}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center">
                    <Button Content="添加文件" Width="80" Height="28" Margin="0,2" Click="AddFiles_Click"/>
                    <Button Content="移除选中" Width="80" Height="28" Margin="0,2" Click="RemoveSelected_Click"/>
                    <Button Content="清空" Width="80" Height="28" Margin="0,2" Click="ClearAll_Click"/>
                    <Button Content="上移 ↑" Width="80" Height="28" Margin="0,10,0,2" Click="MoveUp_Click"/>
                    <Button Content="下移 ↓" Width="80" Height="28" Margin="0,2" Click="MoveDown_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Configuration -->
        <GroupBox Grid.Row="2" Header="融合配置" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="计算模式：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="ComboBoxMode" Width="200" SelectedIndex="0">
                    <ComboBoxItem Content="自动 (CUDA可用时使用GPU)"/>
                    <ComboBoxItem Content="CPU (OpenCV)"/>
                    <ComboBoxItem Content="GPU (CUDA)"/>
                    <ComboBoxItem Content="GPU 异步 (CUDA Async)"/>
                </ComboBox>
                <TextBlock x:Name="TextBlockCudaStatus" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Timing Statistics -->
        <GroupBox Grid.Row="3" Header="性能统计" Margin="0,0,0,10">
            <Grid Margin="5,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ListView x:Name="TimingListView" Grid.Column="0" MaxHeight="110" FontSize="12"
                          BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="模式" Width="140" DisplayMemberBinding="{Binding Mode}"/>
                            <GridViewColumn Header="加载(ms)" Width="80" DisplayMemberBinding="{Binding LoadMs}"/>
                            <GridViewColumn Header="融合(ms)" Width="80" DisplayMemberBinding="{Binding FusionMs}"/>
                            <GridViewColumn Header="转换(ms)" Width="80" DisplayMemberBinding="{Binding ConvertMs}"/>
                            <GridViewColumn Header="总计(ms)" Width="80" DisplayMemberBinding="{Binding TotalMs}"/>
                            <GridViewColumn Header="图像数" Width="55" DisplayMemberBinding="{Binding ImageCount}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <Button Grid.Column="1" Content="清除" Width="50" Height="24" VerticalAlignment="Top"
                        Margin="5,0,0,0" Click="ClearTiming_Click"/>
            </Grid>
        </GroupBox>

        <!-- Actions -->
        <DockPanel Grid.Row="4" LastChildFill="False">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Content="取消" Width="80" Height="30" DockPanel.Dock="Right" Margin="5,0,0,0" Click="Cancel_Click"/>
            <Button x:Name="ButtonExecute" Content="执行融合" Width="100" Height="30" DockPanel.Dock="Right" Click="Execute_Click" IsEnabled="False"/>
        </DockPanel>
    </Grid>
</Window>
