<UserControl x:Class="ColorVision.Solution.Terminal.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ColorVision.Solution.Terminal"
             xmlns:properties="clr-namespace:ColorVision.Solution.Properties"
             xmlns:uiProperties="clr-namespace:ColorVision.UI.Properties;assembly=ColorVision.UI"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600"
             Background="#1E1E1E"
    Loaded="UserControl_Loaded">
    <!-- Terminal area: custom drawn terminal view with IME proxy overlay -->
    <Grid x:Name="TerminalRoot" Background="#1E1E1E">
        <Grid.ContextMenu>
            <ContextMenu Opened="TerminalContextMenu_Opened">
                <MenuItem x:Name="MenuCopy"
                          Header="{x:Static uiProperties:Resources.MenuCopy}"
                          InputGestureText="Ctrl+C"
                          Click="MenuCopy_Click"/>
                <MenuItem x:Name="MenuPaste"
                          Header="{x:Static uiProperties:Resources.MenuPaste}"
                          InputGestureText="Ctrl+V"
                          Click="MenuPaste_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuNewPowerShell"
                          Header="新建 PowerShell"
                          Click="MenuNewPowerShell_Click"/>
                <MenuItem x:Name="MenuNewCmd"
                          Header="新建 CMD"
                          Click="MenuNewCmd_Click"/>
                <MenuItem x:Name="MenuClear"
                          Header="{x:Static properties:Resources.Sol_ClearScreen}"
                          Click="MenuClear_Click"/>
                <MenuItem x:Name="MenuKill"
                          Header="{x:Static properties:Resources.Sol_Terminate}"
                          Click="MenuKill_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuStatus" IsEnabled="False" Header="PowerShell / Exited"/>
            </ContextMenu>
        </Grid.ContextMenu>
        <ScrollViewer x:Name="TerminalScrollViewer"
                      Background="#1E1E1E"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="True"
                      SizeChanged="TerminalScrollViewer_SizeChanged"
                      PreviewKeyDown="TerminalScrollViewer_PreviewKeyDown"
                      PreviewTextInput="TerminalScrollViewer_PreviewTextInput"
                      MouseDown="TerminalScrollViewer_MouseDown"
                      GotFocus="TerminalScrollViewer_GotFocus">
            <local:TerminalView x:Name="TerminalDisplay"
                                Focusable="False"/>
        </ScrollViewer>
        <!-- Invisible TextBox positioned at cursor for correct IME candidate window placement -->
        <Canvas x:Name="ImeCanvas" IsHitTestVisible="False">
            <TextBox x:Name="ImeProxy"
                     Width="2" Height="20"
                     Background="Transparent"
                     Foreground="Transparent"
                     CaretBrush="Transparent"
                     BorderThickness="0"
                     FontFamily="Cascadia Mono, Consolas, Courier New"
                     FontSize="14"
                     Focusable="True"
                     AcceptsReturn="False"
                     PreviewKeyDown="OutputTextBox_PreviewKeyDown"
                     PreviewTextInput="ImeProxy_PreviewTextInput"/>
        </Canvas>
    </Grid>
</UserControl>
