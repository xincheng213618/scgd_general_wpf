<UserControl x:Class="ColorVision.Solution.Terminal.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ColorVision.Solution.Terminal"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600"
             Background="#1E1E1E"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="Transparent" Band="0" BandIndex="0">
            <ComboBox x:Name="ShellSelector" Width="120" Margin="2" SelectionChanged="ShellSelector_Changed">
                <ComboBoxItem Content="PowerShell" IsSelected="True"/>
                <ComboBoxItem Content="CMD"/>
            </ComboBox>
            <Separator/>
            <Button x:Name="ButtonNewShell" Content="+ 新终端" Click="ButtonNewShell_Click" Padding="6,2" Margin="2"
                    Foreground="{DynamicResource GlobalTextBrush}" ToolTip="启动新的终端会话"/>
            <Button x:Name="ButtonClear" Content="清屏" Click="ButtonClear_Click" Padding="6,2" Margin="2"
                    Foreground="{DynamicResource GlobalTextBrush}"/>
            <Button x:Name="ButtonKill" Content="终止" Click="ButtonKill_Click" Padding="6,2" Margin="2"
                    Foreground="{DynamicResource GlobalTextBrush}" ToolTip="终止当前终端进程"/>
        </ToolBar>

        <!-- Terminal area: custom drawn terminal view with IME proxy overlay -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="TerminalScrollViewer"
                          Background="#1E1E1E"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="True"
                          PreviewKeyDown="TerminalScrollViewer_PreviewKeyDown"
                          PreviewTextInput="TerminalScrollViewer_PreviewTextInput"
                          MouseDown="TerminalScrollViewer_MouseDown"
                          GotFocus="TerminalScrollViewer_GotFocus">
                <local:TerminalView x:Name="TerminalDisplay"
                                    Focusable="False"/>
            </ScrollViewer>
            <!-- Invisible TextBox positioned at cursor for correct IME candidate window placement -->
            <Canvas x:Name="ImeCanvas" IsHitTestVisible="False">
                <TextBox x:Name="ImeProxy"
                         Width="2" Height="20"
                         Background="Transparent"
                         Foreground="Transparent"
                         CaretBrush="Transparent"
                         BorderThickness="0"
                         FontFamily="Cascadia Mono, Consolas, Courier New"
                         FontSize="14"
                         Focusable="True"
                         AcceptsReturn="False"
                         PreviewKeyDown="OutputTextBox_PreviewKeyDown"
                         PreviewTextInput="ImeProxy_PreviewTextInput"/>
            </Canvas>
        </Grid>
    </Grid>
</UserControl>
