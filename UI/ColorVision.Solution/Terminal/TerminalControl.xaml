<UserControl x:Class="ColorVision.Solution.Terminal.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="600"
             Background="#1E1E1E"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Background="Transparent" Band="0" BandIndex="0">
            <ComboBox x:Name="ShellSelector" Width="120" Margin="2" SelectionChanged="ShellSelector_Changed">
                <ComboBoxItem Content="PowerShell" IsSelected="True"/>
                <ComboBoxItem Content="CMD"/>
            </ComboBox>
            <Separator/>
            <Button x:Name="ButtonNewShell" Content="+ 新终端" Click="ButtonNewShell_Click" Padding="6,2" Margin="2"
                    Foreground="{DynamicResource GlobalTextBrush}" ToolTip="启动新的终端会话"/>
            <Button x:Name="ButtonClear" Content="清屏" Click="ButtonClear_Click" Padding="6,2" Margin="2"
                    Foreground="{DynamicResource GlobalTextBrush}"/>
            <Button x:Name="ButtonKill" Content="终止" Click="ButtonKill_Click" Padding="6,2" Margin="2"
                    Foreground="{DynamicResource GlobalTextBrush}" ToolTip="终止当前终端进程"/>
        </ToolBar>

        <!-- Terminal area: single output with direct keyboard input to ConPTY -->
        <ScrollViewer Grid.Row="1" x:Name="TerminalScrollViewer"
                      Background="#1E1E1E"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="True"
                      PreviewKeyDown="TerminalScrollViewer_PreviewKeyDown"
                      PreviewTextInput="TerminalScrollViewer_PreviewTextInput"
                      MouseDown="TerminalScrollViewer_MouseDown"
                      GotFocus="TerminalScrollViewer_GotFocus">
            <TextBox x:Name="OutputTextBox"
                     FontFamily="Cascadia Mono, Consolas, Courier New, monospace"
                     FontSize="14"
                     Background="Transparent"
                     Foreground="#CCCCCC"
                     CaretBrush="#CCCCCC"
                     BorderThickness="0"
                     IsReadOnly="True"
                     IsReadOnlyCaretVisible="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Disabled"
                     HorizontalScrollBarVisibility="Disabled"
                     Padding="8,4"
                     PreviewKeyDown="OutputTextBox_PreviewKeyDown"
                     PreviewTextInput="OutputTextBox_PreviewTextInput"
                     FocusVisualStyle="{x:Null}"/>
        </ScrollViewer>
    </Grid>
</UserControl>
