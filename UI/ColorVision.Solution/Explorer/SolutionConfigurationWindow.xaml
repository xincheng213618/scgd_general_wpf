<Window x:Class="ColorVision.Solution.Explorer.SolutionConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="解决方案配置管理"
        Width="980" Height="680" MinWidth="820" MinHeight="560"
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Margin="0,0,0,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="活动配置" FontWeight="Bold" Margin="0,0,10,0"/>
                <ComboBox x:Name="ActiveConfigurationComboBox" Grid.Column="1" MinWidth="160"
                          ItemsSource="{Binding AvailableConfigurations}"
                          SelectedItem="{Binding ActiveConfiguration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="3" Text="活动平台" FontWeight="Bold" Margin="0,0,10,0"/>
                <ComboBox x:Name="ActivePlatformComboBox" Grid.Column="4" MinWidth="140"
                          ItemsSource="{Binding AvailablePlatforms}"
                          SelectedItem="{Binding ActivePlatform, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Column="6" Text="启动项目" FontWeight="Bold" Margin="0,0,10,0"/>
                <ComboBox x:Name="StartupProjectComboBox" Grid.Column="7" MinWidth="220"
                          ItemsSource="{Binding StartupProjects}"
                          DisplayMemberPath="DisplayName"
                          SelectedItem="{Binding SelectedStartupProject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="项目配置">
                <DataGrid x:Name="ProjectConfigurationDataGrid" ItemsSource="{Binding Projects}"
                          SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserReorderColumns="False" SelectionMode="Single" SelectionUnit="FullRow"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="项目" Binding="{Binding DisplayName}" Width="2*" IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="项目配置" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Margin="3,1" MinWidth="120"
                                              ItemsSource="{Binding AvailableConfigurations}"
                                              SelectedItem="{Binding SelectedConfiguration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="项目文件" Binding="{Binding ProjectReference}" Width="2*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="项目依赖">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding SelectedProject.DisplayName, TargetNullValue=请选择一个项目}"
                               FontWeight="Bold" Margin="2,0,0,8"/>
                    <ListBox x:Name="ProjectDependencyListBox" Grid.Row="1" ItemsSource="{Binding SelectedProject.Dependencies}"
                             Background="Transparent" BorderThickness="0"
                             IsEnabled="{Binding SelectedProject.CanEditDependencies}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="2,4" ToolTip="{Binding Reference}">
                                    <TextBlock Text="{Binding DisplayName}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                        <Setter Property="Foreground" Value="OrangeRed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Grid.Row="2" Text="当前项目 Provider 不支持修改依赖。"
                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,8,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProject.CanEditDependencies}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Header="验证结果" Margin="0,12,0,12">
            <Grid Margin="8">
                <TextBlock Text="未发现配置或依赖错误。" Foreground="{DynamicResource SecondaryTextBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasDiagnostics}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ListBox x:Name="DiagnosticsListBox" ItemsSource="{Binding Diagnostics}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Margin="2,3" Foreground="OrangeRed"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="保存" Width="88" Height="30" Margin="0,0,8,0"
                    IsDefault="True" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
