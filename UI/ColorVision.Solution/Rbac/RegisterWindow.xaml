<Window x:Class="ColorVision.Rbac.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="注册新用户" Height="580" Width="440"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Initialized="Window_Initialized"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="RbacStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border Background="{DynamicResource GlobalBackground}" CornerRadius="12"
            BorderBrush="{DynamicResource BordrBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.25" BlurRadius="12"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0" Style="{StaticResource RbacCloseButton}" 
                    Click="BtnCancel_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                    Panel.ZIndex="10"/>
            
            <!-- 顶部区域 -->
            <Border Grid.Row="0" Background="{DynamicResource StatusBarBackgroundBrush}" 
                    CornerRadius="12,12,0,0" Padding="20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE8FA;" 
                               FontFamily="Segoe MDL2 Assets" 
                               FontSize="42" 
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,8"/>
                    <TextBlock Text="创建新账户" 
                               FontSize="22" 
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="加入 ColorVision 系统" 
                               FontSize="12" 
                               Foreground="#C0FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- 表单区域 -->
            <StackPanel Grid.Row="1" Margin="30,20,30,10" VerticalAlignment="Center">
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="用户名" FontSize="13" Margin="0,0,0,6"/>
                    <hc:TextBox x:Name="TxtUsername"   
                                VerticalAlignment="Center" 
                                hc:InfoElement.Placeholder="请输入用户名"  
                                Padding="10,8"
                                FontSize="14"/>
                </StackPanel>
                
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="密码" FontSize="13" Margin="0,0,0,6"/>
                    <hc:PasswordBox x:Name="Pwd1"  
                                    VerticalAlignment="Center"  
                                    hc:InfoElement.Placeholder="请输入密码（至少6位）"  
                                    Padding="10,8"
                                    FontSize="14"
                                    hc:ShowEyeButton="True"/>
                </StackPanel>
                
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="确认密码" FontSize="13" Margin="0,0,0,6"/>
                    <hc:PasswordBox x:Name="Pwd2"  
                                    VerticalAlignment="Center"  
                                    hc:InfoElement.Placeholder="再次输入密码"  
                                    Padding="10,8"
                                    FontSize="14"
                                    hc:ShowEyeButton="True"/>
                </StackPanel>
                
                <!-- 状态提示 -->
                <Border Background="#FFF3E0" 
                        CornerRadius="6" 
                        Padding="10,6"
                        Margin="0,0,0,12"
                        Visibility="{Binding ElementName=TxtStatus, Path=Text, Converter={StaticResource String2VisibilityConverter}}">
                    <TextBlock x:Name="TxtStatus" 
                               Foreground="#E65100" 
                               TextWrapping="Wrap"
                               FontSize="12"/>
                </Border>
                
                <!-- 按钮组 -->
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnRegister" 
                            Grid.Column="0"
                            Content="注册" 
                            Height="38"
                            Click="BtnRegister_Click"
                            Style="{StaticResource ModernButton}"/>
                    <Button Grid.Column="2" 
                            Content="取消" 
                            Height="38"
                            Click="BtnCancel_Click"
                            Style="{StaticResource SecondaryButton}"/>
                </Grid>
            </StackPanel>
            
            <!-- 底部信息 -->
            <Border Grid.Row="2" 
                    BorderBrush="{DynamicResource GlobalBorderBrush1}" 
                    BorderThickness="0,1,0,0"
                    Padding="20,10"
                    CornerRadius="0,0,12,12">
                <TextBlock HorizontalAlignment="Center" 
                           Opacity="0.5"
                           FontSize="11"
                           Text="注册即表示您同意 ColorVision 使用条款"/>
            </Border>
        </Grid>
    </Border>
</Window>
