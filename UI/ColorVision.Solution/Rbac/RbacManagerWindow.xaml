<Window x:Class="ColorVision.Rbac.RbacManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Rbac"
        xmlns:properties ="clr-namespace:ColorVision.Solution.Properties"
        xmlns:hc ="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:RbacManager}"
        Title="{x:Static properties:Resources.UserCenter}" Height="500" Width="700"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Initialized="Window_Initialized"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="RbacStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border Background="{DynamicResource GlobalBackground}" CornerRadius="12"
            BorderBrush="{DynamicResource BordrBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.25" BlurRadius="12"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0" Style="{StaticResource RbacCloseButton}" 
                    Click="BtnClose_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                    Panel.ZIndex="10"/>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{DynamicResource StatusBarBackgroundBrush}" 
                    CornerRadius="12,12,0,0" Padding="20,15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE77B;" 
                               FontFamily="Segoe MDL2 Assets" 
                               FontSize="22" 
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="{x:Static properties:Resources.UserCenter}" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 操作按钮区域 -->
            <Border Grid.Row="1" Background="{DynamicResource ButtonBackground}" Padding="20,12"
                    BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding LoginCommand}" 
                            Style="{StaticResource ModernButton}"
                            Margin="0,0,10,0"
                            Visibility="{Binding LoginButtonVisibility}"
                            ToolTip="点击登录或切换账户">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="{x:Static properties:Resources.LoginOrSwitch}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditCommand}" 
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,10,0"
                            Visibility="{Binding LoggedInButtonVisibility}"
                            ToolTip="编辑当前用户详细信息">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="{x:Static properties:Resources.EditInfo}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnChangePassword"
                            Click="BtnChangePassword_Click"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,10,0"
                            Visibility="{Binding LoggedInButtonVisibility}"
                            ToolTip="修改当前账户密码">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="修改密码"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenUserManagerCommand}" 
                            Style="{StaticResource ModernButton}"
                            Visibility="{Binding AdminButtonVisibility}"
                            ToolTip="管理系统用户和角色（仅管理员可用）">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="{x:Static properties:Resources.UserManagement}"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BtnLogout_Click" 
                            Style="{StaticResource SecondaryButton}"
                            Margin="10,0,0,0"
                            Visibility="{Binding LoggedInButtonVisibility}"
                            ToolTip="退出登录">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="{x:Static properties:Resources.Sign_out}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 用户信息卡片 -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="20">
                <Border Background="{DynamicResource GlobalBackground}" 
                        CornerRadius="8" 
                        BorderBrush="{DynamicResource GlobalBorderBrush1}" 
                        BorderThickness="1"
                        Padding="25"
                        Margin="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 头像区域 -->
                        <Border Grid.Column="0" 
                                Background="{DynamicResource ButtonBackground}" 
                                CornerRadius="8" 
                                Padding="15"
                                Margin="0,0,25,0">
                            <StackPanel>
                                <hc:Gravatar Id="{Binding Config.LoginResult.User.Username}" 
                                             Width="96" 
                                             Height="96"/>
                                <TextBlock Text="{Binding CurrentUserDisplay}" 
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                            
                            <!-- 用户详细信息 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,15"
                                           Foreground="{DynamicResource StatusBarBackgroundBrush}">
                                    <Run Text="{x:Static properties:Resources.WelcomeBack}"/>
                                    <Run Text="{Binding CurrentUserDisplay}"/>
                                </TextBlock>
                                
                                <!-- 信息网格 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- 用户ID -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static properties:Resources.UserId}" FontWeight="SemiBold" Margin="0,0,20,10" Opacity="0.6"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Config.LoginResult.User.Id}" Margin="0,0,0,10"/>
                                    
                                    <!-- 用户名 -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static properties:Resources.UserName}" FontWeight="SemiBold" Margin="0,0,20,10" Opacity="0.6"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Config.LoginResult.User.Username}" Margin="0,0,0,10"/>
                                   
                                    
                                    <!-- 权限模式 -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static properties:Resources.PermissionMode}" FontWeight="SemiBold" Margin="0,0,20,10" Opacity="0.6"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Config.LoginResult.UserDetail.PermissionMode}" Margin="0,0,0,10"/>
                                    
                                    <!-- 登录时间 -->
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static properties:Resources.LoginTime}" FontWeight="SemiBold" Margin="0,0,20,10" Opacity="0.6"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Config.LoginResult.User.UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Margin="0,0,0,10" Opacity="0.6"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ScrollViewer>
                
                <!-- 底部信息栏 -->
                <Border Grid.Row="3" 
                        Background="{DynamicResource ButtonBackground}" 
                        BorderBrush="{DynamicResource GlobalBorderBrush1}" 
                        BorderThickness="0,1,0,0"
                        Padding="20,10"
                        CornerRadius="0,0,12,12">
                    <TextBlock HorizontalAlignment="Center" 
                               Opacity="0.5" 
                               FontSize="11">
                        <Run Text="ColorVision RBAC "/>
                        <Run Text="{x:Static properties:Resources.UserManagementSystem}"/>
                        <Run Text=" | "/>
                        <Run Text="Version 2.0"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>
</Window>
