<Window x:Class="ColorVision.Rbac.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="修改密码" Height="420" Width="400"
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Initialized="Window_Initialized">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F0FE" Offset="0"/>
                <GradientStop Color="#F8FBFF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Background="White" CornerRadius="12" Margin="20" Padding="0"
                Effect="{DynamicResource EffectShadow2}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标题栏 -->
                <Border Grid.Row="0" Background="#0078D4" CornerRadius="12,12,0,0" Padding="20,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                   Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtTitle" Text="修改密码" FontSize="18" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 表单 -->
                <StackPanel Grid.Row="1" Margin="25,20,25,25" VerticalAlignment="Center">
                    <!-- 提示信息 -->
                    <Border x:Name="BdrHint" Background="#FFF3E0" BorderBrush="#FFB74D"
                            BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,15"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtHint" TextWrapping="Wrap" Foreground="#E65100" FontSize="12"/>
                    </Border>

                    <!-- 旧密码 -->
                    <StackPanel x:Name="PnlOldPassword" Margin="0,0,0,15">
                        <TextBlock Text="当前密码" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Background="White">
                            <hc:PasswordBox x:Name="TxtOldPassword" BorderThickness="0" Padding="10,8"
                                            FontSize="14" hc:InfoElement.Placeholder="请输入当前密码"/>
                        </Border>
                    </StackPanel>

                    <!-- 新密码 -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="新密码" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Background="White">
                            <hc:PasswordBox x:Name="TxtNewPassword" BorderThickness="0" Padding="10,8"
                                            FontSize="14" hc:InfoElement.Placeholder="至少6个字符"/>
                        </Border>
                    </StackPanel>

                    <!-- 确认密码 -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="确认新密码" FontSize="13" Foreground="#666666" Margin="0,0,0,6"/>
                        <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Background="White">
                            <hc:PasswordBox x:Name="TxtConfirmPassword" BorderThickness="0" Padding="10,8"
                                            FontSize="14" hc:InfoElement.Placeholder="再次输入新密码"/>
                        </Border>
                    </StackPanel>

                    <!-- 错误提示 -->
                    <Border x:Name="BdrError" Background="#FFEBEE" BorderBrush="#EF5350"
                            BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,15"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtError" Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                    </Border>

                    <!-- 按钮 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnSave" Grid.Column="0" Content="保存" Height="38"
                                Click="BtnSave_Click" Background="#0078D4" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="14"/>
                        <Button x:Name="BtnCancel" Grid.Column="2" Content="取消" Height="38"
                                Click="BtnCancel_Click" Background="#F3F3F3" Foreground="#333333"
                                BorderThickness="1" BorderBrush="#DDDDDD" Cursor="Hand" FontSize="14"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
