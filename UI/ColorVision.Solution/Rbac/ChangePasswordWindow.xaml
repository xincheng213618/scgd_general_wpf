<Window x:Class="ColorVision.Rbac.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="修改密码" Height="420" Width="400"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Initialized="Window_Initialized"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="RbacStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource GlobalBackground}" CornerRadius="12"
            BorderBrush="{DynamicResource BordrBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.25" BlurRadius="12"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0" Style="{StaticResource RbacCloseButton}" 
                    Click="BtnCancel_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                    Panel.ZIndex="10"/>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{DynamicResource StatusBarBackgroundBrush}" 
                    CornerRadius="12,12,0,0" Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtTitle" Text="修改密码" FontSize="16" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- 表单 -->
            <StackPanel Grid.Row="1" Margin="25,18,25,25" VerticalAlignment="Center">
                <!-- 提示信息 -->
                <Border x:Name="BdrHint" Background="#FFF3E0" BorderBrush="#FFB74D"
                        BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtHint" TextWrapping="Wrap" Foreground="#E65100" FontSize="12"/>
                </Border>

                <!-- 旧密码 -->
                <StackPanel x:Name="PnlOldPassword" Margin="0,0,0,12">
                    <TextBlock Text="当前密码" FontSize="13" Margin="0,0,0,6"/>
                    <hc:PasswordBox x:Name="TxtOldPassword" Padding="10,8"
                                    FontSize="14" hc:InfoElement.Placeholder="请输入当前密码"/>
                </StackPanel>

                <!-- 新密码 -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="新密码" FontSize="13" Margin="0,0,0,6"/>
                    <hc:PasswordBox x:Name="TxtNewPassword" Padding="10,8"
                                    FontSize="14" hc:InfoElement.Placeholder="至少6个字符"/>
                </StackPanel>

                <!-- 确认密码 -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="确认新密码" FontSize="13" Margin="0,0,0,6"/>
                    <hc:PasswordBox x:Name="TxtConfirmPassword" Padding="10,8"
                                    FontSize="14" hc:InfoElement.Placeholder="再次输入新密码"/>
                </StackPanel>

                <!-- 错误提示 -->
                <Border x:Name="BdrError" Background="#FFEBEE" BorderBrush="#EF5350"
                        BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,12"
                        Visibility="Collapsed">
                    <TextBlock x:Name="TxtError" Foreground="#C62828" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <!-- 按钮 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnSave" Grid.Column="0" Content="保存" Height="36"
                            Click="BtnSave_Click" Style="{StaticResource ModernButton}"/>
                    <Button x:Name="BtnCancel" Grid.Column="2" Content="取消" Height="36"
                            Click="BtnCancel_Click" Style="{StaticResource SecondaryButton}"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
