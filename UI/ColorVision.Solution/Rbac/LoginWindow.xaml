<Window x:Class="ColorVision.Rbac.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Rbac"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:properties="clr-namespace:ColorVision.Solution.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.Sign_in}" Height="550"  Width="420" 
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Initialized="Window_Initialized"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="RbacStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border Background="{DynamicResource GlobalBackground}" CornerRadius="12"
            BorderBrush="{DynamicResource BordrBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.25" BlurRadius="12"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0" Style="{StaticResource RbacCloseButton}" 
                    Click="BtnClose_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                    Panel.ZIndex="10"/>
            
            <!-- 顶部区域 -->
            <Border Grid.Row="0" Background="{DynamicResource StatusBarBackgroundBrush}" 
                    CornerRadius="12,12,0,0" Padding="20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE77B;" 
                               FontFamily="Segoe MDL2 Assets" 
                               FontSize="42" 
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,8"/>
                    <TextBlock Text="{x:Static properties:Resources.AccountLogin}" 
                               FontSize="22" 
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="欢迎使用 ColorVision 系统" 
                               FontSize="12" 
                               Foreground="#C0FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
            <!-- 表单区域 -->
            <StackPanel Grid.Row="1" Margin="35,25,35,15" VerticalAlignment="Center">
                <StackPanel Margin="0,0,0,18">
                    <TextBlock Text="{x:Static properties:Resources.UserName}" 
                               FontSize="13" Margin="0,0,0,6"/>
                    <hc:TextBox x:Name="Account1"   
                                ToolTip="{x:Static properties:Resources.Account}"  
                                VerticalAlignment="Center" 
                                Text="{Binding Name}" 
                                hc:InfoElement.Placeholder="{x:Static properties:Resources.FillAccount}"  
                                Padding="10,8"
                                FontSize="14"/>
                </StackPanel>
                
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="{x:Static properties:Resources.Password}" 
                               FontSize="13" Margin="0,0,0,6"/>
                    <hc:PasswordBox x:Name="PasswordBox1"  
                                    ToolTip="{x:Static properties:Resources.Password}"  
                                    VerticalAlignment="Center"  
                                    hc:InfoElement.Placeholder="{x:Static properties:Resources.FillPassword}"  
                                    Padding="10,8"
                                    FontSize="14"
                                    hc:ShowEyeButton="True"/>
                </StackPanel>
                
                <CheckBox x:Name="ChkRememberMe"
                          Content="{x:Static properties:Resources.RememberLoginStatus7Days}"
                          FontSize="12"
                          Margin="0,0,0,20"
                          ToolTip="勾选后，下次启动软件将自动登录"/>
                
                <Button x:Name="BtnLogin"
                        Content="{x:Static properties:Resources.Sign_in}" 
                        Height="40"
                        Click="Button_Click"
                        Style="{StaticResource ModernButton}"/>
            </StackPanel>
            
            <!-- 底部区域 -->
            <Border Grid.Row="2" 
                    BorderBrush="{DynamicResource GlobalBorderBrush1}" 
                    BorderThickness="0,1,0,0"
                    Padding="20,12"
                    CornerRadius="0,0,12,12">
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center" FontSize="12">
                        <Run Text="{x:Static properties:Resources.NoAccountYet}"/>
                        <Hyperlink Click="RegisterHyperlink_Click" 
                                   ToolTip="注册新账户"
                                   Foreground="{DynamicResource StatusBarBackgroundBrush}"
                                   TextDecorations="None">
                            <Run Text="{x:Static properties:Resources.Create_an_account}" />
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock x:Name="TxtVersion"
                               Text="ColorVision RBAC v2.0"
                               HorizontalAlignment="Center"
                               Opacity="0.5"
                               FontSize="10"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
