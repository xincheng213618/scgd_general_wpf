<Window x:Class="ColorVision.Rbac.EditUserRolesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="编辑用户角色 - RBAC" Height="600" Width="500" 
        WindowStartupLocation="CenterOwner" 
        Background="Transparent" 
        AllowsTransparency="True" 
        WindowStyle="None"
        Initialized="Window_Initialized"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="RbacStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12" Background="{DynamicResource GlobalBackground}"
            BorderBrush="{DynamicResource BordrBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.25" BlurRadius="12"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0" Style="{StaticResource RbacCloseButton}" 
                    Click="BtnCancel_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                    Panel.ZIndex="10"/>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource StatusBarBackgroundBrush}" CornerRadius="12,12,0,0" Padding="20,15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="28" 
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <StackPanel>
                        <TextBlock x:Name="TxtTitle" Text="编辑用户角色" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock x:Name="TxtSubtitle" Text="选择用户的角色分配" FontSize="12" Foreground="White" Opacity="0.8" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Search Box -->
            <Border Grid.Row="1" Background="{DynamicResource ButtonBackground}" Padding="20,12"
                    BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16" 
                               VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.5"/>
                    <TextBox x:Name="TxtSearch" Grid.Column="1" Padding="8,6" FontSize="13"
                             TextChanged="TxtSearch_TextChanged"
                             ToolTip="搜索角色名称"/>
                </Grid>
            </Border>

            <!-- Role List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="25,20">
                <StackPanel x:Name="PnlRoles">
                    <!-- Roles will be added dynamically -->
                </StackPanel>
            </ScrollViewer>

            <!-- Footer Buttons -->
            <Border Grid.Row="3" BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="0,1,0,0" Padding="25,15"
                    Background="{DynamicResource ButtonBackground}" CornerRadius="0,0,12,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock x:Name="TxtSelectedCount" Text="已选择 0 个角色" FontSize="13" 
                                   Opacity="0.6" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Width="100" Margin="0,0,10,0"
                                Style="{StaticResource SecondaryButton}" Click="BtnCancel_Click"/>
                        <Button x:Name="BtnSave" Content="保存" Width="100"
                                Style="{StaticResource PrimaryButton}" Click="BtnSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
