<Window x:Class="ColorVision.Rbac.EditUserInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="编辑用户信息" Height="560" Width="500"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="RbacStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource GlobalBackground}" CornerRadius="12"
            BorderBrush="{DynamicResource BordrBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.25" BlurRadius="12"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮 -->
            <Button Grid.Row="0" Style="{StaticResource RbacCloseButton}" 
                    Click="BtnCancel_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                    Panel.ZIndex="10"/>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{DynamicResource StatusBarBackgroundBrush}" 
                    CornerRadius="12,12,0,0" Padding="20,15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="编辑用户信息" FontSize="18" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="修改个人资料" FontSize="12" Foreground="White" Opacity="0.8" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 表单内容 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25,18,25,10">
                <StackPanel>
                    <!-- 邮箱 -->
                    <StackPanel Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource StatusBarBackgroundBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="邮箱" FontSize="13"/>
                        </StackPanel>
                        <hc:TextBox x:Name="TxtEmail" Padding="10,8" FontSize="14"
                                    hc:InfoElement.Placeholder="user@example.com"/>
                    </StackPanel>

                    <!-- 电话 -->
                    <StackPanel Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource StatusBarBackgroundBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="电话" FontSize="13"/>
                        </StackPanel>
                        <hc:TextBox x:Name="TxtPhone" Padding="10,8" FontSize="14"
                                    hc:InfoElement.Placeholder="联系电话"/>
                    </StackPanel>

                    <!-- 公司 -->
                    <StackPanel Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xE731;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource StatusBarBackgroundBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="公司" FontSize="13"/>
                        </StackPanel>
                        <hc:TextBox x:Name="TxtCompany" Padding="10,8" FontSize="14"
                                    hc:InfoElement.Placeholder="公司名称"/>
                    </StackPanel>

                    <!-- 部门 -->
                    <StackPanel Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource StatusBarBackgroundBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="部门" FontSize="13"/>
                        </StackPanel>
                        <hc:TextBox x:Name="TxtDepartment" Padding="10,8" FontSize="14"
                                    hc:InfoElement.Placeholder="所属部门"/>
                    </StackPanel>

                    <!-- 职位 -->
                    <StackPanel Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource StatusBarBackgroundBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="职位" FontSize="13"/>
                        </StackPanel>
                        <hc:TextBox x:Name="TxtPosition" Padding="10,8" FontSize="14"
                                    hc:InfoElement.Placeholder="职位名称"/>
                    </StackPanel>

                    <!-- 地址 -->
                    <StackPanel Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xE707;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource StatusBarBackgroundBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="地址" FontSize="13"/>
                        </StackPanel>
                        <hc:TextBox x:Name="TxtAddress" Padding="10,8" FontSize="14"
                                    hc:InfoElement.Placeholder="联系地址"/>
                    </StackPanel>

                    <!-- 备注 -->
                    <StackPanel Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="&#xE70B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource StatusBarBackgroundBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="备注" FontSize="13"/>
                        </StackPanel>
                        <TextBox x:Name="TxtRemark" Padding="10,8" FontSize="14" Height="70"
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="0,1,0,0"
                    Padding="25,15" Background="{DynamicResource ButtonBackground}" CornerRadius="0,0,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="保存" Height="36"
                            Click="BtnSave_Click" Style="{StaticResource ModernButton}"/>
                    <Button Grid.Column="2" Content="取消" Height="36"
                            Click="BtnCancel_Click" Style="{StaticResource SecondaryButton}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
