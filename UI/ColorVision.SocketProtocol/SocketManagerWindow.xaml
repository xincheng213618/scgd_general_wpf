<Window x:Class="ColorVision.SocketProtocol.SocketManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.SocketProtocol"
        xmlns:properties="clr-namespace:ColorVision.SocketProtocol.Properties"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:SocketManager}"
        Title="{x:Static properties:Resources.SocketManagementWindow}"
        Height="780"
        Width="1340"
        MinHeight="640"
        MinWidth="1040"
        Background="{DynamicResource GlobalBackground}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Initialized="Window_Initialized"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PaneCardBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="MetricCardBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style x:Key="SectionTitleTextBlock" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MessageDirectionTextBlock" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Direction}" Value="{x:Static local:SocketMessageDirection.Sent}">
                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetaLabelTextBlock" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="StatusValueTextBlock" TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ServerState}" Value="{x:Static local:SocketServerState.Running}">
                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ServerState}" Value="{x:Static local:SocketServerState.Starting}">
                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ServerState}" Value="{x:Static local:SocketServerState.Stopping}">
                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ServerState}" Value="{x:Static local:SocketServerState.Error}">
                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusDotBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource ThirdlyTextBrush}"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ServerState}" Value="{x:Static local:SocketServerState.Running}">
                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ServerState}" Value="{x:Static local:SocketServerState.Starting}">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ServerState}" Value="{x:Static local:SocketServerState.Stopping}">
                    <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding ServerState}" Value="{x:Static local:SocketServerState.Error}">
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChromeButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="78"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource GlobalBorderBrush1}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerChromeButton" TargetType="{x:Type Button}" BasedOn="{StaticResource ChromeButton}">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <Style x:Key="HeroToggleButton" TargetType="{x:Type ToggleButton}">
            <Setter Property="Content" Value="{x:Static properties:Resources.StartService}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextIconBrush}"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="MinWidth" Value="170"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="30" Height="30" CornerRadius="15" Background="#33FFFFFF" VerticalAlignment="Center">
                                    <TextBlock x:Name="Glyph"
                                               Text="&#xE768;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextIconBrush}"/>
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="10,0,0,0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Glyph" Property="Text" Value="&#xE71A;"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Content" Value="{x:Static properties:Resources.StopService}"/>
                    <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                Background="{DynamicResource ButtonBackground}"
                BorderBrush="{DynamicResource ButtonBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="12" Background="{DynamicResource GlobalBorderBrush1}" Margin="0,0,14,0">
                        <TextBlock Text="&#xE774;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="24"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{x:Static properties:Resources.SocketManagementWindow}" FontSize="24" FontWeight="SemiBold" Margin="0,0,12,0"/>
                            <Border Style="{StaticResource StatusDotBorder}" Margin="0,1,7,0"/>
                            <TextBlock Text="{Binding ServerStateText}" Style="{StaticResource StatusValueTextBlock}" FontSize="17"/>
                        </StackPanel>
                        <TextBlock Text="{Binding LastStatusChangedText}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ToggleButton Grid.Row="0"
                                  Style="{StaticResource HeroToggleButton}"
                                  IsChecked="{Binding Config.IsServerEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Checked="ServerEnabledCheckBox_Changed"
                                  Unchecked="ServerEnabledCheckBox_Changed"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="{x:Static properties:Resources.ServiceSettings}" Command="{Binding EditCommand}" Style="{StaticResource ChromeButton}" Margin="0,0,8,0"/>
                        <Button Content="{x:Static properties:Resources.MessageSettings}" Command="{Binding MessageManager.EditConfigCommand}" Style="{StaticResource ChromeButton}" Margin="0,0,8,0"/>
                        <Button Content="{x:Static properties:Resources.OpenDatabase}" Command="{Binding MessageManager.SelectDbFileCommand}" Style="{StaticResource ChromeButton}" MinWidth="96"/>
                    </StackPanel>
                </Grid>

                <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Columns="4" Margin="0,18,0,0">
                    <Border Style="{StaticResource MetricCardBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE839;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource WarningBrush}" FontSize="20" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{x:Static properties:Resources.ListenAddress}" Style="{StaticResource MetaLabelTextBlock}"/>
                                <TextBlock Text="{Binding ListenAddress}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource MetricCardBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource PrimaryBrush}" FontSize="20" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{x:Static properties:Resources.ProtocolAndClients}" Style="{StaticResource MetaLabelTextBlock}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Config.SocketPhraseType}" FontSize="16" FontWeight="SemiBold" Margin="0,0,12,0"/>
                                    <TextBlock Text="{Binding ClientCountText}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource MetricCardBorder}">
                        <Grid ToolTip="{Binding PrivateFirewallTooltip}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource PrimaryBrush}" FontSize="20" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="防火墙 - 专用" Style="{StaticResource MetaLabelTextBlock}"/>
                                <TextBlock Text="{Binding PrivateFirewallStatusText}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanAllowPrivateFirewall}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="放行"
                                    Command="{Binding AllowFirewallRuleCommand}"
                                    CommandParameter="private"
                                    Height="28"
                                    Width="54"
                                    MinWidth="54"
                                    Padding="8,0"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="为当前程序创建专用网络入站允许规则。">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ChromeButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanAllowPrivateFirewall}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource MetricCardBorder}" Margin="0">
                        <Grid ToolTip="{Binding PublicFirewallTooltip}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource PrimaryBrush}" FontSize="20" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="防火墙 - 公用" Style="{StaticResource MetaLabelTextBlock}"/>
                                <TextBlock Text="{Binding PublicFirewallStatusText}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanAllowPublicFirewall}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Content="放行"
                                    Command="{Binding AllowFirewallRuleCommand}"
                                    CommandParameter="public"
                                    Height="28"
                                    Width="54"
                                    MinWidth="54"
                                    Padding="8,0"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="为当前程序创建公用网络入站允许规则。">
                                <Button.Style>
                                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource ChromeButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanAllowPublicFirewall}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Margin="0,14,0,0"
                        Padding="12,10"
                        Background="{DynamicResource ButtonBackground}"
                        BorderBrush="{DynamicResource DangerBrush}"
                        BorderThickness="1"
                        CornerRadius="7">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasLastError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel LastChildFill="True">
                        <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource DangerBrush}" FontSize="16" Margin="0,1,8,0" DockPanel.Dock="Left"/>
                        <TextBlock Text="{x:Static properties:Resources.OpenFailed}" FontWeight="SemiBold" Foreground="{DynamicResource DangerBrush}" Margin="0,0,10,0" DockPanel.Dock="Left"/>
                        <TextBlock Text="{Binding LastErrorDisplay}" TextWrapping="Wrap" Foreground="{DynamicResource DangerBrush}"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="620"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="2*" MinWidth="360"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PaneCardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="14,10,14,8" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource PrimaryBrush}" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static properties:Resources.MessageLog}" Style="{StaticResource SectionTitleTextBlock}" Margin="0,0,10,0"/>
                            <TextBlock x:Name="FilteredCountTextBlock" Foreground="{DynamicResource SecondaryTextBrush}" MinWidth="72" TextAlignment="Right" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TotalCountTextBlock" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>

                        <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,4">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox x:Name="SearchTextBox"
                                         Width="190"
                                         Height="28"
                                         TextChanged="Filter_Changed"
                                         ToolTip="{x:Static properties:Resources.SearchTooltip}"/>
                                <ComboBox x:Name="DirectionFilterCombo" Width="74" Height="28" Margin="6,0,0,0" SelectedIndex="0" SelectionChanged="Filter_Changed">
                                    <ComboBoxItem Content="{x:Static properties:Resources.FilterAll}" Tag="All"/>
                                    <ComboBoxItem Content="{x:Static properties:Resources.FilterReceived}" Tag="Received"/>
                                    <ComboBoxItem Content="{x:Static properties:Resources.FilterSent}" Tag="Sent"/>
                                </ComboBox>
                            </StackPanel>

                            <CheckBox x:Name="AutoScrollCheckBox" Content="{x:Static properties:Resources.AutoScroll}" IsChecked="True" Margin="0,0,12,4"/>
                            <Button Content="{x:Static properties:Resources.Query}" Command="{Binding MessageManager.QueryCommand}" Style="{StaticResource ChromeButton}" Width="62" MinWidth="62" Height="28" Padding="8,0" Margin="0,0,6,4"/>
                            <Button Content="{x:Static properties:Resources.AdvancedQuery}" Command="{Binding MessageManager.GenericQueryCommand}" Style="{StaticResource ChromeButton}" Width="78" MinWidth="78" Height="28" Padding="8,0" Margin="0,0,6,4"/>
                            <Button Content="{x:Static properties:Resources.ClearMessages}" Command="{Binding MessageManager.MessagesClearCommand}" Style="{StaticResource DangerChromeButton}" Width="78" MinWidth="78" Height="28" Padding="8,0" Margin="0,0,0,4"/>
                        </WrapPanel>
                    </DockPanel>

                    <ListView Grid.Row="1"
                              x:Name="MessagesListView"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding MessageManager.Messages}"
                              SelectionChanged="MessagesListView_SelectionChanged"
                              SizeChanged="MessagesListView_SizeChanged"
                              Padding="8,0,8,8"
                              Style="{DynamicResource ListView.Small}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <ListView.Resources>
                            <ContextMenu x:Key="MessageContextMenu">
                                <MenuItem Header="{x:Static properties:Resources.Copy}" Click="CopyMessage_Click" Tag="{Binding .}"/>
                                <MenuItem Header="{x:Static properties:Resources.Resend}" Click="ResendMessage_Click" Tag="{Binding .}"/>
                                <MenuItem Header="{x:Static properties:Resources.Delete}" Click="DeleteMessage_Click" Tag="{Binding .}"/>
                            </ContextMenu>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource ListViewItemBaseStyle.Small}">
                                <Setter Property="ContextMenu" Value="{StaticResource MessageContextMenu}"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridView.ColumnHeaderContainerStyle>
                                    <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource GridViewColumnHeaderBase}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </GridView.ColumnHeaderContainerStyle>
                                <GridViewColumn Header="{x:Static properties:Resources.Time}" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type local:SocketMessage}">
                                            <TextBlock Text="{Binding MessageTime, StringFormat=HH:mm:ss.fff}" Style="{StaticResource MessageDirectionTextBlock}" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static properties:Resources.EventName}" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type local:SocketMessage}">
                                            <TextBlock Text="{Binding EventName}" TextTrimming="CharacterEllipsis" ToolTip="{Binding EventName}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn x:Name="ContentColumn" Header="{x:Static properties:Resources.Content}" Width="420">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type local:SocketMessage}">
                                            <TextBlock Text="{Binding Content}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Content}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" Style="{StaticResource PaneCardBorder}" Padding="0">
                <Grid x:Name="DetailPanel" Margin="14,12,14,12" d:DataContext="{d:DesignInstance local:SocketMessage}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                        <CheckBox DockPanel.Dock="Right" x:Name="PrettyPrintCheckBox" Content="{x:Static properties:Resources.PrettyPrintView}" IsChecked="True" Checked="PrettyPrintCheckBox_Changed" Unchecked="PrettyPrintCheckBox_Changed"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource PrimaryBrush}" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="消息" Style="{StaticResource SectionTitleTextBlock}"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBox Grid.Row="1"
                             x:Name="DetailContentTextBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             HorizontalContentAlignment="Left"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             BorderBrush="{DynamicResource ButtonBorderBrush}"
                             Background="{DynamicResource GlobalBackground}"
                             Foreground="{DynamicResource GlobalTextBrush}"
                             FontFamily="Consolas"
                             FontSize="13"
                             Padding="10"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
