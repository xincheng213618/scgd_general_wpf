<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="defaultgreyColor">#212121</Color>

    <!-- Global colors -->
    <Color x:Key="GlobalBackgroundColor">#FFF9FB</Color>
    <Color x:Key="GlobalBroderBrushColor">#F1DDE6</Color>
    <Color x:Key="GlobalTextColor">Black</Color>
    <Color x:Key="UpdateDialogBackgroundColor">#FFF9FB</Color>
    <Color x:Key="UpdateDialogSurfaceColor">#FFF2F7</Color>
    <Color x:Key="UpdateDialogSurfaceHoverColor">#FBE5EF</Color>
    <Color x:Key="UpdateDialogBorderColor">#E1B8C9</Color>
    <Color x:Key="UpdateDialogTextPrimaryColor">Black</Color>
    <Color x:Key="UpdateDialogTextSecondaryColor">Black</Color>
    <Color x:Key="UpdateDialogAccentColor">#E91E63</Color>
    <Color x:Key="UpdateDialogAccentHoverColor">#E91E63</Color>

    <Color x:Key="TerminalBackgroundColor">#FFF4F8</Color>
    <Color x:Key="TerminalForegroundColor">#33212A</Color>
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="{StaticResource TerminalBackgroundColor}"/>
    <SolidColorBrush x:Key="TerminalForegroundBrush" Color="{StaticResource TerminalForegroundColor}"/>
    <SolidColorBrush x:Key="TerminalCursorBrush" Color="#805A2A3D"/>
    <SolidColorBrush x:Key="TerminalSelectionBrush" Color="#66D85D91"/>
    <SolidColorBrush x:Key="TerminalUrlBrush" Color="#B0185B"/>

    <!-- Icon colors -->
    <SolidColorBrush x:Key="IconSolidColorBrush" Color="#E91E63"/>
    <!-- 深粉色 -->
    <SolidColorBrush x:Key="IconSolidColorBackgroundBrush" Color="#FADCE4"/>
    <!-- 次要背景色 -->

    <!-- Selection colors -->
    <Color x:Key="SelectedBackgroundColor">#F48FB1</Color>
    <!-- 浅粉色 -->
    <Color x:Key="SelectedUnfocusedColor">#FADCE4</Color>
    <!-- 次要背景色 -->

    <!-- Border colors -->
    <SolidColorBrush x:Key="BordrBrush" Color="#E1B8C9"/>
    <!-- 主背景色 -->
    <SolidColorBrush x:Key="Background" Color="#F48FB1"/>
    <!-- 浅粉色 -->

    <!-- Button colors -->
    <SolidColorBrush x:Key="ButtonBackground" Color="#FFF2F7"/>
    <!-- 控件面 -->
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#E1B8C9"/>
    <!-- 结构边框 -->

    <!-- Global background and border -->
    <SolidColorBrush x:Key="GlobalBackground" Color="{StaticResource GlobalBackgroundColor}" />
    <SolidColorBrush x:Key="GlobalBorderBrush" Color="{StaticResource GlobalBroderBrushColor}"/>

    <!-- More global colors -->
    <SolidColorBrush x:Key="GlobalBorderBrush1" Color="#F3E8EE"/>
    <!-- 页面底色 -->

    <!-- Text colors -->
    <SolidColorBrush x:Key="GlobalTextBrush" Color="{StaticResource GlobalTextColor}" />
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#E91E63"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource UpdateDialogAccentColor}"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource GlobalTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#7A3A50"/>
    <!-- 深粉色 -->
    <SolidColorBrush x:Key="MeasureBackground" Color="{StaticResource GlobalBackgroundColor}"/>
    <SolidColorBrush x:Key="MeasureBarBackgroundBrush" Color="#FADCE4"/>
    <!-- 次要背景色 -->

    <!-- Caption buttons -->
    <SolidColorBrush x:Key="CaptionButtonBrush" Color="#E91E63"/>
    <!-- 深粉色 -->
    <SolidColorBrush x:Key="CaptionButtonForeground" Color="#E91E63"/>
    <!-- 深粉色 -->
    <SolidColorBrush x:Key="WindowIsNotActiveForeground" Color="#F48FB1"/>
    <!-- 浅粉色 -->
    <SolidColorBrush x:Key="CaptionButtonChoiceBrush" Color="#F48FB1"/>
    <!-- 浅粉色 -->
    <SolidColorBrush x:Key="CaptionButtonChoiceBackgrouundBrush" Color="#FADCE4"/>
    <!-- 次要背景色 -->
    <SolidColorBrush x:Key="CaptionButtonCloseBrush" Color="Red"/>

    <!-- Menu Items -->
    <!-- ... (other menu item styles) ... -->

    <!-- Context Menu -->
    <SolidColorBrush x:Key="toplevelmenuheaderhoverborder" Color="Transparent" />
    <SolidColorBrush x:Key="toplevelmenuheaderhover" Color="#FADCE4"/>
    <!-- 次要背景色 -->
    <SolidColorBrush x:Key="menuitemglyphpanelborderbrush" Color="#FADCE4"/>
    <!-- 次要背景色 -->
    <SolidColorBrush x:Key="MenuItemHighlightedInnerBorder" Color="#FADCE4"/>
    <!-- 次要背景色 -->
    <SolidColorBrush x:Key="MenuItemDisabledForeground" Color="#F48FB1"/>
    <!-- 浅粉色 -->
    <SolidColorBrush x:Key="MenuItemDisabledGlyphPanelBackground" Color="#FADCE4"/>
    <!-- 次要背景色 -->
    <SolidColorBrush x:Key="SubMenuBrushKey"   Color="#EAB1C7"/>
    <SolidColorBrush x:Key="SubMenuBorderBrushKey"   Color="Transparent"/>
    
    
    <SolidColorBrush x:Key="MenuItemDisabledGlyphFill" Color="#E91E63"/>
    <!-- 深粉色 -->
    <SolidColorBrush x:Key="environmentcommandbar"  Color="#F8BBD0"/>
    <!-- 浅粉色 -->
    <SolidColorBrush x:Key="environmentcommandbaricon" Color="#FADCE4"/>
    <!-- 次要背景色 -->
    <SolidColorBrush x:Key="EnvironmentCommandBarMenuMouseOverSubmenuGlyph" Color="#F48FB1"/>
    <!-- 浅粉色 -->
    <SolidColorBrush x:Key="environmentcommandbarmenuseparator" Color="#F48FB1"/>
    <!-- 浅粉色 -->
    <SolidColorBrush x:Key="EnvironmentCommandBarCheckBox" Color="#E91E63"/>
    <!-- 深粉色 -->
    <SolidColorBrush x:Key="EnvironmentCommandBarSelectedIcon" Color="#FADCE4"/>
    <!-- 次要背景色 -->
    <SolidColorBrush x:Key="EnvironmentCommandBarCheckBoxMouseOver" Color="#F5E6FF"/>
    <!-- 浅粉色 -->
    <SolidColorBrush x:Key="EnvironmentCommandBarHoverOverSelectedIcon" Color="#F48FB1"/>
    <!-- 浅粉色 -->
    <SolidColorBrush x:Key="EnvironmentCommandBarMenuItemMouseOver" Color="#F48FB1"/>
    <!-- 浅粉色 -->

    <SolidColorBrush x:Key="ContextMenuBackground" Color="#FADCE4"/>
    <!-- 次要背景色 -->
    <SolidColorBrush x:Key="ContextMenuBorderBrush" Color="#FADCE4"/>
    <!-- 次要背景色 -->
    <SolidColorBrush x:Key="ContextMenuRectangleFill" Color="#FADCE4"/>
    <!-- 次要背景色 -->

    <!-- ... (other styles) ... -->
</ResourceDictionary>
