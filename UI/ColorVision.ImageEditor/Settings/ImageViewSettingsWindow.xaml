<Window x:Class="ColorVision.ImageEditor.Settings.ImageViewSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:ColorVision.ImageEditor.Properties"
        Title="{x:Static properties:Resources.Settings_ImageSettingsTitle}"
        Width="940"
        Height="620"
        MinWidth="800"
        MinHeight="480"
        Background="{DynamicResource GlobalBackground}"
        Foreground="{DynamicResource GlobalTextBrush}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SettingsListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBackground}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBackground}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource GlobalTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10" TextElement.Foreground="{DynamicResource GlobalTextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" Background="{DynamicResource GlobalBorderBrush}">
                <ListBox x:Name="SettingsList"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource GlobalTextBrush}"
                         ItemContainerStyle="{StaticResource SettingsListBoxItemStyle}"
                         SelectionChanged="SettingsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Header}" Foreground="{DynamicResource GlobalTextBrush}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource ButtonBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource GlobalBorderBrush}">
                <ContentControl x:Name="SettingsContent"
                                Foreground="{DynamicResource GlobalTextBrush}" />
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,12,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button MinWidth="96" Margin="0,0,8,0" Click="Save_Click" Content="{x:Static properties:Resources.Settings_Save}" Style="{DynamicResource ButtonDefault}" />
            <Button MinWidth="96" Click="Close_Click" Content="{x:Static properties:Resources.Settings_Close}" Style="{DynamicResource ButtonDefault}" />
        </StackPanel>
    </Grid>
</Window>
