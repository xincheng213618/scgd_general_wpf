<UserControl x:Class="ColorVision.ImageEditor.Settings.ImageViewWorkspaceSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:properties="clr-namespace:ColorVision.ImageEditor.Properties">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Background="{DynamicResource GlobalBorderBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Margin="0,0,0,12" CornerRadius="6">
                <StackPanel Margin="10">
                    <TextBlock Text="{x:Static properties:Resources.Settings_ToolbarVisibility}" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{x:Static properties:Resources.Settings_ToolbarVisibilityDesc}"
                               Opacity="0.75" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <DockPanel Margin="0,5">
                        <ui:ToggleSwitch IsChecked="{Binding Config.IsToolBarAlVisible}" DockPanel.Dock="Right" />
                        <TextBlock Text="{x:Static properties:Resources.Settings_BottomToolbar}" Width="260"/>
                    </DockPanel>

                    <DockPanel Margin="0,5">
                        <ui:ToggleSwitch IsChecked="{Binding Config.IsToolBarDrawVisible}" DockPanel.Dock="Right" />
                        <TextBlock Text="{x:Static properties:Resources.Settings_DrawToolbar}" Width="260"/>
                    </DockPanel>

                    <DockPanel Margin="0,5">
                        <ui:ToggleSwitch IsChecked="{Binding Config.IsToolBarTopVisible}" DockPanel.Dock="Right" />
                        <TextBlock Text="{x:Static properties:Resources.Settings_TopToolbar}" Width="260"/>
                    </DockPanel>

                    <DockPanel Margin="0,5">
                        <ui:ToggleSwitch IsChecked="{Binding Config.IsToolBarLeftVisible}" DockPanel.Dock="Right" />
                        <TextBlock Text="{x:Static properties:Resources.Settings_LeftToolbar}" Width="260"/>
                    </DockPanel>

                    <DockPanel Margin="0,5">
                        <ui:ToggleSwitch IsChecked="{Binding Config.IsToolBarRightVisible}" DockPanel.Dock="Right" />
                        <TextBlock Text="{x:Static properties:Resources.Settings_RightToolbar}" Width="260"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource GlobalBorderBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Margin="0,0,0,12" CornerRadius="6">
                <StackPanel Margin="10">
                    <DockPanel Margin="0,0,0,10">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="{x:Static properties:Resources.Settings_EditorTools}" FontWeight="Bold"/>
                            <TextBlock Text="{x:Static properties:Resources.Settings_EditorToolsDesc}"
                                       Opacity="0.75" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{x:Static properties:Resources.Settings_ShowAll}" Click="ShowAll_Click" Margin="0,0,8,0" MinWidth="88"/>
                            <Button Content="{x:Static properties:Resources.Settings_HideAll}" Click="HideAll_Click" MinWidth="88"/>
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding EditorTools}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TypeName}" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding Location}" FontSize="11" Opacity="0.7" VerticalAlignment="Center" Margin="12,0,12,0"/>
                                    <ui:ToggleSwitch Grid.Column="2" IsChecked="{Binding IsVisible}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource GlobalBorderBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6">
                <StackPanel Margin="10">
                    <TextBlock Text="{x:Static properties:Resources.Settings_ImageOpeners}" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="{x:Static properties:Resources.Settings_ImageOpenersDesc}"
                               Opacity="0.75" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding ImageOpens}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding HandlerName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TypeName}" FontSize="11" Opacity="0.7"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{Binding Extensions}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>