<UserControl x:Class="ColorVision.ImageEditor.Settings.ImageViewContextSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:properties="clr-namespace:ColorVision.ImageEditor.Properties">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Background="{DynamicResource GlobalBorderBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" Margin="0,0,0,12" CornerRadius="6">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{x:Static properties:Resources.Settings_PropertySnapshot}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SummaryText}" Opacity="0.75" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>

                    <Button DockPanel.Dock="Right" Content="{x:Static properties:Resources.Settings_Refresh}" Click="Refresh_Click" MinWidth="88"/>
                </DockPanel>
            </Border>

            <Border Background="{DynamicResource GlobalBorderBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="16"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{x:Static properties:Resources.Settings_NoContextProperties}" TextWrapping="Wrap" Opacity="0.75"/>
            </Border>

            <ItemsControl ItemsSource="{Binding Sections}"
                          Visibility="{Binding HasEntries, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource GlobalBorderBrush}" BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" Margin="0,0,0,12" CornerRadius="6">
                            <StackPanel Margin="10">
                                <DockPanel Margin="0,0,0,10">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding ScopeName}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ScopeDescription}" FontSize="11" Opacity="0.75"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <TextBlock DockPanel.Dock="Right" Text="{Binding CountText}"
                                               Opacity="0.7" VerticalAlignment="Top"/>
                                </DockPanel>

                                <ItemsControl ItemsSource="{Binding Entries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="170"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Key}" FontWeight="SemiBold" Margin="0,0,12,0"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" FontFamily="Consolas"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Owner" Opacity="0.7" Margin="0,6,12,0"
                                                               Visibility="{Binding HasOwner, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Owner}" Opacity="0.8" Margin="0,6,0,0"
                                                               TextWrapping="Wrap"
                                                               Visibility="{Binding HasOwner, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static properties:Resources.Settings_DescriptionLabel}" Opacity="0.7" Margin="0,6,12,0"
                                                               Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Description}" Opacity="0.8" Margin="0,6,0,0"
                                                               TextWrapping="Wrap"
                                                               Visibility="{Binding HasDescription, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>