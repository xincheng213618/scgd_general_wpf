<Window x:Class="ColorVision.ImageEditor.BatchProcessing.BatchImageProcessingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量执行图像算法" Height="720" Width="980" MinHeight="600" MinWidth="820"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource GlobalBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="SettingsPanel" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="算法" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ComboBox x:Name="AlgorithmComboBox" DisplayMemberPath="Name" SelectionChanged="AlgorithmComboBox_SelectionChanged"/>
                    <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" MinHeight="82">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ContentControl x:Name="AlgorithmOptionsContent"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="输出" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="结果格式"/>
                    <ComboBox x:Name="OutputFormatComboBox" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="3" DisplayMemberPath="Name" SelectedValuePath="Value"/>

                    <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="文件名后缀"/>
                    <TextBox x:Name="SuffixTextBox" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3"/>

                    <TextBlock Grid.Row="4" VerticalAlignment="Center" Text="输出目录"/>
                    <TextBox x:Name="OutputDirectoryTextBox" Grid.Row="4" Grid.Column="2" ToolTip="留空时保存到每个源文件所在目录"/>
                    <Button Grid.Row="4" Grid.Column="4" Content="浏览..." Padding="12,3" Click="BrowseOutputDirectory_Click"/>

                    <StackPanel Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="3">
                        <CheckBox x:Name="PreserveFolderStructureCheckBox" Content="文件夹输入时保留目录结构" IsChecked="True"/>
                        <CheckBox x:Name="AvoidOverwriteCheckBox" Content="不覆盖已有结果（自动追加编号）" IsChecked="True" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Header="待处理图像" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="AddFilesButton" Content="添加文件..." Padding="14,4" Margin="0,0,8,0" Click="AddFiles_Click"/>
                    <Button x:Name="AddFolderButton" Content="添加文件夹..." Padding="14,4" Margin="0,0,8,0" Click="AddFolder_Click"/>
                    <Button x:Name="RemoveButton" Content="移除选中" Padding="14,4" Margin="0,0,8,0" Click="RemoveSelected_Click"/>
                    <Button x:Name="ClearButton" Content="清空" Padding="14,4" Click="Clear_Click"/>
                    <CheckBox x:Name="RecursiveCheckBox" Content="包含子文件夹" IsChecked="True" Margin="20,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FileCountTextBlock" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <DataGrid x:Name="FilesDataGrid" Grid.Row="2" ItemsSource="{Binding Files}" AutoGenerateColumns="False"
                          IsReadOnly="True" SelectionMode="Extended" CanUserAddRows="False" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="180"/>
                        <DataGridTextColumn Header="源文件" Binding="{Binding FilePath}" Width="2*"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="150"/>
                        <DataGridTextColumn Header="输出文件" Binding="{Binding OutputPath}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ProgressBar" Height="18" Minimum="0"/>
            <TextBlock x:Name="ProgressTextBlock" Grid.Column="2" MinWidth="110" TextAlignment="Right" VerticalAlignment="Center" Text="尚未执行"/>
        </Grid>

        <DockPanel Grid.Row="6">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="取消" Width="90" Margin="12,0,8,0" IsEnabled="False" Click="Cancel_Click"/>
                <Button x:Name="ExecuteButton" Content="开始执行" Width="100" Click="Execute_Click"/>
            </StackPanel>
            <TextBlock Text="输出目录留空时，将在源文件同目录按“原名 + 后缀”保存；CVRAW/CVCIE 的“与源格式相同”会输出 TIFF。"
                       VerticalAlignment="Center" Opacity="0.75" TextWrapping="Wrap"/>
        </DockPanel>
    </Grid>
</Window>
