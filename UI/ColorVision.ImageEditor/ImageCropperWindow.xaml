<Window x:Class="ColorVision.ImageEditor.ImageCropperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ColorVision.ImageEditor"
        Title="框选区域" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Style="{StaticResource ResourceKey=WindowBaseStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0" ToolBarTray.IsLocked="True" Margin="2">
            <TextBlock Text="请在图像上框选区域" VerticalAlignment="Center" Margin="5,0"/>
            <Separator/>
            <TextBlock Text="结果:" VerticalAlignment="Center" Margin="5,0"/>
            <TextBlock x:Name="ResultText" VerticalAlignment="Center" Margin="5,0" Foreground="DodgerBlue"/>
        </ToolBar>

        <local:ImageView x:Name="ImageView" Grid.Row="1"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="确定" Width="80" Height="28" Margin="5" Click="OK_Click" IsDefault="True" x:Name="OKButton" IsEnabled="False"/>
            <Button Content="取消" Width="80" Height="28" Margin="5" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
