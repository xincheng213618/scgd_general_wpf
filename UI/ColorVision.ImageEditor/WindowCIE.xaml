<Window x:Class="ColorVision.ImageEditor.WindowCIE"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cie="clr-namespace:ColorVision.ImageEditor.Cie"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.ImageEditor.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.Cie_Title}"
        Height="760"
        Width="1080"
        MinHeight="580"
        MinWidth="860"
        Background="{DynamicResource GlobalBackground}"
        Icon="/ColorVision.ImageEditor;component/Assets/Image/CIE1931xy.ico"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PanelGroupBox" TargetType="{x:Type GroupBox}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="OptionCheckBox" TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Margin" Value="0,3,10,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PanelButton" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style x:Key="ReadoutText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Margin" Value="0,2,0,2" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10,8"
                Background="{DynamicResource GlobalBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,8,0" Text="{x:Static properties:Resources.Cie_CoordinateSystem}" />
                    <ComboBox x:Name="ComboBoxDiagram"
                              Width="150"
                              SelectedIndex="0"
                              SelectionChanged="ComboBoxDiagram_SelectionChanged">
                        <ComboBoxItem Content="CIE 1931 xy" />
                        <ComboBoxItem Content="CIE 1960 uv" />
                        <ComboBoxItem Content="CIE 1976 u'v'" />
                    </ComboBox>
                    <Button Margin="8,0,0,0"
                            Padding="10,2"
                            Click="ButtonFit_Click"
                            Content="{x:Static properties:Resources.Cie_Fit}" />
                </StackPanel>
                <TextBlock x:Name="TextBlockDiagramSummary"
                           Margin="16,0,0,0"
                           HorizontalAlignment="Right"
                           FontWeight="SemiBold" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="286" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="10"
                    Background="{DynamicResource GlobalBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <GroupBox Header="{x:Static properties:Resources.Cie_DisplayPresets}" Style="{StaticResource PanelGroupBox}">
                            <UniformGrid Columns="2">
                                <Button Content="{x:Static properties:Resources.Cie_Display}"
                                        Click="PresetButton_Click"
                                        Style="{StaticResource PanelButton}"
                                        Tag="Display" />
                                <Button Content="{x:Static properties:Resources.Cie_Cinema}"
                                        Click="PresetButton_Click"
                                        Style="{StaticResource PanelButton}"
                                        Tag="Cinema" />
                                <Button Content="{x:Static properties:Resources.Cie_SelectAll}"
                                        Click="PresetButton_Click"
                                        Style="{StaticResource PanelButton}"
                                        Tag="All" />
                                <Button Content="{x:Static properties:Resources.Cie_Clear}"
                                        Click="PresetButton_Click"
                                        Style="{StaticResource PanelButton}"
                                        Tag="Clear" />
                            </UniformGrid>
                        </GroupBox>

                        <GroupBox Header="{x:Static properties:Resources.Cie_ColorGamut}" Style="{StaticResource PanelGroupBox}">
                            <UniformGrid Columns="2">
                                <CheckBox x:Name="CheckBoxSRgb"
                                          Content="sRGB"
                                          IsChecked="True"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxRec709"
                                          Content="BT.709"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxAdobeRgb"
                                          Content="Adobe RGB"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxDisplayP3"
                                          Content="Display P3"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxNtsc"
                                          Content="NTSC 1953"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxDciP3"
                                          Content="DCI-P3"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxRec2020"
                                          Content="BT.2020"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxPal"
                                          Content="EBU/PAL"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxSmpteC"
                                          Content="SMPTE-C"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxProPhoto"
                                          Content="ProPhoto"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxAcesCg"
                                          Content="ACEScg"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="GamutCheckBox_Changed"
                                          Unchecked="GamutCheckBox_Changed" />
                            </UniformGrid>
                        </GroupBox>

                        <GroupBox Header="{x:Static properties:Resources.Cie_WhitePointLightSource}" Style="{StaticResource PanelGroupBox}">
                            <UniformGrid Columns="2">
                                <CheckBox x:Name="CheckBoxD65"
                                          Content="D65"
                                          IsChecked="True"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="IlluminantCheckBox_Changed"
                                          Unchecked="IlluminantCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxE"
                                          Content="E"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="IlluminantCheckBox_Changed"
                                          Unchecked="IlluminantCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxD50"
                                          Content="D50"
                                          IsChecked="True"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="IlluminantCheckBox_Changed"
                                          Unchecked="IlluminantCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxD55"
                                          Content="D55"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="IlluminantCheckBox_Changed"
                                          Unchecked="IlluminantCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxD60"
                                          Content="D60"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="IlluminantCheckBox_Changed"
                                          Unchecked="IlluminantCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxC"
                                          Content="C"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="IlluminantCheckBox_Changed"
                                          Unchecked="IlluminantCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxA"
                                          Content="A"
                                          IsChecked="True"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="IlluminantCheckBox_Changed"
                                          Unchecked="IlluminantCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxD75"
                                          Content="D75"
                                          IsChecked="True"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="IlluminantCheckBox_Changed"
                                          Unchecked="IlluminantCheckBox_Changed" />
                            </UniformGrid>
                        </GroupBox>

                        <GroupBox Header="{x:Static properties:Resources.Cie_ReferenceLines}" Style="{StaticResource PanelGroupBox}">
                            <StackPanel>
                                <CheckBox x:Name="CheckBoxCct"
                                          Content="Tc(K)"
                                          IsChecked="True"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="CctCheckBox_Changed"
                                          Unchecked="CctCheckBox_Changed" />
                                <CheckBox x:Name="CheckBoxDaylight"
                                          Content="D locus"
                                          IsChecked="True"
                                          Style="{StaticResource OptionCheckBox}"
                                          Checked="DaylightCheckBox_Changed"
                                          Unchecked="DaylightCheckBox_Changed" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="{x:Static properties:Resources.Cie_CurrentPoint}" Style="{StaticResource PanelGroupBox}">
                            <StackPanel>
                                <TextBlock x:Name="TextBlockSelectedXy"
                                           Style="{StaticResource ReadoutText}"
                                           Text="xy: --" />
                                <TextBlock x:Name="TextBlockSelectedUv1960"
                                           Style="{StaticResource ReadoutText}"
                                           Text="uv: --" />
                                <TextBlock x:Name="TextBlockSelectedUv1976"
                                           Style="{StaticResource ReadoutText}"
                                           Text="u'v': --" />
                                <TextBlock x:Name="TextBlockSelectedCct"
                                           Style="{StaticResource ReadoutText}"
                                           Text="CCT: --" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BorderBrush}" />

            <Border Grid.Column="2" Background="#1E1E1E">
                <cie:CieDiagramView x:Name="CieView" />
            </Border>
        </Grid>

        <Border Grid.Row="2"
                MinHeight="28"
                Padding="10,4"
                Background="{DynamicResource GlobalBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="TextBlockCursor"
                       FontFamily="Consolas"
                       Foreground="{DynamicResource GlobalTextBrush}"
                       Text="Cursor: --" />
        </Border>
    </Grid>
</Window>
