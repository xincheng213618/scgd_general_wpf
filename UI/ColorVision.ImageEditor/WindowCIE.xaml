<Window x:Class="ColorVision.ImageEditor.WindowCIE"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cie="clr-namespace:ColorVision.ImageEditor.Cie"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CIE" Height="560" Width="560" Icon="/ColorVision.ImageEditor;component/Assets/Image/CIE1931xy.ico" Initialized="Window_Initialized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ToolBarTray Grid.Row="0">
            <ToolBar ToolBarTray.IsLocked="True">
                <ComboBox x:Name="ComboBoxDiagram"
                          Width="130"
                          Margin="2,0,6,0"
                          SelectedIndex="0"
                          SelectionChanged="ComboBoxDiagram_SelectionChanged">
                    <ComboBoxItem Content="CIE 1931 xy" />
                    <ComboBoxItem Content="CIE 1976 u'v'" />
                </ComboBox>
                <Separator />
                <CheckBox x:Name="CheckBoxSRgb"
                          Margin="6,0,2,0"
                          Content="sRGB"
                          IsChecked="True"
                          Checked="GamutCheckBox_Changed"
                          Unchecked="GamutCheckBox_Changed" />
                <CheckBox x:Name="CheckBoxP3"
                          Margin="6,0,2,0"
                          Content="P3"
                          Checked="GamutCheckBox_Changed"
                          Unchecked="GamutCheckBox_Changed" />
                <CheckBox x:Name="CheckBoxRec2020"
                          Margin="6,0,2,0"
                          Content="BT.2020"
                          Checked="GamutCheckBox_Changed"
                          Unchecked="GamutCheckBox_Changed" />
            </ToolBar>
        </ToolBarTray>

        <cie:CieDiagramView x:Name="CieView" Grid.Row="1" />
    </Grid>
</Window>
