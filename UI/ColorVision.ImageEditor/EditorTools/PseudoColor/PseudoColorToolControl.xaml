<UserControl x:Class="ColorVision.ImageEditor.EditorTools.PseudoColor.PseudoColorToolControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <StackPanel>
        <ToggleButton Margin="0,0,0,2" IsChecked="{Binding IsEnabled, Mode=TwoWay}">
            <Image Margin="-5" Source="/ColorVision.ImageEditor;component/Assets/png/PowerToy.png" Style="{StaticResource ToolBarImage}" />
        </ToggleButton>
        <ToggleButton Margin="0,0,0,2"
                      Padding="3"
                      HorizontalAlignment="Stretch"
                      Content="A"
                      FontSize="9"
                      IsChecked="{Binding IsAutoSetRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="Auto Range"
                      Visibility="{Binding IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
        <Grid Height="120" Visibility="{Binding IsEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBox Grid.Row="0" Width="28" HorizontalContentAlignment="Center" Background="Transparent" BorderThickness="0" FontSize="8" Style="{StaticResource BaseStyle}" Text="{Binding SliderValueEnd, StringFormat=#0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Grid.Row="2" Width="28" HorizontalContentAlignment="Center" Background="Transparent" BorderThickness="0" FontSize="8" Style="{StaticResource BaseStyle}" Text="{Binding SliderValueStart, StringFormat=#0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Grid Grid.Row="1" Width="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="White" CornerRadius="10,10,0,0" />
                <Border Grid.Row="1" Background="Transparent">
                    <Image Source="{Binding ColormapPreviewImage}" VerticalAlignment="Top" Stretch="Fill" />
                </Border>
                <Border Grid.Row="2" Background="Black" CornerRadius="0,0,10,10 " />
            </Grid>
            <hc:RangeSlider Grid.Row="1"
                            HorizontalAlignment="Center"
                            hc:TipElement.Placement="Left"
                            hc:TipElement.StringFormat="#0"
                            hc:TipElement.Visibility="Visible"
                            Background="Transparent"
                            FocusVisualStyle="{x:Null}"
                            Minimum="{Binding SliderMinimum, Mode=TwoWay}"
                            Maximum="{Binding SliderMaximum, Mode=TwoWay}"
                            Orientation="Vertical"
                            SmallChange="{Binding SliderSmallChange, Mode=TwoWay}"
                            LargeChange="{Binding SliderLargeChange, Mode=TwoWay}"
                            Style="{StaticResource RangeSliderBaseStyle}"
                            ValueEnd="{Binding SliderValueEnd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            ValueStart="{Binding SliderValueStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
    </StackPanel>
</UserControl>