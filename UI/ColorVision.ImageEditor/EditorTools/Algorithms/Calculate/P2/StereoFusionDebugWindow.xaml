<Window x:Class="ColorVision.ImageEditor.EditorTools.Algorithms.Calculate.P2.StereoFusionDebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ColorVision.ImageEditor.EditorTools.Algorithms.Calculate.P2"
        Title="双目标定融合" Height="780" Width="1200" MinHeight="640" MinWidth="980"
        Background="#F6F7F9" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0B6B5E"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#667085"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D9DEE5"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF"/>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="选择右图..." Click="SelectRightImage_Click"/>
                <Button Content="加载标定 JSON..." Click="LoadCalibration_Click"/>
                <Button x:Name="RunButton" Content="运行融合" Click="RunButton_Click"/>
                <Button Content="清除 Overlay" Click="ClearOverlay_Click"/>
                <Button Content="复制配置" Click="CopyConfig_Click"/>
                <Button Content="复制结果" Click="CopyResult_Click"/>
            </StackPanel>
            <TextBlock x:Name="SummaryText" DockPanel.Dock="Right"
                       FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="LeftInfoText" Text="左图：当前编辑器图像" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid Grid.Row="1">
                        <Image x:Name="LeftPreview" Stretch="Uniform"/>
                        <local:StereoPointPreviewOverlay x:Name="LeftPointOverlay" IsHitTestVisible="False"/>
                    </Grid>
                </Grid>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="RightInfoText" Text="右图：尚未选择" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid Grid.Row="1">
                        <Image x:Name="RightPreview" Stretch="Uniform"/>
                        <local:StereoPointPreviewOverlay x:Name="RightPointOverlay" IsHitTestVisible="False"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.45*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="融合配置 JSON（标定值必须替换为真实数据）"
                               FontWeight="SemiBold" Margin="2,0,0,8"/>
                    <TextBox x:Name="ConfigText" AcceptsReturn="True" AcceptsTab="True"
                             FontFamily="Consolas" FontSize="12" TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="8">
                <TabControl>
                    <TabItem Header="三维点">
                        <DataGrid x:Name="PointsGrid" AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True" GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="72"/>
                                <DataGridTextColumn Header="Left" Binding="{Binding Left}" Width="110"/>
                                <DataGridTextColumn Header="Right" Binding="{Binding Right}" Width="110"/>
                                <DataGridTextColumn Header="X mm" Binding="{Binding X, StringFormat=F2}" Width="82"/>
                                <DataGridTextColumn Header="Y mm" Binding="{Binding Y, StringFormat=F2}" Width="82"/>
                                <DataGridTextColumn Header="Z mm" Binding="{Binding Z, StringFormat=F2}" Width="90"/>
                                <DataGridTextColumn Header="Parallax" Binding="{Binding Parallax, StringFormat=F2}" Width="84"/>
                                <DataGridTextColumn Header="Reproj" Binding="{Binding Reprojection, StringFormat=F3}" Width="78"/>
                                <DataGridTextColumn Header="Conf" Binding="{Binding Confidence, StringFormat=F3}" Width="72"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="结果 JSON">
                        <TextBox x:Name="ResultText" AcceptsReturn="True" AcceptsTab="True"
                                 FontFamily="Consolas" FontSize="12" IsReadOnly="True"
                                 TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"/>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="4" Margin="0,10,0,0"
                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/>
    </Grid>
</Window>
