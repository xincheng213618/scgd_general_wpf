<Window x:Class="ColorVision.ImageEditor.EditorTools.Algorithms.FilterDenoiseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:properties="clr-namespace:ColorVision.ImageEditor.Properties"
        Title="滤波/去噪" Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="滤波/去噪" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="类型" VerticalAlignment="Center" MinWidth="70" Margin="0,0,10,0"/>
            <ComboBox x:Name="FilterCombo" SelectedIndex="0" SelectionChanged="Param_Changed">
                <ComboBoxItem Content="双边滤波"/>
                <ComboBoxItem Content="均值模糊"/>
            </ComboBox>
        </DockPanel>

        <DockPanel Grid.Row="2" Margin="0,0,0,8">
            <TextBlock Text="{x:Static properties:Resources.Algorithm_KernelSizeOdd}" VerticalAlignment="Center" MinWidth="70" Margin="0,0,10,0"/>
            <TextBox DockPanel.Dock="Right" Text="{Binding ElementName=KernelSlider, Path=Value, StringFormat=F0}" Width="50" Margin="5,0,0,0"/>
            <hc:PreviewSlider x:Name="KernelSlider"
                              Minimum="1" Maximum="31" Value="5"
                              TickFrequency="2"
                              IsSnapToTickEnabled="True"
                              ValueChanged="Param_Changed"/>
        </DockPanel>

        <DockPanel Grid.Row="3" x:Name="SigmaPanel" Margin="0,0,0,8">
            <TextBlock Text="空间 Sigma" VerticalAlignment="Center" MinWidth="70" Margin="0,0,10,0"/>
            <TextBox DockPanel.Dock="Right" Text="{Binding ElementName=SigmaSlider, Path=Value, StringFormat=F1}" Width="50" Margin="5,0,0,0"/>
            <hc:PreviewSlider x:Name="SigmaSlider"
                              Minimum="0.1" Maximum="20" Value="1.5"
                              TickFrequency="0.1"
                              IsSnapToTickEnabled="False"
                              ValueChanged="Param_Changed"/>
        </DockPanel>

        <DockPanel Grid.Row="4" x:Name="SigmaColorPanel" Margin="0,0,0,8">
            <TextBlock Text="颜色 Sigma" VerticalAlignment="Center" MinWidth="70" Margin="0,0,10,0"/>
            <TextBox DockPanel.Dock="Right" Text="{Binding ElementName=SigmaColorSlider, Path=Value, StringFormat=F0}" Width="50" Margin="5,0,0,0"/>
            <hc:PreviewSlider x:Name="SigmaColorSlider"
                              Minimum="1" Maximum="200" Value="75"
                              TickFrequency="1"
                              IsSnapToTickEnabled="True"
                              ValueChanged="Param_Changed"/>
        </DockPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{x:Static properties:Resources.Algorithm_Apply}" Width="80" Click="Apply_Click" Margin="0,0,10,0"/>
            <Button Content="{x:Static properties:Resources.Algorithm_Cancel}" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
