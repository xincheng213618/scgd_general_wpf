<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="ToolBtn" TargetType="Button">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Margin" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#DDFFFFFF"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="#50505050" BorderBrush="#40707070"
                            BorderThickness="1" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#80707070"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#80AAAAAA"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#A0909090"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource ToolBtn}">
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style x:Key="ToggleActionBtn" TargetType="ToggleButton">
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="6,0"/>
        <Setter Property="Foreground" Value="#DDFFFFFF"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd" Background="#50505050" BorderBrush="#40707070"
                            BorderThickness="1" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#80707070"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#80AAAAAA"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#A0909090"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#80AAAAAA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#99FFFFFF"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Margin" Value="2,0,0,3"/>
    </Style>

    <!-- Dark theme TreeView -->
    <Style x:Key="DarkTreeView" TargetType="TreeView">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#D0D0D0"/>
        <Setter Property="BorderBrush" Value="#30FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="2"/>
    </Style>

    <Style x:Key="DarkTreeViewItem" TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="#D0D0D0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="2,1"/>
        <Setter Property="Margin" Value="0,1"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#304090DD"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#20FFFFFF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Panel action button (smaller, for tree panel header) -->
    <Style x:Key="PanelActionBtn" TargetType="Button">
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="4,0,0,0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="#CCFFFFFF"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="#30505050" BorderBrush="#30707070"
                            BorderThickness="1" CornerRadius="3" Padding="6,2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#50707070"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#60AAAAAA"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#70909090"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
