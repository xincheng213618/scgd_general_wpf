<Window x:Class="ColorVision.ImageEditor.Window3D"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.ImageEditor.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.ThreeD_View3D}" Height="600" Width="1000"
        Initialized="Window_Initialized" Closed="Window_Closed">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ThreeDStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid x:Name="ContentGrid"/>

            <!-- Toolbar overlay panel -->
            <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8" Panel.ZIndex="99"
                    Background="#C8181818" CornerRadius="6" Padding="8"
                    BorderBrush="#30FFFFFF" BorderThickness="1">
                <StackPanel Width="130">
                    <!-- Height Scale -->
                    <DockPanel>
                        <TextBlock Text="{x:Static properties:Resources.ThreeD_HeightScale}" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource ToolBtn}" Content="+" ToolTip="{x:Static properties:Resources.ThreeD_IncreaseHeightToolTip}" Click="HeightScaleIncrease_Click"/>
                            <Button Style="{StaticResource ToolBtn}" Content="-" ToolTip="{x:Static properties:Resources.ThreeD_DecreaseHeightToolTip}" Click="HeightScaleDecrease_Click"/>
                        </StackPanel>
                    </DockPanel>

                    <Separator Background="#20FFFFFF" Margin="0,4"/>

                    <!-- Camera Position -->
                    <TextBlock Text="{x:Static properties:Resources.ThreeD_CameraPosition}" Style="{StaticResource SectionLabel}"/>
                    <Grid HorizontalAlignment="Center" Width="96">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource ToolBtn}" Content="&#x25C0;" ToolTip="{x:Static properties:Resources.ThreeD_MoveLeftToolTip}" Click="CameraMoveLeft_Click"/>
                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource ToolBtn}" Content="&#x25B2;" ToolTip="{x:Static properties:Resources.ThreeD_MoveForwardToolTip}" Click="CameraMoveForward_Click"/>
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource ToolBtn}" Content="&#x25B6;" ToolTip="{x:Static properties:Resources.ThreeD_MoveRightToolTip}" Click="CameraMoveRight_Click"/>
                        <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource ToolBtn}" Content="&#x25BC;" ToolTip="{x:Static properties:Resources.ThreeD_MoveBackToolTip}" Click="CameraMoveBack_Click"/>
                    </Grid>

                    <Separator Background="#20FFFFFF" Margin="0,4"/>

                    <!-- Look Direction -->
                    <TextBlock Text="{x:Static properties:Resources.ThreeD_LookDirection}" Style="{StaticResource SectionLabel}"/>
                    <Grid HorizontalAlignment="Center" Width="96">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource ToolBtn}" Content="&#x25C0;" ToolTip="{x:Static properties:Resources.ThreeD_LookLeftToolTip}" Click="LookLeft_Click"/>
                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource ToolBtn}" Content="&#x25B2;" ToolTip="{x:Static properties:Resources.ThreeD_LookUpToolTip}" Click="LookUp_Click"/>
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource ToolBtn}" Content="&#x25B6;" ToolTip="{x:Static properties:Resources.ThreeD_LookRightToolTip}" Click="LookRight_Click"/>
                        <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource ToolBtn}" Content="&#x25BC;" ToolTip="{x:Static properties:Resources.ThreeD_LookDownToolTip}" Click="LookDown_Click"/>
                    </Grid>

                    <Separator Background="#20FFFFFF" Margin="0,4"/>

                    <!-- Colormap Selection -->
                    <TextBlock Text="{x:Static properties:Resources.ThreeD_PseudoColor}" Style="{StaticResource SectionLabel}"/>
                    <ComboBox x:Name="ComboBoxColormap" Margin="2"
                              SelectionChanged="ComboBoxColormap_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <Image Width="14" Height="50" Stretch="Fill" Source="{Binding ImageSource}">
                                        <Image.LayoutTransform>
                                            <RotateTransform Angle="90"/>
                                        </Image.LayoutTransform>
                                    </Image>
                                    <TextBlock Text="{Binding Name}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Separator Background="#20FFFFFF" Margin="0,4"/>

                    <!-- Action Buttons -->
                    <Button Style="{StaticResource ActionBtn}" ToolTip="{x:Static properties:Resources.ThreeD_ResetViewToolTip}" Click="ResetViewButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#x21BB;" Margin="0,0,4,0"/><TextBlock Text="{x:Static properties:Resources.ThreeD_ResetView}"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource ActionBtn}" ToolTip="{x:Static properties:Resources.ThreeD_ScreenshotToolTip}" Click="ScreenshotButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#x1F4F7;" Margin="0,0,4,0"/><TextBlock Text="{x:Static properties:Resources.ThreeD_Screenshot}"/></StackPanel>
                    </Button>
                    <Button Style="{StaticResource ActionBtn}" Content="{x:Static properties:Resources.ThreeD_ExportModel}" ToolTip="{x:Static properties:Resources.ThreeD_ExportModelToolTip}" Click="ExportModelButton_Click"/>
                    <Button Style="{StaticResource ActionBtn}" ToolTip="{x:Static properties:Resources.ThreeD_SettingsToolTip}" Click="SettingsButton_Click">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#x2699;" Margin="0,0,4,0"/><TextBlock Text="{x:Static properties:Resources.ThreeD_Settings}"/></StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Settings Popup -->
            <Popup x:Name="SettingsPopup" Placement="Center"
                   PlacementTarget="{Binding ElementName=ContentGrid}"
                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                <Border Background="#F0202020" CornerRadius="8" Padding="16"
                        BorderBrush="#60808080" BorderThickness="1">
                    <StackPanel Width="220">
                        <TextBlock Text="{x:Static properties:Resources.ThreeD_RenderSettings}" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"/>
                        <TextBlock Text="{x:Static properties:Resources.ThreeD_TargetResolutionX}" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtTargetX" Margin="0,0,0,8" Padding="4,2"/>
                        <TextBlock Text="{x:Static properties:Resources.ThreeD_TargetResolutionY}" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtTargetY" Margin="0,0,0,12" Padding="4,2"/>
                        <TextBlock Text="{x:Static properties:Resources.ThreeD_ApplyNote}" Foreground="#999999" FontSize="10" Margin="0,0,0,8"/>
                        <Button Content="{x:Static properties:Resources.ThreeD_ApplyRefresh}" Click="ApplySettings_Click" Padding="8,4"
                                HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- Hover Info Popup -->
            <Popup x:Name="HoverInfoPopup" Placement="RelativePoint"
                   PlacementTarget="{Binding ElementName=ContentGrid}"
                   AllowsTransparency="True">
                <Border Background="#D0000000" CornerRadius="4" Padding="8,4"
                        BorderBrush="#40FFFFFF" BorderThickness="1">
                    <TextBlock x:Name="HoverInfoText" Foreground="White" FontSize="11"
                               LineHeight="16" LineStackingStrategy="BlockLineHeight"/>
                </Border>
            </Popup>
        </Grid>

        <!-- Colorbar Legend -->
        <Grid x:Name="ColorBarPanel" Grid.Column="1" Width="75" Margin="0,15,5,15" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="5" BorderBrush="#888" BorderThickness="1" Margin="2,0">
                <Image x:Name="ColorBarImage" Stretch="Fill"/>
            </Border>

            <TextBlock Grid.Row="0" Grid.Column="1" Text="255" Foreground="White" FontSize="10" VerticalAlignment="Top" Margin="4,0,0,0"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="204" Foreground="White" FontSize="10" VerticalAlignment="Bottom" Margin="4,0,0,0"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="153" Foreground="White" FontSize="10" VerticalAlignment="Bottom" Margin="4,0,0,0"/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="102" Foreground="White" FontSize="10" VerticalAlignment="Bottom" Margin="4,0,0,0"/>
            <TextBlock Grid.Row="3" Grid.Column="1" Text="  51" Foreground="White" FontSize="10" VerticalAlignment="Bottom" Margin="4,0,0,0"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="    0" Foreground="White" FontSize="10" VerticalAlignment="Bottom" Margin="4,0,0,0"/>
        </Grid>
    </Grid>

</Window>
