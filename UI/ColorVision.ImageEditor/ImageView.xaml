<UserControl x:Class="ColorVision.ImageEditor.ImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converter="clr-namespace:ColorVision.ImageEditor.Draw.Converter"
             xmlns:converters="clr-namespace:ColorVision.ImageEditor.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:ColorVision.ImageEditor"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.ImageEditor.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:ImageView, IsDesignTimeCreatable=False}"
             d:DesignHeight="600" d:DesignWidth="800" AllowDrop="True"
             FocusVisualStyle="{x:Null}"
             Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="TextBox">
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown" />
        </Style>
        <Style x:Key="CompactInspectorButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" />
                            <Border x:Name="HoverLayer"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="6"
                                    Opacity="0" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverLayer" Property="Opacity" Value="0.14" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverLayer" Property="Opacity" Value="0.22" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CompactInspectorToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="CheckedLayer"
                                    Background="{TemplateBinding BorderBrush}"
                                    CornerRadius="6"
                                    Opacity="0" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckedLayer" Property="Opacity" Value="0.14" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CheckedLayer" Property="Opacity" Value="0.22" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckedLayer" Property="Opacity" Value="0.28" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CompactInspectorValueTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="MinHeight" Value="20" />
        </Style>
        <Style x:Key="CompactInspectorValueComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboBox.Small}">
            <Setter Property="MinHeight" Value="20" />
        </Style>
        <GeometryDrawing x:Key="GridSquare" Brush="{DynamicResource GlobalTextBrush}" Geometry="M0,0 L0,1 1,1 1,0 Z" />
        <DrawingBrush x:Key="TransparentGridBrush" Opacity="0.1" TileMode="Tile" Viewport="0 0 20 20" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <!--  Gray square  -->
                    <GeometryDrawing Brush="Gray" Geometry="M0,0 L0,10 10,10 10,0 Z" />
                    <!--  Transparent square  -->
                    <GeometryDrawing Brush="Transparent" Geometry="M10,0 L10,10 20,10 20,0 Z" />
                    <!--  Another row  -->
                    <GeometryDrawing Brush="Transparent" Geometry="M0,10 L0,20 10,20 10,10 Z" />
                    <GeometryDrawing Brush="Gray" Geometry="M10,10 L10,20 20,20 20,10 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <GeometryDrawing x:Key="SmallGridGeometry" Brush="{DynamicResource GlobalTextBrush}" Geometry="M0,0 L0,1 0.03,1 0.03,0.03 1,0.03 1,0 Z" />

        <GeometryDrawing x:Key="LargeGridGeometry" Brush="{DynamicResource GlobalTextBrush}" Geometry="M0,0 L0,1 0.015,1 0.015,0.015 1,0.015 1,0 Z" />

        <DrawingBrush x:Key="SmallGridLinesDrawingBrush" Drawing="{StaticResource SmallGridGeometry}" Opacity="0.1" TileMode="Tile" Viewport="0 0 20 20" ViewportUnits="Absolute" />

        <DrawingBrush x:Key="LargeGridLinesDrawingBrush" Drawing="{StaticResource LargeGridGeometry}" Opacity="0.5" TileMode="Tile" Viewport="0 0 200 200" ViewportUnits="Absolute" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid x:Name="ImageContentGrid" Grid.Row="1">
            <Grid Background="{StaticResource LargeGridLinesDrawingBrush}" Visibility="Collapsed" />
            <Grid Background="{StaticResource SmallGridLinesDrawingBrush}" Visibility="Collapsed" />

            <Grid x:Name="ZoomGrid" Background="{StaticResource TransparentGridBrush}">
                <local:Zoombox x:Name="Zoombox1" Grid.ColumnSpan="2" x:FieldModifier="public" MaxZoom="{Binding MaxZoom}" MinZoom="{Binding MinZoom}">
                    <local:DrawCanvas x:Name="ImageShow" x:FieldModifier="public" FocusVisualStyle="{x:Null}" RenderOptions.BitmapScalingMode="HighQuality" RenderOptions.ClearTypeHint="Auto" />
                </local:Zoombox>
                <Canvas x:Name="TextEditorOverlay" Grid.ColumnSpan="2" Background="{x:Null}" Panel.ZIndex="6" />
                <local:PixelValueOverlay x:Name="PixelValueOverlay"
                                         Grid.ColumnSpan="2"
                                         IsHitTestVisible="False" ClipToBounds="True" Opacity="0.9"/>

                <ComboBox x:Name="ComboBoxLayers" Grid.Column="1" Margin="5,5,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" x:FieldModifier="public" BorderThickness="0" DisplayMemberPath="DisplayName" Opacity="0.6" SelectedIndex="0" Style="{StaticResource ComboBox.Small}" Visibility="Collapsed" />
                <ToolBar x:Name="ToolBarAl" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Bottom" x:FieldModifier="public" Background="Transparent" Opacity="0.8" Style="{StaticResource ToolBarBaseStyle}" ToolBarTray.IsLocked="True" Visibility="{Binding Config.IsToolBarAlVisible, Converter={StaticResource bool2VisibilityConverter}}" />

                <StackPanel x:Name="DrawToolbarHost"
                        Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="10"
                            Visibility="{Binding Config.IsToolBarDrawVisible, Converter={StaticResource bool2VisibilityConverter}}">
                    <Border x:Name="CompactInspectorOverlay"
                        Margin="0,0,0,2"
                            Padding="5,3"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource GlobalBackground}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0"
                            CornerRadius="12"
                            Visibility="Collapsed"
                            Opacity="0.9">
                        <StackPanel x:Name="CompactInspectorPanel" Orientation="Horizontal" />
                    </Border>
                    <ToolBarTray x:Name="ToolBarDraw" HorizontalAlignment="Center" VerticalAlignment="Bottom" Opacity="0.9">
                        <ToolBar ToolBarTray.IsLocked="True" />
                    </ToolBarTray>
                </StackPanel>

                <ToolBarTray x:Name="ToolBarTop" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0.9" Visibility="{Binding Config.IsToolBarTopVisible, Converter={StaticResource bool2VisibilityConverter}}">
                    <ToolBar Margin="0,2,4,0" ToolBarTray.IsLocked="True" />
                </ToolBarTray>

                <ToolBarTray x:Name="ToolBarLeft" Margin="2,50,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.9" Orientation="Vertical" Visibility="{Binding Config.IsToolBarLeftVisible, Converter={StaticResource bool2VisibilityConverter}}">
                    <ToolBar Padding="2,3" ToolBarTray.IsLocked="True" />
                </ToolBarTray>
                <ToolBarTray x:Name="ToolBarRight" Grid.Row="0" Grid.Column="1" Margin="0,50,2,0" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.9" Orientation="Vertical" Visibility="{Binding Config.IsToolBarRightVisible, Converter={StaticResource bool2VisibilityConverter}}">
                    <ToolBar Padding="2,3" ToolBarTray.IsLocked="True" />
                </ToolBarTray>

                <Border x:Name="ImageGroupNavigator"
                        Margin="8,0,0,42"
                        Padding="4,3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Panel.ZIndex="20"
                        Background="{DynamicResource GlobalBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Opacity="0.88"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ImageGroupPreviousButton"
                                Width="26"
                                Height="22"
                                Padding="0"
                                Content="&lt;"
                                Click="ImageGroupPreviousButton_Click"
                                Style="{StaticResource CompactInspectorButtonStyle}" />
                        <TextBlock x:Name="ImageGroupStatusText"
                                   MinWidth="42"
                                   Margin="7,0"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="12"
                                   Text="1/1" />
                        <Button x:Name="ImageGroupNextButton"
                                Width="26"
                                Height="22"
                                Padding="0"
                                Content="&gt;"
                                Click="ImageGroupNextButton_Click"
                                Style="{StaticResource CompactInspectorButtonStyle}" />
                    </StackPanel>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
