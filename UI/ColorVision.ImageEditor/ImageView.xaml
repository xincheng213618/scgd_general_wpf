<UserControl x:Class="ColorVision.ImageEditor.ImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converter="clr-namespace:ColorVision.ImageEditor.Draw.Converter"
             xmlns:converters="clr-namespace:ColorVision.ImageEditor.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:ColorVision.ImageEditor"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.ImageEditor.Properties"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:ImageViewModel}"
             d:DesignHeight="600" d:DesignWidth="800" AllowDrop="True"
             FocusVisualStyle="{x:Null}"
             Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
        </Style>
        <Style BasedOn="{StaticResource TextBox.Small}" TargetType="TextBox">
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown" />
        </Style>
        <GeometryDrawing x:Key="GridSquare" Brush="{DynamicResource GlobalTextBrush}" Geometry="M0,0 L0,1 1,1 1,0 Z" />
        <DrawingBrush x:Key="TransparentGridBrush" Opacity="0.1" TileMode="Tile" Viewport="0 0 20 20" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <!--  Gray square  -->
                    <GeometryDrawing Brush="Gray" Geometry="M0,0 L0,10 10,10 10,0 Z" />
                    <!--  Transparent square  -->
                    <GeometryDrawing Brush="Transparent" Geometry="M10,0 L10,10 20,10 20,0 Z" />
                    <!--  Another row  -->
                    <GeometryDrawing Brush="Transparent" Geometry="M0,10 L0,20 10,20 10,10 Z" />
                    <GeometryDrawing Brush="Gray" Geometry="M10,10 L10,20 20,20 20,10 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
        <GeometryDrawing x:Key="SmallGridGeometry" Brush="{DynamicResource GlobalTextBrush}" Geometry="M0,0 L0,1 0.03,1 0.03,0.03 1,0.03 1,0 Z" />

        <GeometryDrawing x:Key="LargeGridGeometry" Brush="{DynamicResource GlobalTextBrush}" Geometry="M0,0 L0,1 0.015,1 0.015,0.015 1,0.015 1,0 Z" />

        <DrawingBrush x:Key="SmallGridLinesDrawingBrush" Drawing="{StaticResource SmallGridGeometry}" Opacity="0.1" TileMode="Tile" Viewport="0 0 20 20" ViewportUnits="Absolute" />

        <DrawingBrush x:Key="LargeGridLinesDrawingBrush" Drawing="{StaticResource LargeGridGeometry}" Opacity="0.5" TileMode="Tile" Viewport="0 0 200 200" ViewportUnits="Absolute" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid x:Name="ImageContentGrid" Grid.Row="1">
            <Grid Background="{StaticResource LargeGridLinesDrawingBrush}" Visibility="Collapsed" />
            <Grid Background="{StaticResource SmallGridLinesDrawingBrush}" Visibility="Collapsed" />

            <Grid x:Name="ZoomGrid" Background="{StaticResource TransparentGridBrush}">
                <local:Zoombox x:Name="Zoombox1" Grid.ColumnSpan="2" x:FieldModifier="public" MaxZoom="{Binding MaxZoom}" MinZoom="{Binding MinZoom}">
                    <local:DrawCanvas x:Name="ImageShow" x:FieldModifier="public" FocusVisualStyle="{x:Null}" RenderOptions.BitmapScalingMode="HighQuality" RenderOptions.ClearTypeHint="Auto" />

                </local:Zoombox>

                <ComboBox x:Name="ComboBoxLayers" Grid.Column="1" Margin="5,5,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" x:FieldModifier="public" BorderThickness="0" Opacity="0.6" SelectedIndex="0" Style="{StaticResource ComboBox.Small}" Visibility="Collapsed" />
                <ToolBar x:Name="ToolBarAl" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Bottom" x:FieldModifier="public" Background="Transparent" Opacity="0.8" Style="{StaticResource ToolBarBaseStyle}" ToolBarTray.IsLocked="True" Visibility="{Binding Config.IsToolBarAlVisible, Converter={StaticResource bool2VisibilityConverter}}">
                    <ComboBox x:Name="ComboxPOITemplate" Width="100" HorizontalAlignment="Left" x:FieldModifier="public" DisplayMemberPath="Key" SelectedValuePath="Value" Style="{StaticResource ComboBox.Small}" />
                </ToolBar>

                <ToolBarTray x:Name="ToolBarDraw" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" Opacity="0.9" Visibility="{Binding Config.IsToolBarDrawVisible, Converter={StaticResource bool2VisibilityConverter}}">
                    <ToolBar ToolBarTray.IsLocked="True" />
                </ToolBarTray>

                <ToolBarTray x:Name="ToolBarTop" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Top" Opacity="0.9" Visibility="{Binding Config.IsToolBarTopVisible, Converter={StaticResource bool2VisibilityConverter}}">
                    <ToolBar Margin="0,2,4,0" ToolBarTray.IsLocked="True">
                        <ToggleButton Margin="1,0" IsChecked="{Binding ImageEditMode}">
                            <Image Margin="-5" Source="{DynamicResource DrawingImagedrag}" Style="{StaticResource ToolBarImage}" />
                        </ToggleButton>
                    </ToolBar>
                </ToolBarTray>

                <ToolBarTray x:Name="ToolBarLeft" Margin="2,50,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.9" Orientation="Vertical" Visibility="{Binding Config.IsToolBarLeftVisible, Converter={StaticResource bool2VisibilityConverter}}">
                    <ToolBar Padding="2,3" ToolBarTray.IsLocked="True" />
                </ToolBarTray>
                <ToolBarTray x:Name="ToolBarRight" Grid.Row="0" Grid.Column="1" Margin="0,50,2,0" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.9" Orientation="Vertical" Visibility="{Binding Config.IsToolBarRightVisible, Converter={StaticResource bool2VisibilityConverter}}">
                    <ToolBar Padding="2,3" ToolBarTray.IsLocked="True">
                        <ToggleButton x:Name="AdvancedButton" Margin="0,0,0,2" Padding="5">
                            <Image Source="{DynamicResource DIExpand}" Style="{StaticResource ToolBarImage}" />
                        </ToggleButton>
                        <Button x:Name="Button1931" Margin="0,0,0,2" Padding="5" x:FieldModifier="public">
                            <Image Source="/ColorVision.ImageEditor;component/Assets/Image/CIE1931xy1.png" Style="{StaticResource ToolBarImage}" />
                        </Button>
                        <StackPanel>
                            <ToggleButton x:Name="Pseudo" Margin="0,0,0,2" Click="ToggleButton_Click" IsChecked="{Binding Config.IsPseudo}">
                                <Image Margin="-5" Source="/ColorVision.ImageEditor;component/Assets/png/PowerToy.png" Style="{StaticResource ToolBarImage}" />
                            </ToggleButton>
                            <ToggleButton x:Name="AutoSetRange" Margin="0,0,0,2" Padding="3" HorizontalAlignment="Stretch" Click="AutoSetRange_Click" Content="A" FontSize="9" IsChecked="{Binding Config.IsAutoSetRange}" ToolTip="Auto Range" Visibility="{Binding Config.IsPseudo, Converter={StaticResource bool2VisibilityConverter}}" />
                            <Grid Height="200" Visibility="{Binding Config.IsPseudo, Converter={StaticResource bool2VisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBox Grid.Row="0" Width="28" HorizontalContentAlignment="Center" Background="Transparent" BorderThickness="0" FontSize="8" Style="{StaticResource BaseStyle}" Text="{Binding ValueEnd, ElementName=PseudoSlider, StringFormat=#0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Grid.Row="2" Width="28" HorizontalContentAlignment="Center" Background="Transparent" BorderThickness="0" FontSize="8" Style="{StaticResource BaseStyle}" Text="{Binding ValueStart, ElementName=PseudoSlider, StringFormat=#0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Grid Grid.Row="1" Width="18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition x:Name="RowDefinitionStart" Height="0" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition x:Name="RowDefinitionEnd" Height="0" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="White" CornerRadius="10,10,0,0" />
                                    <Border Grid.Row="1" Background="Transparent">
                                        <Image x:Name="ColormapTypesImage" VerticalAlignment="Top" Source="/ColorVision.ImageEditor;component/Assets/Image/pictureBox1.Image.png" Stretch="Fill" />
                                    </Border>
                                    <Border Grid.Row="2" Background="Black" CornerRadius="0,0,10,10 " />
                                </Grid>
                                <hc:RangeSlider x:Name="PseudoSlider" Grid.Row="1" HorizontalAlignment="Center" hc:TipElement.Placement="Left" hc:TipElement.StringFormat="#0" hc:TipElement.Visibility="Visible" x:FieldModifier="public" Background="Transparent" FocusVisualStyle="{x:Null}" Maximum="255" Minimum="0" Orientation="Vertical" Style="{StaticResource RangeSliderBaseStyle}" ValueChanged="PseudoSlider_ValueChanged" ValueEnd="255" ValueStart="0" />
                            </Grid>
                        </StackPanel>
                    </ToolBar>
                </ToolBarTray>
            </Grid>
        </Grid>

        <Grid Grid.Column="1" Width="300" Visibility="{Binding ElementName=AdvancedButton, Path=IsChecked, Converter={StaticResource bool2VisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ScrollViewer Margin="5,0">
                <StackPanel x:Name="AdvancedStackPanel">

                    <Border Grid.Column="1" Margin="0,5" Background="{DynamicResource GlobalBorderBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5">
                        <StackPanel Margin="5">
                            <Button Command="{Binding Config.ClearCommand}" Content="Clear" />
                            <DockPanel Margin="0,0,0,5">
                                <ui:ToggleSwitch Background="DodgerBlue" DockPanel.Dock="Right" IsChecked="{Binding Config.IsLayoutUpdated}" />
                                <TextBlock Width="100" HorizontalAlignment="Left" Text="{x:Static properties:Resources.IsLayoutUpdated}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5">
                                <ui:ToggleSwitch Background="DodgerBlue" DockPanel.Dock="Right" IsChecked="{Binding Config.IsShowText}" />
                                <TextBlock Width="100" HorizontalAlignment="Left" Text="{x:Static properties:Resources.IsShowText}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5">
                                <ui:ToggleSwitch Background="DodgerBlue" DockPanel.Dock="Right" IsChecked="{Binding Config.IsShowMsg}" />
                                <TextBlock Width="100" HorizontalAlignment="Left" Text="{x:Static properties:Resources.IsShowMsg}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Width="100" Text="MaxZoom" />
                                <TextBox Text="{Binding MaxZoom}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Width="100" Text="MinZoom" />
                                <TextBox Text="{Binding MinZoom}" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5">
                                <TextBlock Width="100" Text="{x:Static properties:Resources.ColormapTypes}" />
                                <ComboBox x:Name="ComColormapTypes" DisplayMemberPath="Key" SelectedValuePath="Value" Style="{StaticResource ComboBox.Small}" Text="{Binding Config.ColormapTypes}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <StackPanel Grid.Row="1" Margin="5" VerticalAlignment="Bottom" Orientation="Horizontal">
                <Button Margin="0,0,10,0" Click="Apply_Click" Content="{x:Static properties:Resources.Apply}" />
                <Button Click="Reload_Click" Content="{x:Static properties:Resources.Reload}" />
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
