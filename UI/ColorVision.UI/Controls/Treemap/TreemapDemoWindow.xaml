<Window x:Class="ColorVision.UI.Controls.TreemapDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ColorVision.UI.Controls"
        Title="磁盘空间分析 - Treemap Viewer"
        Width="1100" Height="720"
        MinWidth="500" MinHeight="400">
    <DockPanel>
        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top" Height="36" Padding="2,0">

            <!-- Drive selection -->
            <TextBlock VerticalAlignment="Center" Margin="4,0,2,0" Text="盘符："/>
            <ComboBox x:Name="CmbDrives" Width="72" VerticalAlignment="Center"
                      SelectionChanged="CmbDrives_SelectionChanged"
                      DisplayMemberPath="Name" Margin="0,0,4,0"/>

            <!-- Manual path browse -->
            <Button x:Name="BtnBrowse" Content="浏览目录…" Padding="8,3"
                    Click="BtnBrowse_Click" ToolTip="选择要扫描的目录"/>

            <!-- Current path display -->
            <TextBlock x:Name="TxtPath" VerticalAlignment="Center"
                       Margin="6,0" FontSize="11" Foreground="#ccc"
                       MaxWidth="320" TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

            <Separator/>

            <!-- Scan / cancel -->
            <Button x:Name="BtnScan" Content="扫 描" Padding="10,3"
                    Click="BtnScan_Click" IsEnabled="False"
                    ToolTip="扫描选定目录并显示树图"/>
            <Button x:Name="BtnCancel" Content="取 消" Padding="8,3"
                    Click="BtnCancel_Click" IsEnabled="False"
                    ToolTip="中止当前扫描"/>

            <Separator/>

            <!-- Save / Load scan results -->
            <Button x:Name="BtnSave" Content="保 存" Padding="8,3"
                    Click="BtnSave_Click" IsEnabled="False"
                    ToolTip="将当前扫描结果保存为 JSON 文件"/>
            <Button x:Name="BtnLoad" Content="加 载" Padding="8,3"
                    Click="BtnLoad_Click"
                    ToolTip="从已保存的 JSON 文件加载扫描结果"/>

            <Separator/>

            <!-- Navigation -->
            <Button x:Name="BtnUp" Content="↑ 上级" Padding="8,3"
                    Click="BtnUp_Click" IsEnabled="False"
                    ToolTip="返回父目录节点"/>

            <Separator/>

            <!-- Labels toggle -->
            <CheckBox x:Name="ChkLabels" Content="显示标签" IsChecked="True"
                      Checked="ChkLabels_Changed" Unchecked="ChkLabels_Changed"
                      VerticalAlignment="Center" Margin="4,0"/>

            <Separator/>

            <!-- Node count -->
            <TextBlock VerticalAlignment="Center" Text="节点数：" Margin="4,0,0,0"/>
            <TextBlock x:Name="TxtNodeCount" VerticalAlignment="Center" MinWidth="50"
                       Margin="0,0,4,0"/>
        </ToolBar>

        <!-- Scan progress -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Height="20"
                    Background="#1a1a1a">
            <ProgressBar x:Name="ProgressBar" Width="200" Height="8"
                         VerticalAlignment="Center" Margin="8,0"
                         IsIndeterminate="True" Visibility="Collapsed"/>
            <TextBlock x:Name="TxtProgress" VerticalAlignment="Center"
                       Foreground="#aaa" FontSize="11" Margin="4,0"/>
        </StackPanel>

        <!-- Treemap canvas -->
        <Border Background="#1e1e1e" Padding="4">
            <local:TreemapControl x:Name="TreemapCtrl" ShowLabels="True"
                                  NodeRightClicked="TreemapCtrl_NodeRightClicked"
                                  NodeClicked="TreemapCtrl_NodeClicked"/>
        </Border>
    </DockPanel>
</Window>
