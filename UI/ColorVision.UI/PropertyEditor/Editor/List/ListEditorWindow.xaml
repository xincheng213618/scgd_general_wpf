<!-- ListEditorWindow.xaml -->
<Window x:Class="ColorVision.UI.PropertyEditor.Editor.List.ListEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.UI.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.ListEditor_Title}" Height="600" Width="800" 
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Top">
            <Button x:Name="AddButton" Content="{x:Static properties:Resources.ListEditor_Add}" Width="80" Click="AddButton_Click"
                    Margin="0,0,5,0" />
            <Button x:Name="EditButton" Content="{x:Static properties:Resources.Edit}" Width="80" Click="EditButton_Click"
                    Margin="0,0,5,0" IsEnabled="False"/>
            <Button x:Name="DeleteButton" Content="{x:Static properties:Resources.ListEditor_Delete}" Width="80" Click="DeleteButton_Click"
                    Margin="0,0,5,0" IsEnabled="False" />
            <Button x:Name="DeleteAllButton" Content="{x:Static properties:Resources.ListEditor_DeleteAll}" Width="80" Click="DeleteAllButton_Click"
                    Margin="0,0,5,0" IsEnabled="False" />
            <Button x:Name="MoveUpButton" Content="{x:Static properties:Resources.ListEditor_MoveUp}" Width="80" Click="MoveUpButton_Click"
                    Margin="0,0,5,0" IsEnabled="False"/>
            <Button x:Name="MoveDownButton" Content="{x:Static properties:Resources.ListEditor_MoveDown}" Width="80" Click="MoveDownButton_Click"
                    IsEnabled="False"/>
        </StackPanel>

        <!-- List Display -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" 
                BorderThickness="1" CornerRadius="5">
            <ListView x:Name="ItemsListView" 
                      SelectionMode="Extended"
                      SelectionChanged="ItemsListView_SelectionChanged"
                      MouseDoubleClick="ItemsListView_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{x:Static properties:Resources.ListEditor_Index}" Width="60" DisplayMemberBinding="{Binding Index}"/>
                        <GridViewColumn Header="{x:Static properties:Resources.ListEditor_Value}" Width="550" DisplayMemberBinding="{Binding DisplayValue}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{x:Static properties:Resources.OK}" Width="80" Click="OkButton_Click"
                    Margin="0,0,5,0" Background="{StaticResource PrimaryBrush}"
                    Foreground="White" BorderThickness="0"/>
            <Button Content="{x:Static properties:Resources.Cancel}" Width="80" Click="CancelButton_Click"
                    Background="{StaticResource PrimaryBrush}"
                    Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
