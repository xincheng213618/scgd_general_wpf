<UserControl x:Class="ColorVision.UI.StatusBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="800">
    <Border Background="{DynamicResource GlobalBackground}"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource BorderBrush}"
            Height="30">
        <Grid x:Name="RootGrid" Background="{DynamicResource GlobalBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="LeftItemsPanel" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"/>
            <StackPanel x:Name="RightItemsPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
