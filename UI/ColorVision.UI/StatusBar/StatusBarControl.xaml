<UserControl x:Class="ColorVision.UI.StatusBar.StatusBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="800">
    <Border Height="30" Background="{DynamicResource GlobalBackground}"
            BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
        <Grid x:Name="StatusBarGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="LeftPanel" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Stretch"/>
            <StackPanel x:Name="RightPanel" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch"/>
        </Grid>
    </Border>
</UserControl>
