<UserControl x:Class="ColorVision.UI.HotKey.HoyKeyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.UI.HotKey"
             xmlns:properties="clr-namespace:ColorVision.UI.Properties;assembly=ColorVision.UI"
             d:DataContext="{d:DesignInstance Type=local:HotKeys}"
             mc:Ignorable="d"
             d:DesignHeight="48"
             d:DesignWidth="760"
             LostFocus="HotkeyTextBox_LostFocus">
    <UserControl.Resources>
        <local:BoolToStringConverer x:Key="BoolToStringConverer"/>
        <local:HotKeyToStringConverer x:Key="HotKeyToStringConverer"/>
    </UserControl.Resources>

    <Border BorderBrush="{DynamicResource GlobalBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="14,8">
        <Grid MinHeight="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="180"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="Auto" MinWidth="140"/>
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource GlobalTextBrush}"
                       Text="{Binding Name}"
                       TextTrimming="CharacterEllipsis"/>

            <Grid Grid.Column="1"
                  Margin="16,0,0,0"
                  VerticalAlignment="Center">
                <TextBox x:Name="HotkeyTextBox"
                         Height="28"
                         Padding="10,0"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         GotFocus="HotkeyTextBox_GotFocus"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         IsUndoEnabled="False"
                         PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                         Text="{Binding Hotkey, Converter={StaticResource HotKeyToStringConverer}, Mode=OneWay}"/>
                <TextBox x:Name="HotkeyTextBox1"
                         Height="28"
                         Padding="10,0"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         IsUndoEnabled="False"
                         LostFocus="HotkeyTextBox_LostFocus"
                         PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                         Visibility="Collapsed"/>
            </Grid>

            <CheckBox Grid.Column="2"
                      Margin="16,0,0,0"
                      Padding="4,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      VerticalContentAlignment="Center"
                      Content="{x:Static properties:Resources.GlobalMode}"
                      IsChecked="{Binding IsGlobal}"/>
        </Grid>
    </Border>
</UserControl>
