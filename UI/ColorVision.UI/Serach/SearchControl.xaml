<UserControl x:Class="ColorVision.UI.Serach.SearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.UI.Properties"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="210">
    <Grid x:Name="SearchGrid" Width="210" HorizontalAlignment="Left" VerticalAlignment="Center">
        <hc:TextBox x:Name="Searchbox" Padding="20,1,2,1" VerticalContentAlignment="Center"
                    hc:InfoElement.Placeholder="{x:Static properties:Resources.Search}"
                    BorderBrush="#CCCEDB" BorderThickness="1"
                    GotFocus="Searchbox_GotFocus" MaxLength="15"
                    PreviewKeyDown="Searchbox_PreviewKeyDown"
                    Style="{DynamicResource TextBoxPlus.Small}"
                    TextChanged="Searchbox_TextChanged" />
        <Viewbox Width="12" Height="12" Margin="4,0,0,0" HorizontalAlignment="Left">
            <Rectangle Width="16" Height="16">
                <Rectangle.Resources>
                    <SolidColorBrush x:Key="canvas" Opacity="0" />
                    <SolidColorBrush x:Key="light-defaultgrey-10" Opacity="0.1" Color="{DynamicResource defaultgreyColor}" />
                    <SolidColorBrush x:Key="light-defaultgrey" Opacity="1" Color="{DynamicResource defaultgreyColor}" />
                </Rectangle.Resources>
                <Rectangle.Fill>
                    <DrawingBrush Stretch="None">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <DrawingGroup x:Name="canvas">
                                    <GeometryDrawing Brush="{DynamicResource canvas}" Geometry="F1M0,0H16V16H0Z" />
                                </DrawingGroup>
                                <DrawingGroup x:Name="level_1">
                                    <GeometryDrawing Brush="{DynamicResource light-defaultgrey-10}" Geometry="F1M11.5,6.5a5,5,0,1,1-5-5A5,5,0,0,1,11.5,6.5Z" />
                                    <GeometryDrawing Brush="{DynamicResource light-defaultgrey}" Geometry="F1M1,6.5a5.5,5.5,0,0,0,9.017,4.224l5.129,5.13.708-.708-5.13-5.129A5.5,5.5,0,1,0,1,6.5Zm1,0A4.5,4.5,0,1,1,6.5,11,4.505,4.505,0,0,1,2,6.5Z" />
                                </DrawingGroup>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Viewbox>
        <Popup x:Name="SearchPopup" AllowsTransparency="true" Focusable="false"
               Placement="Bottom" PlacementTarget="{Binding ElementName=Searchbox}"
               PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}"
               StaysOpen="false">
            <Border Width="210" Height="500" Margin="5">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource RegionBrush}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="CornerRadius" Value="4" />
                    </Style>
                </Border.Style>
                <ListView x:Name="ListViewSearch" Background="Transparent" BorderThickness="0"
                          MouseDoubleClick="ListViewSearch_MouseDoubleClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          SelectionChanged="ListViewSearch_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource ListViewItemBaseStyle.Small}" TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridView.ColumnHeaderContainerStyle>
                                <Style BasedOn="{StaticResource InputElementBaseStyle}" TargetType="{x:Type GridViewColumnHeader}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                </Style>
                            </GridView.ColumnHeaderContainerStyle>
                            <GridViewColumn Width="240">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Margin="0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                       FontSize="12" Foreground="{DynamicResource Foreground}"
                                                       Text="{Binding Header}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Popup>
    </Grid>
</UserControl>
