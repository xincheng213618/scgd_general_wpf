<Window x:Class="ColorVision.Rbac.UserManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Rbac"
        xmlns:properties="clr-namespace:ColorVision.Solution.Properties;assembly=ColorVision.Solution"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.Sol_UserMgr_Title}" Height="750" Width="1100" WindowStartupLocation="CenterOwner" Initialized="Window_Initialized">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="RbacStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <local:BoolToDeleteColorConverter x:Key="BoolToDeleteColorConverter"/>
            <local:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter"/>
            <local:BoolToYesNoConverter x:Key="BoolToYesNoConverter"/>
            <local:BoolToToggleIconConverter x:Key="BoolToToggleIconConverter"/>
            <local:BoolToToggleColorConverter x:Key="BoolToToggleColorConverter"/>
            <local:BoolToToggleTooltipConverter x:Key="BoolToToggleTooltipConverter"/>
        </ResourceDictionary>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header with Status -->
        <Border Grid.Row="0" Background="{DynamicResource ButtonBackground}" Padding="12,8" Margin="0,0,0,15" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="24" 
                               VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource StatusBarBackgroundBrush}"/>
                    <StackPanel>
                        <TextBlock Text="{x:Static properties:Resources.Sol_UserMgr_Label}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtStatusInfo" Text="{x:Static properties:Resources.Sol_UserMgr_Admin}" FontSize="11"
                                   Opacity="0.6" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="TxtSessionInfo" Text="" FontSize="11" 
                               Opacity="0.6" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" 
                            Style="{StaticResource SecondaryButton}" Width="36" Height="32"
                            ToolTip="{x:Static properties:Resources.Sol_UserMgr_Refresh}" Click="BtnRefresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Create User Section -->
        <Border Grid.Row="1" Background="{DynamicResource ButtonBackground}" Padding="15,12" Margin="0,0,0,12" CornerRadius="4" BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets" FontSize="20" 
                               VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource StatusBarBackgroundBrush}"/>
                    <TextBlock Text="{x:Static properties:Resources.Sol_UserMgr_Ops}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="{x:Static properties:Resources.Sol_UserMgr_CreateUser}"
                        Width="120" Click="BtnCreateUser_Click"
                        Style="{StaticResource ModernButton}" ToolTip="{x:Static properties:Resources.Sol_UserMgr_CreateUserTooltip}"/>
            </Grid>
        </Border>
        
        <!-- Role Management Section -->
        <GroupBox Header="{x:Static properties:Resources.Sol_UserMgr_RoleMgmt}" Grid.Row="2" Margin="0,0,0,12">
            <Grid Margin="12,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Label Content="{x:Static properties:Resources.Sol_UserMgr_RoleName}" VerticalAlignment="Center" Width="70"/>
                    <TextBox x:Name="TxtRoleName" Width="130" Margin="5,0" Padding="6,4" ToolTip="{x:Static properties:Resources.Sol_UserMgr_RoleNameTooltip}"/>
                    <Label Content="{x:Static properties:Resources.Sol_UserMgr_RoleCode}" VerticalAlignment="Center" Width="70" Margin="15,0,0,0"/>
                    <TextBox x:Name="TxtRoleCode" Width="130" Margin="5,0" Padding="6,4" ToolTip="{x:Static properties:Resources.Sol_UserMgr_RoleCodeTooltip}"/>
                    <Label Content="{x:Static properties:Resources.Sol_UserMgr_Remark}" VerticalAlignment="Center" Width="50" Margin="15,0,0,0"/>
                    <TextBox x:Name="TxtRoleRemark" Width="150" Margin="5,0" Padding="6,4" ToolTip="{x:Static properties:Resources.Sol_UserMgr_RemarkTooltip}"/>
                    <Button Content="{x:Static properties:Resources.Sol_UserMgr_CreateRole}" Width="90" Margin="20,0,5,0" Click="BtnCreateRole_Click"
                            Style="{StaticResource ModernButton}"/>
                    <Button Content="{x:Static properties:Resources.Sol_UserMgr_PermMgmt}" Width="90" Margin="5,0" Click="BtnOpenPermissionManager_Click"
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
                <ListView x:Name="RolesListView" Grid.Row="1" Height="130" Margin="0,5,0,0"
                          BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="1">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_RoleName}" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_RoleCode}" Width="140" DisplayMemberBinding="{Binding Code}" />
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_Remark}" Width="220" DisplayMemberBinding="{Binding Remark}" />
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_Status}" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding IsEnable, Converter={StaticResource BoolToColorConverter}}"
                                                CornerRadius="3" Padding="6,2">
                                            <TextBlock Text="{Binding IsEnable, Converter={StaticResource BoolToStatusTextConverter}}"
                                                       Foreground="White" FontSize="10" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_CreateTime}" Width="160" DisplayMemberBinding="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </GroupBox>

        <!-- Search/Filter Section -->
        <Border Grid.Row="3" Background="{DynamicResource ButtonBackground}" Padding="10,8" Margin="0,0,0,10" CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           VerticalAlignment="Center" Margin="0,0,8,0" Opacity="0.6"/>
                <TextBox x:Name="TxtSearch" Grid.Column="1" Padding="8,6"
                         MaxWidth="400" HorizontalAlignment="Left"
                         TextChanged="TxtSearch_TextChanged"
                         ToolTip="{x:Static properties:Resources.Sol_UserMgr_SearchTooltip}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock x:Name="TxtTotalCount" Text="" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- User List -->
        <GroupBox Header="{x:Static properties:Resources.Sol_UserMgr_UserList}" Grid.Row="4">
            <ListView x:Name="UsersListView" Margin="12,10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_Username}" Width="140">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" 
                                                   FontSize="14" Foreground="{DynamicResource StatusBarBackgroundBrush}" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Username}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_Role}" Width="180">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RolesDisplay}" ToolTip="{Binding RolesDisplay}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_Remark}" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Remark}" TextTrimming="CharacterEllipsis" 
                                               ToolTip="{Binding Remark}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_Status}" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding IsEnable, Converter={StaticResource BoolToColorConverter}}"
                                            CornerRadius="3" Padding="6,2">
                                        <TextBlock Text="{Binding IsEnable, Converter={StaticResource BoolToStatusTextConverter}}"
                                                   Foreground="White" FontSize="10" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_Delete}" Width="60">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsDelete, Converter={StaticResource BoolToYesNoConverter}}"
                                               Foreground="{Binding IsDelete, Converter={StaticResource BoolToDeleteColorConverter}}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_CreateTime}" Width="160" DisplayMemberBinding="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                        <GridViewColumn Header="{x:Static properties:Resources.Sol_UserMgr_Col_Action}" Width="280">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="&#xE70F;" FontFamily="Segoe MDL2 Assets" Padding="6,3" Tag="{Binding}" Click="BtnEditRoles_Click"
                                                Style="{StaticResource ModernButton}" FontSize="11" Margin="0,0,4,0" Width="32" Height="26"
                                                ToolTip="{x:Static properties:Resources.Sol_UserMgr_EditRoleTooltip}" Background="#0078D4"/>
                                        <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" Padding="6,3" Tag="{Binding}" Click="BtnDeleteUser_Click"
                                                Style="{StaticResource ModernButton}" FontSize="11" Margin="0,0,4,0" Width="32" Height="26"
                                                ToolTip="{x:Static properties:Resources.Sol_UserMgr_DeleteUserTooltip}" Background="#D32F2F"/>
                                        <Button Content="{Binding IsEnable, Converter={StaticResource BoolToToggleIconConverter}}" FontFamily="Segoe MDL2 Assets" Padding="6,3" Tag="{Binding}" Click="BtnToggleUser_Click"
                                                Style="{StaticResource ModernButton}" FontSize="11" Margin="0,0,4,0" Width="32" Height="26"
                                                Background="{Binding IsEnable, Converter={StaticResource BoolToToggleColorConverter}}">
                                            <Button.ToolTip>
                                                <TextBlock Text="{Binding IsEnable, Converter={StaticResource BoolToToggleTooltipConverter}}"/>
                                            </Button.ToolTip>
                                        </Button>
                                        <Button Content="&#xE72E;" FontFamily="Segoe MDL2 Assets" Padding="6,3" Tag="{Binding}" Click="BtnResetPassword_Click"
                                                Style="{StaticResource ModernButton}" FontSize="11" Margin="0,0,0,0" Width="32" Height="26"
                                                ToolTip="{x:Static properties:Resources.Sol_UserMgr_ResetPwdTooltip}" Background="#F57C00"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
        
        <!-- Footer with Statistics -->
        <Border Grid.Row="5" Background="{DynamicResource ButtonBackground}" Padding="12,8" Margin="0,10,0,0" CornerRadius="4">
            <Grid>
                <TextBlock x:Name="TxtCacheStats" Text="{x:Static properties:Resources.Sol_UserMgr_PermStats}"
                           FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Static properties:Resources.Sol_UserMgr_DoubleClickHint}"
                           FontSize="11" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
