<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0-windows7.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <VersionPrefix>1.5.6.1</VersionPrefix>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <PackageProjectUrl>https://github.com/xincheng213618/scgd_general_wpf</PackageProjectUrl>
    <IncludeSymbols>True</IncludeSymbols>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Description>ColorVision multi-image viewing and image fusion tools for WPF applications.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="SqlSugarCore" Version="5.1.4.215" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ColorVision.Common\ColorVision.Common.csproj" />
    <ProjectReference Include="..\ColorVision.Core\ColorVision.Core.csproj" />
    <ProjectReference Include="..\ColorVision.ImageEditor\ColorVision.ImageEditor.csproj" />
    <ProjectReference Include="..\ColorVision.Solution\ColorVision.Solution.csproj" />
    <ProjectReference Include="..\ColorVision.UI\ColorVision.UI.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>
</Project>
