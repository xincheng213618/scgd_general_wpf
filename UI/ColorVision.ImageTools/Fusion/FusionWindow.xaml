<Window x:Class="ColorVision.Solution.Fusion.FusionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Solution.Properties;assembly=ColorVision.Solution"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.Sol_Fusion_Title}" Height="620" Width="780"
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="{x:Static properties:Resources.Sol_Fusion_Label}" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- File List -->
        <GroupBox Grid.Row="1" Header="{x:Static properties:Resources.Sol_Fusion_FileList}" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ListBox x:Name="FileListBox" Grid.Column="0" AllowDrop="True" 
                         Drop="FileListBox_Drop" DragOver="FileListBox_DragOver"
                         SelectionMode="Extended">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" ToolTip="{Binding}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Column="1" Margin="5,0,0,0" VerticalAlignment="Center">
                    <Button Content="{x:Static properties:Resources.Sol_Fusion_AddFile}" Width="80" Height="28" Margin="0,2" Click="AddFiles_Click"/>
                    <Button Content="{x:Static properties:Resources.Sol_Fusion_Remove}" Width="80" Height="28" Margin="0,2" Click="RemoveSelected_Click"/>
                    <Button Content="{x:Static properties:Resources.Sol_Fusion_Clear}" Width="80" Height="28" Margin="0,2" Click="ClearAll_Click"/>
                    <Button Content="{x:Static properties:Resources.Sol_Fusion_MoveUp}" Width="80" Height="28" Margin="0,10,0,2" Click="MoveUp_Click"/>
                    <Button Content="{x:Static properties:Resources.Sol_Fusion_MoveDown}" Width="80" Height="28" Margin="0,2" Click="MoveDown_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Configuration -->
        <GroupBox Grid.Row="2" Header="{x:Static properties:Resources.Sol_Fusion_Config}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="{x:Static properties:Resources.Sol_Fusion_Mode}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="ComboBoxMode" Width="200" SelectedIndex="0">
                    <ComboBoxItem Content="{x:Static properties:Resources.Sol_Fusion_Auto}"/>
                    <ComboBoxItem Content="CPU (OpenCV)"/>
                    <ComboBoxItem Content="GPU (CUDA)"/>
                    <ComboBoxItem Content="{x:Static properties:Resources.Sol_Fusion_Async}"/>
                </ComboBox>
                <TextBlock x:Name="TextBlockCudaStatus" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Timing Statistics -->
        <GroupBox Grid.Row="3" Header="{x:Static properties:Resources.Sol_Fusion_Perf}" Margin="0,0,0,10">
            <Grid Margin="5,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ListView x:Name="TimingListView" Grid.Column="0" MaxHeight="110" FontSize="12"
                          BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_Fusion_ModeCol}" Width="140" DisplayMemberBinding="{Binding Mode}"/>
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_Fusion_LoadMs}" Width="80" DisplayMemberBinding="{Binding LoadMs}"/>
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_Fusion_FusionMs}" Width="80" DisplayMemberBinding="{Binding FusionMs}"/>
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_Fusion_ConvertMs}" Width="80" DisplayMemberBinding="{Binding ConvertMs}"/>
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_Fusion_TotalMs}" Width="80" DisplayMemberBinding="{Binding TotalMs}"/>
                            <GridViewColumn Header="{x:Static properties:Resources.Sol_Fusion_ImageCount}" Width="55" DisplayMemberBinding="{Binding ImageCount}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <Button Grid.Column="1" Content="{x:Static properties:Resources.Sol_Fusion_ClearBtn}" Width="50" Height="24" VerticalAlignment="Top"
                        Margin="5,0,0,0" Click="ClearTiming_Click"/>
            </Grid>
        </GroupBox>

        <!-- Actions -->
        <DockPanel Grid.Row="4" LastChildFill="False">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" DockPanel.Dock="Left"/>
            <Button Content="{x:Static properties:Resources.Sol_Fusion_Cancel}" Width="80" Height="30" DockPanel.Dock="Right" Margin="5,0,0,0" Click="Cancel_Click"/>
            <Button x:Name="ButtonExecute" Content="{x:Static properties:Resources.Sol_Fusion_Execute}" Width="100" Height="30" DockPanel.Dock="Right" Click="Execute_Click" IsEnabled="False"/>
        </DockPanel>
    </Grid>
</Window>
