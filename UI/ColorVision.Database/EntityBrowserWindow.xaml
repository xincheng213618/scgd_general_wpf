<Window x:Class="ColorVision.Database.EntityBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Database"
        mc:Ignorable="d"
        Title="实体浏览器" Height="650" Width="1100"
        Background="{StaticResource GlobalBackground}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Entity type DataGrid -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="实体类型" FontSize="14" FontWeight="SemiBold" Margin="10,10,10,5"/>
            <Grid DockPanel.Dock="Top" Margin="10,0,10,5">
                <TextBox x:Name="SearchBox" Padding="4,2" TextChanged="SearchBox_TextChanged" ToolTip="搜索表名或类名"/>
            </Grid>
            <Border Margin="10,0,10,10">
                <DataGrid x:Name="EntityDataGrid"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="EntityDataGrid_SelectionChanged"
                          AutoGenerateColumns="False"
                          GridLinesVisibility="Horizontal"
                          Background="Transparent"
                          BorderThickness="1"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource GlobalBackground}"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="表名" Binding="{Binding TableName}" Width="*"/>
                        <DataGridTextColumn Header="数据库" Binding="{Binding DbType}" Width="60"/>
                        <DataGridTextColumn Header="记录数" Binding="{Binding RecordCountDisplay}" Width="60"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}"/>

        <!-- Right: CRUD area -->
        <Grid Grid.Column="2" x:Name="CrudContainer">
            <TextBlock x:Name="PlaceholderText" Text="← 请从左侧选择一个实体类型"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="16" Opacity="0.4"/>
        </Grid>
    </Grid>
</Window>
