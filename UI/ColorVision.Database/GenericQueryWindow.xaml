<Window x:Class="ColorVision.Database.GenericQueryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Database"
        xmlns:properties="clr-namespace:ColorVision.Database.Properties"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:GenericQueryBase}"
        Title="{x:Static properties:Resources.DB_AdvancedQuery}" Height="550" Width="680" Background="{StaticResource GlobalBackground}" Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{x:Static properties:Resources.DB_ClearTable}" Command="{Binding DeleteAllCommand}" Margin="5,0,0,0" Foreground="#E53935"/>
                    <Button Content="{x:Static properties:Resources.DB_TruncateTable}" Command="{Binding TruncateTableCommand}" Margin="5,0,0,0" Foreground="#E53935"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <ComboBox x:Name="PropertyInfoCB" DisplayMemberPath="Key" SelectedValuePath="Value" Width="180" VerticalAlignment="Center"/>
                    <Button Content="{x:Static properties:Resources.DB_Add}" Click="AddPropertyInfo_Click" Margin="5,0,0,0" Padding="8,3" ToolTip="{x:Static properties:Resources.DB_AddTooltip}"/>
                    <Button Content="{x:Static properties:Resources.DB_AddAll}" Click="AddAllPropertyInfo_Click" Margin="5,0,0,0" Padding="8,3" ToolTip="{x:Static properties:Resources.DB_AddAllTooltip}"/>
                    <Button Content="{x:Static properties:Resources.DB_Reset}" Click="ResetConditions_Click" Margin="5,0,0,0" Padding="8,3" ToolTip="{x:Static properties:Resources.DB_ResetTooltip}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Query conditions area -->
        <ScrollViewer Grid.Row="1" Margin="5,5,5,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid x:Name="QueryGrid"/>
            </StackPanel>
        </ScrollViewer>

        <!-- SQL preview (collapsible) -->
        <Expander Grid.Row="2" Header="{x:Static properties:Resources.DB_SqlPreview}" Margin="5,5,5,0" IsExpanded="False">
            <TextBox TextWrapping="WrapWithOverflow" Text="{Binding Sql}" MaxHeight="80"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     BorderThickness="1" VerticalAlignment="Stretch" VerticalContentAlignment="Top" IsReadOnly="True"
                     Foreground="{DynamicResource GlobalTextBrush}" Background="Transparent"/>
        </Expander>

        <!-- Status bar -->
        <Border Grid.Row="3" Margin="5,5,5,0" Padding="5,3">
            <TextBlock x:Name="StatusText" Text="{x:Static properties:Resources.DB_Ready}" Foreground="{DynamicResource GlobalTextBrush}" FontSize="12"/>
        </Border>

        <!-- Query button -->
        <Border Grid.Row="4" Margin="5">
            <Button Height="38" Content="{x:Static properties:Resources.DB_Query}" Background="{DynamicResource PrimaryBrush}" Foreground="White" FontSize="16" Click="Query_Click"/>
        </Border>
    </Grid>
</Window>
