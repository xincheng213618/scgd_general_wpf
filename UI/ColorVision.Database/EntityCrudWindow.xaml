<Window x:Class="ColorVision.Database.EntityCrudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ColorVision.Database"
        mc:Ignorable="d"
        Title="数据管理" Height="600" Width="900"
        Background="{StaticResource GlobalBackground}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="5">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="新增" Click="Add_Click" Margin="5,0,0,0" Padding="8,3" Background="{DynamicResource PrimaryBrush}" Foreground="White"/>
                    <Button Content="编辑" Click="Edit_Click" Margin="5,0,0,0" Padding="8,3"/>
                    <Button Content="删除" Click="Delete_Click" Margin="5,0,0,0" Padding="8,3" Foreground="#E53935"/>
                    <Button Content="刷新" Click="Refresh_Click" Margin="5,0,0,0" Padding="8,3"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="搜索:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="SearchTextBox" Width="200" VerticalAlignment="Center"/>
                    <Button Content="搜索" Click="Search_Click" Margin="5,0,0,0" Padding="8,3"/>
                    <Button Content="清空" Click="ClearSearch_Click" Margin="5,0,0,0" Padding="8,3"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="1" Margin="5">
            <DataGrid x:Name="EntityDataGrid"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="Transparent"
                      AlternatingRowBackground="{DynamicResource GlobalBackground}"/>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="5,0,5,0" Padding="5,3">
            <DockPanel>
                <TextBlock x:Name="StatusText" Text="就绪" Foreground="{DynamicResource GlobalTextBrush}" FontSize="12"/>
                <TextBlock x:Name="RecordCountText" Text="0 条记录" Foreground="{DynamicResource GlobalTextBrush}" FontSize="12" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Pagination -->
        <Border Grid.Row="3" Margin="5" Padding="5">
            <DockPanel HorizontalAlignment="Center">
                <Button Content="&lt;&lt;" Click="FirstPage_Click" Padding="8,3" Margin="0,0,5,0"/>
                <Button Content="&lt;" Click="PrevPage_Click" Padding="8,3" Margin="0,0,5,0"/>
                <TextBlock Text="第" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox x:Name="PageNumberTextBox" Text="1" Width="40" TextAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Text="/" VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock x:Name="TotalPagesTextBlock" Text="1" VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock Text="页" VerticalAlignment="Center" Margin="5,0"/>
                <Button Content="&gt;" Click="NextPage_Click" Padding="8,3" Margin="5,0,0,0"/>
                <Button Content="&gt;&gt;" Click="LastPage_Click" Padding="8,3" Margin="5,0,0,0"/>
                <ComboBox x:Name="PageSizeComboBox" Width="80" Margin="10,0,0,0" SelectedIndex="0" SelectionChanged="PageSize_Changed">
                    <ComboBoxItem Content="10 条/页"/>
                    <ComboBoxItem Content="20 条/页"/>
                    <ComboBoxItem Content="50 条/页"/>
                    <ComboBoxItem Content="100 条/页"/>
                </ComboBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
