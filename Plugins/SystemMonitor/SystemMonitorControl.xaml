<UserControl x:Class="ColorVision.Settings.SystemMonitorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:ColorVision.Settings"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:SystemMonitor.Properties"
             xmlns:u="clr-namespace:ColorVision.UI.Configs;assembly=ColorVision.UI"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance u:SystemMonitors}"
             d:DesignHeight="700" d:DesignWidth="850" Initialized="UserControl_Initialized">
    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalForeground}" />
        </Style>
        <Style x:Key="InfoLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalForeground2}" />
            <Setter Property="Margin" Value="0,2" />
        </Style>
        <Style x:Key="InfoValue" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalForeground}" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
        <Style x:Key="BigValue" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalForeground}" />
        </Style>
    </UserControl.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4">

            <!--  性能监控 (顶部，更醒目)  -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static properties:Resources.PerformanceMonitor}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  CPU  -->
                        <Border Grid.Column="0" Margin="0,0,6,0" Padding="16" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,10" FontSize="15" FontWeight="Bold" Text="CPU" />
                                <Grid Margin="0,4" HorizontalAlignment="Center">
                                    <hc:WaveProgressBar Width="130" Height="130" Value="{Binding CPUPercent}" />
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Text="{Binding CPUText}" />
                                    </StackPanel>
                                </Grid>
                                <DockPanel Margin="0,10,0,2">
                                    <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.TotalUsage}" />
                                    <TextBlock FontWeight="SemiBold" Style="{StaticResource InfoValue}" Text="{Binding CPUText}" />
                                </DockPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.CurrentApp}" />
                                    <TextBlock Style="{StaticResource InfoValue}" Text="{Binding CPUThisText}" />
                                </DockPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.ThreadCount}" />
                                    <TextBlock Style="{StaticResource InfoValue}" Text="{Binding ThreadCount}" />
                                </DockPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.HandleCount}" />
                                    <TextBlock Style="{StaticResource InfoValue}" Text="{Binding HandleCount}" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!--  RAM  -->
                        <Border Grid.Column="1" Margin="6,0,0,0" Padding="16" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="1" CornerRadius="6">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock FontSize="15" FontWeight="Bold" Text="RAM" />
                                    <TextBlock FontSize="15" Style="{StaticResource InfoValue}" Text="{Binding TotalRAMText}" />
                                </DockPanel>
                                <Grid Margin="0,4" HorizontalAlignment="Center">
                                    <hc:WaveProgressBar Width="130" Height="130" Value="{Binding RAMPercent}" />
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Text="{Binding RAMText}" />
                                    </StackPanel>
                                </Grid>
                                <DockPanel Margin="0,10,0,2">
                                    <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.TotalUsage}" />
                                    <TextBlock FontWeight="SemiBold" Style="{StaticResource InfoValue}" Text="{Binding RAMText}" />
                                </DockPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.CurrentApp}" />
                                    <TextBlock Style="{StaticResource InfoValue}" Text="{Binding RAMThis}" />
                                </DockPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.AvailableMemory}" />
                                    <TextBlock Style="{StaticResource InfoValue}" Text="{Binding MemoryAvailable}" />
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!--  存储管理 (Steam风格)  -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static properties:Resources.StorageManagement}" />
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal">
                            <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Style="{StaticResource InfoLabel}">
                                <Run Text="{x:Static properties:Resources.TotalStorage}" />
                                <Run Text=": " />
                                <Run FontWeight="SemiBold" Text="{Binding TotalDiskSpace, Mode=OneWay}" />
                                <Run Text=" | " />
                                <Run Text="{x:Static properties:Resources.FreeSpace}" />
                                <Run Text=": " />
                                <Run FontWeight="SemiBold" Text="{Binding TotalDiskFree, Mode=OneWay}" />
                            </TextBlock>
                            <Button Width="28" Height="28" Padding="0" Command="{Binding RefreshDrivesCommand}" Content="⟳" ToolTip="{x:Static properties:Resources.Refresh}" />
                        </StackPanel>
                    </DockPanel>
                    <ItemsControl Margin="0,4,0,0" ItemsSource="{Binding Drives}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4" Padding="12,10" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="1" CornerRadius="6">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,6">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Width="18" Height="18" Margin="0,0,8,0" Source="{DynamicResource DrawingImageHardDisk}" />
                                                <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold">
                                                    <Run Text="{Binding VolumeLabel, Mode=OneWay}" />
                                                    <Run Text=" (" />
                                                    <Run Text="{Binding Name, Mode=OneWay}" />
                                                    <Run Text=")" />
                                                </TextBlock>
                                                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{Binding DriveFormat, Mode=OneWay}" />
                                            </StackPanel>
                                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="13">
                                                <Run FontWeight="SemiBold" Text="{Binding UsedSpaceText, Mode=OneWay}" />
                                                <Run Text=" / " />
                                                <Run Text="{Binding TotalSizeText, Mode=OneWay}" />
                                            </TextBlock>
                                        </DockPanel>

                                        <!--  使用率进度条  -->
                                        <ProgressBar Height="22" Margin="0,0,0,4" Background="{DynamicResource GlobalBorderBrush1}" Foreground="{Binding UsageColor, Mode=OneWay}" Maximum="100" Minimum="0" Value="{Binding UsagePercent, Mode=OneWay}" />

                                        <DockPanel>
                                            <TextBlock Style="{StaticResource InfoLabel}">
                                                <Run Text="{x:Static properties:Resources.FreeSpace}" />
                                                <Run Text=": " />
                                                <Run Text="{Binding FreeSpaceText, Mode=OneWay}" />
                                            </TextBlock>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!--  进程监控  -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static properties:Resources.ProcessMonitor}" />
                        <Button Width="28" Height="28" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding RefreshProcessesCommand}" Content="⟳" ToolTip="{x:Static properties:Resources.Refresh}" />
                    </DockPanel>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontWeight="SemiBold" Style="{StaticResource InfoLabel}" Text="PID" />
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.ProcessName}" />
                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" FontWeight="SemiBold" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.MemoryUsage}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding TopProcesses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1" Padding="4,3" Background="{DynamicResource RegionBrush}" CornerRadius="3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="11" Style="{StaticResource InfoLabel}" Text="{Binding PID}" />
                                        <TextBlock Grid.Column="1" FontSize="11" Style="{StaticResource InfoLabel}" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" FontSize="11" Style="{StaticResource InfoValue}" Text="{Binding MemoryText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!--  系统信息  -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static properties:Resources.SystemInfo}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.ComputerName}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding MachineName}" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.OS}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding OSVersion}" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="CPU" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding ProcessorName}" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.CoreCount}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding ProcessorCount}" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.ScreenResolution}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding ScreenInfo}" />
                            </DockPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="GPU" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding GPUName}" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.GPUMemory}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding GPUMemoryText}" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.TotalRAM}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding TotalRAMText}" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.Architecture}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding Architecture}" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.UserName}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding UserName}" />
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!--  运行时信息  -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static properties:Resources.RuntimeInfo}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text=".NET" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding DotNetVersion}" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="PID" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding CurrentPID}" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.AppStartTime}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding ProcessStartTimeText}" />
                            </DockPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.OSBootTime}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding OSBootTimeText}" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.Uptime}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding GetUptime}" />
                            </DockPanel>
                            <DockPanel Margin="0,3">
                                <TextBlock Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.OSUptime}" />
                                <TextBlock Style="{StaticResource InfoValue}" Text="{Binding OSUptime}" />
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!--  网络  -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static properties:Resources.Network}" />
                        <Button Width="28" Height="28" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding RefreshNetworkCommand}" Content="⟳" ToolTip="{x:Static properties:Resources.Refresh}" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding NetworkInterfaces}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,3" Padding="10,8" Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource GlobalBorderBrush1}" BorderThickness="1" CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding StatusColor, Mode=OneWay}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" />
                                            <TextBlock FontSize="11" Style="{StaticResource InfoLabel}">
                                                <Run Text="IP: " />
                                                <Run Text="{Binding IPAddress, Mode=OneWay}" />
                                                <Run Text="  |  MAC: " />
                                                <Run Text="{Binding MacAddress, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{Binding SpeedText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!--  设置和缓存  -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="{x:Static properties:Resources.Settings}" />

                    <DockPanel Margin="0,4">
                        <TextBlock Width="120" VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.UpdateSpeed}" />
                        <TextBox Width="120" Margin="8,0" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Text="{Binding UpdateSpeed}" />
                        <TextBlock VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="ms" />
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Width="120" VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.DateFormat}" />
                        <TextBox Width="200" Margin="8,0" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Text="{Binding Config.DefaultTimeFormat}" />
                    </DockPanel>

                    <Separator Margin="0,8" />
                    <TextBlock Margin="0,4,0,8" FontWeight="SemiBold" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.StatusBarSettings}" />

                    <DockPanel Margin="0,4">
                        <TextBlock Width="120" VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.ShowTime}" />
                        <ui:ToggleSwitch HorizontalAlignment="Left" IsChecked="{Binding Config.IsShowTime}" />
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Width="120" VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.ShowUptime}" />
                        <ui:ToggleSwitch HorizontalAlignment="Left" IsChecked="{Binding Config.IsShowUptime}" />
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Width="120" VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.ShowCPU}" />
                        <ui:ToggleSwitch HorizontalAlignment="Left" IsChecked="{Binding Config.IsShowCPU}" />
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Width="120" VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.ShowRAM}" />
                        <ui:ToggleSwitch HorizontalAlignment="Left" IsChecked="{Binding Config.IsShowRAM}" />
                    </DockPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock Width="120" VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.ShowDisk}" />
                        <ui:ToggleSwitch HorizontalAlignment="Left" IsChecked="{Binding Config.IsShowDisk}" />
                    </DockPanel>

                    <Separator Margin="0,8" />
                    <DockPanel Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource InfoLabel}" Text="{x:Static properties:Resources.CacheSize}" />
                            <TextBlock Margin="8,0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding CacheSize}" />
                        </StackPanel>
                        <Button Padding="16,4" HorizontalAlignment="Right" Command="{Binding ClearCacheCommand}" Content="{x:Static properties:Resources.ClearCache}" />
                    </DockPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
