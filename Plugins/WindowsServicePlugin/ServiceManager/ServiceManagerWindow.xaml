<Window x:Class="WindowsServicePlugin.ServiceManager.ServiceManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsServicePlugin.ServiceManager"
        xmlns:res="clr-namespace:WindowsServicePlugin.Properties"
        xmlns:logControls="clr-namespace:ColorVision.UI.LogImp.Controls;assembly=ColorVision.UI"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:ServiceManagerViewModel}"
        Title="{x:Static res:Resources.ServiceManager}" Height="750" Width="1000"
        Background="{DynamicResource GlobalBackground}"
        Foreground="{DynamicResource GlobalTextBrush}"
        WindowStartupLocation="CenterScreen"
        Initialized="Window_Initialized">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部：全局操作 -->
        <Border Grid.Row="0" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- 安装路径 -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="{x:Static res:Resources.BaseInstallRootLabel}" VerticalAlignment="Center" Width="80"/>
                    <Button DockPanel.Dock="Right" Content="{x:Static res:Resources.SetDirectory}" Command="{Binding SetBasePathCommand}" Margin="8,0,0,0" Padding="12,4"/>
                    <TextBox Text="{Binding Config.BaseLocation, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" IsReadOnly="True"/>
                </DockPanel>

                <!-- 版本和操作 -->
                <WrapPanel>
                    <Button Content="{x:Static res:Resources.OneKeyStart}" Command="{Binding OneKeyStartCommand}" Margin="0,0,8,0" Padding="16,6"
                            Style="{StaticResource ButtonPrimary}"/>
                    <Button Content="{x:Static res:Resources.OneKeyStop}" Command="{Binding OneKeyStopCommand}" Margin="0,0,8,0" Padding="16,6"
                            Style="{StaticResource ButtonPrimary}"/>
                    <Button Content="{x:Static res:Resources.UpdateConfig}" Command="{Binding UpdateConfigCommand}" Margin="0,0,8,0" Padding="12,6"/>
                    <Button Content="{x:Static res:Resources.LegacyAppConfig}" Command="{Binding OpenLegacyConfigCommand}" Margin="0,0,8,0" Padding="12,6"
                            Visibility="{Binding HasLegacyConfig, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="{x:Static res:Resources.Update}" Command="{Binding OpenInstallManagerCommand}" Margin="0,0,8,0" Padding="12,6"
                            Style="{StaticResource ButtonPrimary}" ToolTip="{x:Static res:Resources.OpenInstallManagerToolTip}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- 中间：TabControl -->
        <TabControl Grid.Row="1" Margin="8">
            <!-- 服务列表 Tab -->
            <TabItem Header="{x:Static res:Resources.CVWindowsService}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Services}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8" Margin="0,0,0,4">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock DockPanel.Dock="Left" FontWeight="Bold" FontSize="13">
                                                <Run Text="{Binding DisplayName}"/>
                                                <Run Text="[" Foreground="Gray"/>
                                                <Run Text="{Binding VersionText}" Foreground="Gray"/>
                                                <Run Text="]" Foreground="Gray"/>
                                            </TextBlock>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="{Binding ExePath}" TextTrimming="CharacterEllipsis" Foreground="Gray"/>
                                        </DockPanel>
                                        <WrapPanel>
                                            <TextBlock Text="{Binding ServiceName}" Width="200" VerticalAlignment="Center"/>
                                            <TextBlock Width="80" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding StatusText}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Foreground" Value="Green"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </WrapPanel>
                                        <WrapPanel Margin="0,6,0,0">
                                            <Button Content="{x:Static res:Resources.Install}" Command="{Binding DataContext.ServiceInstallCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,6,0" Padding="10,2"/>
                                            <Button Content="{x:Static res:Resources.Uninstall}" Command="{Binding DataContext.ServiceUninstallCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,6,0" Padding="10,2" Foreground="Red"/>
                                            <Button Content="{x:Static res:Resources.Start}" Command="{Binding DataContext.ServiceStartCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,6,0" Padding="10,2"/>
                                            <Button Content="{x:Static res:Resources.Stop}" Command="{Binding DataContext.ServiceStopCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,6,0" Padding="10,2"/>
                                            <Button Content="{x:Static res:Resources.Restart}" Command="{Binding DataContext.ServiceRestartCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,6,0" Padding="10,2"/>
                                            <Button Content="{x:Static res:Resources.Terminate}" Command="{Binding DataContext.ServiceTerminateCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,6,0" Padding="10,2"/>
                                            <Button Content="{x:Static res:Resources.OpenFolder}" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Margin="0,0,6,0" Padding="10,2"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- MySQL Tab -->
            <TabItem Header="{x:Static res:Resources.MySQL}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- MySQL 信息 -->
                    <GroupBox Header="{x:Static res:Resources.MySqlServiceInfo}" Grid.Row="0" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{x:Static res:Resources.ServiceName}" Width="80" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding MySqlManager.Config.ServiceName}" Width="120" Margin="4,0" IsReadOnly="True"/>
                                <TextBlock Text="{x:Static res:Resources.Status}" Width="40" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                <TextBlock VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding MySqlManager.Config.Status}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MySqlManager.Config.IsRunning}" Value="True">
                                                    <Setter Property="Foreground" Value="Green"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding MySqlManager.Config.IsRunning}" Value="False">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{x:Static res:Resources.Path}" Width="80" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="{x:Static res:Resources.Browse}" Command="{Binding MySqlBrowseCommand}" Padding="8,2" Margin="4,0,0,0"/>
                                <TextBox Text="{Binding MySqlManager.Config.ExePath}" IsReadOnly="True"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{x:Static res:Resources.RootPassword}" Width="80" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="{x:Static res:Resources.ApplyRootPassword}" Command="{Binding MySqlApplyRootPasswordCommand}" Padding="8,2" Margin="4,0,0,0"/>
                                <Button DockPanel.Dock="Right" Content="{x:Static res:Resources.GenerateRandom}" Command="{Binding MySqlGenerateRandomRootPasswordCommand}" Padding="8,2" Margin="4,0,0,0"/>
                                <TextBox Text="{Binding MySqlManager.Config.RootPassword, UpdateSourceTrigger=PropertyChanged}" Width="260" Margin="4,0,0,0"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{x:Static res:Resources.AppUser}" Width="80" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="{x:Static res:Resources.CreateOrUpdateUser}" Command="{Binding MySqlCreateOrUpdateUserCommand}" Padding="8,2" Margin="4,0,0,0"/>
                                <TextBox Text="{Binding MySqlManager.Config.AppUser, UpdateSourceTrigger=PropertyChanged}" Width="140" Margin="4,0,0,0"/>
                                <TextBlock Text="{x:Static res:Resources.AppPassword}" Width="70" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <TextBox Text="{Binding MySqlManager.Config.AppPassword, UpdateSourceTrigger=PropertyChanged}" Width="180" Margin="4,0,0,0"/>
                                <TextBlock Text="{x:Static res:Resources.Database}" Width="52" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <TextBox Text="{Binding MySqlManager.Config.Database, UpdateSourceTrigger=PropertyChanged}" Width="140" Margin="4,0,0,0"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{x:Static res:Resources.SqlScript}" Width="80" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" Content="{x:Static res:Resources.RunScript}" Command="{Binding MySqlRunScriptCommand}" Padding="8,2" Margin="4,0,0,0"/>
                                <Button DockPanel.Dock="Right" Content="..." Command="{Binding MySqlBrowseSqlScriptCommand}" Padding="10,2" Margin="4,0,0,0"/>
                                <TextBox Text="{Binding MySqlManager.Config.SqlScriptPath, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- MySQL 操作按钮 -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <Button Content="{x:Static res:Resources.ZipFullInstall}" Command="{Binding MySqlInstallZipCommand}" Margin="0,0,8,0" Padding="12,6"/>
                        <Button Content="{x:Static res:Resources.RegisterService}" Command="{Binding MySqlRegisterExistingCommand}" Margin="0,0,8,0" Padding="12,6"
                                ToolTip="{x:Static res:Resources.RegisterMySqlTooltip}"/>
                        <Button Content="{x:Static res:Resources.Start}" Command="{Binding MySqlStartCommand}" Margin="0,0,8,0" Padding="12,6"/>
                        <Button Content="{x:Static res:Resources.Stop}" Command="{Binding MySqlStopCommand}" Margin="0,0,8,0" Padding="12,6"/>
                        <Button Content="{x:Static res:Resources.Uninstall}" Command="{Binding MySqlUninstallCommand}" Margin="0,0,8,0" Padding="12,6" Foreground="Red"/>

                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0"/>

                        <Button Content="{x:Static res:Resources.ResetDatabase}" Command="{Binding MySqlResetDatabaseCommand}" Margin="0,0,8,0" Padding="12,6" Foreground="Red"
                                ToolTip="{x:Static res:Resources.ResetDatabaseTooltip}"/>
                    </WrapPanel>
                </Grid>
            </TabItem>

            <!-- MQTT Tab -->
            <TabItem Header="{x:Static res:Resources.MQTT}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="{x:Static res:Resources.MqttServiceInfo}" Grid.Row="0" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,4">
                                <TextBlock Text="{x:Static res:Resources.ServiceName}" Width="80" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding MqttManager.Config.ServiceName}" Width="180" Margin="4,0" IsReadOnly="True"/>
                                <TextBlock Text="{x:Static res:Resources.Status}" Width="40" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                <TextBlock VerticalAlignment="Center" Margin="4,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding MqttManager.Config.Status}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MqttManager.Config.IsRunning}" Value="True">
                                                    <Setter Property="Foreground" Value="Green"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding MqttManager.Config.IsRunning}" Value="False">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="{x:Static res:Resources.Path}" Width="80" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding MqttManager.Config.ExePath}" IsReadOnly="True"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                        <Button Content="{x:Static res:Resources.Start}" Command="{Binding MqttStartCommand}" Margin="0,0,8,0" Padding="12,6"/>
                        <Button Content="{x:Static res:Resources.Stop}" Command="{Binding MqttStopCommand}" Margin="0,0,8,0" Padding="12,6"/>
                    </WrapPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 进度条 -->
        <Grid Grid.Row="2" Margin="8,0,8,4" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding ProgressText}" Margin="0,0,0,2"/>
                <ProgressBar Value="{Binding Progress}" Height="16" Maximum="100"/>
            </StackPanel>
        </Grid>

        <!-- 日志输出 -->
        <Grid Grid.Row="3" Margin="8,0,8,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{x:Static res:Resources.LogOutput}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,0,6"/>
            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6">
                <logControls:LogViewerControl x:Name="LogViewer"
                                              TextWrapping="Wrap"
                                              ViewerMode="TextBox"
                                              MaxChars="100000"
                                              FontFamily="Consolas"
                                              FontSize="12"/>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock Text="{Binding ProgressText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
