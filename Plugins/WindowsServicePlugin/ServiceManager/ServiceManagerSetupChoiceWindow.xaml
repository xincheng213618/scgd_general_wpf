<Window x:Class="WindowsServicePlugin.ServiceManager.ServiceManagerSetupChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="服务管理器配置" Height="260" Width="460"
        Background="{DynamicResource GlobalBackground}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="选择初始化配置方式"
                   FontSize="17"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource GlobalTextBrush}"/>

        <TextBlock x:Name="LegacyConfigText"
                   Grid.Row="1"
                   Margin="0,8,0,12"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource GlobalTextBrush}"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="ImportButton"
                    Grid.Column="0"
                    Height="86"
                    Padding="12"
                    Click="Import_Click">
                <StackPanel>
                    <TextBlock Text="导入配置" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="定位旧版 CVWinSMS 并读取 App.config" Margin="0,6,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Height="86"
                    Padding="12"
                    Click="Manual_Click">
                <StackPanel>
                    <TextBlock Text="手动配置" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="配置 MySQL 和 MQTT" Margin="0,6,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Button Grid.Row="3"
                Content="跳过配置"
                Width="120"
                Height="30"
                Margin="0,14,0,0"
                HorizontalAlignment="Center"
                Click="Skip_Click"/>
    </Grid>
</Window>
