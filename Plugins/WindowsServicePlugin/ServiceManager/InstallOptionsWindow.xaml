<Window x:Class="WindowsServicePlugin.ServiceManager.InstallOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="安装选项" Height="300" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="请配置安装选项" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <CheckBox Content="安装后一键启动所有服务"
                      IsChecked="{Binding AutoStartAfterInstall}"
                      Margin="0,10"/>

            <CheckBox Content="安装后自动执行数据库更新脚本"
                      IsChecked="{Binding AutoUpdateDatabase}"
                      Margin="0,10"/>

            <TextBlock Text="SQL 脚本将从解压目录的 SQL 文件夹中自动读取执行"
                      Foreground="Gray"
                      Margin="25,5,0,0"
                      TextWrapping="Wrap"/>

            <Separator Margin="0,20"/>

            <TextBlock Text="注意：" FontWeight="Bold" Foreground="OrangeRed"/>
            <TextBlock Text="• 全新安装会卸载现有服务并重新安装"
                      Foreground="Gray"
                      Margin="0,5"
                      TextWrapping="Wrap"/>
            <TextBlock Text="• 建议先备份数据库再执行全新安装"
                      Foreground="Gray"
                      TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="开始安装" Click="OkButton_Click"
                    Padding="20,6" Margin="0,0,10,0" IsDefault="True"
                    Style="{StaticResource ButtonPrimary}"/>
            <Button Content="取消" Click="CancelButton_Click"
                    Padding="20,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
