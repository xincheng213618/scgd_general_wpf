<Window x:Class="WindowsServicePlugin.ServiceManager.ServiceInstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsServicePlugin.ServiceManager"
        xmlns:logControls="clr-namespace:ColorVision.UI.LogImp.Controls;assembly=ColorVision.UI"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="服务安装管理" Height="780" Width="980"
        d:DataContext="{d:DesignInstance local:ServiceInstallViewModel}"
        Background="{DynamicResource GlobalBackground}"
        Foreground="{DynamicResource GlobalTextBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 安装组件选择 -->
        <Border Grid.Row="0" Padding="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="服务安装管理" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="安装根目录：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Text="{Binding Config.BaseLocation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="目录设置" Command="{Binding SelectBaseLocationCommand}" Padding="12,4"/>
                </Grid>

                <!-- 一键安装包 -->
                <Border Padding="8" Background="{DynamicResource RegionBrush}" CornerRadius="3" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="一键安装：选择安装包后自动解压、识别组件并勾选，然后点击下方安装按钮" VerticalAlignment="Center" Foreground="Gray" TextWrapping="Wrap"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="在线下载" Command="{Binding OnlineDownloadCommand}" Padding="16,6" Margin="0,0,8,0"/>
                            <Button Content="选择一键安装包" Command="{Binding OneKeyInstallAllCommand}" Padding="16,6" Style="{StaticResource ButtonPrimary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 服务包 -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="服务包" IsChecked="{Binding InstallServiceChecked}" VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="80"/>
                    <TextBox Grid.Column="1" Text="{Binding ServicePackagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="下载" Command="{Binding DownloadServicePackageCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="选择" Command="{Binding SelectServicePackageCommand}" Padding="12,4"/>
                </Grid>

                <!-- MySQL -->
                <Grid Margin="0,0,0,6" Visibility="{Binding IsMySqlInstallVisible, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="MySQL" IsChecked="{Binding InstallMySqlChecked}" VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="80"/>
                    <TextBox Grid.Column="1" Text="{Binding MySqlPackagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="下载" Command="{Binding DownloadMySqlPackageCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="选择" Command="{Binding SelectMySqlZipCommand}" Padding="12,4"/>
                </Grid>

                <!-- VC++ 2013 -->
                <Grid Margin="0,0,0,6" Visibility="{Binding IsVc2013InstallVisible, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="VC++ 2013" IsChecked="{Binding InstallVc2013Checked}" VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="80"/>
                    <TextBox Grid.Column="1" Text="{Binding Vc2013InstallerPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="下载" Command="{Binding DownloadVc2013InstallerCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="选择" Command="{Binding SelectVc2013InstallerCommand}" Padding="12,4"/>
                </Grid>

                <!-- MQTT -->
                <Grid Margin="0,0,0,4" Visibility="{Binding IsMqttInstallVisible, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="MQTT" IsChecked="{Binding InstallMqttChecked}" VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="80"/>
                    <TextBox Grid.Column="1" Text="{Binding MqttInstallerPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="下载" Command="{Binding DownloadMqttInstallerCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="选择" Command="{Binding SelectMqttInstallerCommand}" Padding="12,4"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 安装选项 -->
        <Border Grid.Row="1" Padding="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="安装选项" FontWeight="Bold" Margin="0,0,0,6"/>
                <WrapPanel>
                    <CheckBox Content="更新数据库到最近版本" IsChecked="{Binding AutoUpdateDatabase}" Margin="0,2,20,2"/>
                </WrapPanel>
                
                <!-- 数据库备份 -->
                <TextBlock Text="数据库备份" FontSize="12" Margin="0,8,0,4" Foreground="{DynamicResource GlobalTextBrush}"/>
                <WrapPanel Margin="0,0,0,8">
                    <CheckBox Content="安装前备份数据库" IsChecked="{Binding BackupBeforeInstall}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <Button Content="立即备份" Command="{Binding BackupNowCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Content="恢复备份" Command="{Binding RestoreBackupCommand}" Padding="12,4"/>
                    <TextBlock Text="(保存至：我的文档\ColorVision\Backup)" VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0" FontSize="11"/>
                </WrapPanel>
                
                <!-- 服务备份 -->
                <TextBlock Text="服务备份" FontSize="12" Margin="0,4,0,4" Foreground="{DynamicResource GlobalTextBrush}"/>
                <WrapPanel>
                    <CheckBox Content="安装前备份服务文件夹" IsChecked="{Binding BackupServiceBeforeInstall}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <Button Content="立即备份服务" Command="{Binding BackupServiceNowCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Content="恢复服务备份" Command="{Binding RestoreServiceBackupCommand}" Padding="12,4"/>
                    <TextBlock Text="(保存至：我的文档\ColorVision\ServiceBackup)" VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0" FontSize="11"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- 进度条 -->
        <Grid Grid.Row="2" Margin="0,0,0,8" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding ProgressText}" Margin="0,0,0,4"/>
                <ProgressBar Value="{Binding Progress}" Height="16" Maximum="100"/>
            </StackPanel>
        </Grid>

        <!-- 安装日志 -->
        <Border Grid.Row="4" Padding="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="安装日志" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,0,6"/>
                <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="6">
                    <logControls:LogViewerControl x:Name="LogViewer"
                                                  TextWrapping="Wrap"
                                                  ViewerMode="TextBox"
                                                  MaxChars="100000"
                                                  FontFamily="Consolas"
                                                  FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="5" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="立即安装" Command="{Binding DoInstallCommand}" Padding="40,5" FontSize="14" FontWeight="Bold" Style="{StaticResource ButtonPrimary}" Margin="0,0,8,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
