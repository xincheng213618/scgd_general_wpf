<Window x:Class="WindowsServicePlugin.ServiceManager.ServiceInstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="服务安装管理" Height="720" Width="980"
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="服务安装管理" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="服务包" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding ServicePackagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="更新" Command="{Binding CheckUpdateCommand}" Padding="12,4" Margin="0,0,8,0" Style="{StaticResource ButtonPrimary}"/>
                    <Button Grid.Column="3" Content="选择" Command="{Binding SelectServicePackageCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="4" Content="安装" Command="{Binding InstallServicePackageCommand}" Padding="12,4"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="MySQL" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding MySqlPackagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="在线下载" Command="{Binding DownloadMySqlCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="选择" Command="{Binding SelectMySqlZipCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="4" Content="安装" Command="{Binding InstallMySqlCommand}" Padding="12,4"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="MQTT" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding MqttInstallerPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="2" Content="在线下载" Command="{Binding DownloadMqttCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="选择" Command="{Binding SelectMqttInstallerCommand}" Padding="12,4" Margin="0,0,8,0"/>
                    <Button Grid.Column="4" Content="安装" Command="{Binding InstallMqttCommand}" Padding="12,4"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Padding="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="安装选项" FontWeight="Bold" Margin="0,0,0,6"/>
                <CheckBox Content="安装后一键启动所有服务" IsChecked="{Binding AutoStartAfterInstall}" Margin="0,2"/>
                <CheckBox Content="安装后自动执行数据库更新脚本" IsChecked="{Binding AutoUpdateDatabase}" Margin="0,2"/>
                <TextBlock Text="说明：服务包安装后会自动执行 UpdateConfig，避免使用安装包默认配置。" Foreground="Gray" Margin="22,2,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding ProgressText}" Margin="0,0,0,4"/>
                <ProgressBar Value="{Binding Progress}" Height="16" Maximum="100"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" Padding="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="安装日志" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding UpdateStatusText}" VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0"/>
                    <Button DockPanel.Dock="Right" Content="清除" Command="{Binding ClearLogCommand}" Padding="8,2"/>
                </DockPanel>
                <TextBox Grid.Row="1" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="关闭" Command="{Binding CloseCommand}" Padding="20,6" IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
