<Window x:Class="WindowsServicePlugin.ServiceManager.ServiceInstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WindowsServicePlugin.ServiceManager"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        mc:Ignorable="d"
        Title="服务安装管理" Height="600" Width="900"
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部：下载/手动选择 -->
        <Border Grid.Row="0" Padding="15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="服务安装包管理" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                <!-- 在线下载区域 -->
                <GroupBox Header="在线下载" Margin="0,0,0,10">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <Button DockPanel.Dock="Right" Content="检查更新" Command="{Binding CheckUpdateCommand}"
                                    Padding="15,5" Margin="10,0,0,0" Style="{StaticResource ButtonPrimary}"/>
                            <TextBox Text="{Binding UpdateServerUrl, Mode=OneWay}"
                                     VerticalAlignment="Center" IsReadOnly="True"/>
                        </DockPanel>
                        <TextBlock Text="{Binding UpdateStatusText}" Margin="0,5" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

                <!-- 手动安装区域 -->
                <GroupBox Header="手动安装">
                    <StackPanel>
                        <TextBlock Text="如果您已手动下载安装包，请选择文件进行安装：" Margin="0,5" Foreground="Gray"/>
                        <WrapPanel Margin="0,5">
                            <Button Content="选择 FullPackage 安装" Command="{Binding SelectFullPackageCommand}"
                                    Margin="0,0,10,0" Padding="15,6" Style="{StaticResource ButtonPrimary}"/>
                            <Button Content="选择 MySQL ZIP 安装" Command="{Binding SelectMySqlZipCommand}"
                                    Margin="0,0,10,0" Padding="15,6"/>
                            <Button Content="选择 MQTT 安装" Command="{Binding SelectMqttInstallerCommand}"
                                    Margin="0,0,10,0" Padding="15,6"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Border>

        <!-- 已下载包列表 -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="已下载的安装包" FontWeight="Bold" Margin="0,0,0,8"/>
            <DataGrid Grid.Row="1" ItemsSource="{Binding DownloadedPackages}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectedItem="{Binding SelectedPackage}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="*"/>
                    <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="100"/>
                    <DataGridTextColumn Header="类型" Binding="{Binding PackageType}" Width="100"/>
                    <DataGridTextColumn Header="下载时间" Binding="{Binding DownloadTime, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                    <DataGridTextColumn Header="大小" Binding="{Binding FileSizeText}" Width="100"/>
                    <DataGridTemplateColumn Header="操作" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="安装" Command="{Binding DataContext.InstallPackageCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Margin="0,0,5,0" Padding="10,2"/>
                                    <Button Content="打开位置" Command="{Binding DataContext.OpenPackageLocationCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Margin="0,0,5,0" Padding="10,2"/>
                                    <Button Content="删除" Command="{Binding DataContext.DeletePackageCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" Padding="10,2" Foreground="Red"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="2" Margin="15,0" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{Binding ProgressText}" Margin="0,0,0,5"/>
                <ProgressBar Value="{Binding Progress}" Height="20" Maximum="100"/>
            </StackPanel>
        </Grid>

        <!-- 日志输出 -->
        <Grid Grid.Row="3" Margin="15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Grid.Row="0" Margin="0,0,0,5">
                <TextBlock Text="安装日志" VerticalAlignment="Center" FontWeight="Bold"/>
                <Button DockPanel.Dock="Right" Content="清除" Command="{Binding ClearLogCommand}" Padding="8,2"/>
            </DockPanel>
            <TextBox Grid.Row="1" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
        </Grid>

        <!-- 底部按钮 -->
        <Border Grid.Row="4" Padding="15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="关闭" Command="{Binding CloseCommand}" Padding="20,6" IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
