<Window x:Class="Spectrum.Help.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="光谱仪帮助文档" Height="700" Width="1000"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="200"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: search + list -->
        <DockPanel Grid.Column="0" Margin="8">
            <!-- Search box -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0"
                         Padding="6,4" FontSize="13"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <Label Content="🔍 搜索术语或功能..." Foreground="Gray" FontSize="13" Padding="4,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button Grid.Column="1" Content="✕" Width="28" Height="28" Margin="4,0,0,0"
                        Click="ClearSearch_Click" ToolTip="清除搜索"
                        Background="Transparent" BorderThickness="0" FontSize="14"/>
            </Grid>

            <!-- Category filter -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton x:Name="FilterAll" Content="全部" IsChecked="True"
                             Checked="Filter_Changed" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <RadioButton x:Name="FilterTerminology" Content="📖 术语"
                             Checked="Filter_Changed" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <RadioButton x:Name="FilterUsage" Content="🔧 指南"
                             Checked="Filter_Changed" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Item count -->
            <TextBlock x:Name="ItemCountText" DockPanel.Dock="Bottom"
                       Margin="0,4,0,0" Foreground="Gray" FontSize="11"/>

            <!-- Help entry list -->
            <ListBox x:Name="HelpList" SelectionChanged="HelpList_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     BorderThickness="1" BorderBrush="#CCCCCC">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="4,6">
                            <TextBlock Text="{Binding CategoryDisplay}" FontSize="10"
                                       Foreground="#888888" Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                       FontSize="13" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Summary}" FontSize="11"
                                       Foreground="#666666" TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="#E0E0E0"/>

        <!-- Right panel: detail -->
        <DockPanel Grid.Column="2" Margin="8">
            <!-- Header -->
            <TextBlock x:Name="DetailTitle" DockPanel.Dock="Top"
                       FontSize="20" FontWeight="Bold"
                       TextWrapping="Wrap" Margin="0,0,0,8"/>
            <TextBlock x:Name="DetailCategory" DockPanel.Dock="Top"
                       FontSize="12" Foreground="#888888" Margin="0,0,0,12"/>

            <!-- Placeholder when nothing selected -->
            <TextBlock x:Name="PlaceholderText" DockPanel.Dock="Top"
                       Text="← 请从左侧列表中选择一个条目查看详情"
                       Foreground="Gray" FontSize="14"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Visibility="Visible"/>

            <!-- Detail content -->
            <ScrollViewer x:Name="DetailScroll" VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed">
                <TextBlock x:Name="DetailContent"
                           TextWrapping="Wrap" FontSize="13"
                           LineHeight="22" Padding="0,0,8,0"/>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
