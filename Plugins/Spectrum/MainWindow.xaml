<Window x:Class="Spectrum.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Spectrum"
        xmlns:models="clr-namespace:Spectrum.Models"
        xmlns:wpf="http://schemas.microsoft.com/netfx/2007/xaml/presentation"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:wfi ="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:properties ="clr-namespace:Spectrum.Properties"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:SpectrometerManager}"
        Title="光谱仪软件" Height="1080" Width="1920" Background="{DynamicResource GlobalBackground}" Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}" >
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Margin" Value="2,2,2,6"/>
            <Setter Property="Padding" Value="6,6"/>
        </Style>
    </Window.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Menu x:Name="menu" Grid.Row="0" Padding="2" >
            </Menu>
            <Button HorizontalAlignment="Right" Margin="5,0,5,0"  Command="{Binding SetEmissionSP100Config.EditCommand}" Padding="2" Height="18" Width="18" >
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="rotateTransform2" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <TextBlock Text="&#xE713;"  HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" RenderTransformOrigin="0.5,0.5" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="rotateTransform2"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Button>
        </Grid>
        

        <xcad:DockingManager x:Name="DockingManager" Grid.Row="1" BorderThickness="0" Background="Transparent">
            <xcad:LayoutRoot x:Name="_layoutRoot">
                <xcad:LayoutPanel Orientation="Horizontal">

                    <!-- ═══ Left: Control Panel ═══ -->
                    <xcad:LayoutAnchorablePaneGroup DockWidth="330">
                        <xcad:LayoutAnchorablePane>
                            <xcad:LayoutAnchorable x:Name="ControlPanelPane" Title="控制面板" ContentId="ControlPanel" CanClose="False" CanAutoHide="True" CanFloat="True">
                                <ScrollViewer Margin="3,0,3,5">
                                    <StackPanel x:Name="MainStackPanel">

                        <!-- ═══ 光谱仪连接 (Spectrometer Connection) ═══ -->
                        <GroupBox Header="光谱仪连接">
                            <StackPanel>
                                <StackPanel Visibility="{Binding IsConnected,Converter={StaticResource bool2VisibilityConverter1}}">
                                    <Button Command="{Binding GetSpectrSerialNumberCommand}" Content="获取设备列表" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" >
                                        <ComboBox x:Name="ComboBoxSpectrometerType" Width="140" Style="{StaticResource ComboBox.Small}" SelectedValue="{Binding Config.SpectrometerType}" SelectedValuePath="Key" DisplayMemberPath="Value"/>
                                        <CheckBox Content="串口连接" IsChecked="{Binding Config.IsComPort}" Margin="10,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal" Visibility="{Binding Config.IsComPort,Converter={StaticResource bool2VisibilityConverter}}">
                                        <DockPanel>
                                            <TextBlock Text="串口" VerticalAlignment="Center" Width="40" />
                                            <ComboBox x:Name="ComboBoxPort" Style="{StaticResource ComboBox.Small}" IsEditable="True" Text="{Binding Config.SzComName}" Width="80" />
                                        </DockPanel>
                                        <DockPanel Margin="8,0,0,0">
                                            <TextBlock Text="波特率" VerticalAlignment="Center" Width="45" />
                                            <ComboBox x:Name="ComboBoxSerial" Style="{StaticResource ComboBox.Small}" Width="70" IsEditable="True" Text="{Binding Config.BaudRate}" />
                                        </DockPanel>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Margin="0,4,0,0">
                                    <Button Content="{x:Static properties:Resources.连接光谱仪}" Click="Button_Click"  Visibility="{Binding IsConnected,Converter={StaticResource bool2VisibilityConverter1}}" Padding="12,4" Background="#2196F3" Foreground="White" />
                                    <Button x:Name="ButtonClose" Content="{x:Static properties:Resources.断开光谱仪}" Background="#E53935" Foreground="White" Click="ButtonClose_Click" Visibility="{Binding IsConnected,Converter={StaticResource bool2VisibilityConverter}}" Padding="12,4" />
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ 标定文件 (Calibration Files) ═══ -->
                        <GroupBox Header="标定文件">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <Button DockPanel.Dock="Right" Content="管理..." Command="{Binding OpenCalibrationGroupWindowCommand}" Margin="4,0,0,0" Padding="8,2" ToolTip="打开标定分组管理窗口"/>
                                    <Button DockPanel.Dock="Right" Content="加载分组" Command="{Binding ApplyActiveGroupCommand}" Margin="4,0,0,0" Padding="8,2" ToolTip="加载当前选择分组的标定文件" Visibility="{Binding IsConnected,Converter={StaticResource bool2VisibilityConverter}}"/>
                                    <TextBlock Text="当前分组: " Width="60"/>
                                    <ComboBox Style="{StaticResource ComboBox.Small}" ItemsSource="{Binding CalibrationGroupNames}" SelectedItem="{Binding ActiveCalibrationGroupName, Mode=TwoWay}" />
                                </DockPanel>
                                <DockPanel Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right" Content="加载" Style="{StaticResource ButtonDefault.Small}" Margin="5,0,0,0" Command="{Binding LoadWavelengthFileCommand}" Visibility="{Binding IsConnected,Converter={StaticResource bool2VisibilityConverter}}" />
                                    <TextBlock Text="波长标定" MinWidth="60"/>
                                    <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding WavelengthFile}" ToolTip="{Binding WavelengthFile}" IsReadOnly="True"/>
                                </DockPanel>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="加载" Margin="5,0,0,0" Style="{StaticResource ButtonDefault.Small}" Command="{Binding LoadMaguideFileCommand}" Visibility="{Binding IsConnected,Converter={StaticResource bool2VisibilityConverter}}" />
                                    <TextBlock Text="幅值标定" MinWidth="60"/>
                                    <TextBox Style="{StaticResource TextBox.Small}" Text="{Binding MaguideFile}" ToolTip="{Binding MaguideFile}" IsReadOnly="True"/>
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ 测量参数 (Measurement Parameters) ═══ -->
                        <GroupBox Header="测量参数" Visibility="{Binding IsConnected,Converter={StaticResource bool2VisibilityConverter}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="自动积分阈值 (%)" Width="110"/>
                                    <TextBox Style="{StaticResource TextBox.Small}" Width="90" VerticalAlignment="Center" Text="{Binding MaxPercent}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="积分时间 (ms)" Width="110"/>
                                    <TextBox Style="{StaticResource TextBox.Small}" Width="90" VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding IntTime}" />
                                    <Button Margin="4,0,4,0" HorizontalAlignment="Left" Command="{Binding EditIntTimeConfigCommand}" Padding="0" Height="20" Width="20" >
                                        <Button.Triggers>
                                            <EventTrigger RoutedEvent="Button.Click">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="rotateTransform21" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Button.Triggers>
                                        <TextBlock Text="&#xE713;" HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" RenderTransformOrigin="0.5,0.5" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform x:Name="rotateTransform21"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Button>
                                    <Button x:Name="ButtonAutoInt" Content="自动积分" Click="AutoIntTime_Click" Padding="10,4" Background="#E67E22" Foreground="White"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="平均次数" Width="110" />
                                    <TextBox Style="{StaticResource TextBox.Small}" Width="90" VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding Average}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ 测试 (Test & Calibration) ═══ -->
                        <GroupBox Header="测试" Visibility="{Binding IsConnected,Converter={StaticResource bool2VisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="校零" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button x:Name="button3" Content="{x:Static properties:Resources.单次校零}" Click="Button3_Click" Margin="0,0,4,0" Padding="10,4" Background="#E67E22" Foreground="White"/>
                                    <Button Margin="4,0,0,0" HorizontalAlignment="Left" Command="{Binding EditAutodarkParamCommand}" Padding="0" Height="20" Width="20" >
                                        <Button.Triggers>
                                            <EventTrigger RoutedEvent="Button.Click">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="rotateTransform24" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Button.Triggers>
                                        <TextBlock Text="&#xE713;" HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" RenderTransformOrigin="0.5,0.5" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform x:Name="rotateTransform24"/>
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Button>
                                </StackPanel>
                                <DockPanel Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox Content="{x:Static properties:Resources.自动积分}" IsChecked="{Binding EnableAutoIntegration}" Margin="0,0,8,0"/>
                                        <CheckBox Content="自适应校零" IsChecked="{Binding EnableAdaptiveAutoDark}" Margin="0,0,8,0"/>
                                        <CheckBox Content="自动校零" IsChecked="{Binding EnableAutodark}" Margin="0,0,8,0"/>
                                    </StackPanel>
                                </DockPanel>

                                <Separator Margin="0,2,0,6"/>

                                <TextBlock Text="单次测试" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <Button x:Name="button5" Content="{x:Static properties:Resources.单次测试}" Click="Button5_Click" Margin="0,0,0,8" Padding="10,6" Background="#3498DB" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>

                                <TextBlock Text="连续测试" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="间隔 (ms)" Grid.Row="0" Grid.Column="0" Margin="0,0,6,4"/>
                                    <TextBox Style="{StaticResource TextBox.Small}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding MeasurementInterval}" Margin="0,0,8,4"/>
                                    <TextBlock Text="测试次数" Grid.Row="0" Grid.Column="2" Margin="0,0,6,4"/>
                                    <TextBox Style="{StaticResource TextBox.Small}" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" TextWrapping="Wrap" Text="{Binding MeasurementNum}" Margin="0,0,0,4"/>
                                    <TextBlock Text="进度" Grid.Row="1" Grid.Column="0" Margin="0,0,6,0"/>
                                    <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding LoopMeasureNum}" FontWeight="SemiBold" Foreground="#3498DB"/>
                                        <TextBlock Text=" / "/>
                                        <TextBlock Text="{Binding MeasurementNum}"/>
                                    </StackPanel>
                                </Grid>
                                <ProgressBar x:Name="ContinuousProgressBar" Height="15" Margin="0,4,0,4" Minimum="0" Maximum="100" Value="0" Foreground="#3498DB"/>
                                <StackPanel x:Name="TimeEstimationPanel" Orientation="Horizontal" Margin="0,0,0,4" Visibility="Collapsed">
                                    <TextBlock Text="已用: " FontSize="11"/>
                                    <TextBlock x:Name="ElapsedTimeText" Text="--:--" FontSize="11" FontWeight="SemiBold" Foreground="#2196F3"/>
                                    <TextBlock Text="  预计剩余: " FontSize="11"/>
                                    <TextBlock x:Name="RemainingTimeText" Text="--:--" FontSize="11" FontWeight="SemiBold" Foreground="#E67E22"/>
                                </StackPanel>

                                <Grid Margin="0,2,0,0" Visibility="{Binding IsConnected,Converter={StaticResource bool2VisibilityConverter}}">
                                    <Button x:Name="button6" Content="{x:Static properties:Resources.连续测试}" Click="Button6_Click" Padding="10,6" Background="#27AE60" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                                    <Button x:Name="button7" Content="{x:Static properties:Resources.停止}" Foreground="White" Background="#E53935" Click="Button7_Click" Padding="10,6" FontWeight="SemiBold" HorizontalAlignment="Stretch" Visibility="Collapsed"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ 快门控制 (Shutter) ═══ -->
                        <GroupBox Header="快门 (Shutter)">
                            <StackPanel>
                                <!-- Not connected: show connect button + gear -->
                                <StackPanel Visibility="{Binding ShutterController.IsConnected,Converter={StaticResource bool2VisibilityConverter1}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="连接" Command="{Binding ShutterController.ConnectCommand}" Padding="10,4" Background="#2196F3" Foreground="White"/>
                                        <Button Margin="4,0,0,0" HorizontalAlignment="Left" Command="{Binding EditShutterConfigCommand}" Padding="0" Height="20" Width="20" >
                                            <Button.Triggers>
                                                <EventTrigger RoutedEvent="Button.Click">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="rotateTransform26" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Button.Triggers>
                                            <TextBlock Text="&#xE713;" HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" RenderTransformOrigin="0.5,0.5" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform x:Name="rotateTransform26"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Connected: show status + disconnect + open/close -->
                                <StackPanel Visibility="{Binding ShutterController.IsConnected,Converter={StaticResource bool2VisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="断开" Command="{Binding ShutterController.DisconnectCommand}" Margin="0,0,4,0" Padding="8,2" Background="#E53935" Foreground="White"/>
                                        <Button Content="Open Shutter" Command="{Binding ShutterController.OpenShutterCommand}" Margin="0,0,4,0" Padding="8,2"/>
                                        <Button Content="Close Shutter" Command="{Binding ShutterController.CloseShutterCommand}" Margin="0,0,4,0" Padding="8,2"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ 滤色轮 (Filter Wheel) ═══ -->
                        <GroupBox Header="滤色轮 (Filter Wheel)">
                            <StackPanel>
                                <!-- Connection controls (visible when NOT connected) -->
                                <StackPanel Visibility="{Binding FilterWheelController.IsConnected,Converter={StaticResource bool2VisibilityConverter1}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="连接" Command="{Binding FilterWheelController.ConnectCommand}" Padding="10,4" Background="#2196F3" Foreground="White"/>
                                        <Button Margin="4,0,0,0" HorizontalAlignment="Left" Command="{Binding EditFilterWheelConfigCommand}" Padding="0" Height="20" Width="20" >
                                            <Button.Triggers>
                                                <EventTrigger RoutedEvent="Button.Click">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="rotateTransformFW" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Button.Triggers>
                                            <TextBlock Text="&#xE713;" HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" RenderTransformOrigin="0.5,0.5" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform x:Name="rotateTransformFW"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Connected state controls -->
                                <StackPanel Visibility="{Binding FilterWheelController.IsConnected,Converter={StaticResource bool2VisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="当前位置: " VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FilterWheelController.CurrentPositionName}" FontWeight="SemiBold" Foreground="#2196F3" VerticalAlignment="Center" Margin="4,0,8,0"/>
                                        <Button Content="查询" Command="{Binding FilterWheelController.QueryPositionCommand}" Padding="8,2" Margin="0,0,4,0"/>
                                        <Button Content="断开" Command="{Binding FilterWheelController.DisconnectCommand}" Padding="8,2" Background="#E53935" Foreground="White"/>
                                    </StackPanel>

                                    <!-- Position buttons -->
                                    <TextBlock Text="切换位置:" Margin="0,2,0,2"/>
                                    <ItemsControl ItemsSource="{Binding FilterWheelConfig.HoleMapping}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,4,4" Padding="10,4"
                                                        Command="{Binding DataContext.FilterWheelController.SetPositionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding HoleIndex}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding HoleIndex, StringFormat='{}{0}: '}"/>
                                                        <TextBlock Text="{Binding HoleName}"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- ═══ 光通量参数配置 ═══ -->
                        <GroupBox x:Name="EqeGroupBox" Header="光通量参数配置" Visibility="Collapsed">
                            <StackPanel>
                                <StackPanel x:Name="EqePanel" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="电压 (V)" Width="80"/>
                                        <TextBox x:Name="TextBoxVoltage" Style="{StaticResource TextBox.Small}" Width="80" Text="{Binding Source={x:Static local:MainWindowConfig.Instance}, Path=EqeVoltage, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="电流 (mA)" Width="80"/>
                                        <TextBox x:Name="TextBoxCurrentMA" Style="{StaticResource TextBox.Small}" Width="80" Text="{Binding Source={x:Static local:MainWindowConfig.Instance}, Path=EqeCurrentMA, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Button Content="EQE重新计算" Click="CalculateEqe_Click" Margin="0,4,0,0" HorizontalAlignment="Left" />

                                    <!-- ═══ 源表(SMU)配置 ═══ -->
                                    <Separator Margin="0,6,0,6"/>
                                    <TextBlock Text="源表(SMU)" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="设备名称" Width="80"/>
                                        <TextBox Style="{StaticResource TextBox.Small}" Width="140" Text="{Binding SmuController.Config.DevName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <CheckBox Content="网络连接" IsChecked="{Binding SmuController.Config.IsNet}" Margin="0,0,8,0"/>
                                        <CheckBox Content="电压源" IsChecked="{Binding SmuController.Config.IsSourceV}" Margin="0,0,8,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <CheckBox Content="通道A" IsChecked="{Binding SmuController.Config.IsChannelA}" Margin="0,0,8,0"/>
                                        <CheckBox Content="四线制" IsChecked="{Binding SmuController.Config.Is4Wire}" Margin="0,0,8,0"/>
                                        <CheckBox Content="前接口" IsChecked="{Binding SmuController.Config.IsFront}" Margin="0,0,8,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="测量值" Width="50"/>
                                        <TextBox Style="{StaticResource TextBox.Small}" Width="60" Text="{Binding SmuController.Config.MeasureVal, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="限制值" Width="50" Margin="8,0,0,0"/>
                                        <TextBox Style="{StaticResource TextBox.Small}" Width="60" Text="{Binding SmuController.Config.LimitVal, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                        <Button x:Name="ButtonSmuConnect" Content="连接源表" Click="SmuConnect_Click" Width="80" Margin="0,0,4,0"/>
                                        <Button x:Name="ButtonSmuMeasure" Content="读取V/I" Click="SmuMeasure_Click" Width="80" IsEnabled="False"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="V:" Width="20"/>
                                        <TextBlock x:Name="SmuVDisplay" Text="{Binding SmuController.V, StringFormat='{}{0:F4}'}" Width="80" Foreground="DodgerBlue"/>
                                        <TextBlock Text="I(mA):" Width="45" Margin="8,0,0,0"/>
                                        <TextBlock x:Name="SmuIDisplay" Text="{Binding SmuController.I, StringFormat='{}{0:F4}'}" Width="80" Foreground="DodgerBlue"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                    </StackPanel>
                </ScrollViewer>
                            </xcad:LayoutAnchorable>
                        </xcad:LayoutAnchorablePane>
                    </xcad:LayoutAnchorablePaneGroup>

                    <!-- ═══ Center + Bottom Layout ═══ -->
                    <xcad:LayoutPanel Orientation="Vertical">

                        <!-- ═══ Center: Spectrum Charts + Data ═══ -->
                        <xcad:LayoutDocumentPaneGroup>
                            <xcad:LayoutDocumentPane>
                                <xcad:LayoutDocument Title="光谱图表" ContentId="SpectrumChart" CanClose="False">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition x:Name="ListRow1" Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition x:Name="ListRow2" Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ScottPlot:WpfPlot  x:Name="wpfplot1" Panel.ZIndex="9" />
                        <ScottPlot:WpfPlot  x:Name="wpfplot2" Panel.ZIndex="9" Visibility="Collapsed" />
                        <ListView x:Name="listView2"  Grid.Column="1"  Padding="2,0,2,2"  Style="{StaticResource ListView.Small}" BorderThickness="0" SelectionChanged="listView2_SelectionChanged">
                            <ListView.Resources>
                                <ContextMenu x:Key="ItemContextMenu" Opened="ContextMenu1_Opened" >
                                </ContextMenu>
                            </ListView.Resources>
                            <ListView.View >
                                <GridView >
                                    <GridView.ColumnHeaderContainerStyle>
                                        <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource  InputElementBaseStyle}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
                                        </Style>
                                    </GridView.ColumnHeaderContainerStyle>
                                    <GridViewColumn  Header="波长" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:SpectralData}">
                                                <TextBlock Text="{ Binding  Wavelength}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="相对光谱">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:SpectralData}">
                                                <TextBlock Text="{Binding  RelativeSpectrum, StringFormat={}{0:F4}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="绝对光谱" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:SpectralData}">
                                                <TextBlock Text="{ Binding   AbsoluteSpectrum, StringFormat={}{0:F4}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                                        </Grid>
                                        <GridSplitter Grid.Row="1" Background="#FFFFFF" Height="2" HorizontalAlignment="Stretch" VerticalAlignment="Center" DragCompleted="GridSplitter_DragCompleted"/>
                                        <Grid x:Name="Grid1" Grid.Row="2" >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ToolBarTray Grid.Row="0" HorizontalAlignment="Left">
                            <ToolBar Padding="3,2">
                                <ToggleButton Click="ButtonMul_Click"  IsChecked="True" Margin="2,0,0,0" >
                                    <Image  Stretch="Uniform" Source="{DynamicResource DrawingImageSwitch}" />
                                </ToggleButton>
                                <ToggleButton x:Name="ToggleSpectrumType" Click="ToggleSpectrumType_Click" Margin="2,0,0,0" ToolTip="切换相对/绝对光谱">
                                    <TextBlock Text="相对光谱" x:Name="SpectrumTypeText"/>
                                </ToggleButton>
                                <Separator/>
                                <Button  Content="查询" Command="{Binding ViewResultManager.QueryCommand}" Margin="2,0,0,0" ToolTip="查询数据"/>
                                <Button  Content="通用查询" Command="{Binding ViewResultManager.GenericQueryCommand}" Margin="2,0,0,0"/>
                                <Button  Content="刷新" Command="{Binding ViewResultManager.ReloadCommand}" Margin="2,0,0,0" ToolTip="从数据库重新加载数据"/>
                                <Separator/>
                                <Button  Content="清空记录" Command="{Binding ViewResultManager.DeleteAllCommand}" Margin="2,0,0,0" ToolTip="删除数据库中所有记录" Foreground="#E53935"/>
                                <Button  Content="重置数据库" Command="{Binding ViewResultManager.ResetDatabaseCommand}" Margin="2,0,0,0" ToolTip="删除数据库文件并重新创建" Foreground="#E53935"/>
                                <Separator/>
                                <TextBlock Text="加载条数:" VerticalAlignment="Center" Margin="4,0,2,0"/>
                                <TextBox Width="50" VerticalAlignment="Center" Text="{Binding ViewResultManager.Config.Count, UpdateSourceTrigger=PropertyChanged}" ToolTip="默认加载数据条数 (-1为全部)"/>
                            </ToolBar>
                        </ToolBarTray>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <StackPanel HorizontalAlignment="Right"  Orientation="Horizontal">
                                <Button Command="{Binding ViewResultManager.SaveCommand}" Click="Export_Click" Padding="2" Height="25" Width="25" Margin="0,1,5,0">
                                    <Rectangle Width="16" Height="16" Fill="{StaticResource DISave}" />
                                </Button>
                                <Button  Click="Cleartable_Click" Command="{Binding ViewResultManager.ViewReslutsClearCommand}" Padding="2" Height="25" Width="25" Margin="0,1,5,0" >
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="Button.Click">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation  Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleX" To="0.7" Duration="0:0:0.1" AutoReverse="True" />
                                                    <DoubleAnimation  Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleY" To="0.7" Duration="0:0:0.1" AutoReverse="True" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>
                                    <Image  Stretch="Uniform" Source="{DynamicResource DrawingImageDelete}" RenderTransformOrigin="0.5,0.5">
                                        <Image.RenderTransform>
                                            <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
                                        </Image.RenderTransform>
                                    </Image>
                                </Button>
                                <Button Grid.Column="1" Margin="0,1,5,0" HorizontalAlignment="Left" Command="{Binding ViewResultManager.EditConfigCommand}" Padding="2" Height="25" Width="25" >
                                    <Button.Triggers>
                                        <EventTrigger RoutedEvent="Button.Click">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="rotateTransform99" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Button.Triggers>
                                    <TextBlock Text="&#xE713;"  HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource GlobalTextBrush}">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform x:Name="rotateTransform99" CenterX="8" CenterY="8"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <ListView x:Name="ViewResultList" Grid.Row="1" Height="250"  Style="{StaticResource ListView.Small}" BorderThickness="0" Padding="2"  SelectedIndex="{Binding ViewResultManager.ViewReslutsSelectedIndex}" SelectionChanged="listView1_SelectionChanged"  PreviewKeyDown="listView1_PreviewKeyDown" >
                            <ListView.Resources>
                                <ContextMenu x:Key="ItemContextMenu" Opened="ContextMenu_Opened" />
                            </ListView.Resources>
                            <ListView.View >
                                <GridView>
                                    <GridView.ColumnHeaderContainerStyle>
                                        <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource  InputElementBaseStyle}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
                                            <EventSetter Event="Click" Handler="GridViewColumnSort"/>
                                        </Style>
                                    </GridView.ColumnHeaderContainerStyle>
                                    <GridViewColumn  Header="序号" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{Binding Id}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="测量时间">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{Binding CreateTime,StringFormat='yyyy/MM/dd HH:mm:ssss' }"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="IP" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{Binding IP}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColEqe" Header="EQE(%)" Width="0">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{Binding EqePercent, StringFormat={}{0:F4}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColLuminousFlux" Header="光通量(lm)" Width="0">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{Binding LuminousFlux, StringFormat={}{0:F4}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColRadiantFlux" Header="辐射通量(W)" Width="0">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{Binding RadiantFlux, StringFormat={}{0:F6}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColLuminousEfficacy" Header="光效(lm/W)" Width="0">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{Binding LuminousEfficacy, StringFormat={}{0:F4}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColVoltage" Header="U(V)" Width="0">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{Binding V}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColCurrent" Header="I(mA)" Width="0">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{Binding I}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColRecalculated" Header="数据来源" Width="0">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="原始"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRecalculated}" Value="True">
                                                                    <Setter Property="Text" Value="重新计算"/>
                                                                    <Setter Property="Foreground" Value="#E67E22"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColBrightness" Header="亮度Lv(cd/m2)" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding Lv}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="蓝光" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding Blue}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="CIEx" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fCIEx}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="CIEy" > 
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fCIEy}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="CIEz" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fCIEz}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="色度x" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fx}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="色度y" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fy}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="色度u" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fu}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="色度v" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fv}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="相关色温(K)" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fCCT}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="主波长Ld(nm)" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fLd}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="兴奋纯度(%)" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding ExcitationPurityPercent, StringFormat={}{0:F4}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="色纯度(%)" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding ColorPurityPercent, StringFormat={}{0:F4}}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="峰值波长Lp(nm)" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fLp}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="显色性指数Ra" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fRa}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="半波宽" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fHW}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="CIE2015X" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fCIEx2015}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="CIE2015Y" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fCIEy2015}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="CIE2015Z" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fCIEz2015}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="CIE2015x" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fx2015}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn  Header="CIE2015y" >
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate  DataType="{x:Type models:ViewResultSpectrum}">
                                                <TextBlock Text="{ Binding fy2015}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                                        </Grid>
                                    </Grid>
                                </xcad:LayoutDocument>
                            </xcad:LayoutDocumentPane>
                        </xcad:LayoutDocumentPaneGroup>

                        <!-- ═══ Bottom: Log + CIE Diagram ═══ -->
                        <xcad:LayoutAnchorablePaneGroup DockHeight="250">
                            <xcad:LayoutAnchorablePane>
                                <xcad:LayoutAnchorable x:Name="LogPane" Title="日志" ContentId="LogPanel" CanClose="True" CanAutoHide="True" CanFloat="True">
                                    <Grid x:Name="LogGrid">
                                    </Grid>
                                </xcad:LayoutAnchorable>
                                <xcad:LayoutAnchorable x:Name="CiePane" Title="CIE色度图" ContentId="CIEDiagram" CanClose="True" CanAutoHide="True" CanFloat="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- CIE 1931 Diagram -->
                                        <StackPanel Grid.Column="0" Margin="2">
                                            <TextBlock Text="CIE 1931" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2"/>
                                            <Image x:Name="image1931" Height="220" Width="210" Stretch="Uniform" Source="Assets\Image\CIE-1931.jpg"/>
                                        </StackPanel>
                                        <!-- CIE 1976 Diagram -->
                                        <StackPanel Grid.Column="1" Margin="2">
                                            <TextBlock Text="CIE 1976" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2"/>
                                            <Image x:Name="image1976" Height="220" Width="210" Stretch="Uniform" Source="Assets\Image\CIE-1976.jpg"/>
                                        </StackPanel>
                                    </Grid>
                                </xcad:LayoutAnchorable>
                            </xcad:LayoutAnchorablePane>
                        </xcad:LayoutAnchorablePaneGroup>

                    </xcad:LayoutPanel>

                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#E53935"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#27AE60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock x:Name="State1" Text="{x:Static properties:Resources.连接状态}" />
                    <TextBlock x:Name="State2" Text="{x:Static properties:Resources.未连接}" Margin="2,0,0,0"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem ToolTip="双击打开设备管理器" MouseDoubleClick="StatusBarConnectionType_DoubleClick">
                <TextBlock x:Name="StateConnectionType" Text="{Binding ConnectionTypeDisplay}" />
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="State3" Text="{x:Static properties:Resources.硬件型号}" />
                    <TextBlock x:Name="State4" Text="---" Margin="2,0,0,0"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem ToolTip="SN序列号，双击复制" MouseDoubleClick="StatusBarSN_DoubleClick">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="SN: "/>
                    <TextBlock x:Name="StateSN" Text="{Binding SerialNumber, FallbackValue='---'}"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="标定: "/>
                    <TextBlock Text="{Binding ActiveCalibrationGroupName, FallbackValue='Default'}" Foreground="#3498DB"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem ToolTip="当前测量模式 (通过 工具 菜单切换)">
                <TextBlock x:Name="StatusModeText" Text="亮色度模式" Foreground="#8E44AD"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Shutter: "/>
                    <Ellipse Width="8" Height="8" Margin="2,0,0,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#E53935"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShutterController.IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#27AE60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CFW: "/>
                    <Ellipse Width="8" Height="8" Margin="2,0,0,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#E53935"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterWheelController.IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#27AE60"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
