                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.TotalDurationMs}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding TotalDurationMs}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="IP">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding IP}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColEqe" Width="0" Header="EQE(%)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding EqePercent, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColLuminousFlux" Width="0" Header="{x:Static properties:Resources.LuminousFlux}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding LuminousFlux, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColRadiantFlux" Width="0" Header="{x:Static properties:Resources.RadiantFlux}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding RadiantFlux, StringFormat={}{0:F6}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColLuminousEfficacy" Width="0" Header="{x:Static properties:Resources.LuminousEfficacy}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding LuminousEfficacy, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColVoltage" Width="0" Header="U(V)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding V}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColCurrent" Width="0" Header="I(mA)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding I}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColRecalculated" Width="0" Header="{x:Static properties:Resources.DataSource}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock>
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="原始" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsRecalculated}" Value="True">
                                                                                        <Setter Property="Text" Value="重新计算" />
                                                                                        <Setter Property="Foreground" Value="#E67E22" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColBrightness" Header="{x:Static properties:Resources.亮度LvCdM2}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding Lv}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.蓝光}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding Blue}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="X">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEx}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="Y">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEy}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="Z">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEz}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.色度x}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fx}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.色度y}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fy}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.色度u}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fu}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.色度v}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fv}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.相关色温K}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCCT}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.主波长LdNm}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fLd}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.ExcitationPurity}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding ExcitationPurityPercent, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.色纯度}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding ColorPurityPercent, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.峰值波长LpNm}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fLp}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.显色性指数Ra}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fRa}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.HalfWidth}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fHW}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015X">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEx2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015Y">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEy2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015Z">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEz2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015x">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fx2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015y">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fy2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>

                                        </Grid>
                                    </Grid>
                                </xcad:LayoutDocument>
                            </xcad:LayoutDocumentPane>
                        </xcad:LayoutDocumentPaneGroup>

                        <!--  ═══ Bottom: Log + Native Log ═══  -->
                        <xcad:LayoutAnchorablePaneGroup DockHeight="250">
                            <xcad:LayoutAnchorablePane>
                                <xcad:LayoutAnchorable x:Name="LogPane" Title="{x:Static properties:Resources.Log}" CanAutoHide="True" CanClose="True" CanFloat="True" ContentId="LogPanel">
                                    <Grid x:Name="LogGrid" />
                                </xcad:LayoutAnchorable>
                                <xcad:LayoutAnchorable x:Name="NativeLogPane" Title="{x:Static properties:Resources.NativeSpectrumLog}" CanAutoHide="True" CanClose="True" CanFloat="True" ContentId="NativeLogPanel">
                                    <Grid x:Name="NativeLogGrid" />
                                </xcad:LayoutAnchorable>
                            </xcad:LayoutAnchorablePane>
                        </xcad:LayoutAnchorablePaneGroup>

                    </xcad:LayoutPanel>

                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>

        <Grid x:Name="StatusBarGrid" Grid.Row="2" />

    </Grid>
</Window>
