<Window x:Class="Spectrum.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:Spectrum"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:Spectrum.Models"
        xmlns:properties="clr-namespace:Spectrum.Properties"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wpf="http://schemas.microsoft.com/netfx/2007/xaml/presentation"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:SpectrometerManager}"
        Title="{x:Static properties:Resources.SpectrumWindowTitle}" Width="1920" Height="1080"
        Background="{DynamicResource GlobalBackground}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Margin" Value="2,2,2,6" />
            <Setter Property="Padding" Value="6,6" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Menu x:Name="menu" Grid.Row="0" Padding="2" />
            <Button Width="18" Height="18" Margin="5,0,5,0" Padding="2" HorizontalAlignment="Right" Command="{Binding SetEmissionSP100Config.EditCommand}">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform2" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="rotateTransform2" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Button>
        </Grid>


        <xcad:DockingManager x:Name="DockingManager" Grid.Row="1" Background="Transparent" BorderThickness="0">
            <xcad:LayoutRoot x:Name="_layoutRoot">
                <xcad:LayoutPanel Orientation="Horizontal">

                    <!--  ═══ Left: Control Panel ═══  -->
                    <xcad:LayoutAnchorablePaneGroup DockWidth="330">
                        <xcad:LayoutAnchorablePane>
                            <xcad:LayoutAnchorable x:Name="ControlPanelPane" Title="{x:Static properties:Resources.ControlPanel}" CanAutoHide="True" CanClose="False" CanFloat="True" ContentId="ControlPanel">
                                <ScrollViewer Margin="3,0,3,5">
                                    <StackPanel x:Name="MainStackPanel">

                                        <!--  ═══ 光谱仪连接 (Spectrometer Connection) ═══  -->
                                        <GroupBox Header="{x:Static properties:Resources.SpectrometerConnection}">
                                            <StackPanel>
                                                <StackPanel Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter1}}">
                                                    <Button Margin="0,0,0,4" Command="{Binding GetSpectrSerialNumberCommand}" Content="{x:Static properties:Resources.GetDeviceList}" />
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <ComboBox x:Name="ComboBoxSpectrometerType" Width="140" DisplayMemberPath="Value" SelectedValue="{Binding Config.SpectrometerType}" SelectedValuePath="Key" Style="{StaticResource ComboBox.Small}" />
                                                        <CheckBox Margin="10,0,0,0" VerticalAlignment="Center" Content="{x:Static properties:Resources.SerialPortConnection}" IsChecked="{Binding Config.IsComPort}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal" Visibility="{Binding Config.IsComPort, Converter={StaticResource bool2VisibilityConverter}}">
                                                        <DockPanel>
                                                            <TextBlock Width="40" VerticalAlignment="Center" Text="{x:Static properties:Resources.SerialPort}" />
                                                            <ComboBox x:Name="ComboBoxPort" Width="80" IsEditable="True" Style="{StaticResource ComboBox.Small}" Text="{Binding Config.SzComName}" />
                                                        </DockPanel>
                                                        <DockPanel Margin="8,0,0,0">
                                                            <TextBlock Width="45" VerticalAlignment="Center" Text="{x:Static properties:Resources.BaudRate}" />
                                                            <ComboBox x:Name="ComboBoxSerial" Width="70" IsEditable="True" Style="{StaticResource ComboBox.Small}" Text="{Binding Config.BaudRate}" />
                                                        </DockPanel>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Grid Margin="0,4,0,0">
                                                    <Button Padding="12,4" Background="#2196F3" Click="Button_Click" Content="{x:Static properties:Resources.连接光谱仪}" Foreground="White" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter1}}" />
                                                    <Button x:Name="ButtonClose" Padding="12,4" Background="#E53935" Click="ButtonClose_Click" Content="{x:Static properties:Resources.断开光谱仪}" Foreground="White" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}" />
                                                </Grid>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 标定文件 (Calibration Files) ═══  -->
                                        <GroupBox Header="{x:Static properties:Resources.CalibrationFiles}">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,6">
                                                    <Button Margin="4,0,0,0" Padding="8,2" Command="{Binding OpenCalibrationGroupWindowCommand}" Content="{x:Static properties:Resources.Manage}" DockPanel.Dock="Right" ToolTip="{x:Static properties:Resources.OpenCalibrationGroupTooltip}" />
                                                    <Button Margin="4,0,0,0" Padding="8,2" Command="{Binding ApplyActiveGroupCommand}" Content="{x:Static properties:Resources.LoadGroup}" DockPanel.Dock="Right" ToolTip="{x:Static properties:Resources.ApplyCalibrationGroupTooltip}" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}" />
                                                    <TextBlock Width="60" Text="{x:Static properties:Resources.CurrentGroup}" />
                                                    <ComboBox ItemsSource="{Binding CalibrationGroupNames}" SelectedItem="{Binding ActiveCalibrationGroupName, Mode=TwoWay}" Style="{StaticResource ComboBox.Small}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,0,0,4">
                                                    <Button Margin="5,0,0,0" Command="{Binding LoadWavelengthFileCommand}" Content="{x:Static properties:Resources.Load}" DockPanel.Dock="Right" Style="{StaticResource ButtonDefault.Small}" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}" />
                                                    <TextBlock MinWidth="60" Text="{x:Static properties:Resources.WavelengthCalibration}" />
                                                    <TextBox IsReadOnly="True" Style="{StaticResource TextBox.Small}" Text="{Binding WavelengthFile}" ToolTip="{Binding WavelengthFile}" />
                                                </DockPanel>
                                                <DockPanel>
                                                    <Button Margin="5,0,0,0" Command="{Binding LoadMaguideFileCommand}" Content="{x:Static properties:Resources.Load}" DockPanel.Dock="Right" Style="{StaticResource ButtonDefault.Small}" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}" />
                                                    <TextBlock MinWidth="60" Text="{x:Static properties:Resources.MagnitudeCalibration}" />
                                                    <TextBox IsReadOnly="True" Style="{StaticResource TextBox.Small}" Text="{Binding MaguideFile}" ToolTip="{Binding MaguideFile}" />
                                                </DockPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 测量参数 (Measurement Parameters) ═══  -->
                                        <GroupBox Header="{x:Static properties:Resources.MeasurementParameters}" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                                                    <TextBlock Width="110" Text="{x:Static properties:Resources.IntegrationTimeMs}" />
                                                    <TextBox Width="90" VerticalAlignment="Center" Style="{StaticResource TextBox.Small}" Text="{Binding IntTime}" TextWrapping="Wrap" />
                                                    <Button Width="20" Height="20" Margin="4,0,4,0" Padding="0" HorizontalAlignment="Left" Command="{Binding EditIntTimeConfigCommand}">
                                                        <Button.Triggers>
                                                            <EventTrigger RoutedEvent="Button.Click">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform21" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Button.Triggers>
                                                        <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                                            <TextBlock.RenderTransform>
                                                                <RotateTransform x:Name="rotateTransform21" />
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </Button>
                                                    <Button x:Name="ButtonAutoInt" Padding="10,4" Background="#E67E22" Click="AutoIntTime_Click" Content="{x:Static properties:Resources.自动积分}" Foreground="White" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Width="110" Text="{x:Static properties:Resources.平均次数}" />
                                                    <TextBox Width="90" VerticalAlignment="Center" Style="{StaticResource TextBox.Small}" Text="{Binding Average}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 测试 (Test & Calibration) ═══  -->
                                        <GroupBox Header="{x:Static properties:Resources.TestSection}" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="{x:Static properties:Resources.ZeroCalibration}" />
                                                <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                                                    <Button x:Name="button3" Margin="0,0,4,0" Padding="10,4" Background="#E67E22" Click="Button3_Click" Content="{x:Static properties:Resources.单次校零}" Foreground="White" />
                                                    <Button Width="20" Height="20" Margin="4,0,0,0" Padding="0" HorizontalAlignment="Left" Command="{Binding EditAutodarkParamCommand}">
                                                        <Button.Triggers>
                                                            <EventTrigger RoutedEvent="Button.Click">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform24" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Button.Triggers>
                                                        <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                                            <TextBlock.RenderTransform>
                                                                <RotateTransform x:Name="rotateTransform24" />
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </Button>
                                                </StackPanel>
                                                <DockPanel Margin="0,0,0,6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <CheckBox Margin="0,0,8,0" Content="{x:Static properties:Resources.自动积分}" IsChecked="{Binding EnableAutoIntegration}" />
                                                        <CheckBox Margin="0,0,8,0" Content="{x:Static properties:Resources.自适应校零}" IsChecked="{Binding EnableAdaptiveAutoDark}" />
                                                        <CheckBox Margin="0,0,8,0" Content="{x:Static properties:Resources.AutoZeroCalibration}" IsChecked="{Binding EnableAutodark}" />
                                                    </StackPanel>
                                                </DockPanel>

                                                <Separator Margin="0,2,0,6" />

                                                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="{x:Static properties:Resources.单次测试}" />
                                                <Button x:Name="button5" Margin="0,0,0,8" Padding="10,6" HorizontalAlignment="Stretch" Background="#3498DB" Click="Button5_Click" Content="{x:Static properties:Resources.单次测试}" FontWeight="SemiBold" Foreground="White" />

                                                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="{x:Static properties:Resources.连续测试}" />
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition />
                                                        <RowDefinition />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,6,4" Text="{x:Static properties:Resources.IntervalMs}" />
                                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,8,4" VerticalAlignment="Center" Style="{StaticResource TextBox.Small}" Text="{Binding MeasurementInterval}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,6,4" Text="{x:Static properties:Resources.MeasurementCount}" />
                                                    <TextBox Grid.Row="0" Grid.Column="3" Margin="0,0,0,4" VerticalAlignment="Center" Style="{StaticResource TextBox.Small}" Text="{Binding MeasurementNum}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,6,0" Text="{x:Static properties:Resources.Progress}" />
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center" Orientation="Horizontal">
                                                        <TextBlock FontWeight="SemiBold" Foreground="#3498DB" Text="{Binding LoopMeasureNum}" />
                                                        <TextBlock Text=" / " />
                                                        <TextBlock Text="{Binding MeasurementNum}" />
                                                    </StackPanel>
                                                </Grid>
                                                <ProgressBar x:Name="ContinuousProgressBar" Height="15" Margin="0,4,0,4" Foreground="#3498DB" Maximum="100" Minimum="0" Value="0" />
                                                <StackPanel x:Name="TimeEstimationPanel" Margin="0,0,0,4" Orientation="Horizontal" Visibility="Collapsed">
                                                    <TextBlock FontSize="11" Text="{x:Static properties:Resources.Elapsed}" />
                                                    <TextBlock x:Name="ElapsedTimeText" FontSize="11" FontWeight="SemiBold" Foreground="#2196F3" Text="--:--" />
                                                    <TextBlock FontSize="11" Text="{x:Static properties:Resources.Remaining}" />
                                                    <TextBlock x:Name="RemainingTimeText" FontSize="11" FontWeight="SemiBold" Foreground="#E67E22" Text="--:--" />
                                                </StackPanel>

                                                <Grid Margin="0,2,0,0" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                                    <Button x:Name="button6" Padding="10,6" HorizontalAlignment="Stretch" Background="#27AE60" Click="Button6_Click" Content="{x:Static properties:Resources.连续测试}" FontWeight="SemiBold" Foreground="White" />
                                                    <Button x:Name="button7" Padding="10,6" HorizontalAlignment="Stretch" Background="#E53935" Click="Button7_Click" Content="{x:Static properties:Resources.停止}" FontWeight="SemiBold" Foreground="White" Visibility="Collapsed" />
                                                </Grid>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 快门控制 (Shutter) ═══  -->
                                        <GroupBox Header="{x:Static properties:Resources.Shutter}">
                                            <StackPanel>
                                                <!--  Not connected: show connect button + gear  -->
                                                <StackPanel Visibility="{Binding ShutterController.IsConnected, Converter={StaticResource bool2VisibilityConverter1}}">
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <Button Padding="10,4" Background="#2196F3" Command="{Binding ShutterController.ConnectCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Content="{x:Static properties:Resources.Connect}" Foreground="White" />
                                                        <Button Width="20" Height="20" Margin="4,0,0,0" Padding="0" HorizontalAlignment="Left" Command="{Binding EditShutterConfigCommand}">
                                                            <Button.Triggers>
                                                                <EventTrigger RoutedEvent="Button.Click">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform26" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Button.Triggers>
                                                            <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                                                <TextBlock.RenderTransform>
                                                                    <RotateTransform x:Name="rotateTransform26" />
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!--  Connected: show status + disconnect + open/close  -->
                                                <StackPanel Visibility="{Binding ShutterController.IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Margin="0,0,4,0" Padding="8,2" Background="#E53935" Command="{Binding ShutterController.DisconnectCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Content="{x:Static properties:Resources.Disconnect}" Foreground="White" />
                                                        <Button Margin="0,0,4,0" Padding="8,2" Command="{Binding ShutterController.OpenShutterCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Content="{x:Static properties:Resources.OpenShutter}" />
                                                        <Button Margin="0,0,4,0" Padding="8,2" Command="{Binding ShutterController.CloseShutterCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Content="{x:Static properties:Resources.CloseShutter}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 滤色轮 (Filter Wheel) ═══  -->
                                        <GroupBox Header="{x:Static properties:Resources.FilterWheel}">
                                            <StackPanel>
                                                <!--  Connection controls (visible when NOT connected)  -->
                                                <StackPanel Visibility="{Binding FilterWheelController.IsConnected, Converter={StaticResource bool2VisibilityConverter1}}">
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <Button Padding="10,4" Background="#2196F3" Command="{Binding FilterWheelController.ConnectCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Content="{x:Static properties:Resources.Connect}" Foreground="White" />
                                                        <Button Width="20" Height="20" Margin="4,0,0,0" Padding="0" HorizontalAlignment="Left" Command="{Binding EditFilterWheelConfigCommand}">
                                                            <Button.Triggers>
                                                                <EventTrigger RoutedEvent="Button.Click">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransformFW" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Button.Triggers>
                                                            <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                                                <TextBlock.RenderTransform>
                                                                    <RotateTransform x:Name="rotateTransformFW" />
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!--  Connected state controls  -->
                                                <StackPanel Visibility="{Binding FilterWheelController.IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock VerticalAlignment="Center" Text="{x:Static properties:Resources.CurrentPosition}" />
                                                        <TextBlock Margin="4,0,8,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2196F3" Text="{Binding FilterWheelController.CurrentPositionName}" />
                                                        <Button Margin="0,0,4,0" Padding="8,2" Command="{Binding FilterWheelController.QueryPositionCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Content="{x:Static properties:Resources.Query}" />
                                                        <Button Padding="8,2" Background="#E53935" Command="{Binding FilterWheelController.DisconnectCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Content="{x:Static properties:Resources.Disconnect}" Foreground="White" />
                                                    </StackPanel>

                                                    <!--  Position buttons  -->
                                                    <TextBlock Margin="0,2,0,2" Text="{x:Static properties:Resources.SwitchPosition}" />
                                                    <ItemsControl ItemsSource="{Binding FilterWheelConfig.HoleMapping}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Margin="0,0,4,4" Padding="10,4" Command="{Binding DataContext.FilterWheelController.SetPositionCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding RelativeSource={RelativeSource Self}}" Tag="{Binding HoleIndex}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding HoleIndex, StringFormat='{}{0}: '}" />
                                                                        <TextBlock Text="{Binding HoleName}" />
                                                                    </StackPanel>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 光通量参数配置 ═══  -->
                                        <GroupBox x:Name="EqeGroupBox" Header="{x:Static properties:Resources.EqeParameterConfig}" Visibility="Collapsed">
                                            <StackPanel>
                                                <StackPanel x:Name="EqePanel" Visibility="Collapsed">
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock Width="80" Text="{x:Static properties:Resources.VoltageLabel}" />
                                                        <TextBox x:Name="TextBoxVoltage" Width="80" Style="{StaticResource TextBox.Small}" Text="{Binding Source={x:Static local:MainWindowConfig.Instance}, Path=EqeVoltage, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock Width="80" Text="{x:Static properties:Resources.CurrentMilliampLabel}" />
                                                        <TextBox x:Name="TextBoxCurrentMA" Width="80" Style="{StaticResource TextBox.Small}" Text="{Binding Source={x:Static local:MainWindowConfig.Instance}, Path=EqeCurrentMA, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <Button Margin="0,4,0,0" HorizontalAlignment="Left" Click="CalculateEqe_Click" Content="{x:Static properties:Resources.RecalculateEqe}" />

                                                    <!--  ═══ 源表(SMU)配置 ═══  -->
                                                    <Separator Margin="0,6,0,6" />
                                                    <TextBlock Margin="0,0,0,4" FontWeight="Bold" Text="{x:Static properties:Resources.SmuSourceMeter}" />
                                                    <Border Margin="0,0,0,6" Padding="8" Background="#12007ACC" CornerRadius="4">
                                                        <TextBlock Foreground="DodgerBlue" Text="{Binding SmuController.StatusSummary}" TextWrapping="Wrap" />
                                                    </Border>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <Button x:Name="SmuConnectButton" Padding="10,4" Click="SmuConnect_Click" Content="{Binding SmuController.ConnectButtonText}" Foreground="White" IsEnabled="{Binding SmuController.CanToggleConnection}">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Background" Value="#2196F3" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding SmuController.IsOpen}" Value="True">
                                                                            <Setter Property="Background" Value="#E53935" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Button Width="20" Height="20" Margin="4,0,0,0" Padding="0" HorizontalAlignment="Left" Command="{Binding EditSmuConfigCommand}" IsEnabled="{Binding SmuController.CanEditConnectionSettings}" Visibility="{Binding SmuController.IsOpen, Converter={StaticResource bool2VisibilityConverter1}}">
                                                            <Button.Triggers>
                                                                <EventTrigger RoutedEvent="Button.Click">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransformSmuConfig" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Button.Triggers>
                                                            <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                                                <TextBlock.RenderTransform>
                                                                    <RotateTransform x:Name="rotateTransformSmuConfig" />
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                        </Button>
                                                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Foreground="Gray" Text="{x:Static properties:Resources.SmuConnectionSettingsHint}" Visibility="{Binding SmuController.IsOpen, Converter={StaticResource bool2VisibilityConverter}}" />
                                                    </StackPanel>
                                                    <TextBlock Margin="0,0,0,4" Foreground="Gray" Text="{Binding SmuController.ParameterHint}" TextWrapping="Wrap" />
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <CheckBox Margin="0,0,8,0" Content="{x:Static properties:Resources.VoltageSource}" IsChecked="{Binding SmuController.DisplayConfig.IsSourceV}" IsEnabled="{Binding SmuController.CanEditDisplaySettings}" />
                                                        <CheckBox Margin="0,0,8,0" Content="{x:Static properties:Resources.ChannelA}" IsChecked="{Binding SmuController.DisplayConfig.IsChannelA}" IsEnabled="{Binding SmuController.CanEditDisplaySettings}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock Width="68" Text="{Binding SmuController.MeasureValueLabel}" />
                                                        <TextBox Width="70" Style="{StaticResource TextBox.Small}" Text="{Binding SmuController.DisplayConfig.MeasureVal, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding SmuController.CanEditDisplaySettings}" />
