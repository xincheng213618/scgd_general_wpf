                                                        <TextBlock Width="20" Text="V:" />
                                                        <TextBlock x:Name="SmuVDisplay" Width="80" Foreground="DodgerBlue" Text="{Binding SmuController.DisplayConfig.V, StringFormat='{}{0:F4}'}" />
                                                        <TextBlock Width="45" Margin="8,0,0,0" Text="I(mA):" />
                                                        <TextBlock x:Name="SmuIDisplay" Width="80" Foreground="DodgerBlue" Text="{Binding SmuController.DisplayConfig.I, StringFormat='{}{0:F4}'}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                    </StackPanel>
                                </ScrollViewer>
                            </xcad:LayoutAnchorable>
                        </xcad:LayoutAnchorablePane>
                    </xcad:LayoutAnchorablePaneGroup>

                    <!--  ═══ Center + Bottom Layout ═══  -->
                    <xcad:LayoutPanel Orientation="Vertical">

                        <!--  ═══ Center: Spectrum Charts + Data ═══  -->
                        <xcad:LayoutDocumentPaneGroup>
                            <xcad:LayoutDocumentPane>
                                <xcad:LayoutDocument Title="{x:Static properties:Resources.SpectrumChart}" CanClose="False" ContentId="SpectrumChart">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition x:Name="ListRow1" Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition x:Name="ListRow2" Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ScottPlot:WpfPlot x:Name="wpfplot1" Panel.ZIndex="9" />
                                            <ScottPlot:WpfPlot x:Name="wpfplot2" Panel.ZIndex="9" Visibility="Collapsed" />
                                            <ListView x:Name="listView2" Grid.Column="1" Padding="2,0,2,2" BorderThickness="0" SelectionChanged="listView2_SelectionChanged" Style="{StaticResource ListView.Small}">
                                                <ListView.Resources>
                                                    <ContextMenu x:Key="ItemContextMenu" Opened="ContextMenu1_Opened" />
                                                </ListView.Resources>
                                                <ListView.View>
                                                    <GridView>
                                                        <GridView.ColumnHeaderContainerStyle>
                                                            <Style BasedOn="{StaticResource InputElementBaseStyle}" TargetType="{x:Type GridViewColumnHeader}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Setter Property="BorderThickness" Value="0" />
                                                                <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
                                                            </Style>
                                                        </GridView.ColumnHeaderContainerStyle>
                                                        <GridViewColumn Header="{x:Static properties:Resources.Wavelength}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:SpectralData}">
                                                                    <TextBlock Text="{Binding Wavelength}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.相对光谱}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:SpectralData}">
                                                                    <TextBlock Text="{Binding RelativeSpectrum, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.AbsoluteSpectrum}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:SpectralData}">
                                                                    <TextBlock Text="{Binding AbsoluteSpectrum, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>

                                        </Grid>
                                        <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#FFFFFF" DragCompleted="GridSplitter_DragCompleted" />
                                        <Grid x:Name="Grid1" Grid.Row="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="32" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <ToolBarTray Grid.Row="0" HorizontalAlignment="Left">
                                                <ToolBar Padding="3,2">
                                                    <ToggleButton Margin="2,0,0,0" Click="ButtonMul_Click" IsChecked="True">
                                                        <Image Source="{DynamicResource DrawingImageSwitch}" Stretch="Uniform" />
                                                    </ToggleButton>
                                                    <ToggleButton x:Name="ToggleSpectrumType" Margin="2,0,0,0" Click="ToggleSpectrumType_Click" ToolTip="{x:Static properties:Resources.ToggleSpectrumTypeTooltip}">
                                                        <TextBlock x:Name="SpectrumTypeText" Text="{x:Static properties:Resources.相对光谱}" />
                                                    </ToggleButton>
                                                    <Separator />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.QueryCommand}" Content="{x:Static properties:Resources.Query}" ToolTip="{x:Static properties:Resources.QueryDataTooltip}" />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.GenericQueryCommand}" Content="{x:Static properties:Resources.GenericQuery}" />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.ReloadCommand}" Content="{x:Static properties:Resources.Reload}" ToolTip="{x:Static properties:Resources.ReloadDataTooltip}" />
                                                    <Separator />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.DeleteAllCommand}" Content="{x:Static properties:Resources.ClearRecords}" Foreground="#E53935" ToolTip="{x:Static properties:Resources.DeleteAllRecordsTooltip}" />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.ResetDatabaseCommand}" Content="{x:Static properties:Resources.ResetDatabase}" Foreground="#E53935" ToolTip="{x:Static properties:Resources.ResetDatabaseTooltip}" />
                                                    <Separator />
                                                    <TextBlock Margin="4,0,2,0" VerticalAlignment="Center" Text="{x:Static properties:Resources.LoadCount}" />
                                                    <TextBox Width="50" VerticalAlignment="Center" Text="{Binding ViewResultManager.Config.Count, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static properties:Resources.LoadCountTooltip}" />
                                                </ToolBar>
                                            </ToolBarTray>
                                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                    <Button Width="25" Height="25" Margin="0,1,5,0" Padding="2" Click="OpenCieWindow_Click" ToolTip="{x:Static properties:Resources.CieChromaticityDiagram}">
                                                        <Image Source="/ColorVision.ImageEditor;component/Assets/Image/CIE1931xy1.png" Stretch="Uniform" />
                                                    </Button>
                                                    <Button Width="25" Height="25" Margin="0,1,5,0" Padding="2" Click="Export_Click" Command="{Binding ViewResultManager.SaveCommand}">
                                                        <Rectangle Width="16" Height="16" Fill="{DynamicResource DISave}" />
                                                    </Button>
                                                    <Button Width="25" Height="25" Margin="0,1,5,0" Padding="2" Click="Cleartable_Click" Command="{Binding ViewResultManager.ViewReslutsClearCommand}">
                                                        <Button.Triggers>
                                                            <EventTrigger RoutedEvent="Button.Click">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation AutoReverse="True" Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleX" To="0.7" Duration="0:0:0.1" />
                                                                        <DoubleAnimation AutoReverse="True" Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleY" To="0.7" Duration="0:0:0.1" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Button.Triggers>
                                                        <Image RenderTransformOrigin="0.5,0.5" Source="{DynamicResource DrawingImageDelete}" Stretch="Uniform">
                                                            <Image.RenderTransform>
                                                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
                                                            </Image.RenderTransform>
                                                        </Image>
                                                    </Button>
                                                    <Button Grid.Column="1" Width="25" Height="25" Margin="0,1,5,0" Padding="2" HorizontalAlignment="Left" Command="{Binding ViewResultManager.EditConfigCommand}">
                                                        <Button.Triggers>
                                                            <EventTrigger RoutedEvent="Button.Click">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform99" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Button.Triggers>
                                                        <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE713;">
                                                            <TextBlock.RenderTransform>
                                                                <RotateTransform x:Name="rotateTransform99" CenterX="8" CenterY="8" />
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>

                                            <ListView x:Name="ViewResultList" Grid.Row="1" Height="250" Padding="2" BorderThickness="0" PreviewKeyDown="listView1_PreviewKeyDown" SelectedIndex="{Binding ViewResultManager.ViewReslutsSelectedIndex}" SelectionChanged="listView1_SelectionChanged" Style="{StaticResource ListView.Small}">
                                                <ListView.Resources>
                                                    <ContextMenu x:Key="ItemContextMenu" Opened="ContextMenu_Opened" />
                                                </ListView.Resources>
                                                <ListView.View>
                                                    <GridView>
                                                        <GridView.ColumnHeaderContainerStyle>
                                                            <Style BasedOn="{StaticResource InputElementBaseStyle}" TargetType="{x:Type GridViewColumnHeader}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Setter Property="BorderThickness" Value="0" />
