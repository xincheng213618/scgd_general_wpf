                                                            </Style>
                                                        </GridView.ColumnHeaderContainerStyle>
                                                        <GridViewColumn Header="{x:Static properties:Resources.序号}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding Id}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="{x:Static properties:Resources.测量时间}">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
