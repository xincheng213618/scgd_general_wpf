<Window x:Class="Spectrum.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:Spectrum"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:Spectrum.Models"
        xmlns:properties="clr-namespace:Spectrum.Properties"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wpf="http://schemas.microsoft.com/netfx/2007/xaml/presentation"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:SpectrometerManager}"
        Title="光谱仪软件" Width="1920" Height="1080"
        Background="{DynamicResource GlobalBackground}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Margin" Value="2,2,2,6" />
            <Setter Property="Padding" Value="6,6" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid>
            <Menu x:Name="menu" Grid.Row="0" Padding="2" />
            <Button Width="18" Height="18" Margin="5,0,5,0" Padding="2" HorizontalAlignment="Right" Command="{Binding SetEmissionSP100Config.EditCommand}">
                <Button.Triggers>
                    <EventTrigger RoutedEvent="Button.Click">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform2" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
                <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="rotateTransform2" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Button>
        </Grid>


        <xcad:DockingManager x:Name="DockingManager" Grid.Row="1" Background="Transparent" BorderThickness="0">
            <xcad:LayoutRoot x:Name="_layoutRoot">
                <xcad:LayoutPanel Orientation="Horizontal">

                    <!--  ═══ Left: Control Panel ═══  -->
                    <xcad:LayoutAnchorablePaneGroup DockWidth="330">
                        <xcad:LayoutAnchorablePane>
                            <xcad:LayoutAnchorable x:Name="ControlPanelPane" Title="控制面板" CanAutoHide="True" CanClose="False" CanFloat="True" ContentId="ControlPanel">
                                <ScrollViewer Margin="3,0,3,5">
                                    <StackPanel x:Name="MainStackPanel">

                                        <!--  ═══ 光谱仪连接 (Spectrometer Connection) ═══  -->
                                        <GroupBox Header="光谱仪连接">
                                            <StackPanel>
                                                <StackPanel Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter1}}">
                                                    <Button Margin="0,0,0,4" Command="{Binding GetSpectrSerialNumberCommand}" Content="获取设备列表" />
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <ComboBox x:Name="ComboBoxSpectrometerType" Width="140" DisplayMemberPath="Value" SelectedValue="{Binding Config.SpectrometerType}" SelectedValuePath="Key" Style="{StaticResource ComboBox.Small}" />
                                                        <CheckBox Margin="10,0,0,0" VerticalAlignment="Center" Content="串口连接" IsChecked="{Binding Config.IsComPort}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal" Visibility="{Binding Config.IsComPort, Converter={StaticResource bool2VisibilityConverter}}">
                                                        <DockPanel>
                                                            <TextBlock Width="40" VerticalAlignment="Center" Text="串口" />
                                                            <ComboBox x:Name="ComboBoxPort" Width="80" IsEditable="True" Style="{StaticResource ComboBox.Small}" Text="{Binding Config.SzComName}" />
                                                        </DockPanel>
                                                        <DockPanel Margin="8,0,0,0">
                                                            <TextBlock Width="45" VerticalAlignment="Center" Text="波特率" />
                                                            <ComboBox x:Name="ComboBoxSerial" Width="70" IsEditable="True" Style="{StaticResource ComboBox.Small}" Text="{Binding Config.BaudRate}" />
                                                        </DockPanel>
                                                    </StackPanel>
                                                </StackPanel>

                                                <Grid Margin="0,4,0,0">
                                                    <Button Padding="12,4" Background="#2196F3" Click="Button_Click" Content="{x:Static properties:Resources.连接光谱仪}" Foreground="White" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter1}}" />
                                                    <Button x:Name="ButtonClose" Padding="12,4" Background="#E53935" Click="ButtonClose_Click" Content="{x:Static properties:Resources.断开光谱仪}" Foreground="White" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}" />
                                                </Grid>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 标定文件 (Calibration Files) ═══  -->
                                        <GroupBox Header="标定文件">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,6">
                                                    <Button Margin="4,0,0,0" Padding="8,2" Command="{Binding OpenCalibrationGroupWindowCommand}" Content="管理..." DockPanel.Dock="Right" ToolTip="打开标定分组管理窗口" />
                                                    <Button Margin="4,0,0,0" Padding="8,2" Command="{Binding ApplyActiveGroupCommand}" Content="加载分组" DockPanel.Dock="Right" ToolTip="加载当前选择分组的标定文件" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}" />
                                                    <TextBlock Width="60" Text="当前分组: " />
                                                    <ComboBox ItemsSource="{Binding CalibrationGroupNames}" SelectedItem="{Binding ActiveCalibrationGroupName, Mode=TwoWay}" Style="{StaticResource ComboBox.Small}" />
                                                </DockPanel>
                                                <DockPanel Margin="0,0,0,4">
                                                    <Button Margin="5,0,0,0" Command="{Binding LoadWavelengthFileCommand}" Content="加载" DockPanel.Dock="Right" Style="{StaticResource ButtonDefault.Small}" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}" />
                                                    <TextBlock MinWidth="60" Text="波长标定" />
                                                    <TextBox IsReadOnly="True" Style="{StaticResource TextBox.Small}" Text="{Binding WavelengthFile}" ToolTip="{Binding WavelengthFile}" />
                                                </DockPanel>
                                                <DockPanel>
                                                    <Button Margin="5,0,0,0" Command="{Binding LoadMaguideFileCommand}" Content="加载" DockPanel.Dock="Right" Style="{StaticResource ButtonDefault.Small}" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}" />
                                                    <TextBlock MinWidth="60" Text="幅值标定" />
                                                    <TextBox IsReadOnly="True" Style="{StaticResource TextBox.Small}" Text="{Binding MaguideFile}" ToolTip="{Binding MaguideFile}" />
                                                </DockPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 测量参数 (Measurement Parameters) ═══  -->
                                        <GroupBox Header="测量参数" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                            <StackPanel>
                                                <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                                                    <TextBlock Width="110" Text="积分时间 (ms)" />
                                                    <TextBox Width="90" VerticalAlignment="Center" Style="{StaticResource TextBox.Small}" Text="{Binding IntTime}" TextWrapping="Wrap" />
                                                    <Button Width="20" Height="20" Margin="4,0,4,0" Padding="0" HorizontalAlignment="Left" Command="{Binding EditIntTimeConfigCommand}">
                                                        <Button.Triggers>
                                                            <EventTrigger RoutedEvent="Button.Click">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform21" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Button.Triggers>
                                                        <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                                            <TextBlock.RenderTransform>
                                                                <RotateTransform x:Name="rotateTransform21" />
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </Button>
                                                    <Button x:Name="ButtonAutoInt" Padding="10,4" Background="#E67E22" Click="AutoIntTime_Click" Content="自动积分" Foreground="White" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Width="110" Text="平均次数" />
                                                    <TextBox Width="90" VerticalAlignment="Center" Style="{StaticResource TextBox.Small}" Text="{Binding Average}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 测试 (Test & Calibration) ═══  -->
                                        <GroupBox Header="测试" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="校零" />
                                                <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                                                    <Button x:Name="button3" Margin="0,0,4,0" Padding="10,4" Background="#E67E22" Click="Button3_Click" Content="{x:Static properties:Resources.单次校零}" Foreground="White" />
                                                    <Button Width="20" Height="20" Margin="4,0,0,0" Padding="0" HorizontalAlignment="Left" Command="{Binding EditAutodarkParamCommand}">
                                                        <Button.Triggers>
                                                            <EventTrigger RoutedEvent="Button.Click">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform24" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Button.Triggers>
                                                        <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                                            <TextBlock.RenderTransform>
                                                                <RotateTransform x:Name="rotateTransform24" />
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </Button>
                                                </StackPanel>
                                                <DockPanel Margin="0,0,0,6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <CheckBox Margin="0,0,8,0" Content="{x:Static properties:Resources.自动积分}" IsChecked="{Binding EnableAutoIntegration}" />
                                                        <CheckBox Margin="0,0,8,0" Content="自适应校零" IsChecked="{Binding EnableAdaptiveAutoDark}" />
                                                        <CheckBox Margin="0,0,8,0" Content="自动校零" IsChecked="{Binding EnableAutodark}" />
                                                    </StackPanel>
                                                </DockPanel>

                                                <Separator Margin="0,2,0,6" />

                                                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="单次测试" />
                                                <Button x:Name="button5" Margin="0,0,0,8" Padding="10,6" HorizontalAlignment="Stretch" Background="#3498DB" Click="Button5_Click" Content="{x:Static properties:Resources.单次测试}" FontWeight="SemiBold" Foreground="White" />

                                                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="连续测试" />
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition />
                                                        <RowDefinition />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,6,4" Text="间隔 (ms)" />
                                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,8,4" VerticalAlignment="Center" Style="{StaticResource TextBox.Small}" Text="{Binding MeasurementInterval}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,0,6,4" Text="测试次数" />
                                                    <TextBox Grid.Row="0" Grid.Column="3" Margin="0,0,0,4" VerticalAlignment="Center" Style="{StaticResource TextBox.Small}" Text="{Binding MeasurementNum}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,6,0" Text="进度" />
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Center" Orientation="Horizontal">
                                                        <TextBlock FontWeight="SemiBold" Foreground="#3498DB" Text="{Binding LoopMeasureNum}" />
                                                        <TextBlock Text=" / " />
                                                        <TextBlock Text="{Binding MeasurementNum}" />
                                                    </StackPanel>
                                                </Grid>
                                                <ProgressBar x:Name="ContinuousProgressBar" Height="15" Margin="0,4,0,4" Foreground="#3498DB" Maximum="100" Minimum="0" Value="0" />
                                                <StackPanel x:Name="TimeEstimationPanel" Margin="0,0,0,4" Orientation="Horizontal" Visibility="Collapsed">
                                                    <TextBlock FontSize="11" Text="已用: " />
                                                    <TextBlock x:Name="ElapsedTimeText" FontSize="11" FontWeight="SemiBold" Foreground="#2196F3" Text="--:--" />
                                                    <TextBlock FontSize="11" Text="  预计剩余: " />
                                                    <TextBlock x:Name="RemainingTimeText" FontSize="11" FontWeight="SemiBold" Foreground="#E67E22" Text="--:--" />
                                                </StackPanel>

                                                <Grid Margin="0,2,0,0" Visibility="{Binding IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                                    <Button x:Name="button6" Padding="10,6" HorizontalAlignment="Stretch" Background="#27AE60" Click="Button6_Click" Content="{x:Static properties:Resources.连续测试}" FontWeight="SemiBold" Foreground="White" />
                                                    <Button x:Name="button7" Padding="10,6" HorizontalAlignment="Stretch" Background="#E53935" Click="Button7_Click" Content="{x:Static properties:Resources.停止}" FontWeight="SemiBold" Foreground="White" Visibility="Collapsed" />
                                                </Grid>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 快门控制 (Shutter) ═══  -->
                                        <GroupBox Header="快门 (Shutter)">
                                            <StackPanel>
                                                <!--  Not connected: show connect button + gear  -->
                                                <StackPanel Visibility="{Binding ShutterController.IsConnected, Converter={StaticResource bool2VisibilityConverter1}}">
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <Button Padding="10,4" Background="#2196F3" Command="{Binding ShutterController.ConnectCommand}" Content="连接" Foreground="White" />
                                                        <Button Width="20" Height="20" Margin="4,0,0,0" Padding="0" HorizontalAlignment="Left" Command="{Binding EditShutterConfigCommand}">
                                                            <Button.Triggers>
                                                                <EventTrigger RoutedEvent="Button.Click">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform26" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Button.Triggers>
                                                            <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                                                <TextBlock.RenderTransform>
                                                                    <RotateTransform x:Name="rotateTransform26" />
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!--  Connected: show status + disconnect + open/close  -->
                                                <StackPanel Visibility="{Binding ShutterController.IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Margin="0,0,4,0" Padding="8,2" Background="#E53935" Command="{Binding ShutterController.DisconnectCommand}" Content="断开" Foreground="White" />
                                                        <Button Margin="0,0,4,0" Padding="8,2" Command="{Binding ShutterController.OpenShutterCommand}" Content="Open Shutter" />
                                                        <Button Margin="0,0,4,0" Padding="8,2" Command="{Binding ShutterController.CloseShutterCommand}" Content="Close Shutter" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 滤色轮 (Filter Wheel) ═══  -->
                                        <GroupBox Header="滤色轮 (Filter Wheel)">
                                            <StackPanel>
                                                <!--  Connection controls (visible when NOT connected)  -->
                                                <StackPanel Visibility="{Binding FilterWheelController.IsConnected, Converter={StaticResource bool2VisibilityConverter1}}">
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <Button Padding="10,4" Background="#2196F3" Command="{Binding FilterWheelController.ConnectCommand}" Content="连接" Foreground="White" />
                                                        <Button Width="20" Height="20" Margin="4,0,0,0" Padding="0" HorizontalAlignment="Left" Command="{Binding EditFilterWheelConfigCommand}">
                                                            <Button.Triggers>
                                                                <EventTrigger RoutedEvent="Button.Click">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransformFW" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </Button.Triggers>
                                                            <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" RenderTransformOrigin="0.5,0.5" Text="&#xE713;">
                                                                <TextBlock.RenderTransform>
                                                                    <RotateTransform x:Name="rotateTransformFW" />
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!--  Connected state controls  -->
                                                <StackPanel Visibility="{Binding FilterWheelController.IsConnected, Converter={StaticResource bool2VisibilityConverter}}">
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock VerticalAlignment="Center" Text="当前位置: " />
                                                        <TextBlock Margin="4,0,8,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#2196F3" Text="{Binding FilterWheelController.CurrentPositionName}" />
                                                        <Button Margin="0,0,4,0" Padding="8,2" Command="{Binding FilterWheelController.QueryPositionCommand}" Content="查询" />
                                                        <Button Padding="8,2" Background="#E53935" Command="{Binding FilterWheelController.DisconnectCommand}" Content="断开" Foreground="White" />
                                                    </StackPanel>

                                                    <!--  Position buttons  -->
                                                    <TextBlock Margin="0,2,0,2" Text="切换位置:" />
                                                    <ItemsControl ItemsSource="{Binding FilterWheelConfig.HoleMapping}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button Margin="0,0,4,4" Padding="10,4" Command="{Binding DataContext.FilterWheelController.SetPositionCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding HoleIndex}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding HoleIndex, StringFormat='{}{0}: '}" />
                                                                        <TextBlock Text="{Binding HoleName}" />
                                                                    </StackPanel>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                        <!--  ═══ 光通量参数配置 ═══  -->
                                        <GroupBox x:Name="EqeGroupBox" Header="光通量参数配置" Visibility="Collapsed">
                                            <StackPanel>
                                                <StackPanel x:Name="EqePanel" Visibility="Collapsed">
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock Width="80" Text="电压 (V)" />
                                                        <TextBox x:Name="TextBoxVoltage" Width="80" Style="{StaticResource TextBox.Small}" Text="{Binding Source={x:Static local:MainWindowConfig.Instance}, Path=EqeVoltage, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock Width="80" Text="电流 (mA)" />
                                                        <TextBox x:Name="TextBoxCurrentMA" Width="80" Style="{StaticResource TextBox.Small}" Text="{Binding Source={x:Static local:MainWindowConfig.Instance}, Path=EqeCurrentMA, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <Button Margin="0,4,0,0" HorizontalAlignment="Left" Click="CalculateEqe_Click" Content="EQE重新计算" />

                                                    <!--  ═══ 源表(SMU)配置 ═══  -->
                                                    <Separator Margin="0,6,0,6" />
                                                    <TextBlock Margin="0,0,0,4" FontWeight="Bold" Text="源表(SMU)" />
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock Width="80" Text="设备名称" />
                                                        <TextBox Width="140" Style="{StaticResource TextBox.Small}" Text="{Binding SmuController.Config.DevName, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <CheckBox Margin="0,0,8,0" Content="网络连接" IsChecked="{Binding SmuController.Config.IsNet}" />
                                                        <CheckBox Margin="0,0,8,0" Content="电压源" IsChecked="{Binding SmuController.Config.IsSourceV}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <CheckBox Margin="0,0,8,0" Content="通道A" IsChecked="{Binding SmuController.Config.IsChannelA}" />
                                                        <CheckBox Margin="0,0,8,0" Content="四线制" IsChecked="{Binding SmuController.Config.Is4Wire}" />
                                                        <CheckBox Margin="0,0,8,0" Content="前接口" IsChecked="{Binding SmuController.Config.IsFront}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock Width="50" Text="测量值" />
                                                        <TextBox Width="60" Style="{StaticResource TextBox.Small}" Text="{Binding SmuController.Config.MeasureVal, UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Width="50" Margin="8,0,0,0" Text="限制值" />
                                                        <TextBox Width="60" Style="{StaticResource TextBox.Small}" Text="{Binding SmuController.Config.LimitVal, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,4,0,4" Orientation="Horizontal">
                                                        <Button x:Name="ButtonSmuConnect" Width="80" Margin="0,0,4,0" Click="SmuConnect_Click" Content="连接源表" />
                                                        <Button x:Name="ButtonSmuMeasure" Width="80" Click="SmuMeasure_Click" Content="读取V/I" IsEnabled="False" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,4" Orientation="Horizontal">
                                                        <TextBlock Width="20" Text="V:" />
                                                        <TextBlock x:Name="SmuVDisplay" Width="80" Foreground="DodgerBlue" Text="{Binding SmuController.V, StringFormat='{}{0:F4}'}" />
                                                        <TextBlock Width="45" Margin="8,0,0,0" Text="I(mA):" />
                                                        <TextBlock x:Name="SmuIDisplay" Width="80" Foreground="DodgerBlue" Text="{Binding SmuController.I, StringFormat='{}{0:F4}'}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>

                                    </StackPanel>
                                </ScrollViewer>
                            </xcad:LayoutAnchorable>
                        </xcad:LayoutAnchorablePane>
                    </xcad:LayoutAnchorablePaneGroup>

                    <!--  ═══ Center + Bottom Layout ═══  -->
                    <xcad:LayoutPanel Orientation="Vertical">

                        <!--  ═══ Center: Spectrum Charts + Data ═══  -->
                        <xcad:LayoutDocumentPaneGroup>
                            <xcad:LayoutDocumentPane>
                                <xcad:LayoutDocument Title="光谱图表" CanClose="False" ContentId="SpectrumChart">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition x:Name="ListRow1" Height="*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition x:Name="ListRow2" Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ScottPlot:WpfPlot x:Name="wpfplot1" Panel.ZIndex="9" />
                                            <ScottPlot:WpfPlot x:Name="wpfplot2" Panel.ZIndex="9" Visibility="Collapsed" />
                                            <ListView x:Name="listView2" Grid.Column="1" Padding="2,0,2,2" BorderThickness="0" SelectionChanged="listView2_SelectionChanged" Style="{StaticResource ListView.Small}">
                                                <ListView.Resources>
                                                    <ContextMenu x:Key="ItemContextMenu" Opened="ContextMenu1_Opened" />
                                                </ListView.Resources>
                                                <ListView.View>
                                                    <GridView>
                                                        <GridView.ColumnHeaderContainerStyle>
                                                            <Style BasedOn="{StaticResource InputElementBaseStyle}" TargetType="{x:Type GridViewColumnHeader}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Setter Property="BorderThickness" Value="0" />
                                                                <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
                                                            </Style>
                                                        </GridView.ColumnHeaderContainerStyle>
                                                        <GridViewColumn Header="波长">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:SpectralData}">
                                                                    <TextBlock Text="{Binding Wavelength}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="相对光谱">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:SpectralData}">
                                                                    <TextBlock Text="{Binding RelativeSpectrum, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="绝对光谱">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:SpectralData}">
                                                                    <TextBlock Text="{Binding AbsoluteSpectrum, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>

                                        </Grid>
                                        <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#FFFFFF" DragCompleted="GridSplitter_DragCompleted" />
                                        <Grid x:Name="Grid1" Grid.Row="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="32" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <ToolBarTray Grid.Row="0" HorizontalAlignment="Left">
                                                <ToolBar Padding="3,2">
                                                    <ToggleButton Margin="2,0,0,0" Click="ButtonMul_Click" IsChecked="True">
                                                        <Image Source="{DynamicResource DrawingImageSwitch}" Stretch="Uniform" />
                                                    </ToggleButton>
                                                    <ToggleButton x:Name="ToggleSpectrumType" Margin="2,0,0,0" Click="ToggleSpectrumType_Click" ToolTip="切换相对/绝对光谱">
                                                        <TextBlock x:Name="SpectrumTypeText" Text="相对光谱" />
                                                    </ToggleButton>
                                                    <Separator />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.QueryCommand}" Content="查询" ToolTip="查询数据" />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.GenericQueryCommand}" Content="通用查询" />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.ReloadCommand}" Content="刷新" ToolTip="从数据库重新加载数据" />
                                                    <Separator />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.DeleteAllCommand}" Content="清空记录" Foreground="#E53935" ToolTip="删除数据库中所有记录" />
                                                    <Button Margin="2,0,0,0" Command="{Binding ViewResultManager.ResetDatabaseCommand}" Content="重置数据库" Foreground="#E53935" ToolTip="删除数据库文件并重新创建" />
                                                    <Separator />
                                                    <TextBlock Margin="4,0,2,0" VerticalAlignment="Center" Text="加载条数:" />
                                                    <TextBox Width="50" VerticalAlignment="Center" Text="{Binding ViewResultManager.Config.Count, UpdateSourceTrigger=PropertyChanged}" ToolTip="默认加载数据条数 (-1为全部)" />
                                                </ToolBar>
                                            </ToolBarTray>
                                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                    <Button Width="25" Height="25" Margin="0,1,5,0" Padding="2" Click="Export_Click" Command="{Binding ViewResultManager.SaveCommand}">
                                                        <Rectangle Width="16" Height="16" Fill="{StaticResource DISave}" />
                                                    </Button>
                                                    <Button Width="25" Height="25" Margin="0,1,5,0" Padding="2" Click="Cleartable_Click" Command="{Binding ViewResultManager.ViewReslutsClearCommand}">
                                                        <Button.Triggers>
                                                            <EventTrigger RoutedEvent="Button.Click">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation AutoReverse="True" Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleX" To="0.7" Duration="0:0:0.1" />
                                                                        <DoubleAnimation AutoReverse="True" Storyboard.TargetName="ScaleTransform" Storyboard.TargetProperty="ScaleY" To="0.7" Duration="0:0:0.1" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Button.Triggers>
                                                        <Image RenderTransformOrigin="0.5,0.5" Source="{DynamicResource DrawingImageDelete}" Stretch="Uniform">
                                                            <Image.RenderTransform>
                                                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
                                                            </Image.RenderTransform>
                                                        </Image>
                                                    </Button>
                                                    <Button Grid.Column="1" Width="25" Height="25" Margin="0,1,5,0" Padding="2" HorizontalAlignment="Left" Command="{Binding ViewResultManager.EditConfigCommand}">
                                                        <Button.Triggers>
                                                            <EventTrigger RoutedEvent="Button.Click">
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation FillBehavior="Stop" Storyboard.TargetName="rotateTransform99" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </Button.Triggers>
                                                        <TextBlock HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{DynamicResource GlobalTextBrush}" Text="&#xE713;">
                                                            <TextBlock.RenderTransform>
                                                                <RotateTransform x:Name="rotateTransform99" CenterX="8" CenterY="8" />
                                                            </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>

                                            <ListView x:Name="ViewResultList" Grid.Row="1" Height="250" Padding="2" BorderThickness="0" PreviewKeyDown="listView1_PreviewKeyDown" SelectedIndex="{Binding ViewResultManager.ViewReslutsSelectedIndex}" SelectionChanged="listView1_SelectionChanged" Style="{StaticResource ListView.Small}">
                                                <ListView.Resources>
                                                    <ContextMenu x:Key="ItemContextMenu" Opened="ContextMenu_Opened" />
                                                </ListView.Resources>
                                                <ListView.View>
                                                    <GridView>
                                                        <GridView.ColumnHeaderContainerStyle>
                                                            <Style BasedOn="{StaticResource InputElementBaseStyle}" TargetType="{x:Type GridViewColumnHeader}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Setter Property="BorderThickness" Value="0" />
                                                                <Setter Property="ContextMenu" Value="{StaticResource ItemContextMenu}" />
                                                                <EventSetter Event="Click" Handler="GridViewColumnSort" />
                                                            </Style>
                                                        </GridView.ColumnHeaderContainerStyle>
                                                        <GridViewColumn Header="序号">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding Id}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="测量时间">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding CreateTime, StringFormat='yyyy/MM/dd HH:mm:ssss'}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="IP">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding IP}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColEqe" Width="0" Header="EQE(%)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding EqePercent, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColLuminousFlux" Width="0" Header="光通量(lm)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding LuminousFlux, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColRadiantFlux" Width="0" Header="辐射通量(W)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding RadiantFlux, StringFormat={}{0:F6}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColLuminousEfficacy" Width="0" Header="光效(lm/W)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding LuminousEfficacy, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColVoltage" Width="0" Header="U(V)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding V}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColCurrent" Width="0" Header="I(mA)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding I}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColRecalculated" Width="0" Header="数据来源">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock>
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Text" Value="原始" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsRecalculated}" Value="True">
                                                                                        <Setter Property="Text" Value="重新计算" />
                                                                                        <Setter Property="Foreground" Value="#E67E22" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn x:Name="ColBrightness" Header="亮度Lv(cd/m2)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding Lv}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="蓝光">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding Blue}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="X">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEx}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="Y">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEy}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="Z">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEz}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="色度x">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fx}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="色度y">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fy}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="色度u">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fu}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="色度v">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fv}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="相关色温(K)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCCT}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="主波长Ld(nm)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fLd}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="兴奋纯度(%)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding ExcitationPurityPercent, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="色纯度(%)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding ColorPurityPercent, StringFormat={}{0:F4}}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="峰值波长Lp(nm)">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fLp}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="显色性指数Ra">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fRa}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="半波宽">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fHW}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015X">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEx2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015Y">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEy2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015Z">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fCIEz2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015x">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fx2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                        <GridViewColumn Header="CIE2015y">
                                                            <GridViewColumn.CellTemplate>
                                                                <DataTemplate DataType="{x:Type models:ViewResultSpectrum}">
                                                                    <TextBlock Text="{Binding fy2015}" />
                                                                </DataTemplate>
                                                            </GridViewColumn.CellTemplate>
                                                        </GridViewColumn>
                                                    </GridView>
                                                </ListView.View>
                                            </ListView>

                                        </Grid>
                                    </Grid>
                                </xcad:LayoutDocument>
                            </xcad:LayoutDocumentPane>
                        </xcad:LayoutDocumentPaneGroup>

                        <!--  ═══ Bottom: Log + Native Log + CIE Diagram ═══  -->
                        <xcad:LayoutAnchorablePaneGroup DockHeight="250">
                            <xcad:LayoutAnchorablePane>
                                <xcad:LayoutAnchorable x:Name="LogPane" Title="日志" CanAutoHide="True" CanClose="True" CanFloat="True" ContentId="LogPanel">
                                    <Grid x:Name="LogGrid" />
                                </xcad:LayoutAnchorable>
                                <xcad:LayoutAnchorable x:Name="NativeLogPane" Title="光谱仪原生日志" CanAutoHide="True" CanClose="True" CanFloat="True" ContentId="NativeLogPanel">
                                    <Grid x:Name="NativeLogGrid" />
                                </xcad:LayoutAnchorable>
                                <xcad:LayoutAnchorable x:Name="CiePane" Title="CIE色度图" CanAutoHide="True" CanClose="True" CanFloat="True" ContentId="CIEDiagram">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <!--  CIE 1931 Diagram  -->
                                        <StackPanel Grid.Column="0" Margin="2">
                                            <TextBlock Margin="0,2" HorizontalAlignment="Center" FontWeight="Bold" Text="CIE 1931" />
                                            <Image x:Name="image1931" Width="210" Height="220" Source="Assets\Image\CIE-1931.jpg" Stretch="Uniform" />
                                        </StackPanel>
                                        <!--  CIE 1976 Diagram  -->
                                        <StackPanel Grid.Column="1" Margin="2">
                                            <TextBlock Margin="0,2" HorizontalAlignment="Center" FontWeight="Bold" Text="CIE 1976" />
                                            <Image x:Name="image1976" Width="210" Height="220" Source="Assets\Image\CIE-1976.jpg" Stretch="Uniform" />
                                        </StackPanel>
                                    </Grid>
                                </xcad:LayoutAnchorable>
                            </xcad:LayoutAnchorablePane>
                        </xcad:LayoutAnchorablePaneGroup>

                    </xcad:LayoutPanel>

                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>

        <Grid x:Name="StatusBarGrid" Grid.Row="2" />

    </Grid>
</Window>
