<Window x:Class="Spectrum.DirectSpectrometer.AutoRampWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="积分时间自动增长测试" Height="700" Width="900" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" Padding="12" CornerRadius="4" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="起始积分时间 (ms)"/>
                <TextBox x:Name="StartTimeTextBox" Grid.Row="0" Grid.Column="1" Text="1" Padding="6"/>

                <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0" Text="结束积分时间 (ms)"/>
                <TextBox x:Name="EndTimeTextBox" Grid.Row="0" Grid.Column="4" Text="100" Padding="6"/>

                <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center" Margin="0,0,8,0" Text="步长 (ms)"/>
                <TextBox x:Name="StepTimeTextBox" Grid.Row="0" Grid.Column="7" Text="1" Padding="6"/>

                <TextBlock Grid.Row="0" Grid.Column="9" VerticalAlignment="Center" Margin="0,0,8,0" Text="平均次数"/>
                <TextBox x:Name="AvgTimesTextBox" Grid.Row="0" Grid.Column="10" Text="1" Padding="6"/>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="11" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button x:Name="StartButton" Content="开始测试" Width="110" Height="32" Margin="0,0,8,0" Click="StartButton_Click"/>
                    <Button x:Name="StopButton" Content="停止测试" Width="110" Height="32" Margin="0,0,8,0" Click="StopButton_Click" IsEnabled="False"/>
                    <Button x:Name="ExportButton" Content="导出CSV" Width="110" Height="32" Margin="0,0,8,0" Click="ExportButton_Click"/>
                    <Button x:Name="CloseButton" Content="关闭" Width="110" Height="32" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,0,0,8">
            <TextBlock x:Name="StatusTextBlock" Text="就绪" FontSize="14" FontWeight="SemiBold"/>
        </Border>

        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,0,0,8">
            <DataGrid x:Name="ResultsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="60"/>
                    <DataGridTextColumn Header="积分时间 (ms)" Binding="{Binding IntegrationTimeMs, StringFormat=F3}" Width="120"/>
                    <DataGridTextColumn Header="积分时间 (us)" Binding="{Binding IntegrationTimeUs}" Width="100"/>
                    <DataGridTextColumn Header="平均次数" Binding="{Binding AverageTimes}" Width="80"/>
                    <DataGridTextColumn Header="实际耗时 (ms)" Binding="{Binding ElapsedMs, StringFormat=F2}" Width="120"/>
                    <DataGridTextColumn Header="预期耗时 (ms)" Binding="{Binding ExpectedMs, StringFormat=F2}" Width="120"/>
                    <DataGridTextColumn Header="误差 (ms)" Binding="{Binding ErrorMs, StringFormat=F2}" Width="100"/>
                    <DataGridTextColumn Header="误差比例 (%)" Binding="{Binding ErrorPercent, StringFormat=F2}" Width="100"/>
                    <DataGridTextColumn Header="返回码" Binding="{Binding ResultCode}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" Padding="8" CornerRadius="4">
            <TextBox x:Name="LogTextBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" FontFamily="Consolas"/>
        </Border>
    </Grid>
</Window>