<Window x:Class="Spectrum.DirectSpectrometer.DirectSpectrometerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="光谱仪直连测试" Height="900" Width="1400" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" Padding="12" CornerRadius="4" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="积分时间 (ms)"/>
                <TextBox x:Name="IntegrationTimeTextBox" Grid.Row="0" Grid.Column="1" Text="1" Padding="6"/>

                <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0" Text="平均次数"/>
                <TextBox x:Name="AverageTimesTextBox" Grid.Row="0" Grid.Column="4" Text="1" Padding="6"/>

                <TextBlock Grid.Row="0" Grid.Column="6" VerticalAlignment="Center" Margin="0,0,8,0" Text="间隔 (ms)"/>
                <TextBox x:Name="IntervalTextBox" Grid.Row="0" Grid.Column="7" Text="100" Padding="6"/>

                <TextBlock Grid.Row="0" Grid.Column="9" VerticalAlignment="Center" Margin="0,0,8,0" Text="DLL位置"/>
                <TextBlock x:Name="DllLocationTextBlock" Grid.Row="0" Grid.Column="10" Padding="6" Text="待检查" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="11" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button x:Name="OpenButton" Content="打开设备" Width="110" Height="32" Margin="0,0,8,0" Click="OpenButton_Click"/>
                    <Button x:Name="ApplyButton" Content="设置参数" Width="110" Height="32" Margin="0,0,8,0" Click="ApplyButton_Click"/>
                    <Button x:Name="GetSpectrumButton" Content="获取光谱" Width="110" Height="32" Margin="0,0,8,0" Click="GetSpectrumButton_Click"/>
                    <Button x:Name="RunTimingButton" Content="时序测试" Width="110" Height="32" Margin="0,0,8,0" Click="RunTimingButton_Click"/>
                    <Button x:Name="RunContinuousButton" Content="连续测试" Width="110" Height="32" Margin="0,0,8,0" Click="RunContinuousButton_Click"/>
                    <Button x:Name="AutoRampButton" Content="自动增长" Width="110" Height="32" Margin="0,0,8,0" Click="AutoRampButton_Click"/>
                    <Button x:Name="CloseButton" Content="关闭设备" Width="110" Height="32" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Padding="12" CornerRadius="4" Margin="0,0,0,8">
            <TextBlock x:Name="StatusTextBlock" Text="未连接" FontSize="14" FontWeight="SemiBold"/>
        </Border>

        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,0,0,8">
            <ScottPlot:WpfPlot x:Name="SpectrumPlot"/>
        </Border>

        <Border Grid.Row="3" BorderBrush="#DDD" BorderThickness="1" Padding="8" CornerRadius="4">
            <TextBox x:Name="LogTextBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" FontFamily="Consolas"/>
        </Border>
    </Grid>
</Window>