<Window x:Class="Spectrum.CalibrationGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="标定文件分组管理" Height="520" Width="680" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: group selection -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="标定文件分组" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6"/>
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="移除分组" x:Name="BtnRemoveGroup" Click="BtnRemoveGroup_Click" Margin="6,0,0,0" Padding="10,4"/>
                <Button DockPanel.Dock="Right" Content="添加分组" x:Name="BtnAddGroup" Click="BtnAddGroup_Click" Margin="6,0,0,0" Padding="10,4"/>
                <TextBlock Text="当前分组: " Width="70"/>
                <ComboBox x:Name="ComboBoxGroups" SelectionChanged="ComboBoxGroups_SelectionChanged" />
            </DockPanel>
        </StackPanel>

        <!-- Group detail -->
        <GroupBox Grid.Row="1" Header="分组详情" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Group name -->
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="分组名称" Width="80"/>
                    <TextBox x:Name="TextBoxGroupName" TextChanged="TextBoxGroupName_TextChanged" />
                </DockPanel>

                <!-- Wavelength file -->
                <DockPanel Grid.Row="1" Margin="0,0,0,4">
                    <Button DockPanel.Dock="Right" Content="验证" Click="BtnValidateWavelength_Click" Margin="6,0,0,0" Padding="8,2"/>
                    <Button DockPanel.Dock="Right" Content="选择..." Click="BtnSelectWavelength_Click" Margin="6,0,0,0" Padding="8,2"/>
                    <TextBlock Text="波长标定文件" Width="80"/>
                    <TextBox x:Name="TextBoxWavelengthFile" IsReadOnly="True" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </DockPanel>
                <TextBlock Grid.Row="2" x:Name="TextWavelengthValidation" Margin="80,0,0,6" FontSize="11" Foreground="Gray"/>

                <!-- Maguide file -->
                <DockPanel Grid.Row="3" Margin="0,0,0,4">
                    <Button DockPanel.Dock="Right" Content="验证" Click="BtnValidateMaguide_Click" Margin="6,0,0,0" Padding="8,2"/>
                    <Button DockPanel.Dock="Right" Content="选择..." Click="BtnSelectMaguide_Click" Margin="6,0,0,0" Padding="8,2"/>
                    <TextBlock Text="幅值标定文件" Width="80"/>
                    <TextBox x:Name="TextBoxMaguideFile" IsReadOnly="True" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </DockPanel>
                <TextBlock Grid.Row="4" x:Name="TextMaguideValidation" Margin="80,0,0,6" FontSize="11" Foreground="Gray"/>

                <!-- Filter Wheel Position -->
                <DockPanel Grid.Row="5" Margin="0,0,0,8">
                    <TextBlock Text="滤色轮位置" Width="80"/>
                    <ComboBox x:Name="ComboBoxFilterWheelPosition" SelectionChanged="ComboBoxFilterWheelPosition_SelectionChanged" Width="160" HorizontalAlignment="Left">
                        <ComboBoxItem Content="无关联" Tag="-1"/>
                        <ComboBoxItem Content="0: ND0" Tag="0"/>
                        <ComboBoxItem Content="1: ND10" Tag="1"/>
                        <ComboBoxItem Content="2: ND100" Tag="2"/>
                        <ComboBoxItem Content="3: ND1000" Tag="3"/>
                        <ComboBoxItem Content="4: Empty" Tag="4"/>
                    </ComboBox>
                    <TextBlock Text=" (切换滤色轮时自动加载)" Foreground="Gray" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </DockPanel>

                <!-- Validation status summary -->
                <GroupBox Grid.Row="6" Header="标定文件信息" Margin="0,6,0,0" Padding="6">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="波长文件状态: " Width="100"/>
                            <TextBlock x:Name="TextWavelengthStatus" Text="未验证" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="幅值文件状态: " Width="100"/>
                            <TextBlock x:Name="TextMaguideStatus" Text="未验证" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="配置保存路径: " Width="100"/>
                            <TextBlock x:Name="TextConfigPath" Text="---" TextWrapping="Wrap" FontSize="11" Foreground="Gray"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </GroupBox>

        <!-- ND association hint -->
        <TextBlock Grid.Row="2" TextWrapping="Wrap" FontSize="11" Foreground="Gray" Margin="0,0,0,8"
                   Text="提示: 配置滤色轮位置后，切换滤色轮时将自动加载对应分组的标定文件。也可使分组名称与滤色轮位置名称匹配(如 ND0, ND10, ND100, Empty)实现自动关联。"/>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="关闭" Click="BtnClose_Click" Padding="20,6" />
        </StackPanel>
    </Grid>
</Window>
