<Window x:Class="YoloObjectDetection.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YOLO 工业检测"
        Width="1280" Height="820"
        MinWidth="1080" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#171923">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Background" Value="#394150"/>
            <Setter Property="Foreground" Value="#f4f7fb"/>
            <Setter Property="BorderBrush" Value="#505a6e"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e8edf7"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e8edf7"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Background="#222734"
                BorderBrush="#343b4d"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14"
                Margin="0,0,10,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="YOLO 工业检测"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="输入源"
                               Foreground="#9fb0c7"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <UniformGrid Columns="2">
                        <Button x:Name="BtnOpenImage"
                                Content="打开图片"
                                Click="OnOpenImageClick"/>
                        <Button x:Name="BtnOpenVideo"
                                Content="打开视频"
                                Click="OnOpenVideoClick"/>
                        <Button x:Name="BtnStartCamera"
                                Content="启动摄像头"
                                Click="OnStartCameraClick"/>
                        <Button x:Name="BtnStop"
                                Content="停止"
                                Click="OnStopClick"/>
                    </UniformGrid>

                    <Separator Margin="0,8,0,14" Background="#3a4255"/>

                    <DockPanel>
                        <TextBlock Text="置信度" Foreground="#9fb0c7" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtConfidenceValue"
                                   DockPanel.Dock="Right"
                                   Text="0.40"
                                   Foreground="#a6e3a1"/>
                    </DockPanel>
                    <Slider x:Name="SldConfidence"
                            Minimum="0.01"
                            Maximum="0.95"
                            SmallChange="0.01"
                            LargeChange="0.05"
                            ValueChanged="OnThresholdChanged"/>

                    <DockPanel>
                        <TextBlock Text="NMS IoU" Foreground="#9fb0c7" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtNmsValue"
                                   DockPanel.Dock="Right"
                                   Text="0.50"
                                   Foreground="#a6e3a1"/>
                    </DockPanel>
                    <Slider x:Name="SldNms"
                            Minimum="0.05"
                            Maximum="0.95"
                            SmallChange="0.01"
                            LargeChange="0.05"
                            ValueChanged="OnThresholdChanged"/>

                    <CheckBox x:Name="ChkUseRoi"
                              Content="只检测 ROI 区域"
                              Checked="OnRoiToggleChanged"
                              Unchecked="OnRoiToggleChanged"/>
                    <TextBlock x:Name="TxtRoiInfo"
                               Text="ROI: --"
                               Foreground="#c7d2e4"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>

                    <CheckBox x:Name="ChkUseInspection"
                              Content="启用 OK/NG 区域判定"
                              Checked="OnInspectionToggleChanged"
                              Unchecked="OnInspectionToggleChanged"/>
                    <TextBlock x:Name="TxtInspectionInfo"
                               Text="判定区域: --"
                               Foreground="#c7d2e4"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0"/>

                    <Separator Margin="0,14,0,14" Background="#3a4255"/>

                    <TextBlock Text="保存与导出"
                               Foreground="#9fb0c7"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <UniformGrid Columns="1">
                        <Button x:Name="BtnSaveFrame"
                                Content="保存当前帧"
                                Click="OnSaveFrameClick"/>
                        <Button x:Name="BtnExportJson"
                                Content="导出 JSON"
                                Click="OnExportJsonClick"/>
                        <Button x:Name="BtnExportCsv"
                                Content="导出 CSV"
                                Click="OnExportCsvClick"/>
                    </UniformGrid>

                    <Separator Margin="0,8,0,14" Background="#3a4255"/>

                    <TextBlock Text="模型信息"
                               Foreground="#9fb0c7"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtModelInfo"
                               Text="模型: --"
                               Foreground="#d8e1f0"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Background="#0d1018"
                BorderBrush="#343b4d"
                BorderThickness="1"
                CornerRadius="6">
            <Image x:Name="VideoImage"
                   Stretch="Uniform"/>
        </Border>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Background="#222734"
                BorderBrush="#343b4d"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TxtStatus"
                           Text="正在启动..."
                           Foreground="#a6e3a1"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtFps"
                           Grid.Column="1"
                           Text="FPS: --"
                           Foreground="#89b4fa"
                           FontFamily="Consolas"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtInference"
                           Grid.Column="2"
                           Text="Inference: -- ms"
                           Foreground="#cba6f7"
                           FontFamily="Consolas"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtDetections"
                           Grid.Column="3"
                           Text="检测: --"
                           Foreground="#f9e2af"
                           FontFamily="Consolas"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtOkNg"
                           Grid.Column="4"
                           Text="OK/NG: --"
                           Foreground="#f38ba8"
                           FontFamily="Consolas"
                           FontWeight="SemiBold"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>