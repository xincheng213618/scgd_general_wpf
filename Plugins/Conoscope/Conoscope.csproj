<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>disable</ImplicitUsings>
		<UseWPF>true</UseWPF>
		<VersionPrefix>1.4.7.1</VersionPrefix>
		<UseWindowsForms>True</UseWindowsForms>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup>
		<None Remove="Assets\Image\ColorVision1.ico" />
		<None Remove="CHANGELOG.md" />
		<None Remove="README.md" />
	</ItemGroup>
	<ItemGroup>	
		<ProjectReference Include="..\..\Engine\ColorVision.Engine\ColorVision.Engine.csproj" />
		<ProjectReference Include="..\..\UI\ColorVision.ImageEditor\ColorVision.ImageEditor.csproj" />
		<ProjectReference Include="..\..\UI\ColorVision.Solution\ColorVision.Solution.csproj" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="CHANGELOG.md">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</EmbeddedResource>
		<EmbeddedResource Include="README.md">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<Compile Update="Properties\Resources.Designer.cs">
			<DesignTime>True</DesignTime>
			<AutoGen>True</AutoGen>
			<DependentUpon>Resources.resx</DependentUpon>
		</Compile>
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Update="Properties\Resources.resx">
			<Generator>PublicResXFileCodeGenerator</Generator>
			<LastGenOutput>Resources.Designer.cs</LastGenOutput>
		</EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<None Update="manifest.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
	</ItemGroup>

	<ItemGroup>
		<Resource Include="Assets\Image\ColorVision1.ico">
			<CopyToOutputDirectory>Never</CopyToOutputDirectory>
		</Resource>
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="Docs\" />
	</ItemGroup>

	<Target Name="PostBuild" AfterTargets="PostBuildEvent">
		<Exec Condition="'$(SolutionDir)' != '' And '$(SolutionDir)' != '*Undefined*'" Command=":: 定义变量&#xD;&#xA;set DebugPluginsDir=$(SolutionDir)ColorVision\bin\x64\Debug\net10.0-windows\Plugins\$(TargetName)&#xD;&#xA;set ReleasePluginsDir=$(SolutionDir)ColorVision\bin\x64\Release\net10.0-windows\Plugins\$(TargetName)&#xD;&#xA;&#xD;&#xA;:: 创建目录（如果不存在）&#xD;&#xA;if not exist &quot;%25DebugPluginsDir%25&quot; (mkdir &quot;%25DebugPluginsDir%25&quot;)&#xD;&#xA;if not exist &quot;%25ReleasePluginsDir%25&quot; (mkdir &quot;%25ReleasePluginsDir%25&quot;)&#xD;&#xA;&#xD;&#xA;:: 复制主DLL到目标目录&#xD;&#xA;copy &quot;$(OutDir)$(TargetName)$(TargetExt)&quot; &quot;%25DebugPluginsDir%25&quot;&#xD;&#xA;copy &quot;$(OutDir)$(TargetName)$(TargetExt)&quot; &quot;%25ReleasePluginsDir%25&quot;&#xD;&#xA;&#xD;&#xA;:: 从项目目录复制静态元数据，避免共享OutDir中的同名文件互相覆盖&#xD;&#xA;if exist &quot;$(ProjectDir)manifest.json&quot; (&#xD;&#xA;    copy &quot;$(ProjectDir)manifest.json&quot; &quot;%25DebugPluginsDir%25&quot;&#xD;&#xA;    copy &quot;$(ProjectDir)manifest.json&quot; &quot;%25ReleasePluginsDir%25&quot;&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;if exist &quot;$(ProjectDir)ReadMe.md&quot; (&#xD;&#xA;    copy &quot;$(ProjectDir)ReadMe.md&quot; &quot;%25DebugPluginsDir%25&quot;&#xD;&#xA;    copy &quot;$(ProjectDir)ReadMe.md&quot; &quot;%25ReleasePluginsDir%25&quot;&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;if exist &quot;$(ProjectDir)Changelog.md&quot; (&#xD;&#xA;    copy &quot;$(ProjectDir)Changelog.md&quot; &quot;%25DebugPluginsDir%25&quot;&#xD;&#xA;    copy &quot;$(ProjectDir)Changelog.md&quot; &quot;%25ReleasePluginsDir%25&quot;&#xD;&#xA;)" />
	</Target>

	<Target Name="CopyHostProjectReferences" AfterTargets="Build" Condition="'$(SolutionDir)' != '' And '$(SolutionDir)' != '*Undefined*'">
		<PropertyGroup>
			<HostDebugRoot>$(SolutionDir)ColorVision\bin\x64\Debug\net10.0-windows\</HostDebugRoot>
			<HostReleaseRoot>$(SolutionDir)ColorVision\bin\x64\Release\net10.0-windows\</HostReleaseRoot>
		</PropertyGroup>

		<ItemGroup>
			<HostProjectReferenceAssemblies Include="@(ReferenceCopyLocalPaths)"
				Condition="'%(ReferenceCopyLocalPaths.ReferenceSourceTarget)' == 'ProjectReference' and Exists('%(ReferenceCopyLocalPaths.Identity)') and '%(ReferenceCopyLocalPaths.DestinationSubDirectory)' == '' and !$([System.String]::Copy('%(ReferenceCopyLocalPaths.Filename)').EndsWith('.resources'))" />
			<HostProjectReferenceSymbols Include="@(HostProjectReferenceAssemblies->'%(RootDir)%(Directory)%(Filename).pdb')"
				Condition="Exists('%(HostProjectReferenceAssemblies.RootDir)%(HostProjectReferenceAssemblies.Directory)%(HostProjectReferenceAssemblies.Filename).pdb')" />
		</ItemGroup>

		<Copy SourceFiles="@(HostProjectReferenceAssemblies)"
			  DestinationFolder="$(HostDebugRoot)"
			  SkipUnchangedFiles="true" />
		<Copy SourceFiles="@(HostProjectReferenceSymbols)"
			  DestinationFolder="$(HostDebugRoot)"
			  SkipUnchangedFiles="true"
			  Condition="'@(HostProjectReferenceSymbols)' != ''" />
		<Copy SourceFiles="@(HostProjectReferenceAssemblies)"
			  DestinationFolder="$(HostReleaseRoot)"
			  SkipUnchangedFiles="true" />
		<Copy SourceFiles="@(HostProjectReferenceSymbols)"
			  DestinationFolder="$(HostReleaseRoot)"
			  SkipUnchangedFiles="true"
			  Condition="'@(HostProjectReferenceSymbols)' != ''" />
	</Target>
</Project>
