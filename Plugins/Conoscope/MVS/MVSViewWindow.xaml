<Window x:Class="Conoscope.MVS.MVSViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wfCtrl="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        xmlns:local="clr-namespace:Conoscope.MVS"
        xmlns:wfHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:MVSViewManager}"
        Title="{x:Static properties:Resources.TitleMvsCameraView}" Height="600" Width="1024" Initialized="Window_Initialized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="{x:Static properties:Resources.MenuView}">
                <MenuItem Header="{x:Static properties:Resources.MenuShowToolbar}" IsCheckable="True" IsChecked="True" Checked="MenuShowSidePanel_Checked" Unchecked="MenuShowSidePanel_Unchecked"/>
                <MenuItem Header="{x:Static properties:Resources.MenuShowStatusBar}" IsCheckable="True" IsChecked="True" Checked="MenuShowStatusBar_Checked" Unchecked="MenuShowStatusBar_Unchecked"/>
            </MenuItem>
        </Menu>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidePanelColumn" Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid x:Name="SidePanelGrid" Grid.Column="0">
            <StackPanel>
                <DockPanel  Margin="0,0,0,5">
                    <Button  DockPanel.Dock="Right" Command="{Binding  EditMVSViewConfigCommand }" Padding="2" Height="22" Width="22" Margin="5,0,0,0" >
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="rotateTransform2" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <TextBlock Text="&#xE713;"  HorizontalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="rotateTransform2" CenterX="6" CenterY="6"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Button>
                    <Button x:Name="bnEnum"  Click="bnEnum_Click" Content="{x:Static properties:Resources.BtnFindDevice}"/>
                </DockPanel>
                <ComboBox  Name="cbDeviceList" Margin="0,0,0,5"/>

                    <ComboBox x:Name="cbPixelType"  SelectionChanged="cbModelType_SelectionChanged" SelectedItem="{Binding Config.PixelType}"  Margin="0,0,0,5" Visibility="Collapsed"/>
                <UniformGrid Columns="2" Margin="0,0,0,5">
                    <Button x:Name="bnOpen"  Click="bnOpen_Click" Content="{x:Static properties:Resources.BtnOpenDevice}" Margin="0,0,5,0" />
                    <Button x:Name="bnClose"  Click="bnClose_Click" IsEnabled="False" Content="{x:Static properties:Resources.BtnCloseDevice}" />
                </UniformGrid>


                <StackPanel Orientation="Horizontal" Margin="0,0,0,5" Visibility="Collapsed">
                    <RadioButton x:Name="bnContinuesMode" Checked="bnContinuesMode_Checked" IsEnabled="False" Content="{x:Static properties:Resources.RbContinuousMode}" Margin="0,0,5,0" />
                    <RadioButton x:Name="bnTriggerMode" Checked="bnTriggerMode_Checked" IsEnabled="False" Content="{x:Static properties:Resources.RbTriggerMode}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <Button x:Name="bnStartGrab" Click="bnStartGrab_Click" IsEnabled="False"  Content="{x:Static properties:Resources.BtnStartCapture}" Margin="0,0,5,0"/>
                    <Button x:Name="bnStopGrab" Click="bnStopGrab_Click" IsEnabled="False" Content="{x:Static properties:Resources.BtnStopCapture}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5" Visibility="Collapsed">
                    <CheckBox x:Name="cbSoftTrigger" Checked="cbSoftTrigger_Checked" IsEnabled="False" Content="{x:Static properties:Resources.ChkSoftTrigger}"   Margin="0,0,5,0"/>
                    <Button x:Name="bnTriggerExec" Click="bnTriggerExec_Click" IsEnabled="False" Content="{x:Static properties:Resources.BtnSoftTriggerOnce}" />
                </StackPanel>

                    <DockPanel Margin="0,0,0,5">
                        <TextBox x:Name="tbExposure"
                                 DockPanel.Dock="Right"
                                 Width="120"
                                 Style="{StaticResource TextBox.Small}"
                                 Text="{Binding Config.Exposure,StringFormat=F1}"
                                 LostFocus="ExposureTextBox_LostFocus"
                                 PreviewKeyDown="ParameterTextBox_PreviewKeyDown"/>
                        <TextBlock x:Name="label1" Text="{x:Static properties:Resources.LabelExposureMs}" />
                    </DockPanel>
                <DockPanel Margin="0,0,0,5">
                        <TextBox x:Name="tbGain"
                                 DockPanel.Dock="Right"
                                 Width="120"
                                 Style="{StaticResource TextBox.Small}"
                                 LostFocus="GainTextBox_LostFocus"
                                 PreviewKeyDown="ParameterTextBox_PreviewKeyDown" />
                    <TextBlock x:Name="label2" Text="{x:Static properties:Resources.LabelGain}"/>
                </DockPanel>
                <DockPanel Margin="0,0,0,5" Visibility="Collapsed">
                    <TextBox x:Name="tbFrameRate"  DockPanel.Dock="Right" Width="120"  Style="{StaticResource TextBox.Small}"/>
                    <TextBlock x:Name="label3" Text="{x:Static properties:Resources.LabelFrameRate}"/>
                </DockPanel>

                <GroupBox Header="{x:Static properties:Resources.GroupBoxTestArea}" Margin="0,0,0,5">
                    <StackPanel Margin="4">
                        <DockPanel Margin="0,0,0,4">
                            <ComboBox x:Name="cbGratingDiameter"
                                      DockPanel.Dock="Right"
                                      Width="105"
                                      ItemsSource="{Binding Config.GratingDiametersMillimeters}"
                                      SelectedItem="{Binding Config.SelectedGratingDiameterMillimeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      ItemStringFormat="{}{0:g} mm"
                                      SelectionChanged="cbGratingDiameter_SelectionChanged"/>
                            <TextBlock Text="{x:Static properties:Resources.LabelSelectArea}" VerticalAlignment="Center"/>
                        </DockPanel>
                        <Button Content="{x:Static properties:Resources.BtnOpenObservationSettings}" Command="{Binding EditMVSViewConfigCommand}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="tbGratingOverlayStatus" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>
                </GroupBox>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5" Visibility="Collapsed">
                    <Button x:Name="bnGetParam"  Click="bnGetParam_Click" IsEnabled="False" Content="{x:Static properties:Resources.BtnGetParams}" Margin="0,0,5,0" />
                    <Button x:Name="bnSetParam"  Click="bnSetParam_Click" IsEnabled="False" Content="{x:Static properties:Resources.BtnSetParams}"/>
                </StackPanel>

            </StackPanel>
        </Grid>
        <Border x:Name="DisplayGrid" Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8" ClipToBounds="True">
            <Grid x:Name="DisplayHost">
                <Grid x:Name="ImageDisplayHost"/>
            </Grid>
        </Border>

        <!--<wfHost:WindowsFormsHost x:Name="DisplayWindow" Visibility="Collapsed" Grid.Column="1" IsEnabled="True">
            <wfCtrl:PictureBox x:Name="displayArea"/>
        </wfHost:WindowsFormsHost>-->

        </Grid>
        
        <!-- Status Bar -->
        <StatusBar x:Name="StatusBarBottom" Grid.Row="2">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="{x:Static properties:Resources.StatusExposure}"/>
                    <Run x:Name="StatusExposureText" Text="{Binding Config.Exposure}"/>
                    <Run Text=" ms"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="{x:Static properties:Resources.StatusGain}"/>
                    <Run x:Name="StatusGainText" Text="--"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock>
                    <Run Text="{x:Static properties:Resources.StatusFrameRate}"/>
                    <Run x:Name="StatusFrameRateText" Text="--"/>
                    <Run Text=" FPS"/>
                </TextBlock>
            </StatusBarItem>

            <StatusBarItem>
                <TextBlock>
                    <Run Text="{x:Static properties:Resources.StatusImageCount}"/>
                    <Run  Text="{Binding Count}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
