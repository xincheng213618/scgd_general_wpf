<Window x:Class="Conoscope.AdvancedExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.TitleAdvancedExport}" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource GlobalBackground}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="{x:Static properties:Resources.TitleAdvancedExport}" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Settings -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- File Prefix -->
                <GroupBox Header="{x:Static properties:Resources.GroupBoxFileSettings}" Margin="0,0,0,10">
                    <StackPanel>
                        <DockPanel Margin="5">
                            <TextBlock Text="{x:Static properties:Resources.LabelFilePrefix}" Width="100" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtFilePrefix" Text="Conoscope_Export" />
                        </DockPanel>
                        <DockPanel Margin="5,0,5,5">
                            <TextBlock Text="{x:Static properties:Resources.LabelDecimalPlaces}" Width="100" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtDecimalPlaces" Text="4" Width="60"/>
                            <TextBlock Text="{x:Static properties:Resources.HintDecimalPlacesDefault4}" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                        </DockPanel>
                        <TextBlock Text="{x:Static properties:Resources.HintFileNaming}" 
                                   Margin="5" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

                <!-- Channel Selection -->
                <GroupBox Header="{x:Static properties:Resources.GroupBoxChannelSelection}" Margin="0,0,0,10">
                    <StackPanel>
                        <CheckBox x:Name="chkChannelX" Content="{x:Static properties:Resources.ChannelX}" IsChecked="False" Margin="5"/>
                        <CheckBox x:Name="chkChannelY" Content="{x:Static properties:Resources.ChannelY}" IsChecked="True" Margin="5"/>
                        <CheckBox x:Name="chkChannelZ" Content="{x:Static properties:Resources.ChannelZ}" IsChecked="False" Margin="5"/>
                        <CheckBox x:Name="chkChannelCieX" Content="{x:Static properties:Resources.ChannelCieX}" IsChecked="False" Margin="5"/>
                        <CheckBox x:Name="chkChannelCieY" Content="{x:Static properties:Resources.ChannelCieY}" IsChecked="False" Margin="5"/>
                        <CheckBox x:Name="chkChannelCieU" Content="{x:Static properties:Resources.ChannelCieU}" IsChecked="False" Margin="5"/>
                        <CheckBox x:Name="chkChannelCieV" Content="{x:Static properties:Resources.ChannelCieV}" IsChecked="False" Margin="5"/>
                        <CheckBox x:Name="chkChannelColorDifference" Content="{x:Static properties:Resources.ChannelDeltaUV}" IsChecked="False" Margin="5"/>
                        <CheckBox x:Name="chkChannelContrast" Content="{x:Static properties:Resources.ChannelContrast}" IsChecked="False" Margin="5"/>
                        <TextBlock Text="{x:Static properties:Resources.HintChannelPerFile}" 
                                   Margin="5" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

                <!-- Export Mode -->
                <GroupBox Header="{x:Static properties:Resources.GroupBoxExportMode}" Margin="0,0,0,10">
                    <StackPanel>
                        <CheckBox x:Name="chkExportAzimuth" Content="{x:Static properties:Resources.CbiAzimuthExport}" IsChecked="True" Margin="5"/>
                        <CheckBox x:Name="chkExportPolar" Content="{x:Static properties:Resources.CbiPolarExport}" IsChecked="False" Margin="5"/>
                        <TextBlock Text="{x:Static properties:Resources.HintBothExportModes}" 
                                   Margin="5" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

                <!-- Azimuth Settings -->
                <GroupBox Header="{x:Static properties:Resources.GroupBoxAzimuthSettings}" Margin="0,0,0,10">
                    <StackPanel>
                        <DockPanel Margin="5">
                            <TextBlock Text="{x:Static properties:Resources.LabelAzimuthStep}" Width="120" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtAzimuthStep" Text="1" Width="60"/>
                            <TextBlock Text="(0.01-180)" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                        </DockPanel>
                        <DockPanel Margin="5">
                            <TextBlock Text="{x:Static properties:Resources.LabelRadialStep}" Width="120" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtRadialStep" Text="1" Width="60"/>
                            <TextBlock Text="(0.01-80)" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                        </DockPanel>
                        <TextBlock Text="{x:Static properties:Resources.HintAzimuthSampling}" 
                                   Margin="5" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

                <!-- Polar Angle Settings -->
                <GroupBox Header="{x:Static properties:Resources.GroupBoxPolarSettings}" Margin="0,0,0,10">
                    <StackPanel>
                        <DockPanel Margin="5">
                            <TextBlock Text="{x:Static properties:Resources.LabelRingStep}" Width="120" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtPolarStep" Text="1" Width="60"/>
                            <TextBlock Text="(0.01-80)" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                        </DockPanel>
                        <DockPanel Margin="5">
                            <TextBlock Text="{x:Static properties:Resources.LabelCircularStep}" Width="120" VerticalAlignment="Center"/>
                            <TextBox x:Name="txtCircumferentialStep" Text="1" Width="60"/>
                            <TextBlock Text="(0.01-360)" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                        </DockPanel>
                        <TextBlock Text="{x:Static properties:Resources.HintPolarSampling}" 
                                   Margin="5" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>

                <!-- Cross-section Export -->
                <GroupBox Header="{x:Static properties:Resources.GroupBoxSectionExport}" Margin="0,0,0,10">
                    <StackPanel>
                        <CheckBox x:Name="chkEnableCrossSection" Content="{x:Static properties:Resources.ChkEnableSectionExport}" Margin="5" Checked="chkEnableCrossSection_Changed" Unchecked="chkEnableCrossSection_Changed"/>
                        
                        <StackPanel x:Name="panelCrossSection" IsEnabled="False" Margin="10,5,5,5">
                            <RadioButton x:Name="rbCrossSectionAzimuth" Content="{x:Static properties:Resources.RbAzimuthSection}" IsChecked="True" Margin="0,5"/>
                            <DockPanel Margin="20,5">
                                <TextBlock Text="{x:Static properties:Resources.LabelAzimuthDeg}" Width="100" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtCrossSectionAzimuthAngle" Text="0" Width="60"/>
                                <TextBlock Text="(0-180)" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                            </DockPanel>
                            
                            <RadioButton x:Name="rbCrossSectionPolar" Content="{x:Static properties:Resources.RbPolarSection}" Margin="0,10,0,5"/>
                            <DockPanel Margin="20,5">
                                <TextBlock Text="{x:Static properties:Resources.LabelPolarDeg}" Width="100" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtCrossSectionPolarAngle" Text="45" Width="60"/>
                                <TextBlock Text="(0-80)" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                            </DockPanel>
                        </StackPanel>
                        
                        <TextBlock Text="{x:Static properties:Resources.HintSectionExport}" 
                                   Margin="5" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnExport" Content="{x:Static properties:Resources.BtnExport}" Width="80" Height="30" Margin="0,0,10,0" Click="btnExport_Click"/>
            <Button x:Name="btnCancel" Content="{x:Static properties:Resources.BtnCancel}" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
