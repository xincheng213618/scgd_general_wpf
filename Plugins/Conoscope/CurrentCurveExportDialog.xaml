<Window x:Class="Conoscope.CurrentCurveExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        Title="{x:Static properties:Resources.TitleCurrentCurveExport}"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource GlobalBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{x:Static properties:Resources.TitleCurrentCurveExport}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <GroupBox Grid.Row="1" Header="{x:Static properties:Resources.GroupBoxSamplingSettings}" Margin="0,0,0,12">
            <StackPanel Margin="8,6,8,8">
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="{x:Static properties:Resources.LabelSamplingInterval}" Width="110" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtStepDegrees" Width="90" Text="1" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Static properties:Resources.HintSamplingDefault}" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                </DockPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="{x:Static properties:Resources.LabelDecimalPlaces}" Width="110" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtDecimalPlaces" Width="90" Text="4" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Static properties:Resources.HintDecimalPlacesDefault4Saved}" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
                </DockPanel>
                <TextBlock Text="{x:Static properties:Resources.HintSamplingDescription}"
                           TextWrapping="Wrap"
                           Foreground="Gray"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="{x:Static properties:Resources.GroupBoxTitleSettings}" Margin="0,0,0,12">
            <StackPanel Margin="8,6,8,8">
                <CheckBox x:Name="chkIncludeMetadata" Content="{x:Static properties:Resources.ChkExportTitle}" IsChecked="True" Margin="0,0,0,6"/>
                <TextBlock Text="{x:Static properties:Resources.HintExportTitle}"
                           TextWrapping="Wrap"
                           Foreground="Gray"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{x:Static properties:Resources.BtnExport}" Width="84" Margin="0,0,8,0" Click="btnExport_Click"/>
            <Button Content="{x:Static properties:Resources.BtnCancel}" Width="84" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>