<UserControl x:Class="Conoscope.ConoscopeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Conoscope="clr-namespace:Conoscope.Core"
    xmlns:local="clr-namespace:Conoscope"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Conoscope:ConoscopeManager}"
        Background="{DynamicResource GlobalBackground}" d:Height="720" d:Width="1280" Initialized="Window_Initialized">
    <UserControl.Resources>
        <Style x:Key="PanelHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>
        <Style x:Key="PanelMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PanelCompactButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>
        <Style x:Key="PanelSurfaceButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelSurfaceToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelCompactToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="OverlayToolButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelSurfaceButtonStyle}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="OverlayToolToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource PanelSurfaceToggleStyle}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="MinWidth" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <DrawingBrush x:Key="TransparentGridBrush" Opacity="0.1" TileMode="Tile" Viewport="0 0 20 20" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Gray" Geometry="M0,0 L0,10 10,10 10,0 Z" />
                    <GeometryDrawing Brush="Transparent" Geometry="M10,0 L10,10 20,10 20,0 Z" />
                    <GeometryDrawing Brush="Transparent" Geometry="M0,10 L0,20 10,20 10,10 Z" />
                    <GeometryDrawing Brush="Gray" Geometry="M10,10 L10,20 20,20 20,10 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid x:Name="ImageViewHost" Grid.Column="0" Background="{StaticResource TransparentGridBrush}">
            <local:ConoscopeImageHost x:Name="ImageView" />
            <Border x:Name="PseudoColorLegendPanel" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Padding="8" Background="#DD1E1E1E" BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="6" Visibility="Collapsed" IsHitTestVisible="False">
                <StackPanel>
                    <TextBlock x:Name="tbPseudoColorLegendTitle" Foreground="White" FontWeight="SemiBold" Text="Y" HorizontalAlignment="Center" />
                    <TextBlock x:Name="tbPseudoColorLegendMax" Margin="0,6,0,4" Foreground="White" FontSize="11" HorizontalAlignment="Center" Text="0" />
                    <Border Width="18" Height="124" BorderBrush="#55FFFFFF" BorderThickness="1">
                        <Image x:Name="imgPseudoColorLegend" Stretch="Fill" />
                    </Border>
                    <TextBlock x:Name="tbPseudoColorLegendMin" Margin="0,4,0,0" Foreground="White" FontSize="11" HorizontalAlignment="Center" Text="0" />
                </StackPanel>
            </Border>
            <Border x:Name="CoordinateDragOverlay" HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Collapsed" IsHitTestVisible="False" Background="#CC202020" BorderBrush="#FFFFD400" BorderThickness="1" CornerRadius="4" Padding="8,4">
                <TextBlock x:Name="CoordinateDragOverlayText" Foreground="White" FontWeight="SemiBold" />
            </Border>
            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" Padding="3" Background="{DynamicResource GlobalBorderBrush}" BorderBrush="{DynamicResource ButtonBorderBrush}" BorderThickness="1" CornerRadius="6">
                <ToolBar ToolBarTray.IsLocked="True" Background="Transparent" BorderThickness="0" Padding="0">
                    <ToggleButton x:Name="tglFocusCircleMode" Style="{StaticResource OverlayToolToggleStyle}" ToolTip="{x:Static properties:Resources.TbEditFocusPointTip}" Checked="tglFocusCircleMode_Checked" Unchecked="tglFocusCircleMode_Unchecked" />
                    <ToggleButton x:Name="tglFocusCircleDrawTool" Style="{StaticResource OverlayToolToggleStyle}" ToolTip="{x:Static properties:Resources.TbCircleTip}" IsChecked="False" Checked="tglFocusCircleDrawTool_Checked" Unchecked="tglFocusCircleDrawTool_Unchecked" />
                    <ToggleButton x:Name="tglFocusCircleSelectTool" Style="{StaticResource OverlayToolToggleStyle}" Content="{x:Static properties:Resources.TbEdit}" ToolTip="{x:Static properties:Resources.TbEditTip}" Checked="tglFocusCircleSelectTool_Checked" Unchecked="tglFocusCircleSelectTool_Unchecked" Visibility="Collapsed" />
                    <ToggleButton x:Name="tglFocusCircleEraseTool" Style="{StaticResource OverlayToolToggleStyle}" ToolTip="{x:Static properties:Resources.TbEraserTip}" Checked="tglFocusCircleEraseTool_Checked" Unchecked="tglFocusCircleEraseTool_Unchecked" />
                    <Separator/>
                    <Button x:Name="btnCircleFit" Style="{StaticResource OverlayToolButtonStyle}" ToolTip="{x:Static properties:Resources.TbCircleFitTip}" Click="btnCircleFit_Click" />
                    <Button x:Name="btnCalculateFocusCircles" Style="{StaticResource OverlayToolButtonStyle}" ToolTip="{x:Static properties:Resources.TbCalcTip}" Click="btnCalculateFocusCircles_Click" />
                    <Button x:Name="btnClearFocusCircles" Style="{StaticResource OverlayToolButtonStyle}" Content="{x:Static properties:Resources.TbClearAll}" ToolTip="{x:Static properties:Resources.TbClearAllTip}" Click="btnClearFocusCircles_Click" Visibility="Collapsed" />
                    <Separator Visibility="Collapsed"/>
                    <TextBlock x:Name="tbSelectedFocusPointInfo" Width="280" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Visibility="Collapsed" Foreground="{DynamicResource GlobalTextBrush}" ToolTip="{x:Static properties:Resources.TipSelectedFocusPoint}" />
                    <Separator x:Name="sepSelectedFocusPointInfo" Visibility="Collapsed"/>
                    <ComboBox x:Name="cbFocusPoiTemplate" Width="118" Height="28" DisplayMemberPath="Key" SelectedValuePath="Value" ToolTip="{x:Static properties:Resources.TipFocusPoiTemplate}" SelectionChanged="cbFocusPoiTemplate_SelectionChanged"/>
                    <Button x:Name="btnSaveFocusPoiTemplate" Style="{StaticResource OverlayToolButtonStyle}" ToolTip="{x:Static properties:Resources.TipSaveFocusPoiTemplate}" Click="btnSaveFocusPoiTemplate_Click" />
                    <Button x:Name="btnManageFocusPoiTemplate" Style="{StaticResource OverlayToolButtonStyle}" Content="POI" ToolTip="{x:Static properties:Resources.TipManageFocusPoiTemplate}" Click="btnManageFocusPoiTemplate_Click" Visibility="Collapsed" />
                </ToolBar>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Stretch" Background="{DynamicResource BorderBrush}"/>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="5" Visibility="Collapsed">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="132"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="132"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="68"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Static properties:Resources.LabelChannel}" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,6,0"/>
                        <ComboBox x:Name="cbDisplayChannel" Grid.Column="1" MinWidth="120" SelectedIndex="1" SelectionChanged="DisplayChannel_SelectionChanged" Margin="0,0,12,0">
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelX}" Tag="X"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelY}" Tag="Y"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelZ}" Tag="Z"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieX}" Tag="CieX"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieY}" Tag="CieY"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieU}" Tag="CieU"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieV}" Tag="CieV"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelDeltaUV}" Tag="ColorDifference"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelContrast}" Tag="Contrast"/>
                        </ComboBox>

                        <TextBlock Grid.Column="2" Text="{x:Static properties:Resources.LabelRefMode}" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,6,0"/>
                        <ComboBox x:Name="cbQuickReferenceMode" Grid.Column="3" MinWidth="120" SelectionChanged="QuickReferenceMode_SelectionChanged" Margin="0,0,12,0">
                            <ComboBoxItem Content="{x:Static properties:Resources.RefAzimuthLine}" Tag="AzimuthLine"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.RefPolarCircle}" Tag="PolarCircle"/>
                        </ComboBox>

                        <Grid x:Name="rowReferenceAngle" Grid.Column="5" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="68"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="sliderQuickReferenceAngle" Minimum="0" Maximum="180" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="QuickReferenceAngle_ValueChanged"/>
                            <TextBox x:Name="txtQuickReferenceAngle" Grid.Column="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" PreviewKeyDown="QuickReferenceTextBox_PreviewKeyDown" LostFocus="txtQuickReferenceAngle_LostFocus"/>
                        </Grid>

                        <Grid x:Name="rowReferenceRadius" Grid.Column="5" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="68"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="sliderQuickReferenceRadius" Minimum="0" Maximum="80" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="QuickReferenceRadius_ValueChanged"/>
                            <TextBox x:Name="txtQuickReferenceRadius" Grid.Column="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" PreviewKeyDown="QuickReferenceTextBox_PreviewKeyDown" LostFocus="txtQuickReferenceRadius_LostFocus"/>
                        </Grid>
                    </Grid>

                    <StackPanel Visibility="Collapsed">
                        <Border x:Name="gbColorDifference" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="8,6" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="{x:Static properties:Resources.LabelColorDiffCalc}" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,4,0,4">
                                    <TextBlock Text="{x:Static properties:Resources.LabelBaseRef}" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                    <ComboBox x:Name="cbColorDifferenceReference" MinWidth="170" SelectionChanged="ColorDifferenceReference_SelectionChanged">
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiD65}" Tag="D65"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiD50}" Tag="D50"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiA}" Tag="A"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiD75}" Tag="D75"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiCenter50px}" Tag="ImageCenter"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiCustomCoord}" Tag="Custom"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiMeasuredBase}" Tag="ReferenceImage"/>
                                    </ComboBox>
                                    <Button x:Name="btnSaveColorDifferenceReference" Content="{x:Static properties:Resources.BtnSaveBaseImage}" Click="btnSaveColorDifferenceReference_Click" Padding="10,3" Margin="10,0,6,0"/>
                                    <Button Content="{x:Static properties:Resources.BtnComputeColorDiff}" Click="btnCalculateColorDifference_Click" Padding="10,3"/>
                                </WrapPanel>
                                <WrapPanel x:Name="panelColorDifferenceCustomUv" Margin="0,2,0,4">
                                    <TextBlock Text="u:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                    <TextBox x:Name="txtColorDifferenceCustomU" Width="72" Text="0.1978" LostFocus="ColorDifferenceCustom_LostFocus"/>
                                    <TextBlock Text="v:" VerticalAlignment="Center" Margin="12,0,5,0"/>
                                    <TextBox x:Name="txtColorDifferenceCustomV" Width="72" Text="0.4684" LostFocus="ColorDifferenceCustom_LostFocus"/>
                                </WrapPanel>
                                <TextBlock x:Name="tbColorDifferenceReferenceStatus" Margin="5,0,5,2" Foreground="Gray" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="8,6" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="{x:Static properties:Resources.TitleContrastCalc}" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,4,0,4">
                                    <TextBlock Text="{x:Static properties:Resources.LabelCurrentImage}" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                    <ComboBox x:Name="cbContrastReferenceKind" MinWidth="100" SelectionChanged="ContrastReferenceKind_SelectionChanged">
                                        <ComboBoxItem Content="{x:Static properties:Resources.ContrastImageBlack}" Tag="Black"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.ContrastImageWhite}" Tag="White"/>
                                    </ComboBox>
                                    <Button Content="{x:Static properties:Resources.BtnComputeContrast}" Click="btnCalculateContrast_Click" Padding="10,3" Margin="10,0,0,0"/>
                                </WrapPanel>
                                <TextBlock x:Name="tbContrastReferenceStatus" Margin="5,0,5,2" Foreground="Gray" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Grid x:Name="GridSetting" Margin="0,0,0,10" />
                    </StackPanel>
                </StackPanel>

            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,1,0,0" CornerRadius="3" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,5">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="{x:Static properties:Resources.LabelRefCurve}" Style="{StaticResource PanelHeaderTextStyle}"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock Text="{x:Static properties:Resources.LabelMode}" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,5,0"/>
                                <TextBlock x:Name="tbReferenceMode" MinWidth="72" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{x:Static properties:Resources.LabelCurrentValue}" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,5,0"/>
                                <TextBlock x:Name="tbReferenceValue" MinWidth="78" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{x:Static properties:Resources.LabelGraph}" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,5,0"/>
                                <ToggleButton x:Name="tglReferencePolarMode" Content="{x:Static properties:Resources.BtnPolarCoord}" Style="{StaticResource PanelSurfaceToggleStyle}" Checked="tglReferencePolarMode_Checked" Unchecked="tglReferencePolarMode_Unchecked" Margin="0,0,12,0"/>
                                <Button Content="{x:Static properties:Resources.BtnExportCurrent}" Click="btnExportCurrentReference_Click" Style="{StaticResource PanelSurfaceButtonStyle}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <ScottPlot:WpfPlot x:Name="wpfPlotReference" Margin="5" />
                        <local:ConoscopePolarPlot x:Name="polarPlotReference" Margin="5" Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
