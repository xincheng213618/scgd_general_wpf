<UserControl x:Class="Conoscope.ConoscopeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Conoscope="clr-namespace:Conoscope.Core"
    xmlns:local="clr-namespace:Conoscope"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Conoscope:ConoscopeManager}"
        Background="{DynamicResource GlobalBackground}" Initialized="Window_Initialized">
    <UserControl.Resources>
        <Style x:Key="PanelHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>
        <Style x:Key="PanelMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Opacity" Value="0.72"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PanelCompactButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>
        <Style x:Key="PanelPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelCompactButtonStyle}">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PanelInlineCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>
        <Style x:Key="PanelSurfaceButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelSurfacePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelSurfaceButtonStyle}">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PanelSurfaceToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelCompactToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="MinWidth" Value="68"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="OverlayToolButtonStyle" TargetType="Button" BasedOn="{StaticResource PanelCompactButtonStyle}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="OverlayToolToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="MinWidth" Value="46"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <DrawingBrush x:Key="TransparentGridBrush" Opacity="0.1" TileMode="Tile" Viewport="0 0 20 20" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Gray" Geometry="M0,0 L0,10 10,10 10,0 Z" />
                    <GeometryDrawing Brush="Transparent" Geometry="M10,0 L10,10 20,10 20,0 Z" />
                    <GeometryDrawing Brush="Transparent" Geometry="M0,10 L0,20 10,20 10,10 Z" />
                    <GeometryDrawing Brush="Gray" Geometry="M10,10 L10,20 20,20 20,10 Z" />
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid x:Name="ImageViewHost" Grid.Column="0" Background="{StaticResource TransparentGridBrush}">
            <local:ConoscopeImageHost x:Name="ImageView" />
            <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" Padding="3" Background="#F2F4F4F4" BorderBrush="#CCB8B8B8" BorderThickness="1" CornerRadius="6">
                <ToolBar ToolBarTray.IsLocked="True" Background="Transparent" BorderThickness="0" Padding="0">
                    <ToggleButton x:Name="tglPanMode" Style="{StaticResource OverlayToolToggleStyle}" Content="{x:Static properties:Resources.TbPan}" ToolTip="{x:Static properties:Resources.TbPanTip}" IsChecked="True" Checked="tglPanMode_Checked" Unchecked="tglPanMode_Unchecked" />
                    <ToggleButton x:Name="tglReferenceInteraction" Style="{StaticResource OverlayToolToggleStyle}" Content="{x:Static properties:Resources.TbRefDrag}" ToolTip="{x:Static properties:Resources.TbRefDragTip}" IsChecked="True" Checked="tglReferenceInteraction_Checked" Unchecked="tglReferenceInteraction_Unchecked" />
                    <Separator/>
                    <Button Style="{StaticResource OverlayToolButtonStyle}" Content="-" FontSize="16" FontWeight="Bold" ToolTip="{x:Static properties:Resources.TbZoomOut}" Click="ToolbarZoomOut_Click" />
                    <Button Style="{StaticResource OverlayToolButtonStyle}" Content="+" FontSize="16" FontWeight="Bold" ToolTip="{x:Static properties:Resources.TbZoomIn}" Click="ToolbarZoomIn_Click" />
                    <Button Style="{StaticResource OverlayToolButtonStyle}" Content="1:1" ToolTip="{x:Static properties:Resources.TbOriginalSize}" Click="ToolbarZoomNone_Click" />
                    <Button Style="{StaticResource OverlayToolButtonStyle}" Content="{x:Static properties:Resources.TbFit}" ToolTip="{x:Static properties:Resources.TbFitTip}" Click="ToolbarZoomUniform_Click" />
                    <Button Style="{StaticResource OverlayToolButtonStyle}" Content="圆适" ToolTip="按有效圆区适应" Click="ToolbarZoomCircleFit_Click" />
                    <Button Style="{StaticResource OverlayToolButtonStyle}" Content="{x:Static properties:Resources.TbFill}" ToolTip="{x:Static properties:Resources.TbFillTip}" Click="ToolbarZoomUniformToFill_Click" />
                    <TextBox x:Name="txtToolbarZoomRatio" Width="54" Margin="4,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Text="1.00" ToolTip="{x:Static properties:Resources.TbZoomRatioTip}" PreviewKeyDown="txtToolbarZoomRatio_PreviewKeyDown" LostFocus="txtToolbarZoomRatio_LostFocus" />
                    <Button Style="{StaticResource OverlayToolButtonStyle}" Content="{x:Static properties:Resources.TbFullscreen}" ToolTip="{x:Static properties:Resources.TbFullscreenTip}" Click="ToolbarFullScreen_Click" />
                    <Separator/>
                    <Button Style="{StaticResource OverlayToolButtonStyle}" Content="3D" ToolTip="{x:Static properties:Resources.TipOpen3DView}" Click="ToolbarOpen3D_Click" />
                    <Button Style="{StaticResource OverlayToolButtonStyle}" Content="CIE" ToolTip="{x:Static properties:Resources.TipOpenCieDiagram}" Click="ToolbarOpenCie_Click" />
                </ToolBar>
            </Border>
            <Border x:Name="PseudoColorLegendPanel" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Padding="8" Background="#DD1E1E1E" BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="6" Visibility="Collapsed" IsHitTestVisible="False">
                <StackPanel>
                    <TextBlock x:Name="tbPseudoColorLegendTitle" Foreground="White" FontWeight="SemiBold" Text="Y" HorizontalAlignment="Center" />
                    <TextBlock x:Name="tbPseudoColorLegendMax" Margin="0,6,0,4" Foreground="White" FontSize="11" HorizontalAlignment="Center" Text="0" />
                    <Border Width="18" Height="124" BorderBrush="#55FFFFFF" BorderThickness="1">
                        <Image x:Name="imgPseudoColorLegend" Stretch="Fill" />
                    </Border>
                    <TextBlock x:Name="tbPseudoColorLegendMin" Margin="0,4,0,0" Foreground="White" FontSize="11" HorizontalAlignment="Center" Text="0" />
                </StackPanel>
            </Border>
            <Border x:Name="CoordinateDragOverlay" HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Collapsed" IsHitTestVisible="False" Background="#CC202020" BorderBrush="#FFFFD400" BorderThickness="1" CornerRadius="4" Padding="8,4">
                <TextBlock x:Name="CoordinateDragOverlayText" Foreground="White" FontWeight="SemiBold" />
            </Border>
            <Border HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8" Padding="3" Background="#F2F4F4F4" BorderBrush="#CCB8B8B8" BorderThickness="1" CornerRadius="6">
                <ToolBar ToolBarTray.IsLocked="True" Background="Transparent" BorderThickness="0" Padding="0">
                    <ToggleButton x:Name="tglFocusCircleMode" Style="{StaticResource OverlayToolToggleStyle}" Content="{x:Static properties:Resources.TbEditFocusPoint}" ToolTip="{x:Static properties:Resources.TbEditFocusPointTip}" Checked="tglFocusCircleMode_Checked" Unchecked="tglFocusCircleMode_Unchecked" />
                    <ToggleButton x:Name="tglFocusCircleDrawTool" Style="{StaticResource OverlayToolToggleStyle}" Content="{x:Static properties:Resources.TbCircle}" ToolTip="{x:Static properties:Resources.TbCircleTip}" IsChecked="True" Checked="tglFocusCircleDrawTool_Checked" Unchecked="tglFocusCircleDrawTool_Unchecked" />
                    <ToggleButton x:Name="tglFocusCircleSelectTool" Style="{StaticResource OverlayToolToggleStyle}" Content="{x:Static properties:Resources.TbEdit}" ToolTip="{x:Static properties:Resources.TbEditTip}" Checked="tglFocusCircleSelectTool_Checked" Unchecked="tglFocusCircleSelectTool_Unchecked" />
                    <ToggleButton x:Name="tglFocusCircleEraseTool" Style="{StaticResource OverlayToolToggleStyle}" Content="{x:Static properties:Resources.TbEraser}" ToolTip="{x:Static properties:Resources.TbEraserTip}" Checked="tglFocusCircleEraseTool_Checked" Unchecked="tglFocusCircleEraseTool_Unchecked" />
                    <Separator/>
                    <Button x:Name="btnCalculateFocusCircles" Style="{StaticResource OverlayToolButtonStyle}" Content="{x:Static properties:Resources.TbCalc}" ToolTip="{x:Static properties:Resources.TbCalcTip}" Click="btnCalculateFocusCircles_Click" />
                    <Button x:Name="btnClearFocusCircles" Style="{StaticResource OverlayToolButtonStyle}" Content="{x:Static properties:Resources.TbClearAll}" ToolTip="{x:Static properties:Resources.TbClearAllTip}" Click="btnClearFocusCircles_Click" />
                    <Separator/>
                    <TextBlock x:Name="tbSelectedFocusPointInfo" Width="280" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Visibility="Collapsed" Foreground="{DynamicResource GlobalTextBrush}" ToolTip="当前选中关注点" />
                    <Separator x:Name="sepSelectedFocusPointInfo" Visibility="Collapsed"/>
                    <ComboBox x:Name="cbFocusPoiTemplate" Width="118" Height="28" DisplayMemberPath="Key" SelectedValuePath="Value" ToolTip="关注点 POI 模板" SelectionChanged="cbFocusPoiTemplate_SelectionChanged"/>
                    <Button x:Name="btnSaveFocusPoiTemplate" Style="{StaticResource OverlayToolButtonStyle}" Content="存" ToolTip="保存当前关注点到 POI 模板" Click="btnSaveFocusPoiTemplate_Click" />
                    <Button x:Name="btnManageFocusPoiTemplate" Style="{StaticResource OverlayToolButtonStyle}" Content="POI" ToolTip="管理 POI 模板" Click="btnManageFocusPoiTemplate_Click" />
                </ToolBar>
            </Border>
        </Grid>

        <GridSplitter Grid.Column="1" Width="2" HorizontalAlignment="Stretch" Background="{DynamicResource BorderBrush}"/>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          MaxHeight="220"
                          MinHeight="112"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False">
                <StackPanel Margin="5">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="132"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="132"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="68"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="通道" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,6,0"/>
                        <ComboBox x:Name="cbDisplayChannel" Grid.Column="1" MinWidth="120" SelectedIndex="1" SelectionChanged="DisplayChannel_SelectionChanged" Margin="0,0,12,0">
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelX}" Tag="X"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelY}" Tag="Y"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelZ}" Tag="Z"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieX}" Tag="CieX"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieY}" Tag="CieY"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieU}" Tag="CieU"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieV}" Tag="CieV"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelDeltaUV}" Tag="ColorDifference"/>
                            <ComboBoxItem Content="对比度" Tag="Contrast"/>
                        </ComboBox>

                        <TextBlock Grid.Column="2" Text="参考模式" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,6,0"/>
                        <ComboBox x:Name="cbQuickReferenceMode" Grid.Column="3" MinWidth="120" SelectionChanged="QuickReferenceMode_SelectionChanged" Margin="0,0,12,0">
                            <ComboBoxItem Content="{x:Static properties:Resources.RefAzimuthLine}" Tag="AzimuthLine"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.RefPolarCircle}" Tag="PolarCircle"/>
                        </ComboBox>

                        <Grid x:Name="rowReferenceAngle" Grid.Column="5" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="68"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="sliderQuickReferenceAngle" Minimum="0" Maximum="180" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="QuickReferenceAngle_ValueChanged"/>
                            <TextBox x:Name="txtQuickReferenceAngle" Grid.Column="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" PreviewKeyDown="QuickReferenceTextBox_PreviewKeyDown" LostFocus="txtQuickReferenceAngle_LostFocus"/>
                        </Grid>

                        <Grid x:Name="rowReferenceRadius" Grid.Column="5" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="68"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="sliderQuickReferenceRadius" Minimum="0" Maximum="80" TickFrequency="1" IsSnapToTickEnabled="False" ValueChanged="QuickReferenceRadius_ValueChanged"/>
                            <TextBox x:Name="txtQuickReferenceRadius" Grid.Column="2" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" PreviewKeyDown="QuickReferenceTextBox_PreviewKeyDown" LostFocus="txtQuickReferenceRadius_LostFocus"/>
                        </Grid>
                    </Grid>

                    <WrapPanel Margin="0,0,0,8">
                        <Button x:Name="btnApplyFilter" Content="预设" Click="btnApplyFilter_Click" Style="{StaticResource PanelSurfacePrimaryButtonStyle}" Margin="0,0,12,0"/>
                        <CheckBox x:Name="chkViewUsePseudoColor" Content="彩色显示" Style="{StaticResource PanelInlineCheckBoxStyle}" Checked="ViewDisplayQuick_Changed" Unchecked="ViewDisplayQuick_Changed"/>
                        <TextBlock Text="色带" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,6,0"/>
                        <ComboBox x:Name="cbViewPseudoColorMap" Width="130" Margin="0,0,12,0" SelectionChanged="cbViewPseudoColorMap_SelectionChanged"/>
                        <CheckBox x:Name="chkViewDustRemoval" Content="灰尘" Style="{StaticResource PanelInlineCheckBoxStyle}" Checked="ViewPreprocessQuick_Changed" Unchecked="ViewPreprocessQuick_Changed"/>
                        <CheckBox x:Name="chkViewEnableFilter" Content="启用滤波" Style="{StaticResource PanelInlineCheckBoxStyle}" Checked="chkViewEnableFilter_Changed" Unchecked="chkViewEnableFilter_Changed"/>
                        <ComboBox x:Name="cbViewFilterType" Width="122" Margin="0,0,12,0" SelectedValuePath="Tag" SelectionChanged="cbViewFilterType_SelectionChanged">
                            <ComboBoxItem Content="{x:Static properties:Resources.LowPassFilter}" Tag="{x:Static Conoscope:ImageFilterType.LowPass}"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.MovingAverage}" Tag="{x:Static Conoscope:ImageFilterType.MovingAverage}"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.GaussianFilter}" Tag="{x:Static Conoscope:ImageFilterType.Gaussian}"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.MedianFilter}" Tag="{x:Static Conoscope:ImageFilterType.Median}"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.BilateralFilter}" Tag="{x:Static Conoscope:ImageFilterType.Bilateral}"/>
                        </ComboBox>
                        <TextBlock Text="滤波属性" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,6,0"/>
                        <Border Padding="8,4" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource GlobalBorderBrush}">
                            <TextBlock x:Name="tbViewFilterSummary" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                        </Border>
                    </WrapPanel>

                    <WrapPanel Margin="0,0,0,6">
                        <TextBlock Text="导出" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,6,0"/>
                        <ComboBox x:Name="cbExportChannel" MinWidth="120" SelectedIndex="1" Margin="0,0,14,0" SelectionChanged="ExportChannel_SelectionChanged">
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelXShort}" Tag="X"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelYShort}" Tag="Y"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelZShort}" Tag="Z"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieXShort}" Tag="CieX"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieYShort}" Tag="CieY"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieUShort}" Tag="CieU"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieVShort}" Tag="CieV"/>
                            <ComboBoxItem Content="{x:Static properties:Resources.ChannelDeltaUVShort}" Tag="ColorDifference"/>
                            <ComboBoxItem Content="对比度" Tag="Contrast"/>
                        </ComboBox>
                        <Button Content="{x:Static properties:Resources.BtnAzimuthExport}" Click="btnExportAngleMode_Click" Style="{StaticResource PanelSurfaceButtonStyle}" Padding="10,4" Margin="0,0,6,0"/>
                        <Button Content="{x:Static properties:Resources.BtnPolarExport}" Click="btnExportCircleMode_Click" Style="{StaticResource PanelSurfaceButtonStyle}" Padding="10,4" Margin="0,0,6,0"/>
                        <Button Content="高级导出" Click="btnAdvancedExport_Click" Style="{StaticResource PanelSurfaceButtonStyle}" Padding="10,4" ToolTip="{x:Static properties:Resources.TipAdvancedExport}"/>
                    </WrapPanel>

                    <StackPanel Visibility="Collapsed">
                        <Border x:Name="gbColorDifference" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="8,6" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="{x:Static properties:Resources.LabelColorDiffCalc}" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,4,0,4">
                                    <TextBlock Text="{x:Static properties:Resources.LabelBaseRef}" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                    <ComboBox x:Name="cbColorDifferenceReference" MinWidth="170" SelectionChanged="ColorDifferenceReference_SelectionChanged">
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiD65}" Tag="D65"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiD50}" Tag="D50"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiA}" Tag="A"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiD75}" Tag="D75"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiCenter50px}" Tag="ImageCenter"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiCustomCoord}" Tag="Custom"/>
                                        <ComboBoxItem Content="{x:Static properties:Resources.CbiMeasuredBase}" Tag="ReferenceImage"/>
                                    </ComboBox>
                                    <Button x:Name="btnSaveColorDifferenceReference" Content="{x:Static properties:Resources.BtnSaveBaseImage}" Click="btnSaveColorDifferenceReference_Click" Padding="10,3" Margin="10,0,6,0"/>
                                    <Button Content="{x:Static properties:Resources.BtnComputeColorDiff}" Click="btnCalculateColorDifference_Click" Padding="10,3"/>
                                </WrapPanel>
                                <WrapPanel x:Name="panelColorDifferenceCustomUv" Margin="0,2,0,4">
                                    <TextBlock Text="u:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                    <TextBox x:Name="txtColorDifferenceCustomU" Width="72" Text="0.1978" LostFocus="ColorDifferenceCustom_LostFocus"/>
                                    <TextBlock Text="v:" VerticalAlignment="Center" Margin="12,0,5,0"/>
                                    <TextBox x:Name="txtColorDifferenceCustomV" Width="72" Text="0.4684" LostFocus="ColorDifferenceCustom_LostFocus"/>
                                </WrapPanel>
                                <TextBlock x:Name="tbColorDifferenceReferenceStatus" Margin="5,0,5,2" Foreground="Gray" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="8,6" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="对比度计算" Style="{StaticResource PanelHeaderTextStyle}" Margin="0,0,0,6"/>
                                <WrapPanel Margin="0,4,0,4">
                                    <TextBlock Text="当前图像:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                                    <ComboBox x:Name="cbContrastReferenceKind" MinWidth="100" SelectionChanged="ContrastReferenceKind_SelectionChanged">
                                        <ComboBoxItem Content="暗图" Tag="Black"/>
                                        <ComboBoxItem Content="亮图" Tag="White"/>
                                    </ComboBox>
                                    <Button Content="计算对比度" Click="btnCalculateContrast_Click" Padding="10,3" Margin="10,0,0,0"/>
                                </WrapPanel>
                                <TextBlock x:Name="tbContrastReferenceStatus" Margin="5,0,5,2" Foreground="Gray" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Grid x:Name="GridSetting" Margin="0,0,0,10" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Margin="0,6,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,5">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="{x:Static properties:Resources.LabelRefCurve}" Style="{StaticResource PanelHeaderTextStyle}"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock Text="{x:Static properties:Resources.LabelMode}" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,5,0"/>
                                <TextBlock x:Name="tbReferenceMode" MinWidth="72" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{x:Static properties:Resources.LabelCurrentValue}" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,5,0"/>
                                <TextBlock x:Name="tbReferenceValue" MinWidth="78" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{x:Static properties:Resources.LabelGraph}" Style="{StaticResource PanelMutedTextStyle}" Margin="0,0,5,0"/>
                                <ToggleButton x:Name="tglReferencePolarMode" Content="{x:Static properties:Resources.BtnPolarCoord}" Style="{StaticResource PanelSurfaceToggleStyle}" Checked="tglReferencePolarMode_Checked" Unchecked="tglReferencePolarMode_Unchecked" Margin="0,0,12,0"/>
                                <Button Content="{x:Static properties:Resources.BtnExportCurrent}" Click="btnExportCurrentReference_Click" Style="{StaticResource PanelSurfaceButtonStyle}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <ScottPlot:WpfPlot x:Name="wpfPlotReference" Margin="5" />
                        <local:ConoscopePolarPlot x:Name="polarPlotReference" Margin="5" Visibility="Collapsed" IsHitTestVisible="False"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
