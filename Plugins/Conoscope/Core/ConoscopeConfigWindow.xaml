<Window x:Class="Conoscope.Core.ConoscopeConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.TitleConoscopeSettings}" Height="640" Width="720"
        MinHeight="520" MinWidth="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource GlobalBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Static properties:Resources.LabelCurrentModel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="cbCurrentModel" Grid.Column="1" MinHeight="28" SelectionChanged="cbCurrentModel_SelectionChanged"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Header="{x:Static properties:Resources.GroupBoxGlobalSettings}" Grid.Row="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ContentControl x:Name="GlobalSettingsHost" Margin="8"/>
                    </ScrollViewer>
                </GroupBox>

                <GroupBox Header="{x:Static properties:Resources.GroupBoxPreprocessSettings}" Grid.Row="2">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ContentControl x:Name="PreprocessSettingsHost" Margin="8"/>
                    </ScrollViewer>
                </GroupBox>
            </Grid>

            <GroupBox Header="{x:Static properties:Resources.GroupBoxModelParams}" Grid.Column="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ContentControl x:Name="ModelProfileHost" Margin="8"/>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="{x:Static properties:Resources.BtnClose}" Width="88" Height="30" IsDefault="True" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>