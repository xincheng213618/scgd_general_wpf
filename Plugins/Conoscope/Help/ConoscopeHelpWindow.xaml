<Window x:Class="Conoscope.Help.ConoscopeHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        mc:Ignorable="d"
        Title="{x:Static properties:Resources.TitleHelpCenter}"
        Height="760"
        Width="1180"
        MinHeight="560"
        MinWidth="920"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}"
        Foreground="{DynamicResource GlobalTextBrush}">
    <Window.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush1}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.68" />
        </Style>

        <Style x:Key="SearchTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="FilterButtonStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,12">
            <TextBlock x:Name="tbTitle"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="{x:Static properties:Resources.HelpDescription}"
                       Style="{StaticResource MutedTextStyle}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="240" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="380" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="14">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Margin="0,0,0,8"
                            CornerRadius="6"
                            Background="{DynamicResource GlobalBackground}"
                            BorderBrush="{DynamicResource GlobalBorderBrush1}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SearchBox"
                                     Grid.Column="0"
                                     Style="{StaticResource SearchTextBoxStyle}"
                                     TextChanged="SearchBox_TextChanged"
                                     ToolTip="{x:Static properties:Resources.TipSearchHelp}" />
                            <Button Grid.Column="1"
                                    Width="28"
                                    Height="28"
                                    Margin="6,0,6,0"
                                    Click="ClearSearch_Click"
                                    Content="✕"
                                    ToolTip="{x:Static properties:Resources.TipClearSearch}"
                                    Foreground="{DynamicResource GlobalTextBrush}"
                                    Background="{DynamicResource ButtonBackground}"
                                    BorderBrush="{DynamicResource ButtonBorderBrush}" />
                        </Grid>
                    </Border>

                    <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <RadioButton x:Name="FilterAll" Content="{x:Static properties:Resources.RbAll}" Style="{StaticResource FilterButtonStyle}" IsChecked="True" Checked="Filter_Changed" />
                        <RadioButton x:Name="FilterQuickStart" Content="{x:Static properties:Resources.RbQuickStart}" Style="{StaticResource FilterButtonStyle}" Checked="Filter_Changed" />
                        <RadioButton x:Name="FilterWorkflow" Content="{x:Static properties:Resources.RbUsagePaths}" Style="{StaticResource FilterButtonStyle}" Checked="Filter_Changed" />
                        <RadioButton x:Name="FilterPrinciple" Content="{x:Static properties:Resources.RbAlgorithmPrinciples}" Style="{StaticResource FilterButtonStyle}" Checked="Filter_Changed" />
                        <RadioButton x:Name="FilterTerminology" Content="{x:Static properties:Resources.RbGlossary}" Style="{StaticResource FilterButtonStyle}" Checked="Filter_Changed" />
                    </WrapPanel>

                    <TextBlock x:Name="ItemCountText"
                               DockPanel.Dock="Bottom"
                               Margin="0,8,0,0"
                               FontSize="11"
                               Style="{StaticResource MutedTextStyle}" />

                    <ListBox x:Name="HelpList"
                             SelectionChanged="HelpList_SelectionChanged"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource GlobalTextBrush}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" Padding="8,8,6,8" Background="Transparent">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CategoryDisplay}"
                                                   FontSize="10"
                                                   Margin="0,0,0,2"
                                                   Style="{StaticResource MutedTextStyle}" />
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Summary}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource GlobalBorderBrush1}" />

            <Border Grid.Column="2" Margin="8,0,0,0" Style="{StaticResource PanelBorderStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,10">
                        <TextBlock x:Name="DetailCategory"
                                   FontSize="12"
                                   Margin="0,0,0,4"
                                   Style="{StaticResource MutedTextStyle}" />
                        <TextBlock x:Name="DetailTitle"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6" />
                        <TextBlock x:Name="DetailSummary"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <TextBlock x:Name="PlaceholderText"
                                   Text="{x:Static properties:Resources.PlaceholderSelectTopic}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Visibility="Visible"
                                   Style="{StaticResource MutedTextStyle}" />

                        <Border x:Name="DetailDocumentHost"
                                Visibility="Collapsed"
                                CornerRadius="6"
                                Background="{DynamicResource GlobalBackground}"
                                BorderBrush="{DynamicResource GlobalBorderBrush1}"
                                BorderThickness="1">
                            <RichTextBox x:Name="DetailDocumentBox"
                                         IsReadOnly="True"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource GlobalTextBrush}"
                                         IsDocumentEnabled="False"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         Padding="16" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="tbFooterHint"
                       VerticalAlignment="Center"
                       Style="{StaticResource MutedTextStyle}"
                       Text="{x:Static properties:Resources.HintHelpNativeView}" />
            <Button DockPanel.Dock="Right"
                    Width="88"
                    Margin="12,0,0,0"
                    Click="btnClose_Click"
                    Content="{x:Static properties:Resources.BtnClose}"
                    Background="{DynamicResource ButtonBackground}"
                    BorderBrush="{DynamicResource ButtonBorderBrush}"
                    Foreground="{DynamicResource GlobalTextBrush}" />
        </DockPanel>
    </Grid>
</Window>