<Window x:Class="Conoscope.ConoscopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        Title="Conoscope"
        Height="800"
        Width="1520"
        MinHeight="640"
        MinWidth="1080"
        Background="{DynamicResource GlobalBackground}">
    <Window.Resources>
        <DataTemplate x:Key="DocumentHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="QuickButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonGroupStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="92" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="8,6,8,4" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>

        <Style x:Key="RibbonGroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style x:Key="RibbonFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>

        <Style x:Key="RibbonButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="25" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonLargeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="76" />
            <Setter Property="Height" Value="66" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        </Style>

        <Style x:Key="RibbonPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource RibbonLargeButtonStyle}">
            <Setter Property="Width" Value="86" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RibbonSmallButtonStyle" TargetType="Button" BasedOn="{StaticResource RibbonButtonStyle}">
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="Padding" Value="6,2" />
        </Style>

        <Style x:Key="RibbonIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
        </Style>

        <Style x:Key="RibbonComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="25" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="25" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="9,3" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource GlobalBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="10,6,10,4" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Border Style="{StaticResource StatusPillStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,6,0" Text="{x:Static properties:Resources.CurrentModel}" />
                                <TextBlock x:Name="tbCurrentModel" Text="VA60" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatusPillStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Margin="0,0,6,0" Text="{x:Static properties:Resources.ObservationCameraStatus}" />
                                <TextBlock x:Name="tbObservationCameraStatus" Text="{x:Static properties:Resources.NotOpened}" Foreground="Gray" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,14,0" FontSize="16" FontWeight="SemiBold" Text="Conoscope" />
                        <Button Click="OpenFile_Click" Content="打开" Style="{StaticResource QuickButtonStyle}" />
                        <Button Click="btnNewView_Click" Content="新建视图" Style="{StaticResource QuickButtonStyle}" />
                        <Button Click="btnSaveWindowConfig_Click" Content="保存配置" Style="{StaticResource QuickButtonStyle}" />
                    </StackPanel>
                </DockPanel>

                <TabControl Grid.Row="1"
                            MinHeight="116"
                            Margin="6,0,6,6"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                    <TabItem Header="主页">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4,6,4,4" Orientation="Horizontal">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Click="OpenFile_Click" Style="{StaticResource RibbonPrimaryButtonStyle}" ToolTip="打开一个或多个 Conoscope 图像">
                                                <StackPanel>
                                                    <TextBlock Text="&#xE8E5;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="打开" TextAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Click="btnNewView_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="创建一个空白 Conoscope 视图">
                                                <StackPanel>
                                                    <TextBlock Text="&#xE710;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="新建" TextAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="数据" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Width="190" Margin="0,0,8,0">
                                                <TextBlock Text="流程模板" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                <StackPanel Orientation="Horizontal">
                                                    <ComboBox x:Name="cbFlowTemplate" Width="140" DisplayMemberPath="Key" SelectionChanged="cbFlowTemplate_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                                    <Button x:Name="btnEditFlowTemplates" Content="管理" Click="btnEditFlowTemplates_Click" ToolTip="打开流程模板管理" Style="{StaticResource RibbonSmallButtonStyle}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <Button x:Name="btnRunFlow" Click="btnRunFlow_Click" Style="{StaticResource RibbonPrimaryButtonStyle}" ToolTip="执行当前流程并打开结果图像">
                                                <StackPanel>
                                                    <TextBlock Text="&#xE768;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="执行" TextAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="流程" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Width="116" Margin="0,0,8,0">
                                                <TextBlock Text="型号" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                <ComboBox x:Name="cbModelType" SelectionChanged="cbModelType_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                            </StackPanel>
                                            <Button x:Name="btnOpenObservationCamera" Click="btnOpenObservationCamera_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="打开观察相机窗口">
                                                <StackPanel>
                                                    <TextBlock Text="&#xE722;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="观察" TextAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="模型" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="采集">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4,6,4,4" Orientation="Horizontal">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel Width="302" Margin="0,0,8,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="相机" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                    <TextBlock Grid.Column="1" Text="校正" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                </Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <ComboBox x:Name="cbCameraDevice" Width="144" DisplayMemberPath="Config.Name" SelectionChanged="cbCameraDevice_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                                    <ComboBox x:Name="cbCalibrationTemplate" Width="112" DisplayMemberPath="Key" SelectionChanged="cbCalibrationTemplate_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                                    <Button x:Name="btnEditCalibrationTemplates" Content="管理" Click="btnEditCalibrationTemplates_Click" ToolTip="打开当前相机的校正模板管理" Style="{StaticResource RibbonSmallButtonStyle}" />
                                                </StackPanel>
                                                <Button x:Name="btnRefreshCameraDevices" Content="刷新相机列表" Click="btnRefreshCameraDevices_Click" Style="{StaticResource RibbonButtonStyle}" />
                                            </StackPanel>
                                            <Button x:Name="btnCaptureCamera" Click="btnCaptureCamera_Click" Style="{StaticResource RibbonPrimaryButtonStyle}" ToolTip="使用当前相机与校正模板拍照">
                                                <StackPanel>
                                                    <TextBlock Text="&#xE722;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="拍照" TextAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="测量相机" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Width="214">
                                            <TextBlock Text="ND 端口" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBox x:Name="txtNDPort" Width="48" Style="{StaticResource RibbonTextBoxStyle}" />
                                                <Button x:Name="btnSetNDPort" Content="切换" Click="btnSetNDPort_Click" Style="{StaticResource RibbonButtonStyle}" />
                                                <Button x:Name="btnGetNDPort" Content="读取" Click="btnGetNDPort_Click" Style="{StaticResource RibbonButtonStyle}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="btnBindNdCalibration" Content="绑定校正" Click="btnBindNdCalibration_Click" ToolTip="将当前 ND 端口绑定到当前校正模板" Style="{StaticResource RibbonButtonStyle}" />
                                                <Button x:Name="btnClearNdCalibrationBinding" Content="解绑" Click="btnClearNdCalibrationBinding_Click" Style="{StaticResource RibbonSmallButtonStyle}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="ND / 校正" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="分析">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4,6,4,4" Orientation="Horizontal">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="方位导出" Click="btnExportAngleMode_Click" Style="{StaticResource RibbonButtonStyle}" />
                                            <Button Content="极角导出" Click="btnExportCircleMode_Click" Style="{StaticResource RibbonButtonStyle}" />
                                            <Button Content="高级导出" Click="btnAdvancedExport_Click" Style="{StaticResource RibbonButtonStyle}" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="导出" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="btnOpenContrastTest" Click="btnOpenContrastTest_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="打开黑白对比度测试">
                                                <StackPanel>
                                                    <TextBlock Text="&#xE9D2;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="黑白" TextAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="btnOpenColorGamut" Click="btnOpenColorGamut_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="打开 RGB 色域计算">
                                                <StackPanel>
                                                    <TextBlock Text="&#xE790;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="色域" TextAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="分析" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="窗口">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel Margin="4,6,4,4" Orientation="Horizontal">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Click="btnSaveWindowConfig_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="保存窗口配置">
                                                <StackPanel>
                                                    <TextBlock Text="&#xE74E;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="保存" TextAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Command="{Binding EditConoscopeConfigCommand}" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="打开 Conoscope 设置">
                                                <Button.Triggers>
                                                    <EventTrigger RoutedEvent="Button.Click">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="rotateTransformWindowSettings" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Button.Triggers>
                                                <StackPanel>
                                                    <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}">
                                                        <TextBlock.RenderTransform>
                                                            <RotateTransform x:Name="rotateTransformWindowSettings" CenterX="10" CenterY="10" />
                                                        </TextBlock.RenderTransform>
                                                    </TextBlock>
                                                    <TextBlock Text="设置" TextAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="配置" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <xcad:DockingManager x:Name="DockingManager"
                             Grid.Row="1"
                             Margin="-6,-6"
                             Padding="0"
                             Background="Transparent"
                             BorderThickness="0"
                             DocumentHeaderTemplate="{StaticResource DocumentHeaderTemplate}">
            <xcad:LayoutRoot>
                <xcad:LayoutPanel Orientation="Horizontal">
                    <xcad:LayoutDocumentPane x:Name="ViewDocumentPane" />
                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>

        <StatusBar Grid.Row="2" Height="26" Background="{DynamicResource GlobalBackground}">
            <StatusBarItem>
                <TextBlock Text="状态" Margin="0,0,6,0" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="tbOperationStatus" Text="就绪" Foreground="Gray" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
