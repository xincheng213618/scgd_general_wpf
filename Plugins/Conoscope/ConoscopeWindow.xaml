<Window x:Class="Conoscope.ConoscopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:core="clr-namespace:Conoscope.Core"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
    Title="{x:Static properties:Resources.WindowTitleConoscope}"
        Height="760"
        Width="1520"
        MinHeight="640"
        MinWidth="1080"
        Background="{DynamicResource GlobalBackground}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Presentation/Ribbon/ConoscopeRibbonResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource GlobalBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                WindowChrome.IsHitTestVisibleInChrome="True">
                <TabControl Height="{StaticResource RibbonHostHeight}"
                            MinHeight="{StaticResource RibbonHostHeight}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                    <TabItem Header="{x:Static properties:Resources.TabHome}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Click="OpenFile_Click" Style="{StaticResource RibbonPrimaryButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpenFile}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE8E5;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.GroupOpen}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupData}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <ComboBox x:Name="cbModelType" Width="132" SelectionChanged="cbModelType_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                            <Button x:Name="btnOpenObservationCamera" Click="btnOpenObservationCamera_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpenObservationCamera}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE890;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnObservationCamera}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupModel}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <StackPanel x:Name="bdActiveViewControls" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Border Style="{StaticResource RibbonGroupStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <WrapPanel>
                                                <ComboBox x:Name="cbActiveDisplayChannel" Width="112" SelectionChanged="cbActiveDisplayChannel_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}">
                                                    <ComboBoxItem Content="{x:Static properties:Resources.ChannelX}" Tag="X"/>
                                                    <ComboBoxItem Content="{x:Static properties:Resources.ChannelY}" Tag="Y"/>
                                                    <ComboBoxItem Content="{x:Static properties:Resources.ChannelZ}" Tag="Z"/>
                                                    <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieX}" Tag="CieX"/>
                                                    <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieY}" Tag="CieY"/>
                                                    <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieU}" Tag="CieU"/>
                                                    <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieV}" Tag="CieV"/>
                                                    <ComboBoxItem Content="{x:Static properties:Resources.ChannelDeltaUV}" Tag="ColorDifference"/>
                                                    <ComboBoxItem Content="{x:Static properties:Resources.ChannelContrast}" Tag="Contrast"/>
                                                </ComboBox>
                                                <TextBlock Text="{x:Static properties:Resources.LabelReference}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                <RadioButton x:Name="rbActiveReferenceLine" GroupName="ActiveReferenceMode" Checked="rbActiveReferenceLine_Checked" Style="{StaticResource ReferenceModeRadioStyle}" ToolTip="{x:Static properties:Resources.RefAzimuthLine}">
                                                    <Viewbox Width="12" Height="12">
                                                        <Canvas Width="16" Height="16">
                                                            <Line X1="2" Y1="8" X2="14" Y2="8"
                                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                                  StrokeThickness="2"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round" />
                                                        </Canvas>
                                                    </Viewbox>
                                                </RadioButton>
                                                <RadioButton x:Name="rbActiveReferenceCircle" GroupName="ActiveReferenceMode" Checked="rbActiveReferenceCircle_Checked" Style="{StaticResource ReferenceModeRadioStyle}" ToolTip="{x:Static properties:Resources.RefPolarCircle}">
                                                    <Viewbox Width="12" Height="12">
                                                        <Canvas Width="16" Height="16">
                                                            <Ellipse Width="12" Height="12"
                                                                     Canvas.Left="2"
                                                                     Canvas.Top="2"
                                                                     Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                                     StrokeThickness="2" />
                                                        </Canvas>
                                                    </Viewbox>
                                                </RadioButton>
                                                <TextBox x:Name="txtActiveReferenceValue"
                                                         Width="68"
                                                         Style="{StaticResource RibbonTextBoxStyle}"
                                                         PreviewKeyDown="txtActiveReferenceValue_PreviewKeyDown"
                                                         LostFocus="txtActiveReferenceValue_LostFocus" />
                                            </WrapPanel>
                                            <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupCurrentView}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="bdActiveViewExportControls" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Border Style="{StaticResource RibbonGroupStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <WrapPanel>
                                                <Button x:Name="btnActiveOpen3D" Content="3D" Click="btnActiveOpen3D_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpen3DView}" />
                                                <Button x:Name="btnActiveOpenCie" Content="CIE" Click="btnActiveOpenCie_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpenCieDiagram}" />
                                            </WrapPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupDescription}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource RibbonGroupStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <WrapPanel>
                                                <Button x:Name="btnActiveExportAngle" Content="{x:Static properties:Resources.BtnAzimuthExport}" Click="btnActiveExportAngle_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipExportAzimuthData}" />
                                                <Button x:Name="btnActiveExportCircle" Content="{x:Static properties:Resources.BtnPolarExport}" Click="btnActiveExportCircle_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipExportPolarData}" />
                                                <Button x:Name="btnActiveAdvancedExport" Content="{x:Static properties:Resources.TitleAdvancedExport}" Click="btnActiveAdvancedExport_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipAdvancedExport}" />
                                            </WrapPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupExport}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{x:Static properties:Resources.TabCapture}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <ComboBox x:Name="cbFlowTemplate" Width="176" DisplayMemberPath="Key" SelectionChanged="cbFlowTemplate_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                            <Button x:Name="btnEditFlowTemplates" Click="btnEditFlowTemplates_Click" ToolTip="{x:Static properties:Resources.TipOpenFlowTemplateMgmt}" Style="{StaticResource RibbonLargeButtonStyle}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="btnRunFlow" Click="btnRunFlow_Click" Style="{StaticResource RibbonExecuteButtonStyle}" ToolTip="{x:Static properties:Resources.TipExecuteFlow}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE768;" Style="{StaticResource RibbonExecuteButtonIconStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnExecute}" Style="{StaticResource RibbonExecuteButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                            <CheckBox x:Name="chkReuseActiveViewOnCapture"
                                                      Margin="8,0,0,0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="True"
                                                      Content="{x:Static properties:Resources.ChkReuseActiveView}"
                                                      ToolTip="{x:Static properties:Resources.TipReuseActiveView}" />
                                        </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupFlowCapture}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <ComboBox x:Name="cbCameraDevice"
                                                      Width="176"
                                                      DisplayMemberPath="Config.Name"
                                                      SelectionChanged="cbCameraDevice_SelectionChanged"
                                                      Style="{StaticResource RibbonComboBoxStyle}" />
                                            <ComboBox x:Name="cbCalibrationTemplate"
                                                      Width="140"
                                                      DisplayMemberPath="Key"
                                                      SelectionChanged="cbCalibrationTemplate_SelectionChanged"
                                                      Style="{StaticResource RibbonComboBoxStyle}" />
                                            <Button x:Name="btnEditCalibrationTemplates"
                                                    Click="btnEditCalibrationTemplates_Click"
                                                    ToolTip="{x:Static properties:Resources.TipOpenCalibrationMgmt}"
                                                    Style="{StaticResource RibbonLargeButtonStyle}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="btnRefreshCameraDevices"
                                                    Click="btnRefreshCameraDevices_Click"
                                                    ToolTip="{x:Static properties:Resources.TipRefreshCameraList}"
                                                    Style="{StaticResource RibbonButtonStyle}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE72C;" Style="{StaticResource RibbonIconTextStyle}" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="btnCaptureCamera"
                                                    Click="btnCaptureCamera_Click"
                                                    Style="{StaticResource RibbonPrimaryButtonStyle}"
                                                    ToolTip="{x:Static properties:Resources.TipCapturePhoto}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE722;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnCapturePhoto}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupMeasurementCamera}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{x:Static properties:Resources.TabPreprocess}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <WrapPanel>
                                            <CheckBox x:Name="chkWindowApplyFilterOnOpen"
                                                      Content="{x:Static properties:Resources.ChkEnablePreprocess}"
                                                      Checked="WindowPreprocess_Changed"
                                                      Unchecked="WindowPreprocess_Changed"
                                                      Margin="0,0,12,0"
                                                      VerticalAlignment="Center" />
                                            <Button x:Name="btnApplyPreprocessToActiveView"
                                                    Click="btnApplyPreprocessToActiveView_Click"
                                                    Style="{StaticResource RibbonPrimaryButtonStyle}"
                                                    ToolTip="{x:Static properties:Resources.TipApplyPreprocess}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE895;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnReapply}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupEnable}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox x:Name="chkWindowEnableFilter"
                                                      Content="{x:Static properties:Resources.ChkEnableFilter}"
                                                      Checked="chkWindowEnableFilter_Changed"
                                                      Unchecked="chkWindowEnableFilter_Changed"
                                                      VerticalAlignment="Center" />
                                            <WrapPanel x:Name="panelWindowFilterOptions">
                                                <ComboBox x:Name="cbWindowFilterType"
                                                          Width="132"
                                                          SelectedValuePath="Tag"
                                                          SelectionChanged="cbWindowFilterType_SelectionChanged"
                                                          Style="{StaticResource RibbonComboBoxStyle}">
                                                    <ComboBoxItem Content="{x:Static properties:Resources.LowPassFilter}" Tag="{x:Static core:ImageFilterType.LowPass}" />
                                                    <ComboBoxItem Content="{x:Static properties:Resources.MovingAverage}" Tag="{x:Static core:ImageFilterType.MovingAverage}" />
                                                    <ComboBoxItem Content="{x:Static properties:Resources.GaussianFilter}" Tag="{x:Static core:ImageFilterType.Gaussian}" />
                                                    <ComboBoxItem Content="{x:Static properties:Resources.MedianFilter}" Tag="{x:Static core:ImageFilterType.Median}" />
                                                    <ComboBoxItem Content="{x:Static properties:Resources.BilateralFilter}" Tag="{x:Static core:ImageFilterType.Bilateral}" />
                                                </ComboBox>

                                                <WrapPanel x:Name="fieldWindowFilterKernel">
                                                    <TextBox x:Name="txtWindowFilterKernelSize" Width="48" Style="{StaticResource RibbonTextBoxStyle}" PreviewKeyDown="WindowPreprocessValue_PreviewKeyDown" LostFocus="WindowPreprocessValue_LostFocus" />
                                                </WrapPanel>
                                                <WrapPanel x:Name="fieldWindowFilterSigma" Margin="0,0,8,0">
                                                    <TextBlock Text="σ" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                    <TextBox x:Name="txtWindowFilterSigma" Width="48" Style="{StaticResource RibbonTextBoxStyle}" PreviewKeyDown="WindowPreprocessValue_PreviewKeyDown" LostFocus="WindowPreprocessValue_LostFocus" />
                                                </WrapPanel>
                                                <WrapPanel x:Name="fieldWindowFilterD" Margin="0,0,8,0">
                                                    <TextBlock Text="d" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                    <TextBox x:Name="txtWindowFilterD" Width="42" Style="{StaticResource RibbonTextBoxStyle}" PreviewKeyDown="WindowPreprocessValue_PreviewKeyDown" LostFocus="WindowPreprocessValue_LostFocus" />
                                                </WrapPanel>
                                                <WrapPanel x:Name="fieldWindowFilterSigmaColor" Margin="0,0,8,0">
                                                    <TextBlock Text="σColor" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                    <TextBox x:Name="txtWindowFilterSigmaColor" Width="54" Style="{StaticResource RibbonTextBoxStyle}" PreviewKeyDown="WindowPreprocessValue_PreviewKeyDown" LostFocus="WindowPreprocessValue_LostFocus" />
                                                </WrapPanel>
                                                <WrapPanel x:Name="fieldWindowFilterSigmaSpace">
                                                    <TextBlock Text="σSpace" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                    <TextBox x:Name="txtWindowFilterSigmaSpace" Width="54" Style="{StaticResource RibbonTextBoxStyle}" PreviewKeyDown="WindowPreprocessValue_PreviewKeyDown" LostFocus="WindowPreprocessValue_LostFocus" />
                                                </WrapPanel>
                                            </WrapPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupFilter}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <WrapPanel VerticalAlignment="Center">
                                            <CheckBox x:Name="chkWindowUsePseudoColor"
                                                      Content="{x:Static properties:Resources.ChkPseudoColor}"
                                                      Checked="WindowDisplay_Changed"
                                                      Unchecked="WindowDisplay_Changed"
                                                      Margin="0,0,12,0"
                                                      VerticalAlignment="Center" />
                                            <CheckBox x:Name="chkWindowUsePseudoColorRangeLimit"
                                                      Content="{x:Static properties:Resources.ChkRangeLimit}"
                                                      Checked="WindowDisplay_Changed"
                                                      Unchecked="WindowDisplay_Changed"
                                                      Margin="0,0,12,0"
                                                      VerticalAlignment="Center"
                                                      ToolTip="{x:Static properties:Resources.TipRangeLimit}" />
                                            <StackPanel x:Name="panelWindowPseudoColorOptions"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <ComboBox x:Name="cbWindowPseudoColorMap"
                                                          Width="138"
                                                          SelectionChanged="cbWindowPseudoColorMap_SelectionChanged"
                                                          Style="{StaticResource RibbonComboBoxStyle}" />
                                            </StackPanel>
                                        </WrapPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupDisplay}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox x:Name="chkWindowDustRemovalEnabled"
                                                      Content="{x:Static properties:Resources.ChkEnableDustRemoval}"
                                                      Checked="WindowDustRemoval_Changed"
                                                      Unchecked="WindowDustRemoval_Changed"
                                                      VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.DustLabel}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="btnOpenPreprocessSettings"
                                                    Click="btnOpenPreprocessSettings_Click"
                                                    Style="{StaticResource RibbonLargeButtonStyle}"
                                                    ToolTip="{x:Static properties:Resources.TipOpenPreprocessSettings}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnSettings}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupConfig}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{x:Static properties:Resources.TabAnalysis}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <WrapPanel>
                                            <TextBlock Text="{x:Static properties:Resources.GroupGamut}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbRibbonGamutStandard" Width="120" Style="{StaticResource RibbonComboBoxStyle}" />
                                            <TextBlock Text="{x:Static properties:Resources.GroupColorDifference}" Style="{StaticResource RibbonFieldLabelStyle}" Margin="8,0,6,0" />
                                            <ComboBox x:Name="cbActiveColorDifferenceReference" Width="134" SelectionChanged="cbActiveColorDifferenceReference_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}">
                                                <ComboBoxItem Content="{x:Static properties:Resources.CbiD65}" Tag="D65"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.CbiD50}" Tag="D50"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.CbiA}" Tag="A"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.CbiD75}" Tag="D75"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.CbiCenter50px}" Tag="ImageCenter"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.CbiCustomCoord}" Tag="Custom"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.CbiMeasuredBase}" Tag="ReferenceImage"/>
                                            </ComboBox>
                                            <StackPanel x:Name="panelActiveColorDifferenceCustomUv" Orientation="Horizontal" Visibility="Collapsed">
                                                <TextBlock Text="u:" Style="{StaticResource RibbonFieldLabelStyle}" Margin="0,0,3,0" />
                                                <TextBox x:Name="txtActiveColorDifferenceCustomU" Width="62" Style="{StaticResource RibbonTextBoxStyle}" PreviewKeyDown="txtActiveColorDifferenceCustom_PreviewKeyDown" LostFocus="txtActiveColorDifferenceCustom_LostFocus" />
                                                <TextBlock Text="v:" Style="{StaticResource RibbonFieldLabelStyle}" Margin="4,0,3,0" />
                                                <TextBox x:Name="txtActiveColorDifferenceCustomV" Width="62" Style="{StaticResource RibbonTextBoxStyle}" PreviewKeyDown="txtActiveColorDifferenceCustom_PreviewKeyDown" LostFocus="txtActiveColorDifferenceCustom_LostFocus" />
                                            </StackPanel>
                                            <Button x:Name="btnActiveSaveColorDifferenceReference" Content="{x:Static properties:Resources.BtnColorDifferenceReference}" Click="btnActiveSaveColorDifferenceReference_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.BtnColorDifferenceReference}" />
                                            <TextBlock Text="{x:Static properties:Resources.GroupContrast}" Style="{StaticResource RibbonFieldLabelStyle}" Margin="8,0,6,0" />
                                            <ComboBox x:Name="cbActiveContrastImageKind" Width="84" SelectionChanged="cbActiveContrastImageKind_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}">
                                                <ComboBoxItem Content="{x:Static properties:Resources.ContrastImageBlack}" Tag="Black"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ContrastImageWhite}" Tag="White"/>
                                            </ComboBox>
                                            <Button x:Name="btnActiveSaveBlackContrastReference" Content="{x:Static properties:Resources.BtnBlackReference}" Click="btnActiveSaveBlackContrastReference_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.BtnBlackReference}" />
                                            <Button x:Name="btnActiveSaveWhiteContrastReference" Content="{x:Static properties:Resources.BtnWhiteReference}" Click="btnActiveSaveWhiteContrastReference_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.BtnWhiteReference}" />
                                        </WrapPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupAnalysisParameters}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <WrapPanel>
                                            <TextBlock Text="{x:Static properties:Resources.GroupGamut}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <Button x:Name="btnRecordGamutRed" Click="btnRecordGamutRed_Click" Content="R" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordRData}" />
                                            <Button x:Name="btnRecordGamutGreen" Click="btnRecordGamutGreen_Click" Content="G" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordGData}" />
                                            <Button x:Name="btnRecordGamutBlue" Click="btnRecordGamutBlue_Click" Content="B" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordBData}" />
                                            <Button x:Name="btnComputeGamut" Click="btnComputeGamut_Click" Content="{x:Static properties:Resources.BtnComputeGamut}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipComputeGamut}" />
                                            <Button x:Name="btnClearGamut" Click="btnClearGamut_Click" Content="{x:Static properties:Resources.BtnClear}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipClearGamut}" />
                                            <TextBlock Text="{x:Static properties:Resources.GroupContrast}" Style="{StaticResource RibbonFieldLabelStyle}" Margin="10,0,6,0" />
                                            <Button x:Name="btnRecordContrastWhite" Click="btnRecordContrastWhite_Click" Content="W" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordWhiteData}" />
                                            <Button x:Name="btnRecordContrastBlack" Click="btnRecordContrastBlack_Click" Content="B" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordBlackData}" />
                                            <Button x:Name="btnComputeContrast" Click="btnComputeContrast_Click" Content="{x:Static properties:Resources.BtnComputeContrast}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipComputeContrast}" />
                                            <Button x:Name="btnClearContrast" Click="btnClearContrast_Click" Content="{x:Static properties:Resources.BtnClear}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipClearContrast}" />
                                        </WrapPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupComputeActions}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{x:Static properties:Resources.TabSystem}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Click="btnSaveWindowConfig_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipSaveWindowConfig}">
                                                <TextBlock Text="&#xE74E;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                            <Button Command="{Binding EditConoscopeConfigCommand}" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpenConoscopeSettings}">
                                                <Button.Triggers>
                                                    <EventTrigger RoutedEvent="Button.Click">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="rotateTransformWindowSettings" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Button.Triggers>
                                                <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="rotateTransformWindowSettings" CenterX="10" CenterY="10" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupConfig}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static properties:Resources.LabelTheme}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbTheme" Width="120" SelectionChanged="cbTheme_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                            <TextBlock Text="{x:Static properties:Resources.LabelLanguage}" Style="{StaticResource RibbonFieldLabelStyle}" Margin="8,0,6,0" />
                                            <ComboBox x:Name="cbLanguage" Width="140" SelectionChanged="cbLanguage_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupThemeAndLanguage}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
        </Border>

        <xcad:DockingManager x:Name="DockingManager"
                             Grid.Row="1"
                             Margin="-6,-6"
                             Padding="0"
                             Background="Transparent"
                             BorderThickness="0"
                             DocumentHeaderTemplate="{StaticResource DocumentHeaderTemplate}">
            <xcad:LayoutRoot>
                <xcad:LayoutPanel Orientation="Horizontal">
                    <xcad:LayoutDocumentPane x:Name="ViewDocumentPane" />
                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>

        <StatusBar Grid.Row="2" Height="26" Background="{DynamicResource GlobalBackground}">
            <StatusBarItem x:Name="operationProgressStatusItem" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="tbOperationProgressText" Margin="12,0,8,0" Foreground="DodgerBlue" />
                    <ProgressBar x:Name="pbOperationProgress"
                                 Width="180"
                                 Height="12"
                                 Minimum="0"
                                 Maximum="100"
                                 VerticalAlignment="Center"
                                 Foreground="DodgerBlue" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,5,0" Text="{x:Static properties:Resources.CurrentModel}" />
                    <TextBlock x:Name="tbCurrentModel" Text="VA60" FontWeight="SemiBold" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="12,0,5,0" Text="{x:Static properties:Resources.LabelExposure}" />
                    <TextBlock x:Name="tbExposureStatus" Text="{x:Static properties:Resources.StatusNotRecorded}" Foreground="Gray" FontWeight="SemiBold" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="12,0,5,0" Text="{x:Static properties:Resources.ObservationCameraStatus}" />
                    <TextBlock x:Name="tbObservationCameraStatus" Text="{x:Static properties:Resources.NotOpened}" Foreground="Gray" FontWeight="SemiBold" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
