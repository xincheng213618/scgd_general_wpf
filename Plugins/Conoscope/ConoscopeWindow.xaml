<Window x:Class="Conoscope.ConoscopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:core="clr-namespace:Conoscope.Core"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        Title="Conoscope"
        Height="760"
        Width="1520"
        MinHeight="640"
        MinWidth="1080"
        Background="{DynamicResource GlobalBackground}">
    <Window.Resources>
        <sys:Double x:Key="RibbonHostHeight">96</sys:Double>
        <sys:Double x:Key="RibbonContentHeight">50</sys:Double>
        <Thickness x:Key="RibbonTabContentMargin">4,3,4,2</Thickness>

        <DataTemplate x:Key="DocumentHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="QuickButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonGroupStyle" TargetType="Border">
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="5,4,5,3" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style x:Key="RibbonGroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="RibbonFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="38" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonLargeButtonStyle" TargetType="Button" BasedOn="{StaticResource RibbonButtonStyle}">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        </Style>

        <Style x:Key="RibbonPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource RibbonLargeButtonStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RibbonSmallButtonStyle" TargetType="Button" BasedOn="{StaticResource RibbonButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
        </Style>

        <Style x:Key="RibbonIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
        </Style>

        <Style x:Key="RibbonButtonCaptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>

        <Style x:Key="RibbonInlineButtonContentStyle" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ComboBox.Small}">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="RibbonTabScrollViewerStyle" TargetType="ScrollViewer">
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Focusable" Value="False" />
        </Style>

        <Style x:Key="RibbonTabContentPanelStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="{StaticResource RibbonTabContentMargin}" />
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource GlobalBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                WindowChrome.IsHitTestVisibleInChrome="True">
                <TabControl Height="{StaticResource RibbonHostHeight}"
                            MinHeight="{StaticResource RibbonHostHeight}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                    <TabItem Header="{x:Static properties:Resources.TabHome}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Click="OpenFile_Click" Style="{StaticResource RibbonPrimaryButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpenFile}">
                                                <TextBlock Text="&#xE8E5;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                            <Button Click="btnNewView_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipNewView}">
                                                <TextBlock Text="&#xE710;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                            <Button Click="btnSaveWindowConfig_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipSaveConfig}">
                                                <TextBlock Text="&#xE74E;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupData}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static properties:Resources.Model}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbModelType" Width="132" SelectionChanged="cbModelType_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                            <Button x:Name="btnOpenObservationCamera" Click="btnOpenObservationCamera_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpenObservationCamera}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE890;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnObservationCamera}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupModel}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border x:Name="bdHomeQuickControls" Style="{StaticResource RibbonGroupStyle}" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <WrapPanel>
                                            <TextBlock Text="{x:Static properties:Resources.LabelChannel}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbHomeDisplayChannel" Width="112" SelectionChanged="cbHomeDisplayChannel_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}">
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelX}" Tag="X"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelY}" Tag="Y"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelZ}" Tag="Z"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieX}" Tag="CieX"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieY}" Tag="CieY"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieU}" Tag="CieU"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieV}" Tag="CieV"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelDeltaUV}" Tag="ColorDifference"/>
                                            </ComboBox>
                                            <TextBlock Text="{x:Static properties:Resources.LabelReference}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbHomeReferenceMode" Width="118" SelectionChanged="cbHomeReferenceMode_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}">
                                                <ComboBoxItem Content="{x:Static properties:Resources.RefAzimuthLine}" Tag="AzimuthLine"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.RefPolarCircle}" Tag="PolarCircle"/>
                                            </ComboBox>
                                            <TextBlock x:Name="tbHomeReferenceValueLabel" Text="{x:Static properties:Resources.LabelAzimuthDeg}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <TextBox x:Name="txtHomeReferenceValue"
                                                     Width="76"
                                                     Style="{StaticResource RibbonTextBoxStyle}"
                                                     PreviewKeyDown="txtHomeReferenceValue_PreviewKeyDown"
                                                     LostFocus="txtHomeReferenceValue_LostFocus" />
                                            <TextBlock Text="{x:Static properties:Resources.LabelExport}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbHomeExportChannel" Width="112" SelectionChanged="cbHomeExportChannel_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}">
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelX}" Tag="X"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelY}" Tag="Y"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelZ}" Tag="Z"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieX}" Tag="CieX"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieY}" Tag="CieY"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieU}" Tag="CieU"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelCieV}" Tag="CieV"/>
                                                <ComboBoxItem Content="{x:Static properties:Resources.ChannelDeltaUV}" Tag="ColorDifference"/>
                                            </ComboBox>
                                            <Button x:Name="btnHomeExportAngle" Content="{x:Static properties:Resources.BtnAzimuthExport}" Click="btnHomeExportAngle_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipExportAzimuthData}" />
                                            <Button x:Name="btnHomeExportCircle" Content="{x:Static properties:Resources.BtnPolarExport}" Click="btnHomeExportCircle_Click" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipExportPolarData}" />
                                        </WrapPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupCurrentView}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{x:Static properties:Resources.TabCapture}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static properties:Resources.LabelFlowTemplate}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbFlowTemplate" Width="176" DisplayMemberPath="Key" SelectionChanged="cbFlowTemplate_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                            <Button x:Name="btnEditFlowTemplates" Click="btnEditFlowTemplates_Click" ToolTip="{x:Static properties:Resources.TipOpenFlowTemplateMgmt}" Style="{StaticResource RibbonLargeButtonStyle}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnSettings}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="btnRunFlow" Click="btnRunFlow_Click" Style="{StaticResource RibbonPrimaryButtonStyle}" ToolTip="{x:Static properties:Resources.TipExecuteFlow}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE768;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnExecute}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <CheckBox x:Name="chkReuseActiveViewOnCapture"
                                                  Grid.Row="1"
                                                  Margin="0,8,0,0"
                                                  VerticalAlignment="Center"
                                                  IsChecked="True"
                                                  Content="{x:Static properties:Resources.ChkReuseActiveView}"
                                                  ToolTip="{x:Static properties:Resources.TipReuseActiveView}" />
                                        <TextBlock Grid.Row="2" Text="{x:Static properties:Resources.GroupFlowCapture}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static properties:Resources.LabelCamera}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbCameraDevice"
                                                      Width="176"
                                                      DisplayMemberPath="Config.Name"
                                                      SelectionChanged="cbCameraDevice_SelectionChanged"
                                                      Style="{StaticResource RibbonComboBoxStyle}" />
                                            <TextBlock Text="{x:Static properties:Resources.Calibration}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbCalibrationTemplate"
                                                      Width="140"
                                                      DisplayMemberPath="Key"
                                                      SelectionChanged="cbCalibrationTemplate_SelectionChanged"
                                                      Style="{StaticResource RibbonComboBoxStyle}" />
                                            <Button x:Name="btnEditCalibrationTemplates"
                                                    Click="btnEditCalibrationTemplates_Click"
                                                    ToolTip="{x:Static properties:Resources.TipOpenCalibrationMgmt}"
                                                    Style="{StaticResource RibbonLargeButtonStyle}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.Calibration}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="btnRefreshCameraDevices"
                                                    Click="btnRefreshCameraDevices_Click"
                                                    ToolTip="{x:Static properties:Resources.TipRefreshCameraList}"
                                                    Style="{StaticResource RibbonButtonStyle}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE72C;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnRefresh}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="btnCaptureCamera"
                                                    Click="btnCaptureCamera_Click"
                                                    Style="{StaticResource RibbonPrimaryButtonStyle}"
                                                    ToolTip="{x:Static properties:Resources.TipCapturePhoto}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE722;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnCapturePhoto}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupMeasurementCamera}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{x:Static properties:Resources.LabelNdPort}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <TextBox x:Name="txtNDPort" Width="60" Style="{StaticResource RibbonTextBoxStyle}" />
                                            <Button x:Name="btnSetNDPort" Click="btnSetNDPort_Click" ToolTip="{x:Static properties:Resources.TipSwitchNdPort}" Style="{StaticResource RibbonButtonStyle}">
                                                <TextBlock Text="&#xE8AB;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                            <Button x:Name="btnGetNDPort" Click="btnGetNDPort_Click" ToolTip="{x:Static properties:Resources.TipReadNdPort}" Style="{StaticResource RibbonButtonStyle}">
                                                <TextBlock Text="&#xE72C;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                            <Button x:Name="btnBindNdCalibration"
                                                    Click="btnBindNdCalibration_Click"
                                                    ToolTip="{x:Static properties:Resources.TipBindNdCalibration}"
                                                    Style="{StaticResource RibbonButtonStyle}">
                                                <TextBlock Text="&#xE71B;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                            <Button x:Name="btnClearNdCalibrationBinding" Click="btnClearNdCalibrationBinding_Click" ToolTip="{x:Static properties:Resources.TipClearNdCalibration}" Style="{StaticResource RibbonSmallButtonStyle}">
                                                <TextBlock Text="&#xE74D;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupNdCalibration}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{x:Static properties:Resources.TabPreprocess}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox x:Name="chkWindowApplyFilterOnOpen"
                                                      Content="{x:Static properties:Resources.ChkEnablePreprocess}"
                                                      Checked="WindowPreprocess_Changed"
                                                      Unchecked="WindowPreprocess_Changed"
                                                      Margin="0,0,12,0"
                                                      VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupEnable}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Orientation="Horizontal">
                                            <ComboBox x:Name="cbWindowFilterType"
                                                      Width="162"
                                                      SelectedValuePath="Tag"
                                                      SelectionChanged="cbWindowFilterType_SelectionChanged"
                                                      Style="{StaticResource ComboBox.Small}">
                                                <ComboBoxItem Content="{x:Static properties:Resources.NoFilter}" Tag="{x:Static core:ImageFilterType.None}" />
                                                <ComboBoxItem Content="{x:Static properties:Resources.LowPassFilter}" Tag="{x:Static core:ImageFilterType.LowPass}" />
                                                <ComboBoxItem Content="{x:Static properties:Resources.MovingAverage}" Tag="{x:Static core:ImageFilterType.MovingAverage}" />
                                                <ComboBoxItem Content="{x:Static properties:Resources.GaussianFilter}" Tag="{x:Static core:ImageFilterType.Gaussian}" />
                                                <ComboBoxItem Content="{x:Static properties:Resources.MedianFilter}" Tag="{x:Static core:ImageFilterType.Median}" />
                                                <ComboBoxItem Content="{x:Static properties:Resources.BilateralFilter}" Tag="{x:Static core:ImageFilterType.Bilateral}" />
                                            </ComboBox>
                                            <Border Padding="8,4"
                                                    Margin="0,0,6,0"
                                                    Background="{DynamicResource GlobalBorderBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    VerticalAlignment="Center">
                                                <TextBlock x:Name="tbWindowFilterConfigSummary"
                                                           Width="250"
                                                           Foreground="Gray"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
                                            </Border>
                                            <Button x:Name="btnOpenPreprocessSettings"
                                                    Click="btnOpenPreprocessSettings_Click"
                                                    Style="{StaticResource RibbonLargeButtonStyle}"
                                                    ToolTip="{x:Static properties:Resources.TipOpenPreprocessSettings}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnSettings}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="btnApplyPreprocessToActiveView"
                                                    Click="btnApplyPreprocessToActiveView_Click"
                                                    Style="{StaticResource RibbonPrimaryButtonStyle}"
                                                    ToolTip="{x:Static properties:Resources.TipApplyPreprocess}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE895;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnReapply}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupFilter}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox x:Name="chkWindowUsePseudoColor"
                                                      Content="{x:Static properties:Resources.ChkPseudoColor}"
                                                      Margin="0,0,12,0"
                                                      Checked="WindowDisplay_Changed"
                                                      Unchecked="WindowDisplay_Changed"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Text="{x:Static properties:Resources.LabelColorMap}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                            <ComboBox x:Name="cbWindowPseudoColorMap"
                                                      Width="138"
                                                      SelectionChanged="cbWindowPseudoColorMap_SelectionChanged"
                                                      Style="{StaticResource RibbonComboBoxStyle}" />
                                            <Border Width="86" Height="22" Margin="0,2,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                <Image x:Name="imgWindowPseudoColorMapPreview" Stretch="Fill" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupDisplay}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{x:Static properties:Resources.TabAnalysis}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Click="btnExportAngleMode_Click" ToolTip="{x:Static properties:Resources.TipExportAzimuthData}" Style="{StaticResource RibbonButtonStyle}">
                                                <TextBlock Text="&#xE72D;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                            <Button Click="btnExportCircleMode_Click" ToolTip="{x:Static properties:Resources.TipExportPolarData}" Style="{StaticResource RibbonButtonStyle}">
                                                <TextBlock Text="&#xE72D;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                            <Button Click="btnAdvancedExport_Click" ToolTip="{x:Static properties:Resources.TipAdvancedExport}" Style="{StaticResource RibbonButtonStyle}">
                                                <TextBlock Text="&#xE72D;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupExport}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>


                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <WrapPanel Margin="0,0,0,4">
                                                <TextBlock Text="{x:Static properties:Resources.LabelStandard}" Style="{StaticResource RibbonFieldLabelStyle}" />
                                                <ComboBox x:Name="cbRibbonGamutStandard" Width="120" Style="{StaticResource RibbonComboBoxStyle}" />
                                                <Button x:Name="btnComputeGamut" Click="btnComputeGamut_Click" Content="{x:Static properties:Resources.BtnComputeGamut}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipComputeGamut}" />
                                                <Button x:Name="btnClearGamut" Click="btnClearGamut_Click" Content="{x:Static properties:Resources.BtnClear}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipClearGamut}" />
                                            </WrapPanel>
                                            <WrapPanel>
                                                <Button x:Name="btnRecordGamutRed" Click="btnRecordGamutRed_Click" Content="{x:Static properties:Resources.BtnRecordR}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordRData}" />
                                                <Button x:Name="btnRecordGamutGreen" Click="btnRecordGamutGreen_Click" Content="{x:Static properties:Resources.BtnRecordG}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordGData}" />
                                                <Button x:Name="btnRecordGamutBlue" Click="btnRecordGamutBlue_Click" Content="{x:Static properties:Resources.BtnRecordB}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordBData}" />
                                            </WrapPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupGamut}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <WrapPanel Margin="0,0,0,4">
                                                <Button x:Name="btnRecordContrastWhite" Click="btnRecordContrastWhite_Click" Content="{x:Static properties:Resources.BtnRecordWhite}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordWhiteData}" />
                                                <Button x:Name="btnRecordContrastBlack" Click="btnRecordContrastBlack_Click" Content="{x:Static properties:Resources.BtnRecordBlack}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipRecordBlackData}" />
                                            </WrapPanel>
                                            <WrapPanel>
                                                <Button x:Name="btnComputeContrast" Click="btnComputeContrast_Click" Content="{x:Static properties:Resources.BtnComputeContrast}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipComputeContrast}" />
                                                <Button x:Name="btnClearContrast" Click="btnClearContrast_Click" Content="{x:Static properties:Resources.BtnClear}" Style="{StaticResource RibbonSmallButtonStyle}" ToolTip="{x:Static properties:Resources.TipClearContrast}" />
                                            </WrapPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupContrast}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{x:Static properties:Resources.TabWindow}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Click="btnSaveWindowConfig_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipSaveWindowConfig}">
                                                <TextBlock Text="&#xE74E;" Style="{StaticResource RibbonIconTextStyle}" />
                                            </Button>
                                            <Button Command="{Binding EditConoscopeConfigCommand}" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpenConoscopeSettings}">
                                                <Button.Triggers>
                                                    <EventTrigger RoutedEvent="Button.Click">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="rotateTransformWindowSettings" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Button.Triggers>
                                                <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform x:Name="rotateTransformWindowSettings" CenterX="10" CenterY="10" />
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupConfig}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="btnOpenColorGamut" Click="btnOpenColorGamut_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpenLegacyGamut}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE790;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnGamutWindow}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="btnOpenContrastTest" Click="btnOpenContrastTest_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="{x:Static properties:Resources.TipOpenLegacyContrast}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE9D2;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnContrastWindow}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupAnalysisWindows}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <ComboBox x:Name="cbLanguage" Width="140" SelectionChanged="cbLanguage_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                            <ComboBox x:Name="cbTheme" Width="120" SelectionChanged="cbTheme_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupConfig}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="{x:Static properties:Resources.TabHelp}">
                        <ScrollViewer Style="{StaticResource RibbonTabScrollViewerStyle}">
                            <StackPanel Style="{StaticResource RibbonTabContentPanelStyle}">
                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button x:Name="btnOpenHelpCenter"
                                                    Click="btnOpenConoscopeHelp_Click"
                                                    Style="{StaticResource RibbonLargeButtonStyle}"
                                                    ToolTip="{x:Static properties:Resources.TipHelpCenter}">
                                                <StackPanel Style="{StaticResource RibbonInlineButtonContentStyle}">
                                                    <TextBlock Text="&#xE897;" Style="{StaticResource RibbonIconTextStyle}" />
                                                    <TextBlock Text="{x:Static properties:Resources.BtnHelpCenter}" Style="{StaticResource RibbonButtonCaptionStyle}" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupOpen}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>

                                <Border Style="{StaticResource RibbonGroupStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{x:Static properties:Resources.HelpDescription}"
                                                   TextWrapping="Wrap"
                                                   Width="320"
                                                   Foreground="Gray"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.GroupDescription}" Style="{StaticResource RibbonGroupHeaderStyle}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
        </Border>

        <xcad:DockingManager x:Name="DockingManager"
                             Grid.Row="1"
                             Margin="-6,-6"
                             Padding="0"
                             Background="Transparent"
                             BorderThickness="0"
                             DocumentHeaderTemplate="{StaticResource DocumentHeaderTemplate}">
            <xcad:LayoutRoot>
                <xcad:LayoutPanel Orientation="Horizontal">
                    <xcad:LayoutDocumentPane x:Name="ViewDocumentPane" />
                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>

        <StatusBar Grid.Row="2" Height="26" Background="{DynamicResource GlobalBackground}">
            <StatusBarItem>
                <TextBlock Text="{x:Static properties:Resources.LabelStatus}" Margin="0,0,6,0" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock x:Name="tbOperationStatus" Text="{x:Static properties:Resources.StatusReady}" Foreground="Gray" />
            </StatusBarItem>
            <StatusBarItem x:Name="operationProgressStatusItem" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="tbOperationProgressText" Margin="12,0,8,0" Foreground="DodgerBlue" />
                    <ProgressBar x:Name="pbOperationProgress"
                                 Width="180"
                                 Height="12"
                                 Minimum="0"
                                 Maximum="100"
                                 VerticalAlignment="Center"
                                 Foreground="DodgerBlue" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,5,0" Text="{x:Static properties:Resources.CurrentModel}" />
                    <TextBlock x:Name="tbCurrentModel" Text="VA60" FontWeight="SemiBold" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="12,0,5,0" Text="{x:Static properties:Resources.LabelExposure}" />
                    <TextBlock x:Name="tbExposureStatus" Text="{x:Static properties:Resources.StatusNotRecorded}" Foreground="Gray" FontWeight="SemiBold" />
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="12,0,5,0" Text="{x:Static properties:Resources.ObservationCameraStatus}" />
                    <TextBlock x:Name="tbObservationCameraStatus" Text="{x:Static properties:Resources.NotOpened}" Foreground="Gray" FontWeight="SemiBold" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
