<Window x:Class="Conoscope.ConoscopeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        Title="Conoscope" Height="750" Width="1582" Background="{DynamicResource GlobalBackground}">
    <Window.Resources>
        <DataTemplate x:Key="DocumentHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
        <Style x:Key="RibbonGroupBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Padding" Value="8,3,8,2"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="82"/>
        </Style>
        <Style x:Key="RibbonGroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style x:Key="RibbonFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="RibbonButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="Margin" Value="0,0,4,3"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RibbonLargeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="ToolTipService.ShowDuration" Value="12000"/>
        </Style>
        <Style x:Key="RibbonIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>
        <Style x:Key="RibbonSmallButtonStyle" TargetType="Button" BasedOn="{StaticResource RibbonButtonStyle}">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="MinWidth" Value="34"/>
        </Style>
        <Style x:Key="RibbonComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RibbonTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="0,0,4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" MinHeight="98" Background="{DynamicResource GlobalBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid Margin="6,4">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <WrapPanel VerticalAlignment="Top">
                        <Border Style="{StaticResource RibbonGroupBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Bottom" Text="文件" Style="{StaticResource RibbonGroupHeaderStyle}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Click="OpenFile_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="打开一个或多个 Conoscope 图像">
                                        <StackPanel>
                                            <TextBlock Text="&#xE8E5;" Style="{StaticResource RibbonIconTextStyle}"/>
                                            <TextBlock Text="打开" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <StackPanel Width="82">
                                        <Button Content="方位导出" Click="btnExportAngleMode_Click" Style="{StaticResource RibbonButtonStyle}"/>
                                        <Button Content="极角导出" Click="btnExportCircleMode_Click" Style="{StaticResource RibbonButtonStyle}"/>
                                    </StackPanel>
                                    <Button Content="高级导出" Click="btnAdvancedExport_Click" Style="{StaticResource RibbonButtonStyle}" VerticalAlignment="Top"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Style="{StaticResource RibbonGroupBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Bottom" Text="相机" Style="{StaticResource RibbonGroupHeaderStyle}"/>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Width="104" Margin="0,0,6,0">
                                        <TextBlock Text="型号" Style="{StaticResource RibbonFieldLabelStyle}"/>
                                        <ComboBox x:Name="cbModelType" SelectionChanged="cbModelType_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}"/>
                                    </StackPanel>
                                    <Button x:Name="btnOpenObservationCamera" Click="btnOpenObservationCamera_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="打开观察相机窗口">
                                        <StackPanel>
                                            <TextBlock Text="&#xE722;" Style="{StaticResource RibbonIconTextStyle}"/>
                                            <TextBlock Text="观察" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Style="{StaticResource RibbonGroupBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Bottom" Text="流程" Style="{StaticResource RibbonGroupHeaderStyle}"/>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Width="176" Margin="0,0,6,0">
                                        <TextBlock Text="模板" Style="{StaticResource RibbonFieldLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <ComboBox x:Name="cbFlowTemplate" Width="128" DisplayMemberPath="Key" SelectionChanged="cbFlowTemplate_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}"/>
                                            <Button x:Name="btnEditFlowTemplates" Content="管理" Click="btnEditFlowTemplates_Click" ToolTip="打开流程模板管理" Style="{StaticResource RibbonSmallButtonStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button x:Name="btnRunFlow" Click="btnRunFlow_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="执行当前流程并打开结果图像">
                                        <StackPanel>
                                            <TextBlock Text="&#xE768;" Style="{StaticResource RibbonIconTextStyle}"/>
                                            <TextBlock Text="执行" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Style="{StaticResource RibbonGroupBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Bottom" Text="测量相机" Style="{StaticResource RibbonGroupHeaderStyle}"/>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Width="280" Margin="0,0,6,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="138"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="相机" Style="{StaticResource RibbonFieldLabelStyle}"/>
                                            <TextBlock Grid.Column="1" Text="校正" Style="{StaticResource RibbonFieldLabelStyle}"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <ComboBox x:Name="cbCameraDevice" Width="132" DisplayMemberPath="Config.Name" SelectionChanged="cbCameraDevice_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}"/>
                                            <ComboBox x:Name="cbCalibrationTemplate" Width="104" DisplayMemberPath="Key" SelectionChanged="cbCalibrationTemplate_SelectionChanged" Style="{StaticResource RibbonComboBoxStyle}"/>
                                            <Button x:Name="btnEditCalibrationTemplates" Content="管理" Click="btnEditCalibrationTemplates_Click" ToolTip="打开当前相机的校正模板管理" Style="{StaticResource RibbonSmallButtonStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button x:Name="btnCaptureCamera" Click="btnCaptureCamera_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="使用当前相机与校正模板拍照">
                                        <StackPanel>
                                            <TextBlock Text="&#xE722;" Style="{StaticResource RibbonIconTextStyle}"/>
                                            <TextBlock Text="拍照" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Style="{StaticResource RibbonGroupBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Bottom" Text="ND / 校正" Style="{StaticResource RibbonGroupHeaderStyle}"/>
                                <StackPanel Width="190">
                                    <TextBlock Text="ND 端口" Style="{StaticResource RibbonFieldLabelStyle}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox x:Name="txtNDPort" Width="44" Style="{StaticResource RibbonTextBoxStyle}"/>
                                        <Button x:Name="btnSetNDPort" Content="切换" Click="btnSetNDPort_Click" Style="{StaticResource RibbonButtonStyle}"/>
                                        <Button x:Name="btnGetNDPort" Content="读取" Click="btnGetNDPort_Click" Style="{StaticResource RibbonButtonStyle}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="btnBindNdCalibration" Content="绑定校正" Click="btnBindNdCalibration_Click" ToolTip="将当前 ND 端口绑定到当前校正模板" Style="{StaticResource RibbonButtonStyle}"/>
                                        <Button x:Name="btnClearNdCalibrationBinding" Content="解绑" Click="btnClearNdCalibrationBinding_Click" Style="{StaticResource RibbonSmallButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Style="{StaticResource RibbonGroupBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Bottom" Text="分析" Style="{StaticResource RibbonGroupHeaderStyle}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnOpenContrastTest" Click="btnOpenContrastTest_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="打开黑白对比度测试">
                                        <StackPanel>
                                            <TextBlock Text="&#xE9D2;" Style="{StaticResource RibbonIconTextStyle}"/>
                                            <TextBlock Text="黑白" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="btnOpenColorGamut" Click="btnOpenColorGamut_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="打开 RGB 色域计算">
                                        <StackPanel>
                                            <TextBlock Text="&#xE790;" Style="{StaticResource RibbonIconTextStyle}"/>
                                            <TextBlock Text="色域" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Style="{StaticResource RibbonGroupBorderStyle}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Bottom" Text="窗口" Style="{StaticResource RibbonGroupHeaderStyle}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Click="btnSaveWindowConfig_Click" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="保存窗口配置">
                                        <StackPanel>
                                            <TextBlock Text="&#xE74E;" Style="{StaticResource RibbonIconTextStyle}"/>
                                            <TextBlock Text="保存" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding EditConoscopeConfigCommand}" Style="{StaticResource RibbonLargeButtonStyle}" ToolTip="打开 Conoscope 设置">
                                        <Button.Triggers>
                                            <EventTrigger RoutedEvent="Button.Click">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="rotateTransformWindowSettings" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.5" FillBehavior="Stop"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Button.Triggers>
                                        <StackPanel>
                                            <TextBlock Text="&#xE713;" Style="{StaticResource RibbonIconTextStyle}">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform x:Name="rotateTransformWindowSettings" CenterX="10" CenterY="10"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                            <TextBlock Text="设置" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </WrapPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <xcad:DockingManager x:Name="DockingManager" Grid.Row="1" Margin="-6,-6" Padding="0" Background="Transparent" BorderThickness="0" DocumentHeaderTemplate="{StaticResource DocumentHeaderTemplate}">
            <xcad:LayoutRoot>
                <xcad:LayoutPanel Orientation="Horizontal">
                    <xcad:LayoutDocumentPane x:Name="ViewDocumentPane" />
                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>

        <StatusBar Grid.Row="2" Height="25">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static properties:Resources.CurrentModel}" Margin="0,0,5,0"/>
                    <TextBlock x:Name="tbCurrentModel" Text="VA60" FontWeight="Bold"/>
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="tbOperationStatus" Text="就绪" Foreground="Gray"/>
            </StatusBarItem>
            <Separator />
            <StatusBarItem x:Name="ObservationCameraStatusItem">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static properties:Resources.ObservationCameraStatus}" Margin="0,0,5,0"/>
                    <TextBlock x:Name="tbObservationCameraStatus" Text="{x:Static properties:Resources.NotOpened}" Foreground="Gray"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>