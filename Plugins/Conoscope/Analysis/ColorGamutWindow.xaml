<Window x:Class="Conoscope.Analysis.ColorGamutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        Title="{x:Static properties:Resources.TitleColorGamutCalc}" Height="520" Width="860" Background="{DynamicResource GlobalBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="{x:Static properties:Resources.GroupBoxRgbImageSelection}" Grid.Row="0" Margin="0,0,0,10">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{x:Static properties:Resources.LabelRImage}" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="RedFileTextBox" Grid.Column="1" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,6"/>
                <Button Grid.Column="2" Content="{x:Static properties:Resources.BtnSelectRImage}" Click="SelectRed_Click" Padding="12,4" Margin="0,0,0,6"/>
                <Button Grid.Column="3" Content="{x:Static properties:Resources.BtnRecordCurrentR}" Click="CaptureRedFocusPoint_Click" Padding="12,4" Margin="8,0,0,6"/>

                <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.LabelGImage}" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="GreenFileTextBox" Grid.Row="1" Grid.Column="1" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,6"/>
                <Button Grid.Row="1" Grid.Column="2" Content="{x:Static properties:Resources.BtnSelectGImage}" Click="SelectGreen_Click" Padding="12,4" Margin="0,0,0,6"/>
                <Button Grid.Row="1" Grid.Column="3" Content="{x:Static properties:Resources.BtnRecordCurrentG}" Click="CaptureGreenFocusPoint_Click" Padding="12,4" Margin="8,0,0,6"/>

                <TextBlock Grid.Row="2" Text="{x:Static properties:Resources.LabelBImage}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="BlueFileTextBox" Grid.Row="2" Grid.Column="1" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Row="2" Grid.Column="2" Content="{x:Static properties:Resources.BtnSelectBImage}" Click="SelectBlue_Click" Padding="12,4"/>
                <Button Grid.Row="2" Grid.Column="3" Content="{x:Static properties:Resources.BtnRecordCurrentB}" Click="CaptureBlueFocusPoint_Click" Padding="12,4" Margin="8,0,0,0"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="{x:Static properties:Resources.LabelStandard}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="StandardComboBox" Width="150" Margin="0,0,10,0"/>
            <Button Content="{x:Static properties:Resources.BtnComputeGamut}" Click="Calculate_Click" Padding="14,5" Margin="0,0,8,0"/>
            <Button Content="{x:Static properties:Resources.BtnClear}" Click="Clear_Click" Padding="14,5"/>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="{x:Static properties:Resources.GroupBoxResults}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{x:Static properties:Resources.LabelRChromaticity}" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="RedChromaticityText" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Text="{x:Static properties:Resources.LabelGChromaticity}" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="GreenChromaticityText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Text="{x:Static properties:Resources.LabelBChromaticity}" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="BlueChromaticityText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Text="{x:Static properties:Resources.LabelGamutArea}" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="AreaText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Text="{x:Static properties:Resources.LabelCoverageRate}" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="CoverageText" Grid.Row="4" Grid.Column="1" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

                <TextBlock x:Name="StatusText" Grid.Row="5" Grid.ColumnSpan="2" Foreground="Gray" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>