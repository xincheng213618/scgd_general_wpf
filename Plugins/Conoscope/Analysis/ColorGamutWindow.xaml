<Window x:Class="Conoscope.Analysis.ColorGamutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RGB 色域计算" Height="520" Width="860" Background="{DynamicResource GlobalBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="RGB 图像选择" Grid.Row="0" Margin="0,0,0,10">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="R 图" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="RedFileTextBox" Grid.Column="1" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,6"/>
                <Button Grid.Column="2" Content="选择 R 图" Click="SelectRed_Click" Padding="12,4" Margin="0,0,0,6"/>
                <Button Grid.Column="3" Content="记录当前 R" Click="CaptureRedFocusPoint_Click" Padding="12,4" Margin="8,0,0,6"/>

                <TextBlock Grid.Row="1" Text="G 图" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="GreenFileTextBox" Grid.Row="1" Grid.Column="1" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,6"/>
                <Button Grid.Row="1" Grid.Column="2" Content="选择 G 图" Click="SelectGreen_Click" Padding="12,4" Margin="0,0,0,6"/>
                <Button Grid.Row="1" Grid.Column="3" Content="记录当前 G" Click="CaptureGreenFocusPoint_Click" Padding="12,4" Margin="8,0,0,6"/>

                <TextBlock Grid.Row="2" Text="B 图" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="BlueFileTextBox" Grid.Row="2" Grid.Column="1" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Row="2" Grid.Column="2" Content="选择 B 图" Click="SelectBlue_Click" Padding="12,4"/>
                <Button Grid.Row="2" Grid.Column="3" Content="记录当前 B" Click="CaptureBlueFocusPoint_Click" Padding="12,4" Margin="8,0,0,0"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="色域标准" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="StandardComboBox" Width="150" Margin="0,0,10,0"/>
            <Button Content="计算色域" Click="Calculate_Click" Padding="14,5" Margin="0,0,8,0"/>
            <Button Content="清空" Click="Clear_Click" Padding="14,5"/>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="结果">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="R 色坐标" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="RedChromaticityText" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Text="G 色坐标" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="GreenChromaticityText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Text="B 色坐标" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="BlueChromaticityText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Text="色域面积" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="AreaText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Text="覆盖率" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="CoverageText" Grid.Row="4" Grid.Column="1" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

                <TextBlock x:Name="StatusText" Grid.Row="5" Grid.ColumnSpan="2" Foreground="Gray" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>