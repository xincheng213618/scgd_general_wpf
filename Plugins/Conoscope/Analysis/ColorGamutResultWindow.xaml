<Window x:Class="Conoscope.Analysis.ColorGamutResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cie="clr-namespace:ColorVision.ImageEditor.Cie;assembly=ColorVision.ImageEditor"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        Title="{x:Static properties:Resources.TitleColorGamutResult}" Height="760" Width="1240" Background="{DynamicResource GlobalBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="{x:Static properties:Resources.LabelStandard}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="tbStandardName" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>
                    <TextBlock Text="{x:Static properties:Resources.GroupDisplay}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="cbDisplayScope" Width="180" SelectionChanged="cbDisplayScope_SelectionChanged"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="{x:Static properties:Resources.BtnExport}" Padding="12,4" Click="btnExportCsv_Click"/>
                <TextBlock x:Name="tbSummary" DockPanel.Dock="Right" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,12,0"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
                <cie:CieDiagramView x:Name="CieDiagram"/>
            </Border>

            <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
                <DataGrid x:Name="ResultGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionChanged="ResultGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{x:Static properties:Resources.ColNumber}" Binding="{Binding Index}" Width="60"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.ColFocusPoint}" Binding="{Binding PointName}" Width="110"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.ColAzimuthDeg}" Binding="{Binding AzimuthDisplay}" Width="85"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.ColPolarDeg}" Binding="{Binding PolarDisplay}" Width="85"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.ColRadiusDeg}" Binding="{Binding RadiusDisplay}" Width="85"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.ColRChromaticity}" Binding="{Binding RedDisplay}" Width="130"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.ColGChromaticity}" Binding="{Binding GreenDisplay}" Width="130"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.ColBChromaticity}" Binding="{Binding BlueDisplay}" Width="130"/>
                        <DataGridTextColumn Header="{x:Static properties:Resources.ColGamutValue}" Binding="{Binding CoverageDisplay}" Width="95"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>
