<Window x:Class="Conoscope.Analysis.ContrastTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="对比度测试" Height="430" Width="820" Background="{DynamicResource GlobalBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="图像选择" Grid.Row="0" Margin="0,0,0,10">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="白图" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="WhiteFileTextBox" Grid.Column="1" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,6"/>
                <Button Grid.Column="2" Content="选择白图" Click="SelectWhite_Click" Padding="12,4" Margin="0,0,0,6"/>
                <Button Grid.Column="3" Content="记录当前白点" Click="CaptureWhiteFocusPoint_Click" Padding="12,4" Margin="8,0,0,6"/>

                <TextBlock Grid.Row="1" Text="黑图" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="BlackFileTextBox" Grid.Row="1" Grid.Column="1" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Row="1" Grid.Column="2" Content="选择黑图" Click="SelectBlack_Click" Padding="12,4"/>
                <Button Grid.Row="1" Grid.Column="3" Content="记录当前黑点" Click="CaptureBlackFocusPoint_Click" Padding="12,4" Margin="8,0,0,0"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="计算对比度" Click="Calculate_Click" Padding="14,5" Margin="0,0,8,0"/>
            <Button Content="清空" Click="Clear_Click" Padding="14,5"/>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="结果">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="白亮度" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="WhiteLuminanceText" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Text="黑亮度" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="BlackLuminanceText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Text="对比度" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="ContrastText" Grid.Row="2" Grid.Column="1" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="3" Text="色坐标" FontWeight="SemiBold" Margin="0,0,8,8"/>
                <TextBlock x:Name="ChromaticityText" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <TextBlock x:Name="StatusText" Grid.Row="4" Grid.ColumnSpan="2" Foreground="Gray" TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>
    </Grid>
</Window>