<Window x:Class="Conoscope.Analysis.ContrastResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:Conoscope.Properties"
        Title="{x:Static properties:Resources.TitleContrastResult}" Height="560" Width="940" Background="{DynamicResource GlobalBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="tbSummary" Foreground="Gray" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="{x:Static properties:Resources.BtnExport}" Padding="12,4" Click="btnExportCsv_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
            <DataGrid x:Name="ResultGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColNumber}" Binding="{Binding Index}" Width="60"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColFocusPoint}" Binding="{Binding PointName}" Width="110"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColAzimuthDeg}" Binding="{Binding AzimuthDisplay}" Width="85"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColPolarDeg}" Binding="{Binding PolarDisplay}" Width="85"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColRadiusDeg}" Binding="{Binding RadiusDisplay}" Width="85"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColWhiteLuminance}" Binding="{Binding WhiteDisplay}" Width="120"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColBlackLuminance}" Binding="{Binding BlackDisplay}" Width="120"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColContrast}" Binding="{Binding RatioDisplay}" Width="100"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColWhiteChromaticity}" Binding="{Binding WhiteChromaticityDisplay}" Width="140"/>
                    <DataGridTextColumn Header="{x:Static properties:Resources.ColBlackChromaticity}" Binding="{Binding BlackChromaticityDisplay}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
