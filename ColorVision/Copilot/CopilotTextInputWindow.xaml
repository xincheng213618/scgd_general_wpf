<Window x:Class="ColorVision.Copilot.CopilotTextInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="输入"
        Width="520"
        Height="200"
        MinWidth="440"
        Background="{DynamicResource GlobalBackground}"
        mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="DescriptionTextBlock"
                       Foreground="{DynamicResource GlobalTextBrush}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
        </StackPanel>

        <TextBox x:Name="InputTextBox"
                 Grid.Row="1"
                 Margin="0,12,0,12"
                 AcceptsReturn="False"
                 Foreground="{DynamicResource GlobalTextBrush}"
                 TextWrapping="Wrap"
                 VerticalContentAlignment="Center"
                 VerticalScrollBarVisibility="Auto" />

        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Margin="0,0,8,0" Padding="14,6" Click="CancelButton_Click" Content="取消" />
            <Button Padding="14,6" Click="OkButton_Click" Content="确定" />
        </StackPanel>
    </Grid>
</Window>