<Window x:Class="ColorVision.Copilot.CopilotExceptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="异常诊断"
        Width="860"
        Height="680"
        MinWidth="720"
        MinHeight="520"
        ShowInTaskbar="False"
        Background="{DynamicResource GlobalBackground}"
        mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="16"
                Background="{DynamicResource LayoutBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Text="ColorVision 捕获到未处理异常" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Text="{Binding ExceptionTitle}"
                           TextWrapping="Wrap" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Opacity="0.78"
                           Text="{Binding OccurredSummary}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,12"
                Padding="12,10"
                Background="{DynamicResource LayoutBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock Foreground="{DynamicResource GlobalTextBrush}"
                       Text="{Binding DispatchStatus}"
                       TextWrapping="Wrap" />
        </Border>

        <TabControl Grid.Row="2">
            <TabItem Header="异常详情">
                <TextBox Margin="12"
                         FontFamily="Consolas"
                         Foreground="{DynamicResource GlobalTextBrush}"
                         Background="{DynamicResource GlobalBackground}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="{Binding ExceptionDetails}"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </TabItem>
            <TabItem Header="最近日志">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="RecentLinesRadioButton"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"
                                     Checked="RecentLinesRadioButton_Checked"
                                     Content="最近 N 行"
                                     IsChecked="True" />
                        <TextBox x:Name="RecentLineCountTextBox"
                                 Width="72"
                                 VerticalContentAlignment="Center"
                                 Text="160" />
                        <TextBlock Margin="8,0,12,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Text="行" />
                        <RadioButton x:Name="FullDayRadioButton"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center"
                                     Checked="FullDayRadioButton_Checked"
                                     Content="当日日志" />
                        <Button Padding="12,4"
                                Click="RefreshLogButton_Click"
                                Content="刷新日志" />
                    </StackPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Foreground="{DynamicResource GlobalTextBrush}"
                               Text="{Binding RecentLogHeader}"
                               TextWrapping="Wrap" />

                    <TextBox Grid.Row="2"
                             Margin="0,10,0,0"
                             FontFamily="Consolas"
                             Foreground="{DynamicResource GlobalTextBrush}"
                             Background="{DynamicResource GlobalBackground}"
                             BorderThickness="0"
                             IsReadOnly="True"
                             Text="{Binding RecentLogContent}"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Grid>
            </TabItem>
            <TabItem Header="AI 请求">
                <TextBox Margin="12"
                         FontFamily="Consolas"
                         Foreground="{DynamicResource GlobalTextBrush}"
                         Background="{DynamicResource GlobalBackground}"
                         BorderThickness="0"
                         IsReadOnly="True"
                         Text="{Binding AiPromptPreview}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Margin="0,0,8,0"
                    Padding="14,6"
                    Click="CopyDetailsButton_Click"
                    Content="复制详情" />
            <Button Margin="0,0,8,0"
                    Padding="14,6"
                    Click="AskAiButton_Click"
                    Content="询问 AI"
                    IsEnabled="{Binding CanAskAi}" />
            <Button Padding="14,6"
                    Click="CloseButton_Click"
                    Content="关闭" />
        </StackPanel>
    </Grid>
</Window>