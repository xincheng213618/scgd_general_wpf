<Window x:Class="ColorVision.Copilot.CopilotMcpSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ColorVision.Copilot"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Properties"
        Title="MCP Settings"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlobalBackground}"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:CopilotSettingsViewModel}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CopilotStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <SolidColorBrush x:Key="McpValidationErrorBrush" Color="#DB3340" />

        <Style x:Key="McpSurfaceBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotCardBorderStyle}" />

        <Style x:Key="McpTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CopilotPageTitleTextStyle}" />

        <Style x:Key="McpPanelTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource CopilotSectionTitleTextStyle}" />

        <Style x:Key="McpHintTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CopilotMutedTextStyle}">
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="McpSummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.58" />
        </Style>

        <Style x:Key="McpSummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="McpFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CopilotFieldLabelTextStyle}" />

        <Style x:Key="McpFooterStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Opacity" Value="0.66" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasUnsavedSettings}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Opacity" Value="0.92" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="2,2,2,10"
                Background="Transparent"
                BorderThickness="0">
            <StackPanel>
                <TextBlock Style="{StaticResource McpTitleTextStyle}" Text="MCP Settings" />
                <TextBlock Margin="0,4,0,0" Style="{StaticResource McpHintTextStyle}" Text="{Binding McpStatusText}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,0,0,10" Style="{StaticResource McpSurfaceBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="14">
                    <Border Margin="0,0,0,12"
                            Padding="10,8"
                            Style="{StaticResource CopilotSubtleSurfaceBorderStyle}">
                        <UniformGrid Columns="4">
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource McpSummaryLabelStyle}" Text="Service" />
                                <TextBlock Style="{StaticResource McpSummaryValueStyle}" Text="{Binding McpServiceSummaryText}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource McpSummaryLabelStyle}" Text="Activity" />
                                <TextBlock Style="{StaticResource McpSummaryValueStyle}" Text="{Binding McpActivitySummaryText}" />
                            </StackPanel>

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Style="{StaticResource McpSummaryLabelStyle}" Text="Review" />
                                <TextBlock Style="{StaticResource McpSummaryValueStyle}" Text="{Binding McpPendingSummaryText}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Style="{StaticResource McpSummaryLabelStyle}" Text="Error" />
                                <TextBlock Style="{StaticResource McpSummaryValueStyle}" Text="{Binding McpErrorSummaryText}" />
                            </StackPanel>
                        </UniformGrid>
                    </Border>

                    <TextBlock Style="{StaticResource McpPanelTitleStyle}" Text="Local server" />
                    <CheckBox Margin="0,8,0,10"
                              Content="Enable local MCP server"
                              Foreground="{DynamicResource GlobalTextBrush}"
                              IsChecked="{Binding McpEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="108" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource McpFieldLabelStyle}" Text="Port" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                            <TextBox Text="{Binding McpPortText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding McpPortValidationText}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="11"
                                       Text="{Binding McpPortValidationText}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource McpHintTextStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMcpPortValid}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource McpValidationErrorBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Opacity" Value="0.95" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Style="{StaticResource McpFieldLabelStyle}" Text="Endpoint" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" IsReadOnly="True" Text="{Binding McpEndpoint, Mode=OneWay}" />

                        <TextBlock Grid.Row="2" Style="{StaticResource McpFieldLabelStyle}" Text="Bearer token" />
                        <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,4" Command="{Binding RegenerateMcpTokenCommand}" Content="Regenerate token" />
                            <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,4" Command="{Binding CopyMcpTokenCommand}" Content="Copy" />
                            <Button DockPanel.Dock="Right" Margin="8,0,0,0" Width="54" Padding="6,2" Command="{Binding ToggleMcpBearerTokenVisibilityCommand}" Content="{Binding McpBearerTokenVisibilityText}" />
                            <TextBox IsReadOnly="True" IsReadOnlyCaretVisible="{Binding IsMcpBearerTokenVisible}" Text="{Binding McpBearerTokenDisplayText, Mode=OneWay}" />
                        </DockPanel>

                        <TextBlock Grid.Row="3" Style="{StaticResource McpFieldLabelStyle}" Text="Status" />
                        <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,4" Command="{Binding TestMcpConnectionCommand}" Content="Test Connection" IsEnabled="{Binding CanTestMcpConnection}" />
                            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="{Binding McpConnectionTestText}" TextWrapping="Wrap" />
                        </DockPanel>

                        <TextBlock Grid.Row="4" Style="{StaticResource McpFieldLabelStyle}" Text="Codex" />
                        <WrapPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,10">
                            <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding CopyCodexMcpConfigCommand}" Content="Copy Codex Config" />
                            <Button Padding="10,4" Command="{Binding CopyMcpTokenEnvironmentCommand}" Content="Copy Token Command" />
                        </WrapPanel>

                        <Expander Grid.Row="5"
                                  Grid.ColumnSpan="2"
                                  Margin="0,4,0,0"
                                  Header="{Binding McpDiagnosticsHeaderText}"
                                  IsExpanded="False"
                                  Foreground="{DynamicResource GlobalTextBrush}">
                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Foreground="{DynamicResource GlobalTextBrush}"
                                           Opacity="0.74"
                                           Text="{Binding McpDiagnosticsSummaryText}"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="1"
                                           Margin="0,6,0,8"
                                           Foreground="{DynamicResource GlobalTextBrush}"
                                           Opacity="0.74"
                                           Text="{Binding McpLastErrorText}"
                                           TextWrapping="Wrap" />

                                <Expander Grid.Row="2"
                                          Margin="0,0,0,8"
                                          Header="{Binding SubagentRolesSummaryText}"
                                          Foreground="{DynamicResource GlobalTextBrush}">
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                   Opacity="0.72"
                                                   Text="Plugin roles are opt-out individually. Disabled roles leave the model tool list after Apply, reducing prompt metadata and preventing execution."
                                                   TextWrapping="Wrap"/>
                                        <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding PluginSubagentRoles}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,6"
                                                                Padding="10,8"
                                                                Background="{DynamicResource GlobalBorderBrush}"
                                                                BorderBrush="{DynamicResource ButtonBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox Margin="0,2,10,0"
                                                                          VerticalAlignment="Top"
                                                                          IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <StackPanel Grid.Column="1">
                                                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}"/>
                                                                    <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.68" Text="{Binding SourceText}" TextWrapping="Wrap"/>
                                                                    <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.68" Text="{Binding PermissionSummary}" TextWrapping="Wrap"/>
                                                                    <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.68" Text="{Binding BudgetSummary}" TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <TextBox Height="100"
                                                 Margin="0,8,0,0"
                                                 FontFamily="Consolas"
                                                 FontSize="11"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 IsReadOnly="True"
                                                 Text="{Binding SubagentRolesDiagnosticsText, Mode=OneWay}"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto" />
                                    </StackPanel>
                                </Expander>

                                <TextBox Grid.Row="3"
                                         Height="96"
                                         IsReadOnly="True"
                                         Text="{Binding McpRecentAuditText, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />

                                <WrapPanel Grid.Row="4" Margin="0,8,0,0">
                                    <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding RefreshMcpDiagnosticsCommand}" Content="Refresh" />
                                    <Button Padding="10,4" Command="{Binding CopyMcpDiagnosticsCommand}" Content="Copy Diagnostics" />
                                </WrapPanel>
                            </Grid>
                        </Expander>
                    </Grid>

                    <Separator Margin="0,18,0,14" />
                    <TextBlock Style="{StaticResource McpPanelTitleStyle}" Text="Copilot MCP clients" />
                    <TextBlock Margin="0,5,0,8"
                               Style="{StaticResource McpHintTextStyle}"
                               Text="Connect Copilot to explicit Streamable HTTP MCP servers. One server per line: name | endpoint | token environment variable | default policy | optional tool=policy,... Use an exact tool list when possible; blank or * exposes every discovered tool."
                               TextWrapping="Wrap" />
                    <TextBox MinHeight="104"
                             AcceptsReturn="True"
                             Text="{Binding ExternalMcpServersText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBlock Margin="0,5,0,0"
                               FontSize="11"
                               Text="{Binding ExternalMcpServersValidationText}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource McpHintTextStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExternalMcpServersValid}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource McpValidationErrorBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Opacity" Value="0.95" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <DockPanel Margin="0,6,0,0" LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                Margin="10,0,0,0"
                                Padding="10,4"
                                Command="{Binding RefreshExternalMcpClientsCommand}"
                                Content="Refresh Discovery" />
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource McpHintTextStyle}"
                                   Text="{Binding ExternalMcpClientsStatusText}"
                                   TextWrapping="Wrap" />
                    </DockPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Style="{StaticResource McpFooterStatusTextStyle}" Text="{Binding McpStatusText}" />
            <Button Grid.Column="1"
                    Margin="0,0,8,0"
                    Padding="14,6"
                    Click="CloseButton_Click"
                    Content="{x:Static properties:Resources.Close}"
                    IsCancel="True" />
            <Button Grid.Column="2"
                    Margin="0,0,8,0"
                    Padding="14,6"
                    Click="ApplyButton_Click"
                    Content="Apply"
                    IsEnabled="{Binding CanApplySettings}" />
            <Button Grid.Column="3"
                    Padding="14,6"
                    Click="SaveButton_Click"
                    Content="{x:Static properties:Resources.Save}"
                    IsEnabled="{Binding CanSaveSettings}"
                    Style="{StaticResource CopilotPrimaryButtonStyle}" />
        </Grid>
    </Grid>
</Window>
