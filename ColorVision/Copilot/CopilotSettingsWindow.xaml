<Window x:Class="ColorVision.Copilot.CopilotSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ColorVision.Copilot"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Properties"
        Title="{x:Static properties:Resources.CopilotLanguageModel}"
        Width="960"
        Height="700"
        MinWidth="860"
        MinHeight="620"
        Background="{DynamicResource GlobalBackground}"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:CopilotSettingsViewModel}">
    <Window.Resources>
        <Style x:Key="SettingsSurfaceBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="16,16,16,0" Padding="14,10" Style="{StaticResource SettingsSurfaceBorderStyle}">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource GlobalTextBrush}" Text="{x:Static properties:Resources.CopilotLanguageModel}" />
                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="{x:Static properties:Resources.CopilotModelConfigDescription}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16,12,16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SettingsSurfaceBorderStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="12,12,12,10">
                        <WrapPanel>
                            <ComboBox Width="132"
                                      ItemsSource="{Binding VendorOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding NewProfileVendorType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="8,0,0,0" Padding="10,4" Command="{Binding AddProfileCommand}" Content="{x:Static properties:Resources.CopilotAddModel}" />
                            <Button Margin="8,0,0,0" Padding="10,4" Command="{Binding DuplicateProfileCommand}" Content="{x:Static properties:Resources.Copy}" IsEnabled="{Binding CanEditSelectedProfile}" />
                            <Button Margin="8,0,0,0" Padding="10,4" Command="{Binding DeleteProfileCommand}" Content="{x:Static properties:Resources.Delete}" IsEnabled="{Binding CanEditSelectedProfile}" />
                        </WrapPanel>
                        <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.62" Text="{x:Static properties:Resources.CopilotVendorHint}" TextWrapping="Wrap" />
                    </StackPanel>

                    <ListBox Margin="8,0,8,8" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotProfileConfig}">
                                <Border Padding="10,8">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding DisplayLabel}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="{Binding SecondaryLabel}" />
                                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.55" Text="{Binding BaseUrl}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SettingsSurfaceBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="14" IsEnabled="{Binding CanEditSelectedProfile}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="{x:Static properties:Resources.CopilotName}" />
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="1" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="{x:Static properties:Resources.CopilotVendor}" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,0,0,10"
                              ItemsSource="{Binding VendorOptions}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedProfile.VendorType, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="{x:Static properties:Resources.CopilotProtocol}" />
                    <ComboBox Grid.Row="2"
                              Grid.Column="1"
                              Margin="0,0,0,10"
                              ItemsSource="{Binding ProviderOptions}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedProfile.ProviderType, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="3" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="Base URL" />
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Text="{Binding SelectedProfile.BaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="4" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="API Key" />
                    <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,10" Text="{Binding SelectedProfile.ApiKey, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="5" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="{x:Static properties:Resources.CopilotModel}" />
                    <ComboBox Grid.Row="5"
                              Grid.Column="1"
                              Margin="0,0,0,10"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              ItemsSource="{Binding AvailableModelPresets}"
                              Text="{Binding SelectedProfile.Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Grid Grid.Row="6" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="{x:Static properties:Resources.CopilotMaxToken}" />
                        <TextBox Grid.Column="1" Text="{Binding SelectedProfile.MaxTokens, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Column="3" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="{x:Static properties:Resources.CopilotTemperature}" />
                        <TextBox Grid.Column="4" Text="{Binding SelectedProfile.Temperature, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <TextBlock Grid.Row="7" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="{x:Static properties:Resources.CopilotToolRounds}" />
                    <TextBox Grid.Row="7" Grid.Column="1" Margin="0,0,0,10" Text="{Binding SelectedProfile.MaxToolRounds, UpdateSourceTrigger=PropertyChanged}" />

                    <Border Grid.Row="8" Grid.ColumnSpan="2" Margin="0,4,0,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" />

                    <TextBlock Grid.Row="9" Grid.ColumnSpan="2" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="{DynamicResource GlobalTextBrush}" Text="Local MCP" />

                    <CheckBox Grid.Row="10" Grid.ColumnSpan="2" Margin="0,0,0,10" Content="Enable local MCP server" Foreground="{DynamicResource GlobalTextBrush}" IsChecked="{Binding McpEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="11" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="Port" />
                    <TextBox Grid.Row="11" Grid.Column="1" Margin="0,0,0,10" Text="{Binding McpPort, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="12" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="Endpoint" />
                    <TextBox Grid.Row="12" Grid.Column="1" Margin="0,0,0,10" IsReadOnly="True" Text="{Binding McpEndpoint, Mode=OneWay}" />

                    <TextBlock Grid.Row="13" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="Bearer token" />
                    <DockPanel Grid.Row="13" Grid.Column="1" Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,4" Command="{Binding RegenerateMcpTokenCommand}" Content="Regenerate token" />
                        <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,4" Command="{Binding CopyMcpTokenCommand}" Content="Copy" />
                        <TextBox IsReadOnly="True" IsReadOnlyCaretVisible="True" Text="{Binding McpBearerToken, Mode=OneWay}" />
                    </DockPanel>

                    <TextBlock Grid.Row="14" Margin="0,8,12,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="Status" />
                    <DockPanel Grid.Row="14" Grid.Column="1" Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,4" Command="{Binding TestMcpConnectionCommand}" Content="Test Connection" IsEnabled="{Binding CanTestMcpConnection}" />
                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="{Binding McpStatusText}" TextWrapping="Wrap" />
                    </DockPanel>

                    <TextBlock Grid.Row="15" Grid.Column="1" Margin="0,0,0,10" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="{Binding McpConnectionTestText}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="16" Margin="0,8,12,0" VerticalAlignment="Top" Foreground="{DynamicResource GlobalTextBrush}" Text="{x:Static properties:Resources.CopilotSystemPrompt}" />
                    <TextBox Grid.Row="16"
                             Grid.Column="1"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Text="{Binding SelectedProfile.SystemPrompt, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="16,0,16,16" Padding="12,10" Style="{StaticResource SettingsSurfaceBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="{x:Static properties:Resources.CopilotSettingsHint}" TextWrapping="Wrap" />
                <Button Grid.Column="1" Margin="0,0,8,0" Padding="14,6" Click="CancelButton_Click" Content="{x:Static properties:Resources.Cancel}" />
                <Button Grid.Column="2" Margin="0,0,8,0" Padding="14,6" Click="ApplyButton_Click" Content="Apply" />
                <Button Grid.Column="3" Padding="14,6" Click="SaveButton_Click" Content="{x:Static properties:Resources.Save}" />
            </Grid>
        </Border>
    </Grid>
</Window>
