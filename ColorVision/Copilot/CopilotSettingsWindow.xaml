<Window x:Class="ColorVision.Copilot.CopilotSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ColorVision.Copilot"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Properties"
        Title="{x:Static properties:Resources.CopilotLanguageModel}"
        Width="920"
        Height="640"
        MinWidth="780"
        MinHeight="540"
        Background="{DynamicResource GlobalBackground}"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:CopilotSettingsViewModel}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CopilotStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style x:Key="SettingsSurfaceBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotCardBorderStyle}">
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="SettingsPanelTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource CopilotSectionTitleTextStyle}" />

        <Style x:Key="SettingsHintTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CopilotMutedTextStyle}">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="None" />
        </Style>

        <Style x:Key="SettingsSummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SettingsSummaryValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="SettingsFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource CopilotFieldLabelTextStyle}" />

        <Style x:Key="SettingsDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,14,0,14" />
            <Setter Property="Background" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>

        <Style x:Key="SettingsQuickAddPreviewBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotSubtleSurfaceBorderStyle}">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="SettingsUsageBandBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotSubtleSurfaceBorderStyle}">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="10,7" />
        </Style>

        <Style x:Key="SettingsFooterStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,3,0,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.62" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasUnsavedSettings}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Opacity" Value="0.92" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CopilotPrimaryButtonStyle}" />

        <Style x:Key="ProfileStatusPillBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Opacity" Value="0.68" />
        </Style>

        <Style x:Key="ProfileStatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsConfigured}" Value="False">
                    <Setter Property="Opacity" Value="0.74" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl x:Name="SettingsTabs" Grid.Row="0" Margin="12,12,12,10">
            <TabItem Header="Models">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SettingsSurfaceBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="12,10,10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource SettingsPanelTitleStyle}"
                                   Text="{x:Static properties:Resources.CopilotLanguageModel}" />
                        <Button Grid.Column="1"
                                Padding="12,5"
                                Click="OpenAddModelButton_Click"
                                Content="{x:Static properties:Resources.CopilotAddModel}"
                                Style="{StaticResource PrimaryActionButtonStyle}" />
                    </Grid>

                    <DockPanel Grid.Row="1" Margin="8,0,8,8">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding DuplicateProfileCommand}" Content="{x:Static properties:Resources.Copy}" IsEnabled="{Binding CanEditSelectedProfile}" />
                                <Button Padding="10,4" Command="{Binding DeleteProfileCommand}" Content="{x:Static properties:Resources.Delete}" IsEnabled="{Binding CanEditSelectedProfile}" />
                            </StackPanel>
                        </DockPanel>

                        <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:CopilotProfileConfig}">
                                    <Border Padding="9,7">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Margin="0,0,8,0"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Text="{Binding DisplayLabel}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Grid.Column="1"
                                                        Style="{StaticResource ProfileStatusPillBorderStyle}"
                                                        ToolTip="{Binding ConfigurationStatusToolTip}">
                                                    <TextBlock Style="{StaticResource ProfileStatusTextStyle}"
                                                               Text="{Binding ConfigurationStatusText}" />
                                                </Border>
                                            </Grid>
                                            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="{Binding SecondaryLabel}" />
                                            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.55" Text="{Binding BaseUrl}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SettingsSurfaceBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="14">
                        <StackPanel IsEnabled="{Binding CanEditSelectedProfile}">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource SettingsPanelTitleStyle}" Text="Connection" />
                                    <TextBlock Margin="0,6,0,0" Style="{StaticResource SettingsHintTextStyle}" Text="{Binding SelectedProfile.SecondaryLabel}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        MinWidth="96"
                                        Padding="12,5"
                                        VerticalAlignment="Top"
                                        Command="{Binding UseSelectedProfileInChatCommand}"
                                        Content="{Binding SelectedProfileUsageActionText}"
                                        IsEnabled="{Binding CanUseSelectedProfileInChat}" />
                            </Grid>

                            <Border Style="{StaticResource SettingsUsageBandBorderStyle}">
                                <TextBlock Foreground="{DynamicResource GlobalTextBrush}"
                                           Opacity="0.76"
                                           Text="{Binding SelectedProfileUsageText}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="104" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Static properties:Resources.CopilotName}" />
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="1" Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Static properties:Resources.CopilotVendor}" />
                                <ComboBox Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="0,0,0,10"
                                          ItemsSource="{Binding VendorOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedProfile.VendorType, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Static properties:Resources.CopilotApiKey}" />
                                <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <PasswordBox Grid.Column="0"
                                                 local:PasswordBoxBinding.BindPassword="True"
                                                 local:PasswordBoxBinding.BoundPassword="{Binding SelectedProfile.ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding IsSelectedProfileApiKeyHidden, Converter={StaticResource BoolToVisibility}}" />
                                    <TextBox Grid.Column="0"
                                             Text="{Binding SelectedProfile.ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsSelectedProfileApiKeyVisible, Converter={StaticResource BoolToVisibility}}" />
                                    <Button Grid.Column="2"
                                            Width="48"
                                            Padding="6,2"
                                            Command="{Binding ToggleSelectedProfileApiKeyVisibilityCommand}"
                                            Content="{Binding SelectedProfileApiKeyVisibilityText}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="3"
                                               Margin="0,5,0,0"
                                               FontSize="11"
                                               Foreground="#E6A23C"
                                               Text="The saved API key could not be decrypted for this Windows user. Enter it again to continue."
                                               TextWrapping="Wrap"
                                               Visibility="{Binding SelectedProfile.CredentialNeedsReentry, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>

                                <TextBlock Grid.Row="3" Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Static properties:Resources.CopilotModel}" />
                                <ComboBox Grid.Row="3"
                                          Grid.Column="1"
                                          Margin="0,0,0,10"
                                          IsEditable="True"
                                          IsTextSearchEnabled="False"
                                          ItemsSource="{Binding AvailableModelPresets}"
                                          Text="{Binding SelectedProfile.Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="4" Style="{StaticResource SettingsFieldLabelStyle}" Text="Test" />
                                <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,10">
                                    <Button DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Padding="10,4"
                                            Command="{Binding TestSelectedProfileCommand}"
                                            Content="Test Model"
                                            IsEnabled="{Binding CanTestSelectedProfile}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource GlobalTextBrush}"
                                               Opacity="0.72"
                                               Text="{Binding SelectedProfileConnectionTestText}"
                                               TextWrapping="Wrap" />
                                </DockPanel>
                            </Grid>

                            <Expander Margin="0,4,0,0" Header="Connection settings" IsExpanded="False" Foreground="{DynamicResource GlobalTextBrush}">
                                <StackPanel Margin="0,10,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="104" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="{x:Static properties:Resources.CopilotProtocol}" />
                                        <ComboBox Grid.Row="0"
                                                  Grid.Column="1"
                                                  Margin="0,0,0,10"
                                                  ItemsSource="{Binding ProviderOptions}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding SelectedProfile.ProviderType, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="1" Style="{StaticResource SettingsFieldLabelStyle}" Text="Base URL" />
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedProfile.BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </StackPanel>
                            </Expander>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
            </TabItem>

            <TabItem Header="Agent">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Border Margin="12" Padding="18" Style="{StaticResource SettingsSurfaceBorderStyle}">
                        <StackPanel MaxWidth="760">
                            <TextBlock Style="{StaticResource SettingsPanelTitleStyle}" Text="Agent defaults" />
                            <TextBlock Margin="0,6,0,16"
                                       Style="{StaticResource SettingsHintTextStyle}"
                                       Text="Shared by every model connection. These values bound a complete Agent task; model connection and generation settings stay independent."
                                       TextWrapping="Wrap" />

                            <Border Style="{StaticResource SettingsUsageBandBorderStyle}">
                                <TextBlock Foreground="{DynamicResource GlobalTextBrush}"
                                           Opacity="0.76"
                                           Text="Long-running defaults: a 1M context window, 1M cumulative request tokens, 128 tool calls, 32 Agent passes, and a two-hour wall-clock window. Per-request overrides can still tighten a specific task."
                                           TextWrapping="Wrap" />
                            </Border>

                            <Grid Margin="0,4,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Style="{StaticResource SettingsFieldLabelStyle}" Text="Context window" />
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,12,10" Text="{Binding AgentContextWindowTokens, UpdateSourceTrigger=PropertyChanged}" ToolTip="Context window used by Agent compaction and Skill metadata budgeting." />
                                <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource SettingsHintTextStyle}" Text="32,768–1,048,576; default 1,048,576" />

                                <TextBlock Grid.Row="1" Style="{StaticResource SettingsFieldLabelStyle}" Text="Request tokens" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,12,10" Text="{Binding AgentRequestTokenBudget, UpdateSourceTrigger=PropertyChanged}" ToolTip="Cumulative provider-token budget across one Agent task." />
                                <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource SettingsHintTextStyle}" Text="4,096–1,048,576; default 1,048,576" />

                                <TextBlock Grid.Row="2" Style="{StaticResource SettingsFieldLabelStyle}" Text="Tool calls" />
                                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,12,10" Text="{Binding MaxAgentToolCalls, UpdateSourceTrigger=PropertyChanged}" ToolTip="Maximum business tool calls during one Agent task." />
                                <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource SettingsHintTextStyle}" Text="1–512; default 128" />

                                <TextBlock Grid.Row="3" Style="{StaticResource SettingsFieldLabelStyle}" Text="Agent passes" />
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,12,10" Text="{Binding MaxAgentPasses, UpdateSourceTrigger=PropertyChanged}" ToolTip="Maximum automatic continuation passes for an incomplete task." />
                                <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource SettingsHintTextStyle}" Text="1–128; default 32" />

                                <TextBlock Grid.Row="4" Style="{StaticResource SettingsFieldLabelStyle}" Text="Timeout (seconds)" />
                                <TextBox Grid.Row="4" Grid.Column="1" Margin="0,0,12,10" Text="{Binding AgentTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" ToolTip="Total wall-clock budget for one Agent task." />
                                <TextBlock Grid.Row="4" Grid.Column="2" Style="{StaticResource SettingsHintTextStyle}" Text="1–86,400; default 7,200" />

                                <TextBlock Grid.Row="5" Style="{StaticResource SettingsFieldLabelStyle}" Text="Default shell" />
                                <ComboBox Grid.Row="5"
                                          Grid.Column="1"
                                          Grid.ColumnSpan="2"
                                          ItemsSource="{Binding ShellOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding PreferredShell, UpdateSourceTrigger=PropertyChanged}"
                                          ToolTip="Default Windows shell used by approved Agent command execution." />
                            </Grid>

                            <Expander Margin="0,18,0,0"
                                      Header="{Binding AgentSkillsSummaryText}"
                                      IsExpanded="True">
                                <StackPanel Margin="0,10,0,0">
                                    <TextBlock Style="{StaticResource SettingsHintTextStyle}"
                                               Text="Overrides are independent of model profiles. Auto keeps author policy and consecutive-miss demotion; Off hides a Skill without deleting its files."
                                               TextWrapping="Wrap" />
                                    <Grid Margin="0,10,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding NewAgentSkillName, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Agent Skill name: lowercase letters, numbers, and hyphens." />
                                        <Button Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Padding="12,4"
                                                Command="{Binding AddAgentSkillOverrideCommand}"
                                                Content="Add override" />
                                    </Grid>

                                    <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding AgentSkillSettings}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,6"
                                                            Padding="10,8"
                                                            Background="{DynamicResource GlobalBorderBrush}"
                                                            BorderBrush="{DynamicResource ButtonBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="150" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock VerticalAlignment="Center"
                                                                       FontFamily="Consolas"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding Name}" />
                                                            <ComboBox Grid.Column="1"
                                                                      Margin="8,0"
                                                                      ItemsSource="{Binding DataContext.AgentSkillOverrideOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      DisplayMemberPath="Label"
                                                                      SelectedValuePath="State"
                                                                      SelectedValue="{Binding State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <Button Grid.Column="2"
                                                                    Padding="8,3"
                                                                    Command="{Binding DataContext.RemoveAgentSkillOverrideCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="Reset"
                                                                    ToolTip="Reset tracked skills to Auto; remove untracked override entries." />
                                                            <TextBlock Grid.Row="1"
                                                                       Grid.ColumnSpan="3"
                                                                       Margin="0,5,0,0"
                                                                       Style="{StaticResource SettingsHintTextStyle}"
                                                                       Text="{Binding UsageSummary}"
                                                                       TextWrapping="Wrap" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <DockPanel Margin="0,8,0,0">
                                        <Button DockPanel.Dock="Right"
                                                Padding="10,3"
                                                Command="{Binding RefreshAgentSkillDiagnosticsCommand}"
                                                Content="Refresh usage"
                                                ToolTip="Reload local Skill selection and load evidence." />
                                        <TextBlock VerticalAlignment="Center"
                                                   Style="{StaticResource SettingsHintTextStyle}"
                                                   Text="Local usage evidence" />
                                    </DockPanel>
                                    <TextBox Height="96"
                                             Margin="0,6,0,0"
                                             FontFamily="Consolas"
                                             FontSize="11"
                                             HorizontalScrollBarVisibility="Auto"
                                             IsReadOnly="True"
                                             Text="{Binding AgentSkillsDiagnosticsText, Mode=OneWay}"
                                             TextWrapping="NoWrap"
                                             VerticalScrollBarVisibility="Auto" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="MCP">
                <ScrollViewer Padding="10"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <local:CopilotMcpSettingsControl DataContext="{Binding}"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1"
                Margin="12,0,12,12"
                Padding="0,10,0,0"
                Background="Transparent"
                BorderBrush="{DynamicResource ButtonBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource SettingsFooterStatusTextStyle}"
                           Text="{Binding SettingsStatusText}" />
                <Button Grid.Column="1" Margin="0,0,8,0" Padding="14,6" Click="CancelButton_Click" Content="{Binding SettingsCancelButtonText}" />
                <Button Grid.Column="2"
                        Margin="0,0,8,0"
                        Padding="14,6"
                        Click="ApplyButton_Click"
                        Content="Apply"
                        IsEnabled="{Binding CanApplySettings}" />
                <Button Grid.Column="3"
                        Padding="14,6"
                        Click="SaveButton_Click"
                        Content="{x:Static properties:Resources.Save}"
                        IsEnabled="{Binding CanSaveSettings}"
                        Style="{StaticResource CopilotPrimaryButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Window>
