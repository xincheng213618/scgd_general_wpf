<UserControl x:Class="ColorVision.Copilot.CopilotMcpSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.Copilot"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:CopilotSettingsViewModel}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CopilotStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <SolidColorBrush x:Key="McpValidationErrorBrush" Color="#DB3340"/>

        <Style x:Key="McpSurfaceBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotCardBorderStyle}" />

        <Style x:Key="McpPanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
        </Style>

        <Style x:Key="McpHintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Opacity" Value="0.66"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="McpSummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Opacity" Value="0.58"/>
        </Style>

        <Style x:Key="McpSummaryValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="McpFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,14,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="Opacity" Value="0.82"/>
        </Style>

        <Style x:Key="McpFooterStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.66"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasUnsavedSettings}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Opacity" Value="0.92"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <Border Padding="16,14" Style="{StaticResource McpSurfaceBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Style="{StaticResource McpPanelTitleStyle}"
                           Text="Local server"/>
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,18"
                           Style="{StaticResource McpHintTextStyle}"
                           Text="{Binding McpStatusText}"/>

                <UniformGrid Grid.Row="2" Columns="4">
                    <StackPanel Margin="0,0,18,0">
                        <TextBlock Style="{StaticResource McpSummaryLabelStyle}" Text="Service"/>
                        <TextBlock Style="{StaticResource McpSummaryValueStyle}" Text="{Binding McpServiceSummaryText}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,18,0">
                        <TextBlock Style="{StaticResource McpSummaryLabelStyle}" Text="Activity"/>
                        <TextBlock Style="{StaticResource McpSummaryValueStyle}" Text="{Binding McpActivitySummaryText}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,18,0">
                        <TextBlock Style="{StaticResource McpSummaryLabelStyle}" Text="Review"/>
                        <TextBlock Style="{StaticResource McpSummaryValueStyle}" Text="{Binding McpPendingSummaryText}"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Style="{StaticResource McpSummaryLabelStyle}" Text="Error"/>
                        <TextBlock Style="{StaticResource McpSummaryValueStyle}" Text="{Binding McpErrorSummaryText}"/>
                    </StackPanel>
                </UniformGrid>
            </Grid>
        </Border>

        <Border Margin="0,12,0,0" Padding="16,14" Style="{StaticResource McpSurfaceBorderStyle}">
            <StackPanel>
                <CheckBox Margin="0,0,0,18"
                          Content="Enable local MCP server"
                          Foreground="{DynamicResource GlobalTextBrush}"
                          IsChecked="{Binding McpEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="126"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource McpFieldLabelStyle}" Text="Port"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,14">
                        <TextBox Text="{Binding McpPortText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{Binding McpPortValidationText}"/>
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding McpPortValidationText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource McpHintTextStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMcpPortValid}" Value="False">
                                            <Setter Property="Foreground" Value="{StaticResource McpValidationErrorBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Opacity" Value="0.95"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Style="{StaticResource McpFieldLabelStyle}" Text="Endpoint"/>
                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Margin="0,0,0,14"
                             IsReadOnly="True"
                             Text="{Binding McpEndpoint, Mode=OneWay}"/>

                    <TextBlock Grid.Row="2" Style="{StaticResource McpFieldLabelStyle}" Text="Bearer token"/>
                    <DockPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,14">
                        <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,4" Command="{Binding RegenerateMcpTokenCommand}" Content="Regenerate"/>
                        <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,4" Command="{Binding CopyMcpTokenCommand}" Content="{x:Static properties:Resources.Copy}"/>
                        <Button DockPanel.Dock="Right" Margin="8,0,0,0" Width="56" Padding="6,2" Command="{Binding ToggleMcpBearerTokenVisibilityCommand}" Content="{Binding McpBearerTokenVisibilityText}"/>
                        <TextBox IsReadOnly="True"
                                 IsReadOnlyCaretVisible="{Binding IsMcpBearerTokenVisible}"
                                 Text="{Binding McpBearerTokenDisplayText, Mode=OneWay}"/>
                    </DockPanel>

                    <TextBlock Grid.Row="3" Style="{StaticResource McpFieldLabelStyle}" Text="Status"/>
                    <DockPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,14">
                        <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="10,4" Command="{Binding TestMcpConnectionCommand}" Content="Test Connection" IsEnabled="{Binding CanTestMcpConnection}"/>
                        <TextBlock Margin="0,5,0,0" Style="{StaticResource McpHintTextStyle}" Text="{Binding McpConnectionTestText}"/>
                    </DockPanel>

                    <TextBlock Grid.Row="4" Style="{StaticResource McpFieldLabelStyle}" Text="Codex"/>
                    <WrapPanel Grid.Row="4" Grid.Column="1">
                        <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding CopyCodexMcpConfigCommand}" Content="Copy Codex Config"/>
                        <Button Padding="10,4" Command="{Binding CopyMcpTokenEnvironmentCommand}" Content="Copy Token Command"/>
                    </WrapPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Margin="0,12,0,0" Padding="16,14" Style="{StaticResource McpSurfaceBorderStyle}">
            <Expander Header="{Binding McpDiagnosticsHeaderText}"
                      IsExpanded="False"
                      Foreground="{DynamicResource GlobalTextBrush}">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Style="{StaticResource McpHintTextStyle}"
                               Text="{Binding McpDiagnosticsSummaryText}"/>
                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,10"
                               Style="{StaticResource McpHintTextStyle}"
                               Text="{Binding McpLastErrorText}"/>
                    <Expander Grid.Row="2"
                              Margin="0,0,0,10"
                              Header="{Binding SubagentRolesSummaryText}"
                              Foreground="{DynamicResource GlobalTextBrush}">
                        <TextBox Height="138"
                                 Margin="0,8,0,0"
                                 FontFamily="Consolas"
                                 FontSize="11"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 Text="{Binding SubagentRolesDiagnosticsText, Mode=OneWay}"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Expander>
                    <TextBox Grid.Row="3"
                             Height="116"
                             IsReadOnly="True"
                             Text="{Binding McpRecentAuditText, Mode=OneWay}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                    <WrapPanel Grid.Row="4" Margin="0,10,0,0">
                        <Button Margin="0,0,8,0" Padding="10,4" Command="{Binding RefreshMcpDiagnosticsCommand}" Content="Refresh"/>
                        <Button Padding="10,4" Command="{Binding CopyMcpDiagnosticsCommand}" Content="Copy Diagnostics"/>
                    </WrapPanel>
                </Grid>
            </Expander>
        </Border>

        <Border Margin="0,12,0,0" Padding="12,10" Style="{StaticResource McpSurfaceBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource McpFooterStatusTextStyle}"
                           Text="{Binding SettingsStatusText}"/>
                <Button Grid.Column="1"
                        Margin="0,0,8,0"
                        Padding="14,6"
                        Click="ApplyButton_Click"
                        Content="Apply"
                        IsEnabled="{Binding CanApplySettings}"/>
                <Button Grid.Column="2"
                        Padding="14,6"
                        Click="SaveButton_Click"
                        Content="{x:Static properties:Resources.Save}"
                        IsEnabled="{Binding CanSaveSettings}"
                        Style="{StaticResource CopilotPrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
