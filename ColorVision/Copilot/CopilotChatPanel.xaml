<UserControl x:Class="ColorVision.Copilot.CopilotChatPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.Copilot"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:CopilotChatViewModel}" d:Height="500" d:Width="600">
    <UserControl.Resources>
        <Style x:Key="AssistantPlainTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
            <Setter Property="Opacity" Value="0.94" />
        </Style>
        <Style x:Key="ReadOnlyMessageTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style x:Key="MessageActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.54" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.84" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.28" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ComposerComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="CopilotIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.76" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComposerPrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UserMessageTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ReadOnlyMessageTextBoxStyle}">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style x:Key="UserMessageMetaTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style x:Key="UserMessageActionButtonStyle" TargetType="Button" BasedOn="{StaticResource MessageActionButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style x:Key="CopilotSurfaceBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style x:Key="CopilotInsetBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotSurfaceBorderStyle}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
        </Style>
        <Style x:Key="CopilotPillBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotInsetBorderStyle}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style x:Key="ComposerShellBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotSurfaceBorderStyle}">
            <Setter Property="Background" Value="{DynamicResource GlobalBackground}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style x:Key="ContextActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SidebarListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="10,2" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource GlobalBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="SidebarColumnDefinition" Width="220" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="16,14,16,0"
                    Padding="0,0,0,12"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock MaxWidth="560"
                               VerticalAlignment="Center"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource GlobalTextBrush}"
                               Text="{Binding SelectedConversation.Title, FallbackValue={x:Static properties:Resources.CopilotNewConversation}, TargetNullValue={x:Static properties:Resources.CopilotNewConversation}}"
                               TextTrimming="CharacterEllipsis" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="TitleBarConversationButton"
                                Margin="0,0,6,0"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Click="ToggleConversationSidebarButton_Click"
                                ToolTip="{x:Static properties:Resources.CopilotExpandConversationList}"
                                Visibility="Collapsed">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE8A7;" />
                        </Button>

                        <Button Margin="0,0,6,0"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Command="{Binding NewChatCommand}"
                                IsEnabled="{Binding CanSwitchConversation}"
                                ToolTip="{x:Static properties:Resources.CopilotNewConversation}">
                            <TextBlock FontSize="18"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="✚" />
                        </Button>

                        <Button Style="{StaticResource CopilotIconButtonStyle}"
                                Command="{Binding OpenSettingsCommand}"
                                IsEnabled="{Binding CanSwitchConversation}"
                                ToolTip="{x:Static properties:Resources.CopilotConfigureCopilot}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE713;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="18,12,18,0"
                        Padding="12,10"
                        Style="{StaticResource CopilotInsetBorderStyle}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding HasPendingActionPanel, Converter={StaticResource bool2VisibilityConverter}}">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="Pending Actions" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Opacity="0.62"
                                       Text="Approve in ColorVision before MCP can execute" />
                        </DockPanel>

                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.72"
                                   Text="{Binding PendingActionFeedbackText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasPendingActionFeedback, Converter={StaticResource bool2VisibilityConverter}}" />

                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding PendingActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10,8"
                                            Style="{StaticResource CopilotSurfaceBorderStyle}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock MaxWidth="360"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Text="{Binding Title}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Margin="8,0,0,0"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.66"
                                                               Text="{Binding RiskLevel}" />
                                                    <TextBlock Margin="8,0,0,0"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.52"
                                                               Text="{Binding ExpiresAtLabel, StringFormat=expires {0}}" />
                                                </DockPanel>
                                                <WrapPanel Margin="0,4,0,0">
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.68"
                                                               Text="action_id:" />
                                                    <TextBlock Margin="4,0,10,0"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.72"
                                                               Text="{Binding ActionId}" />
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.68"
                                                               Text="tool_name:" />
                                                    <TextBlock Margin="4,0,10,0"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.72"
                                                               Text="{Binding ToolName}" />
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.68"
                                                               Text="expires_at:" />
                                                    <TextBlock Margin="4,0,0,0"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.72"
                                                               Text="{Binding ExpiresAtLabel}" />
                                                </WrapPanel>
                                                <TextBlock Margin="0,3,0,0"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Opacity="0.74"
                                                           Text="{Binding Description}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,3,0,0"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Opacity="0.58"
                                                           Text="{Binding ArgumentsSummary, StringFormat=params: {0}}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Margin="12,0,0,0"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                    <Button Margin="0,0,6,0"
                                                        Padding="10,4"
                                                        Command="{Binding DataContext.CopyPendingActionIdCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Copy ID" />
                                                <Button Margin="0,0,6,0"
                                                        Padding="10,4"
                                                        Command="{Binding DataContext.CopyPendingActionPayloadCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Copy Payload" />
                                                <Button Margin="0,0,6,0"
                                                        Padding="10,4"
                                                        Command="{Binding DataContext.ApprovePendingActionCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Approve" />
                                                <Button Padding="10,4"
                                                        Command="{Binding DataContext.RejectPendingActionCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Reject" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MaxWidth="320"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Opacity="0.68"
                           Text="{Binding EmptyStateText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsConversationEmpty, Converter={StaticResource bool2VisibilityConverter}}" />

                <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl Margin="18,14,18,14" ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotChatMessage}">
                                <Grid Margin="0,0,0,22">
                                    <Border x:Name="UserBubble"
                                            MaxWidth="440"
                                            Padding="14,11"
                                            HorizontalAlignment="Right"
                                            Background="{DynamicResource PrimaryBrush}"
                                            BorderBrush="{DynamicResource PrimaryBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBox Style="{StaticResource UserMessageTextBoxStyle}"
                                                     Text="{Binding Content, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel x:Name="AssistantPanel"
                                                Margin="2,0,30,0"
                                                Visibility="Collapsed">
                                        <Expander Margin="0,0,0,8"
                                                  Foreground="{DynamicResource GlobalTextBrush}"
                                                  Header="{Binding ExecutionHeader}"
                                                  IsExpanded="{Binding IsExecutionExpanded, Mode=TwoWay}"
                                                  Visibility="{Binding HasExecutionTrace, Converter={StaticResource bool2VisibilityConverter}}">
                                            <Border Margin="0,6,0,0"
                                                    Padding="12,8"
                                                    Style="{StaticResource CopilotInsetBorderStyle}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBox Style="{StaticResource ReadOnlyMessageTextBoxStyle}"
                                                         Opacity="0.9"
                                                         Text="{Binding ExecutionContent, Mode=OneWay}" />
                                            </Border>
                                        </Expander>

                                        <Expander Margin="0,0,0,8"
                                                  Foreground="{DynamicResource GlobalTextBrush}"
                                                  Header="{Binding ReasoningHeader}"
                                                  IsExpanded="{Binding IsReasoningExpanded, Mode=TwoWay}"
                                                  Visibility="{Binding HasReasoning, Converter={StaticResource bool2VisibilityConverter}}">
                                            <Border Margin="0,6,0,0"
                                                    Padding="12,8"
                                                    Style="{StaticResource CopilotInsetBorderStyle}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <TextBox Style="{StaticResource ReadOnlyMessageTextBoxStyle}"
                                                         Opacity="0.88"
                                                         Text="{Binding ReasoningContent, Mode=OneWay}" />
                                            </Border>
                                        </Expander>

                                        <TextBox Style="{StaticResource ReadOnlyMessageTextBoxStyle}"
                                                 Opacity="0.94"
                                                 Text="{Binding Content, Mode=OneWay}" />

                                        <StackPanel Margin="0,10,0,0"
                                                    Orientation="Horizontal">
                                            <Button Style="{StaticResource MessageActionButtonStyle}"
                                                    Command="{Binding DataContext.CopyMessageCommand, Source={x:Reference Root}}"
                                                    CommandParameter="{Binding}"
                                                    Content="{x:Static properties:Resources.Copy}"
                                                    ToolTip="{x:Static properties:Resources.CopilotCopyMessage}" />
                                            <Button Style="{StaticResource MessageActionButtonStyle}"
                                                    Command="{Binding DataContext.RetryMessageCommand, Source={x:Reference Root}}"
                                                    CommandParameter="{Binding}"
                                                    Content="{x:Static properties:Resources.CopilotRetry}"
                                                    ToolTip="{x:Static properties:Resources.CopilotRegenerateAnswer}" />
                                            <Button Style="{StaticResource MessageActionButtonStyle}"
                                                    Margin="0"
                                                    Command="{Binding DataContext.RefreshMessageCommand, Source={x:Reference Root}}"
                                                    CommandParameter="{Binding}"
                                                    Content="{x:Static properties:Resources.Refresh}"
                                                    ToolTip="{x:Static properties:Resources.CopilotRefreshWebContext}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter TargetName="UserBubble" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsUser}" Value="False">
                                        <Setter TargetName="AssistantPanel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    Margin="14,0,14,14"
                    Padding="14,10,14,12"
                    Style="{StaticResource ComposerShellBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,8"
                            Padding="12,9"
                            Style="{StaticResource CopilotInsetBorderStyle}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="{Binding HasCurrentLiveContext, Converter={StaticResource bool2VisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource GlobalTextBrush}"
                                           Opacity="0.58"
                                           Text="{x:Static properties:Resources.CopilotCurrentWindowContext}" />
                                <TextBlock Margin="0,2,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource GlobalTextBrush}"
                                           Text="{Binding CurrentLiveContextTitle}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Margin="0,2,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource GlobalTextBrush}"
                                           Opacity="0.74"
                                           Text="{Binding CurrentLiveContextSummary}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource ContextActionButtonStyle}"
                                    VerticalAlignment="Center"
                                    Command="{Binding AttachCurrentLiveContextCommand}"
                                    IsEnabled="{Binding CanAttachCurrentLiveContext}">
                                <TextBlock Text="{Binding CurrentLiveContextActionText}" />
                            </Button>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,0,0,10"
                                Visibility="{Binding HasAttachments, Converter={StaticResource bool2VisibilityConverter}}">
                        <ScrollViewer x:Name="AttachmentScrollViewer"
                                      MaxHeight="104"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl Width="{Binding ViewportWidth, ElementName=AttachmentScrollViewer}"
                                          ItemsSource="{Binding Attachments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:CopilotAttachmentItem}">
                                        <Grid Margin="0,0,8,0">
                                            <Border x:Name="AttachmentChip"
                                                    Padding="8,4"
                                                    Style="{StaticResource CopilotInsetBorderStyle}"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    ToolTip="{Binding TooltipText}"
                                                    Visibility="Collapsed">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.52" Text="{Binding BadgeText}" />
                                                    <TextBlock Margin="8,0,0,0"
                                                               MaxWidth="180"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Text="{Binding DisplayLabel}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Button Margin="8,0,0,0"
                                                            Width="16"
                                                            Height="16"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            Command="{Binding DataContext.RemoveAttachmentCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Foreground="{DynamicResource GlobalTextBrush}"
                                                            Content="×" />
                                                </DockPanel>
                                            </Border>

                                            <Border x:Name="ImageAttachmentCard"
                                                    Padding="6"
                                                    Style="{StaticResource CopilotInsetBorderStyle}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    ToolTip="{Binding TooltipText}"
                                                    Visibility="Collapsed">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="36"
                                                            Height="36"
                                                            Style="{StaticResource CopilotInsetBorderStyle}"
                                                            CornerRadius="10"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" />
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Margin="4"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                                       Opacity="0.52"
                                                                       Text="{Binding ImageFallbackText}"
                                                                       TextAlignment="Center"
                                                                       TextWrapping="Wrap" />
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Center">
                                                        <TextBlock MaxWidth="76"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Text="{Binding DisplayLabel}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock MaxWidth="76"
                                                                   Margin="0,1,0,0"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Opacity="0.5"
                                                                   Text="{Binding ImageMetaText}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <Button Grid.Column="2"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="8,0,0,0"
                                                            Padding="0"
                                                            VerticalAlignment="Center"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            Command="{Binding DataContext.RemoveAttachmentCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Content="×"
                                                            Foreground="{DynamicResource GlobalTextBrush}" />
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                <Setter TargetName="ImageAttachmentCard" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsImage}" Value="False">
                                                <Setter TargetName="AttachmentChip" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <TextBox x:Name="PromptTextBox"
                             Grid.Row="2"
                             MinHeight="44"
                             MaxHeight="104"
                             Padding="0,6,0,6"
                             AcceptsReturn="True"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource GlobalTextBrush}"
                             PreviewKeyDown="PromptTextBox_PreviewKeyDown"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto" />

                    <DockPanel Grid.Row="3" Margin="0,8,0,0">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="30"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    CornerRadius="999"
                                    BorderThickness="1"
                                    ToolTip="{Binding ComposerTokenDetails}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                        <Setter Property="Opacity" Value="0.72" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRealTokenUsage}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                <Setter Property="Opacity" Value="0.92" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTokenUsagePending}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                                <Setter Property="Opacity" Value="0.86" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTokenUsageUnavailable}" Value="True">
                                                <Setter Property="Opacity" Value="0.64" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Viewbox Margin="6" StretchDirection="DownOnly">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding TokenUsageBadgeText}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
                                                <Setter Property="Opacity" Value="0.84" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasRealTokenUsage}" Value="True">
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="Opacity" Value="1" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsTokenUsagePending}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
                                                        <Setter Property="Opacity" Value="0.92" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Viewbox>
                            </Border>

                                <Button Margin="2,0,0,0"
                                    Command="{Binding PrimaryActionCommand}"
                                    Style="{StaticResource ComposerPrimaryActionButtonStyle}"
                                    Content="{Binding PrimaryActionGlyph}"
                                    FontSize="15"
                                    ToolTip="{Binding PrimaryActionToolTip}" />
                        </StackPanel>

                        <Button x:Name="AttachMenuButton"
                                Grid.Column="0"
                                Width="36"
                                Height="36"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Click="AttachMenuButton_Click"
                                ToolTip="{x:Static properties:Resources.CopilotAttachTooltip}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{x:Static properties:Resources.CopilotPasteImage}" Command="{Binding PasteImageAttachmentCommand}" />
                                    <MenuItem Header="{x:Static properties:Resources.CopilotSpecifyWebPage}" Command="{Binding AddWebPageAttachmentCommand}" />
                                    <Separator />
                                    <MenuItem Header="{x:Static properties:Resources.CopilotAddFile}" Command="{Binding AddFileAttachmentCommand}" />
                                    <MenuItem Header="{x:Static properties:Resources.CopilotAddContext}" Command="{Binding AddContextAttachmentCommand}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="✚" />
                        </Button>

                        <ComboBox Width="84"
                                  Margin="8,0,8,0"
                                  Style="{StaticResource ComposerComboBoxStyle}"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding AgentModes}"
                                  DisplayMemberPath="Label"
                                  SelectedValuePath="Mode"
                                  SelectedValue="{Binding SelectedAgentMode, Mode=TwoWay}"
                                  IsEnabled="{Binding CanSelectAgentMode}"
                                  ToolTip="{Binding SelectedAgentModeDescription}" />

                        <ComboBox Grid.Column="2"
                                  Width="118"
                                  Margin="0,0,6,0"
                                  Style="{StaticResource ComposerComboBoxStyle}"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding Profiles}"
                                  DisplayMemberPath="DisplayLabel"
                                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                  ToolTip="{Binding ComposerTokenSummary}"
                                  IsEnabled="{Binding CanSelectProfile}" />

                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1">
            <Border x:Name="ConversationSidebarBorder"
                    Background="{DynamicResource GlobalBorderBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="14,14,12,8" LastChildFill="False">
                        <Button x:Name="CompactSidebarToggleButton"
                                Margin="0,0,6,0"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Click="ToggleConversationSidebarButton_Click"
                                ToolTip="{x:Static properties:Resources.CopilotCollapseConversationList}"
                                Visibility="Collapsed">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE8A7;" />
                        </Button>

                        <Button Width="32"
                                Height="32"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Command="{Binding NewChatCommand}"
                                DockPanel.Dock="Right"
                                ToolTip="{x:Static properties:Resources.CopilotNewConversation}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="✚" />
                        </Button>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Text="{x:Static properties:Resources.CopilotConversations}" />
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             Padding="0,0,0,10"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}"
                             ItemsSource="{Binding Conversations}"
                             SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                             IsEnabled="{Binding CanSwitchConversation}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotConversationRecord}">
                                <Border Padding="11,9"
                                        Style="{StaticResource CopilotInsetBorderStyle}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="{x:Static properties:Resources.Rename}"
                                                      Command="{Binding DataContext.RenameConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="{Binding PinMenuText}"
                                                      Command="{Binding DataContext.TogglePinConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="{x:Static properties:Resources.Delete}"
                                                      Command="{Binding DataContext.DeleteConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock MaxWidth="138"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Text="{Binding Title}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="6,0,0,0"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           FontSize="11"
                                                           Opacity="0.48"
                                                           Text="{Binding PinLabel}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>

                                        <DockPanel Margin="0,4,0,0" LastChildFill="False">
                                            <TextBlock MaxWidth="118"
                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                       FontSize="11"
                                                       Opacity="0.72"
                                                       Text="{Binding PreviewText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="8,0,0,0"
                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                       FontSize="11"
                                                       Opacity="0.5"
                                                       Text="{Binding UpdatedLabel}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
