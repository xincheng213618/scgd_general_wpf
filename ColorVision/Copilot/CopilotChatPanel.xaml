<UserControl x:Class="ColorVision.Copilot.CopilotChatPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.Copilot"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:properties="clr-namespace:ColorVision.Properties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:CopilotChatViewModel}" d:Height="500" d:Width="600">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="CopilotStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        <BooleanToVisibilityConverter x:Key="bool2VisibilityConverter" />
        <SolidColorBrush x:Key="CopilotExecutionFailureBrush" Color="#DB3340" />
        <SolidColorBrush x:Key="CopilotControlBrush" Color="#6EA8FF" />
        <SolidColorBrush x:Key="CopilotControlSurfaceBrush" Color="#226EA8FF" />
        <SolidColorBrush x:Key="CopilotControlBorderBrush" Color="#526EA8FF" />
        <SolidColorBrush x:Key="CopilotControlMutedBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="CopilotControlMutedSurfaceBrush" Color="#1F9CA3AF" />
        <SolidColorBrush x:Key="CopilotControlMutedBorderBrush" Color="#3A9CA3AF" />
        <SolidColorBrush x:Key="CopilotControlWarningBrush" Color="#D6A84E" />
        <SolidColorBrush x:Key="CopilotControlWarningSurfaceBrush" Color="#22D6A84E" />
        <SolidColorBrush x:Key="CopilotControlWarningBorderBrush" Color="#52D6A84E" />
        <SolidColorBrush x:Key="CopilotControlDangerBrush" Color="#F87171" />
        <SolidColorBrush x:Key="CopilotControlDangerSurfaceBrush" Color="#22F87171" />
        <SolidColorBrush x:Key="CopilotControlDangerBorderBrush" Color="#52F87171" />
        <Style x:Key="AssistantPlainTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
            <Setter Property="Opacity" Value="0.94" />
        </Style>
        <Style x:Key="ReadOnlyMessageTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style x:Key="MessageActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.54" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.84" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.28" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ComposerSelectorToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="MaxWidth" Value="180" />
            <Setter Property="Padding" Value="4,0,2,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComposerPopoverRowToggleStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComposerPopoverButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.76" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComposerPopoverListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CopilotIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.76" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ComposerPrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UserMessageTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ReadOnlyMessageTextBoxStyle}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="UserMessageMetaTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        <Style x:Key="UserMessageActionButtonStyle" TargetType="Button" BasedOn="{StaticResource MessageActionButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.68" />
        </Style>
        <Style x:Key="CopilotSurfaceBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
        </Style>
        <Style x:Key="CopilotInsetBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotSurfaceBorderStyle}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}" />
        </Style>
        <Style x:Key="CopilotPillBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotInsetBorderStyle}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style x:Key="ComposerShellBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotSurfaceBorderStyle}">
            <Setter Property="Background" Value="{DynamicResource GlobalBackground}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="McpStatusPillBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotPillBorderStyle}">
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Background" Value="{StaticResource CopilotControlSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CopilotControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Opacity" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMcpEnabled}" Value="False">
                    <Setter Property="Background" Value="{StaticResource CopilotControlMutedSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource CopilotControlMutedBorderBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasPendingMcpActions}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CopilotControlWarningSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource CopilotControlWarningBorderBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasRecentMcpFailures}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CopilotControlDangerSurfaceBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource CopilotControlDangerBorderBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ControlModeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CopilotControlBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMcpEnabled}" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource CopilotControlMutedBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasPendingMcpActions}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource CopilotControlWarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasRecentMcpFailures}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource CopilotControlDangerBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ContextActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ContextStatusPillBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotPillBorderStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Opacity" Value="0.64" />
        </Style>
        <Style x:Key="ContextStatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ExecutionSummaryPillBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Opacity" Value="0.62" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsExecutionInProgress}" Value="True">
                    <Setter Property="Opacity" Value="0.7" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasExecutionFailures}" Value="True">
                    <Setter Property="Opacity" Value="0.72" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ExecutionSummaryTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasExecutionFailures}" Value="True">
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Opacity" Value="0.86" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TraceExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite"
                                          Padding="0"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Left"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"
                                          Cursor="Hand"
                                          FocusVisualStyle="{x:Null}"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="HeaderChrome"
                                                Padding="0,3"
                                                Background="Transparent">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="16" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}" />
                                                <TextBlock x:Name="Chevron"
                                                           Grid.Column="1"
                                                           Margin="4,0,0,0"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Opacity="0.42"
                                                           Text="›" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Chevron" Property="Text" Value="⌄" />
                                                <Setter TargetName="Chevron" Property="Opacity" Value="0.58" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header" />
                            </ToggleButton>
                            <Border Height="1"
                                    Margin="0,4,0,0"
                                    Background="{DynamicResource GlobalBorderBrush1}" />
                            <ContentPresenter x:Name="ExpandSite"
                                              Margin="0,8,0,0"
                                              ContentSource="Content"
                                              Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AttachmentChipBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style x:Key="AttachmentCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.42" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                                <Setter Property="Opacity" Value="0.82" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="McpActionMetaPillBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotPillBorderStyle}">
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Opacity" Value="0.82" />
        </Style>
        <Style x:Key="McpActionDeadlinePillBorderStyle" TargetType="Border" BasedOn="{StaticResource McpActionMetaPillBorderStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsExpiringSoon}" Value="True">
                    <Setter Property="Background" Value="{StaticResource CopilotExecutionFailureBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource CopilotExecutionFailureBrush}" />
                    <Setter Property="Opacity" Value="0.94" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="McpActionMetaTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.72" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="McpActionDeadlineTextStyle" TargetType="TextBlock" BasedOn="{StaticResource McpActionMetaTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsExpiringSoon}" Value="True">
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Opacity" Value="0.96" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SidebarListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="10,2" />
        </Style>
        <Style x:Key="CompactHistoryButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Padding="10,7"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <DataTemplate x:Key="AgentTraceEntryTemplate">
            <Expander Margin="0,1,0,4" Style="{StaticResource TraceExpanderStyle}">
                <Expander.Header>
                    <Grid ToolTip="{Binding ActivityDescription}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="EntryActivityGlyph"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.48"
                                   Text="{Binding ActivityGlyph}" />
                        <TextBlock x:Name="EntryActivityLabel"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.6"
                                   Text="{Binding ActivityLabel}" />
                        <TextBlock Grid.Column="2"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="10"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.38"
                                   Text="{Binding ActivityDurationLabel}" />
                    </Grid>
                </Expander.Header>
                <StackPanel Margin="18,0,0,2">
                    <TextBlock Margin="0,0,0,5"
                               FontSize="11"
                               Foreground="{DynamicResource GlobalTextBrush}"
                               Opacity="0.58"
                               Text="{Binding ActivityDescription}"
                               TextWrapping="Wrap" />
                    <TextBox Style="{StaticResource ReadOnlyMessageTextBoxStyle}"
                             FontSize="10"
                             Opacity="0.42"
                             Text="{Binding DiagnosticDetails, Mode=OneWay}" />
                </StackPanel>
            </Expander>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsFailure}" Value="True">
                    <Setter TargetName="EntryActivityGlyph" Property="Foreground" Value="{StaticResource CopilotControlDangerBrush}" />
                    <Setter TargetName="EntryActivityLabel" Property="Foreground" Value="{StaticResource CopilotControlDangerBrush}" />
                    <Setter TargetName="EntryActivityLabel" Property="Opacity" Value="0.82" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="AgentTraceGroupTemplate">
            <Expander Margin="0,1,0,4" Style="{StaticResource TraceExpanderStyle}">
                <Expander.Header>
                    <Grid ToolTip="{Binding ActivityDescription}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="GroupActivityGlyph"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.48"
                                   Text="{Binding ActivityGlyph}" />
                        <TextBlock x:Name="GroupActivityLabel"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.66"
                                   Text="{Binding ActivityLabel}" />
                        <TextBlock Grid.Column="2"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="10"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.38"
                                   Text="{Binding ActivityDurationLabel}" />
                    </Grid>
                </Expander.Header>
                <StackPanel Margin="18,0,0,2">
                    <StackPanel Visibility="{Binding IsSingle, Converter={StaticResource bool2VisibilityConverter}}">
                        <TextBlock Margin="0,0,0,5"
                                   FontSize="11"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.58"
                                   Text="{Binding FirstEntry.ActivityDescription}"
                                   TextWrapping="Wrap" />
                        <TextBox Style="{StaticResource ReadOnlyMessageTextBoxStyle}"
                                 FontSize="10"
                                 Opacity="0.42"
                                 Text="{Binding FirstEntry.DiagnosticDetails, Mode=OneWay}" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Entries}"
                                  ItemTemplate="{StaticResource AgentTraceEntryTemplate}"
                                  Visibility="{Binding IsMultiple, Converter={StaticResource bool2VisibilityConverter}}" />
                </StackPanel>
            </Expander>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsFailure}" Value="True">
                    <Setter TargetName="GroupActivityGlyph" Property="Foreground" Value="{StaticResource CopilotControlDangerBrush}" />
                    <Setter TargetName="GroupActivityLabel" Property="Foreground" Value="{StaticResource CopilotControlDangerBrush}" />
                    <Setter TargetName="GroupActivityLabel" Property="Opacity" Value="0.82" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource GlobalBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="SidebarColumnDefinition" Width="232" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="12,8,12,0"
                    Padding="0,0,0,8"
                    BorderBrush="{DynamicResource ButtonBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel MaxWidth="560" VerticalAlignment="Center">
                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Text="{Binding SelectedConversation.Title, FallbackValue={x:Static properties:Resources.CopilotNewConversation}, TargetNullValue={x:Static properties:Resources.CopilotNewConversation}}"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Margin="0,3,0,0"
                                Padding="0"
                                HorizontalAlignment="Left"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Command="{Binding OpenAgentRunNoticeCommand}"
                                Foreground="{DynamicResource GlobalTextBrush}"
                                FontSize="10"
                                Opacity="0.62"
                                Content="{Binding AgentRunNoticeText}"
                                ToolTip="打开或查看 Agent 任务状态"
                                Visibility="{Binding HasAgentRunNotice, Converter={StaticResource bool2VisibilityConverter}}" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="10"
                                   Foreground="{StaticResource CopilotControlWarningBrush}"
                                   Text="{Binding StateRecoveryNoticeText}"
                                   TextWrapping="Wrap"
                                   ToolTip="{Binding StateRecoveryNoticeToolTip}"
                                   Visibility="{Binding HasStateRecoveryNotice, Converter={StaticResource bool2VisibilityConverter}}" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="10"
                                   Foreground="{StaticResource CopilotControlWarningBrush}"
                                   Text="{Binding StatePersistenceNoticeText}"
                                   TextWrapping="Wrap"
                                   ToolTip="{Binding StatePersistenceNoticeToolTip}"
                                   Visibility="{Binding HasStatePersistenceNotice, Converter={StaticResource bool2VisibilityConverter}}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="TitleBarConversationButton"
                                Margin="0,0,6,0"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Click="ToggleConversationSidebarButton_Click"
                                ToolTip="{x:Static properties:Resources.CopilotExpandConversationList}"
                                Visibility="Collapsed">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE8A7;" />
                        </Button>

                        <Button Margin="0,0,6,0"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Command="{Binding NewChatCommand}"
                                IsEnabled="{Binding CanSwitchConversation}"
                                ToolTip="{x:Static properties:Resources.CopilotNewConversation}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Text="&#xE710;" />
                        </Button>

                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="18,12,18,0"
                        Padding="12,10"
                        Style="{StaticResource CopilotInsetBorderStyle}"
                        BorderThickness="1"
                        CornerRadius="12"
                        ToolTip="{Binding PendingActionPanelToolTip}"
                        Visibility="{Binding HasPendingActionPanel, Converter={StaticResource bool2VisibilityConverter}}">
                    <StackPanel>
                        <StackPanel>
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="{Binding PendingActionPanelTitle}" />
                            <TextBlock Margin="0,2,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Opacity="0.62"
                                       Text="{Binding PendingActionPanelSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.72"
                                   Text="{Binding PendingActionFeedbackText}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasPendingActionFeedback, Converter={StaticResource bool2VisibilityConverter}}" />

                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding PendingActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10,8"
                                            Style="{StaticResource CopilotSurfaceBorderStyle}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0">
                                                <DockPanel LastChildFill="True">
                                                    <StackPanel DockPanel.Dock="Right"
                                                                Margin="8,0,0,0"
                                                                Orientation="Horizontal">
                                                        <Border Margin="0,0,6,0"
                                                                MaxWidth="150"
                                                                Style="{StaticResource McpActionMetaPillBorderStyle}">
                                                            <TextBlock Style="{StaticResource McpActionMetaTextStyle}"
                                                                       Text="{Binding RiskLevel}" />
                                                        </Border>
                                                        <Border MaxWidth="170"
                                                                Style="{StaticResource McpActionDeadlinePillBorderStyle}"
                                                                ToolTip="{Binding ExpiresAtLabel, StringFormat=Expires at {0}}">
                                                            <TextBlock Style="{StaticResource McpActionDeadlineTextStyle}"
                                                                       Text="{Binding ReviewDeadlineLabel}" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Text="{Binding Title}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                                <WrapPanel Margin="0,4,0,0">
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.68"
                                                               Text="action_id:" />
                                                    <TextBlock Margin="4,0,10,0"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.72"
                                                               Text="{Binding ActionId}" />
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.68"
                                                               Text="tool_name:" />
                                                    <TextBlock Margin="4,0,10,0"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.72"
                                                               Text="{Binding ToolName}" />
                                                </WrapPanel>
                                                <TextBlock Margin="0,3,0,0"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Opacity="0.74"
                                                           Text="{Binding Description}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,3,0,0"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Opacity="0.58"
                                                           Text="{Binding ArgumentsSummary, StringFormat=params: {0}}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>

                                            <WrapPanel Grid.Row="1"
                                                       Margin="0,8,0,0"
                                                       HorizontalAlignment="Right">
                                                <Button Margin="0,0,6,6"
                                                        Padding="10,4"
                                                        Command="{Binding DataContext.ApprovePendingActionCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Review &amp; Approve"
                                                        ToolTip="Review the protected action summary before approving." />
                                                <Button Margin="0,0,6,6"
                                                        Padding="10,4"
                                                        Command="{Binding DataContext.RejectPendingActionCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Reject"
                                                        ToolTip="Reject this pending protected action." />
                                                <Button Margin="0,0,6,6"
                                                        Padding="10,4"
                                                        Command="{Binding DataContext.CopyPendingActionIdCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Copy ID" />
                                                <Button Margin="0,0,0,6"
                                                        Padding="10,4"
                                                        Command="{Binding DataContext.CopyPendingActionPayloadCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="Copy Payload" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="EmptyStateTextBlock"
                           Grid.Row="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MaxWidth="320"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Opacity="0.68"
                           Text="{Binding EmptyStateText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />

                <StackPanel x:Name="CompactHistoryPanel"
                            Grid.Row="1"
                            MaxWidth="620"
                            Margin="24,34,24,18"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Visibility="Collapsed">
                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.82"
                                   Text="{x:Static properties:Resources.CopilotConversations}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.46"
                                   Text="{Binding CompactHistoryFooterText}"
                                   Visibility="{Binding HasCompactHistoryOverflow, Converter={StaticResource bool2VisibilityConverter}}" />
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding CompactHistoryConversations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotConversationRecord}">
                                <Button Style="{StaticResource CompactHistoryButtonStyle}"
                                        Command="{Binding DataContext.SelectConversationCommand, Source={x:Reference Root}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding DataContext.CanSwitchConversation, Source={x:Reference Root}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                   Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Margin="12,0,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                   Opacity="0.44"
                                                   Text="{Binding UpdatedLabel}" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Margin="0,3,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                   Opacity="0.58"
                                                   Text="{Binding PreviewText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <ScrollViewer x:Name="MessagesScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl MaxWidth="880"
                                  Margin="16,12,16,12"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotChatMessage}">
                                <Grid Margin="0,0,0,12">
                                    <Border x:Name="UserBubble"
                                            MaxWidth="680"
                                            Padding="10,5"
                                            HorizontalAlignment="Right"
                                            Background="{DynamicResource GlobalBorderBrush1}"
                                            BorderBrush="{DynamicResource ButtonBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBox Style="{StaticResource UserMessageTextBoxStyle}"
                                                     Text="{Binding Content, Mode=OneWay}" />
                                            <ItemsControl Margin="0,6,0,0"
                                                          ItemsSource="{Binding Attachments}"
                                                          Visibility="{Binding HasAttachments, Converter={StaticResource bool2VisibilityConverter}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type local:CopilotAttachmentItem}">
                                                        <Border Margin="0,0,5,4"
                                                                Padding="6,2"
                                                                Background="{DynamicResource GlobalBorderBrush}"
                                                                CornerRadius="4"
                                                                ToolTip="{Binding TooltipText}">
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock VerticalAlignment="Center"
                                                                           FontSize="9"
                                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                                           Opacity="0.45"
                                                                           Text="{Binding BadgeText}" />
                                                                <TextBlock Margin="5,0,0,0"
                                                                           MaxWidth="150"
                                                                           VerticalAlignment="Center"
                                                                           FontSize="10"
                                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                                           Opacity="0.72"
                                                                           Text="{Binding DisplayLabel}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <Button Margin="5,0,0,0"
                                                                        Style="{StaticResource AttachmentCloseButtonStyle}"
                                                                        Command="{Binding DataContext.OpenAttachmentCommand, Source={x:Reference Root}}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="↗"
                                                                        ToolTip="查看附件" />
                                                            </DockPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <DockPanel Margin="0,5,0,0" LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"
                                                           Style="{StaticResource UserMessageMetaTextStyle}"
                                                           Text="{Binding TimeLabel}" />
                                                <StackPanel DockPanel.Dock="Right"
                                                            HorizontalAlignment="Right"
                                                            Orientation="Horizontal">
                                                    <Button Style="{StaticResource UserMessageActionButtonStyle}"
                                                            Command="{Binding DataContext.CopyMessageCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Content="{x:Static properties:Resources.Copy}"
                                                            ToolTip="{x:Static properties:Resources.CopilotCopyMessage}" />
                                                    <Button Style="{StaticResource UserMessageActionButtonStyle}"
                                                            Command="{Binding DataContext.EditMessageCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Click="EditMessageButton_Click"
                                                            Content="编辑"
                                                            ToolTip="编辑这条请求并替换最新回复" />
                                                    <Button Margin="0"
                                                            Style="{StaticResource UserMessageActionButtonStyle}"
                                                            Command="{Binding DataContext.RetryMessageCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Content="重新发送"
                                                            ToolTip="重新发送这条请求并替换最新回复" />
                                                </StackPanel>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel x:Name="AssistantPanel"
                                                Margin="0"
                                                Visibility="Collapsed">
                                        <Expander Margin="0,8,0,2"
                                                  IsExpanded="{Binding IsThinkingExpanded, Mode=TwoWay}">
                                            <Expander.Style>
                                                <Style TargetType="Expander" BasedOn="{StaticResource TraceExpanderStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding HasThinkingTrace}" Value="True" />
                                                                <Condition Binding="{Binding HasLegacyResponseLayout}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Expander.Style>
                                            <Expander.Header>
                                                <Border Padding="0" Style="{StaticResource ExecutionSummaryPillBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.72"
                                                               Text="{Binding ThinkingHeader}"
                                                               ToolTip="{Binding ThinkingSummaryToolTip}" />
                                                </Border>
                                            </Expander.Header>
                                        </Expander>

                                        <ItemsControl ItemsSource="{Binding VisibleResponseTimelineItems}"
                                                      Visibility="{Binding HasResponseTimeline, Converter={StaticResource bool2VisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <local:CopilotMarkdownView Markdown="{Binding Markdown, Mode=OneWay}"
                                                                                   Visibility="{Binding IsMarkdown, Converter={StaticResource bool2VisibilityConverter}}" />
                                                        <ContentControl Margin="0,4,0,0"
                                                                        Content="{Binding ToolGroup}"
                                                                        ContentTemplate="{StaticResource AgentTraceGroupTemplate}"
                                                                        Focusable="False">
                                                            <ContentControl.Style>
                                                                <Style TargetType="ContentControl">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding IsToolGroup}" Value="True" />
                                                                                <Condition Binding="{Binding DataContext.IsThinkingExpanded, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True" />
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </MultiDataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <local:CopilotMarkdownView Markdown="{Binding Content, Mode=OneWay}"
                                                                   Visibility="{Binding HasLegacyResponseLayout, Converter={StaticResource bool2VisibilityConverter}}" />

                                        <Border Margin="0,8,0,0"
                                                Padding="10,7"
                                                Background="{DynamicResource GlobalBorderBrush}"
                                                BorderBrush="#E6A23C"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Visibility="{Binding HasResponseInterruption, Converter={StaticResource bool2VisibilityConverter}}">
                                            <DockPanel LastChildFill="True">
                                                <Button DockPanel.Dock="Right"
                                                        Margin="10,0,0,0"
                                                        Padding="10,3"
                                                        Command="{Binding DataContext.RetryMessageCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{x:Static properties:Resources.CopilotRetry}"
                                                        Style="{StaticResource MessageActionButtonStyle}"
                                                        ToolTip="{x:Static properties:Resources.CopilotRegenerateAnswer}" />
                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="11"
                                                           Foreground="#E6A23C"
                                                           Text="{Binding ResponseInterruptionText}"
                                                           TextWrapping="Wrap" />
                                            </DockPanel>
                                        </Border>

                                        <StackPanel Margin="0,8,0,0"
                                                    Visibility="{Binding HasLegacyThinkingTrace, Converter={StaticResource bool2VisibilityConverter}}">
                                            <Expander Style="{StaticResource TraceExpanderStyle}"
                                                      IsExpanded="{Binding IsThinkingExpanded, Mode=TwoWay}"
                                                      Visibility="{Binding HasStandaloneThinkingTrace, Converter={StaticResource bool2VisibilityConverter}}">
                                                <Expander.Header>
                                                    <Border Padding="0" Style="{StaticResource ExecutionSummaryPillBorderStyle}">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Opacity="0.72"
                                                                   Text="{Binding ThinkingHeader}"
                                                                   ToolTip="{Binding ThinkingSummaryToolTip}" />
                                                    </Border>
                                                </Expander.Header>
                                                <TextBox Style="{StaticResource ReadOnlyMessageTextBoxStyle}"
                                                         FontSize="12"
                                                         Opacity="0.7"
                                                         Text="{Binding LegacyThinkingContent, Mode=OneWay}"
                                                         Visibility="{Binding HasLegacyThinkingContent, Converter={StaticResource bool2VisibilityConverter}}" />
                                            </Expander>

                                            <ItemsControl ItemsSource="{Binding VisibleAgentTraceGroups}"
                                                          ItemTemplate="{StaticResource AgentTraceGroupTemplate}"
                                                          Visibility="{Binding HasAgentTraceEntries, Converter={StaticResource bool2VisibilityConverter}}" />
                                        </StackPanel>

                                        <Border Margin="0,0,0,10"
                                                Padding="10,8"
                                                Background="{DynamicResource GlobalBorderBrush}"
                                                BorderBrush="{DynamicResource ButtonBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                ToolTip="{Binding AgentTaskSummaryToolTip}"
                                                Visibility="{Binding HasAgentTaskState, Converter={StaticResource bool2VisibilityConverter}}">
                                            <StackPanel>
                                                <DockPanel LastChildFill="True">
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="8,0,0,0"
                                                            Padding="10,3"
                                                            Command="{Binding DataContext.ContinueAgentTasksCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Content="{Binding AgentRecoveryActionLabel}"
                                                            Style="{StaticResource MessageActionButtonStyle}"
                                                            ToolTip="{Binding AgentRecoveryToolTip}"
                                                            Visibility="{Binding HasRecoverableAgentTasks, Converter={StaticResource bool2VisibilityConverter}}" />
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Text="Agent 任务" />
                                                        <Border Margin="8,0,0,0"
                                                                Padding="6,1"
                                                                Background="{DynamicResource GlobalBorderBrush1}"
                                                                CornerRadius="4">
                                                            <TextBlock FontSize="10"
                                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                                       Opacity="0.72"
                                                                       Text="{Binding AgentTaskModeLabel}" />
                                                        </Border>
                                                        <TextBlock Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Opacity="0.62"
                                                                   Text="{Binding AgentTaskProgressLabel}" />
                                                    </StackPanel>
                                                </DockPanel>

                                                <ItemsControl Margin="0,7,0,0" ItemsSource="{Binding AgentTaskLedger.Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="18" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock x:Name="TaskStateGlyph"
                                                                           VerticalAlignment="Top"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                                           Opacity="0.58"
                                                                           Text="○" />
                                                                <StackPanel x:Name="TaskTextPanel" Grid.Column="1">
                                                                    <TextBlock FontSize="11"
                                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                                               Text="{Binding Title}"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Margin="0,1,0,0"
                                                                               FontSize="10"
                                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                                               Opacity="0.5"
                                                                               Text="{Binding Description}"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Grid>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                                                    <Setter TargetName="TaskStateGlyph" Property="Text" Value="✓" />
                                                                    <Setter TargetName="TaskTextPanel" Property="Opacity" Value="0.52" />
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Margin="0,6,0,0"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Opacity="0.62"
                                                           Text="{Binding AgentStopReasonLabel}" />
                                                <TextBlock Margin="0,3,0,0"
                                                           FontSize="10"
                                                           Foreground="#E6A23C"
                                                           Text="{Binding AgentBlockerLabel}"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding HasAgentBlockers, Converter={StaticResource bool2VisibilityConverter}}" />
                                            </StackPanel>
                                        </Border>

                                        <StackPanel x:Name="AssistantActionsPanel"
                                                    Margin="0,10,0,0"
                                                    Orientation="Horizontal"
                                                    Visibility="Collapsed">
                                            <Button Style="{StaticResource MessageActionButtonStyle}"
                                                    Command="{Binding DataContext.CopyMessageCommand, Source={x:Reference Root}}"
                                                    CommandParameter="{Binding}"
                                                    Content="{x:Static properties:Resources.Copy}"
                                                    ToolTip="{x:Static properties:Resources.CopilotCopyMessage}" />
                                            <Button Style="{StaticResource MessageActionButtonStyle}"
                                                    Command="{Binding DataContext.RetryMessageCommand, Source={x:Reference Root}}"
                                                    CommandParameter="{Binding}"
                                                    Content="{x:Static properties:Resources.CopilotRetry}"
                                                    ToolTip="{x:Static properties:Resources.CopilotRegenerateAnswer}" />
                                            <Button Style="{StaticResource MessageActionButtonStyle}"
                                                    Margin="0"
                                                    Command="{Binding DataContext.RefreshMessageCommand, Source={x:Reference Root}}"
                                                    CommandParameter="{Binding}"
                                                    Content="{x:Static properties:Resources.Refresh}"
                                                    ToolTip="{x:Static properties:Resources.CopilotRefreshWebContext}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter TargetName="UserBubble" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsUser}" Value="False">
                                        <Setter TargetName="AssistantPanel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    x:Name="ComposerShellBorder"
                    AllowDrop="True"
                    MaxWidth="880"
                    Margin="24,0,24,14"
                    Padding="10,5,8,5"
                    PreviewDragLeave="ComposerShellBorder_PreviewDragLeave"
                    PreviewDragOver="ComposerShellBorder_PreviewDragOver"
                    PreviewDrop="ComposerShellBorder_PreviewDrop"
                    Style="{StaticResource ComposerShellBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border x:Name="FileDropOverlay"
                            Grid.RowSpan="6"
                            Panel.ZIndex="20"
                            Background="{DynamicResource GlobalBackground}"
                            BorderBrush="{DynamicResource PrimaryBrush}"
                            BorderThickness="2"
                            CornerRadius="7"
                            IsHitTestVisible="False"
                            Opacity="0.94"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="22"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       Text="&#xE898;" />
                            <TextBlock Margin="0,7,0,0"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="松开以附加文件" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Margin="0,0,0,8"
                            Padding="10,7"
                            Background="{DynamicResource GlobalBorderBrush}"
                            BorderBrush="{DynamicResource PrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Visibility="{Binding IsEditingMessage, Converter={StaticResource bool2VisibilityConverter}}">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Width="22"
                                    Height="22"
                                    Margin="8,0,0,0"
                                    Padding="0"
                                    Style="{StaticResource AttachmentCloseButtonStyle}"
                                    Command="{Binding CancelMessageEditCommand}"
                                    Content="×"
                                    ToolTip="取消编辑" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="{Binding EditingMessageStatusText}"
                                       TextWrapping="Wrap" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Margin="0,0,0,8"
                            Padding="12,9"
                            Style="{StaticResource CopilotInsetBorderStyle}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Visibility="{Binding HasLocalCommandResult, Converter={StaticResource bool2VisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Opacity="0.72"
                                       Text="{Binding LocalCommandResultTitle}" />
                            <Button Grid.Column="1"
                                    Width="22"
                                    Height="22"
                                    Padding="0"
                                    Style="{StaticResource AttachmentCloseButtonStyle}"
                                    Command="{Binding DismissLocalCommandResultCommand}"
                                    Content="×"
                                    ToolTip="关闭本地命令结果" />
                            <TextBox Grid.Row="1"
                                     Grid.ColumnSpan="2"
                                     MaxHeight="168"
                                     Margin="0,6,0,0"
                                     Padding="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Foreground="{DynamicResource GlobalTextBrush}"
                                     HorizontalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     Opacity="0.82"
                                     Text="{Binding LocalCommandResultText, Mode=OneWay}"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>

                    <Border x:Name="CurrentLiveContextBorder"
                            Grid.Row="1"
                            Margin="0,0,0,8"
                            Padding="12,9"
                            Style="{StaticResource CopilotInsetBorderStyle}"
                            BorderThickness="1"
                            CornerRadius="12"
                            ToolTip="{Binding CurrentLiveContextToolTip}"
                            Visibility="{Binding HasCurrentLiveContext, Converter={StaticResource bool2VisibilityConverter}}">
                        <Grid x:Name="CurrentLiveContextGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <Border DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Style="{StaticResource ContextStatusPillBorderStyle}">
                                        <TextBlock Style="{StaticResource ContextStatusTextStyle}"
                                                   Text="{Binding CurrentLiveContextStatusText}" />
                                    </Border>
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{DynamicResource GlobalTextBrush}"
                                               Opacity="0.58"
                                               Text="{x:Static properties:Resources.CopilotCurrentWindowContext}" />
                                </DockPanel>
                                <TextBlock Margin="0,2,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource GlobalTextBrush}"
                                           Text="{Binding CurrentLiveContextTitle}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="CurrentLiveContextSummaryText"
                                           Margin="0,2,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource GlobalTextBrush}"
                                           Opacity="0.74"
                                           Text="{Binding CurrentLiveContextSummary}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Button x:Name="CurrentLiveContextActionButton"
                                    Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Style="{StaticResource ContextActionButtonStyle}"
                                    VerticalAlignment="Center"
                                    Command="{Binding AttachCurrentLiveContextCommand}"
                                    IsEnabled="{Binding CanAttachCurrentLiveContext}">
                                <TextBlock Text="{Binding CurrentLiveContextActionText}" />
                            </Button>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2" Margin="0,0,0,10"
                                Visibility="{Binding HasAttachments, Converter={StaticResource bool2VisibilityConverter}}">
                        <TextBlock Margin="0,0,0,5"
                                   FontSize="10"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.5"
                                   Text="附件仅随下一条消息发送" />
                        <ScrollViewer x:Name="AttachmentScrollViewer"
                                      MaxHeight="104"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl Width="{Binding ViewportWidth, ElementName=AttachmentScrollViewer}"
                                          ItemsSource="{Binding Attachments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:CopilotAttachmentItem}">
                                        <Grid Margin="0,0,6,6">
                                            <Border x:Name="AttachmentChip"
                                                    Style="{StaticResource AttachmentChipBorderStyle}"
                                                    BorderThickness="1"
                                                    ToolTip="{Binding TooltipText}"
                                                    Visibility="Collapsed">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock Foreground="{DynamicResource GlobalTextBrush}"
                                                               FontSize="11"
                                                               Opacity="0.48"
                                                               Text="{Binding BadgeText}" />
                                                    <TextBlock Margin="7,0,0,0"
                                                               MaxWidth="180"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.9"
                                                               Text="{Binding DisplayLabel}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Button Margin="7,0,0,0"
                                                            Style="{StaticResource AttachmentCloseButtonStyle}"
                                                            Command="{Binding DataContext.OpenAttachmentCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Content="↗"
                                                            ToolTip="查看附件" />
                                                    <Button Margin="7,0,0,0"
                                                            Style="{StaticResource AttachmentCloseButtonStyle}"
                                                            Command="{Binding DataContext.RemoveAttachmentCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Content="×" />
                                                </DockPanel>
                                            </Border>

                                            <Border x:Name="ImageAttachmentCard"
                                                    Padding="6"
                                                    Style="{StaticResource CopilotInsetBorderStyle}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    ToolTip="{Binding TooltipText}"
                                                    Visibility="Collapsed">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="36"
                                                            Height="36"
                                                            Style="{StaticResource CopilotInsetBorderStyle}"
                                                            CornerRadius="10"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" />
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Margin="4"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                                       Opacity="0.52"
                                                                       Text="{Binding ImageFallbackText}"
                                                                       TextAlignment="Center"
                                                                       TextWrapping="Wrap" />
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Center">
                                                        <TextBlock MaxWidth="76"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Text="{Binding DisplayLabel}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock MaxWidth="76"
                                                                   Margin="0,1,0,0"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Opacity="0.5"
                                                                   Text="{Binding ImageMetaText}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Orientation="Horizontal">
                                                        <Button Style="{StaticResource AttachmentCloseButtonStyle}"
                                                                Command="{Binding DataContext.OpenAttachmentCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding}"
                                                                Content="↗"
                                                                ToolTip="查看附件" />
                                                        <Button Margin="4,0,0,0"
                                                                Style="{StaticResource AttachmentCloseButtonStyle}"
                                                                Command="{Binding DataContext.RemoveAttachmentCommand, Source={x:Reference Root}}"
                                                                CommandParameter="{Binding}"
                                                                Content="×"
                                                                ToolTip="移除附件" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                <Setter TargetName="ImageAttachmentCard" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsImage}" Value="False">
                                                <Setter TargetName="AttachmentChip" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <Border Grid.Row="3"
                            MaxHeight="190"
                            Margin="0,0,0,6"
                            Style="{StaticResource CopilotInsetBorderStyle}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Visibility="{Binding HasLocalCommandSuggestions, Converter={StaticResource bool2VisibilityConverter}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding LocalCommandSuggestions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Padding="10,6"
                                                Style="{StaticResource ComposerPopoverButtonStyle}"
                                                Command="{Binding DataContext.CompleteLocalCommandCommand, Source={x:Reference Root}}"
                                                CommandParameter="{Binding}"
                                                Click="LocalCommandSuggestionButton_Click"
                                                ToolTip="点击或使用 Tab 补全；Enter 执行">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontFamily="Consolas"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Name}" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="12,0,0,0"
                                                           Opacity="0.62"
                                                           Text="{Binding Description}" />
                                                <TextBlock Grid.Column="2"
                                                           Margin="14,0,0,0"
                                                           Opacity="0.48"
                                                           Text="Tab 补全" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="4"
                          MinHeight="24">
                        <TextBlock Padding="0,2"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   IsHitTestVisible="False"
                                   Opacity="0.28"
                                   Text="{Binding InputPlaceholder}"
                                   VerticalAlignment="Top">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsInputEmpty}" Value="True" />
                                                <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=PromptTextBox}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="PromptTextBox"
                                 MinHeight="24"
                                 MaxHeight="112"
                                 Padding="0,2"
                                 AcceptsReturn="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 CaretBrush="{DynamicResource GlobalTextBrush}"
                                 Foreground="{DynamicResource GlobalTextBrush}"
                                 GotKeyboardFocus="PromptTextBox_GotKeyboardFocus"
                                 PreviewKeyDown="PromptTextBox_PreviewKeyDown"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto" />
                    </Grid>

                    <Grid x:Name="ComposerFooterGrid" Grid.Row="5" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="AttachMenuButton"
                                Grid.Row="0"
                                Grid.Column="0"
                                Width="28"
                                Height="28"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Click="AttachMenuButton_Click"
                                ToolTip="{Binding AttachmentMenuToolTip}">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="{x:Static properties:Resources.CopilotPasteImage}" Command="{Binding PasteImageAttachmentCommand}" />
                                    <MenuItem Header="{x:Static properties:Resources.CopilotSpecifyWebPage}" Command="{Binding AddWebPageAttachmentCommand}" />
                                    <Separator />
                                    <MenuItem Header="{x:Static properties:Resources.CopilotAddFile}" Command="{Binding AddFileAttachmentCommand}" />
                                    <MenuItem Header="{x:Static properties:Resources.CopilotAddContext}" Command="{Binding AddContextAttachmentCommand}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Text="&#xE710;" />
                        </Button>

                        <Border x:Name="ControlModePill"
                                Grid.Row="0"
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Style="{StaticResource McpStatusPillBorderStyle}"
                                ToolTip="{Binding McpStatusToolTip}"
                                Visibility="{Binding IsControlModeVisible, Converter={StaticResource bool2VisibilityConverter}}">
                            <DockPanel LastChildFill="False">
                                <TextBlock VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           Style="{StaticResource ControlModeTextStyle}"
                                           Text="&#xE83D;" />
                                <TextBlock Margin="5,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Style="{StaticResource ControlModeTextStyle}"
                                           Text="{Binding McpStatusLabel}" />
                            </DockPanel>
                        </Border>

                        <Grid x:Name="ComposerSelectorGrid"
                              Grid.Row="0"
                              Grid.Column="2"
                              MaxWidth="180"
                              Margin="4,0,4,0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center">
                            <ToggleButton x:Name="ProfileSelectorButton"
                                          MaxWidth="180"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="{Binding CanSelectProfile}"
                                          Style="{StaticResource ComposerSelectorToggleButtonStyle}"
                                          ToolTip="{Binding SelectedProfileToolTip}">
                                <Grid TextElement.Foreground="{DynamicResource GlobalTextBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Viewbox Grid.Column="0"
                                             MaxHeight="17"
                                             HorizontalAlignment="Stretch"
                                             Stretch="Uniform"
                                             StretchDirection="DownOnly">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding SelectedProfile.DisplayLabel}" />
                                            <TextBlock Margin="5,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="10"
                                                       Opacity="0.58"
                                                       Text="{Binding SelectedProfileReasoningLabel}" />
                                        </StackPanel>
                                    </Viewbox>
                                    <TextBlock Grid.Column="1"
                                               Margin="7,0,0,0"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               Opacity="0.64"
                                               Text="&#xE70D;" />
                                </Grid>
                            </ToggleButton>

                            <Popup x:Name="ProfileSelectorPopup"
                                   AllowsTransparency="True"
                                   Closed="ProfileSelectorPopup_Closed"
                                   IsOpen="{Binding IsChecked, ElementName=ProfileSelectorButton, Mode=TwoWay}"
                                   Opened="ProfileSelectorPopup_Opened"
                                   Placement="Top"
                                   PlacementTarget="{Binding ElementName=ProfileSelectorButton}"
                                   PopupAnimation="Fade"
                                   StaysOpen="False"
                                   VerticalOffset="6">
                                <Border Padding="14" Background="Transparent">
                                <Grid TextElement.Foreground="{DynamicResource GlobalTextBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="230" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="1"
                                            Padding="4"
                                            VerticalAlignment="Bottom"
                                            Background="{DynamicResource ButtonBackground}"
                                            BorderBrush="{DynamicResource ButtonBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" Opacity="0.2" ShadowDepth="2" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <ToggleButton x:Name="ModelSelectorRowButton"
                                                          Click="ModelSelectorRowButton_Click"
                                                          Style="{StaticResource ComposerPopoverRowToggleStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="模型" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="12,0,0,0"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               FontSize="10"
                                                               Opacity="0.58"
                                                               Text="{Binding SelectedProfile.DisplayLabel}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="2"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="10"
                                                               Opacity="0.64"
                                                               Text="&#xE76C;" />
                                                </Grid>
                                            </ToggleButton>

                                            <ToggleButton x:Name="ReasoningSelectorRowButton"
                                                          Click="ReasoningSelectorRowButton_Click"
                                                          IsEnabled="{Binding HasConfigurableReasoning}"
                                                          Style="{StaticResource ComposerPopoverRowToggleStyle}"
                                                          ToolTip="{Binding SelectedProfileReasoningToolTip}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="推理强度" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="12,0,0,0"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               FontSize="10"
                                                               Opacity="0.58"
                                                               Text="{Binding SelectedProfileReasoningLabel}" />
                                                    <TextBlock Grid.Column="2"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="10"
                                                               Opacity="0.64"
                                                               Text="&#xE76C;" />
                                                </Grid>
                                            </ToggleButton>

                                            <Border Height="1" Margin="6,3" Background="{DynamicResource ButtonBorderBrush}" />

                                            <Button Command="{Binding OpenSettingsCommand}"
                                                    Click="CloseSelectorPopupButton_Click"
                                                    Style="{StaticResource ComposerPopoverButtonStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Text="设置" />
                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11"
                                                               Opacity="0.68"
                                                               Text="&#xE713;" />
                                                </Grid>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="ModelSubmenuBorder"
                                            Grid.Column="0"
                                            Width="276"
                                            MaxHeight="340"
                                            Margin="0,0,8,0"
                                            Padding="4"
                                            VerticalAlignment="Bottom"
                                            Background="{DynamicResource ButtonBackground}"
                                            BorderBrush="{DynamicResource ButtonBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Visibility="Collapsed">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" Opacity="0.2" ShadowDepth="2" />
                                        </Border.Effect>
                                        <DockPanel LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Top"
                                                       Margin="8,5,8,4"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.58"
                                                       Text="模型" />
                                            <ListBox x:Name="ProfileListBox"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     ItemContainerStyle="{StaticResource ComposerPopoverListBoxItemStyle}"
                                                     ItemsSource="{Binding Profiles}"
                                                     PreviewMouseLeftButtonUp="ProfileListBox_PreviewMouseLeftButtonUp"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     SelectedItem="{Binding SelectedProfile, Mode=TwoWay}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid MinHeight="36" Margin="8,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding DisplayLabel}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Margin="0,2,0,0"
                                                                           FontSize="9"
                                                                           Opacity="0.52"
                                                                           Text="{Binding SecondaryLabel}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <TextBlock x:Name="SelectedProfileCheck"
                                                                       Grid.Column="1"
                                                                       Margin="12,0,2,0"
                                                                       VerticalAlignment="Center"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="10"
                                                                       Text="&#xE73E;"
                                                                       Visibility="Collapsed" />
                                                        </Grid>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                <Setter TargetName="SelectedProfileCheck" Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </DockPanel>
                                    </Border>

                                    <Border x:Name="ReasoningSubmenuBorder"
                                            Grid.Column="0"
                                            Width="276"
                                            Margin="0,0,8,0"
                                            Padding="4"
                                            VerticalAlignment="Bottom"
                                            Background="{DynamicResource ButtonBackground}"
                                            BorderBrush="{DynamicResource ButtonBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Visibility="Collapsed">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" Opacity="0.2" ShadowDepth="2" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Margin="8,5,8,4"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Opacity="0.58"
                                                       Text="推理强度" />
                                            <ItemsControl ItemsSource="{Binding SelectedProfileReasoningOptions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Tag="{Binding Mode}"
                                                                Click="ReasoningOptionButton_Click"
                                                                Style="{StaticResource ComposerPopoverButtonStyle}"
                                                                ToolTip="{Binding Description}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding Label}" />
                                                                <TextBlock Grid.Column="1"
                                                                           Margin="12,0,2,0"
                                                                           VerticalAlignment="Center"
                                                                           FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="10"
                                                                           Text="&#xE73E;"
                                                                           Visibility="{Binding IsSelected, Converter={StaticResource bool2VisibilityConverter}}" />
                                                            </Grid>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                </Grid>
                                </Border>
                            </Popup>
                        </Grid>

                        <StackPanel x:Name="ComposerActionStack"
                                    Grid.Row="0"
                                    Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Width="28"
                                    Height="28"
                                    Margin="0,0,6,0"
                                    Command="{Binding CancelCommand}"
                                    Content="×"
                                    FontSize="16"
                                    Style="{StaticResource CopilotIconButtonStyle}"
                                    Visibility="{Binding CanCancelAgentRun, Converter={StaticResource bool2VisibilityConverter}}"
                                    ToolTip="取消当前 Agent 任务并丢弃本轮新 checkpoint" />
                            <Button Width="28"
                                    Height="28"
                                    Margin="0,0,6,0"
                                    Command="{Binding SteerCommand}"
                                    Content="↳"
                                    FontSize="15"
                                    Style="{StaticResource CopilotIconButtonStyle}"
                                    Visibility="{Binding CanSteerCurrentRun, Converter={StaticResource bool2VisibilityConverter}}"
                                    ToolTip="把输入作为新指令加入当前 Agent 运行（Enter）" />

                            <Button x:Name="VoiceInputButton"
                                    Width="28"
                                    Height="28"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource CopilotIconButtonStyle}"
                                    Click="VoiceInputButton_Click"
                                    ToolTip="语音输入（Windows + H）">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           Text="&#xE720;" />
                            </Button>

                            <Button Margin="2,0,0,0"
                                    Command="{Binding PrimaryActionCommand}"
                                    Style="{StaticResource ComposerPrimaryActionButtonStyle}"
                                    Content="{Binding PrimaryActionGlyph}"
                                    FontSize="15"
                                    ToolTip="{Binding PrimaryActionToolTip}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1">
            <Border x:Name="ConversationSidebarBorder"
                    Background="{DynamicResource ButtonBackground}"
                    BorderBrush="{DynamicResource ButtonBorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="12,8,10,8" LastChildFill="False">
                        <Button x:Name="CompactSidebarToggleButton"
                                Margin="0,0,6,0"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Click="ToggleConversationSidebarButton_Click"
                                ToolTip="{x:Static properties:Resources.CopilotCollapseConversationList}"
                                Visibility="Collapsed">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       Text="&#xE8A7;" />
                        </Button>

                        <Button Width="28"
                                Height="28"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Command="{Binding NewChatCommand}"
                                DockPanel.Dock="Right"
                                ToolTip="{x:Static properties:Resources.CopilotNewConversation}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Text="&#xE710;" />
                        </Button>

                        <Button Width="28"
                                Height="28"
                                Margin="0,0,4,0"
                                Style="{StaticResource CopilotIconButtonStyle}"
                                Command="{Binding ExportConversationCommand}"
                                CommandParameter="{Binding SelectedConversation}"
                                DockPanel.Dock="Right"
                                ToolTip="导出当前会话为 Markdown">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Text="&#xE74E;" />
                        </Button>

                        <TextBlock VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Text="{x:Static properties:Resources.CopilotConversations}" />
                    </DockPanel>

                    <Border Grid.Row="1"
                            Margin="8,0,8,8"
                            Padding="8,5"
                            Style="{StaticResource CopilotInsetBorderStyle}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Opacity="0.42"
                                       Text="&#xE721;" />
                            <Grid Grid.Column="1" Margin="7,0,4,0">
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource GlobalTextBrush}"
                                           IsHitTestVisible="False"
                                           Opacity="0.38"
                                           Text="搜索会话"
                                           Visibility="{Binding IsConversationSearchEmpty, Converter={StaticResource bool2VisibilityConverter}}" />
                                <TextBox Padding="0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="11"
                                         Foreground="{DynamicResource GlobalTextBrush}"
                                         Text="{Binding ConversationSearchText, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                            <Button Grid.Column="2"
                                    Style="{StaticResource AttachmentCloseButtonStyle}"
                                    Command="{Binding ClearConversationSearchCommand}"
                                    Content="×"
                                    ToolTip="清除搜索"
                                    Visibility="{Binding HasConversationSearchQuery, Converter={StaticResource bool2VisibilityConverter}}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="8,0,8,8"
                            Padding="8,7"
                            Style="{StaticResource CopilotInsetBorderStyle}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Visibility="{Binding HasAgentTasks, Converter={StaticResource bool2VisibilityConverter}}">
                        <StackPanel>
                            <DockPanel Margin="2,0,2,5" LastChildFill="False">
                                <Border DockPanel.Dock="Right"
                                        MinWidth="18"
                                        Padding="4,1"
                                        Background="{DynamicResource GlobalBorderBrush1}"
                                        CornerRadius="9">
                                    <TextBlock HorizontalAlignment="Center"
                                               FontSize="10"
                                               Foreground="{DynamicResource GlobalTextBrush}"
                                               Text="{Binding AgentTaskCountLabel}" />
                                </Border>
                                <TextBlock VerticalAlignment="Center"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource GlobalTextBrush}"
                                           Opacity="0.72"
                                           Text="Agent 任务" />
                            </DockPanel>

                            <ScrollViewer MaxHeight="168" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AgentTasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:CopilotAgentTaskSummary}">
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Button Grid.Column="0"
                                                        Padding="4,3"
                                                        HorizontalContentAlignment="Stretch"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        Command="{Binding DataContext.OpenAgentTaskCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel>
                                                        <TextBlock FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Text="{Binding Title}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Margin="0,1,0,0"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Opacity="0.58"
                                                                   Text="{Binding StatusLabel}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding DetailLabel}" />
                                                    </StackPanel>
                                                </Button>

                                                <Button Grid.Column="1"
                                                        Width="24"
                                                        Height="24"
                                                        Margin="3,0,0,0"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        Command="{Binding DataContext.ResumeAgentTaskCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="▶"
                                                        FontSize="9"
                                                        ToolTip="继续 Agent 任务"
                                                        Visibility="{Binding CanResume, Converter={StaticResource bool2VisibilityConverter}}" />
                                                <Button Grid.Column="2"
                                                        Width="24"
                                                        Height="24"
                                                        Margin="2,0,0,0"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        Command="{Binding DataContext.DismissAgentTaskCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="×"
                                                        FontSize="13"
                                                        ToolTip="放弃并清除继续状态" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="ConversationListBox"
                             Grid.Row="3"
                             Padding="0,0,0,10"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}"
                             ItemsSource="{Binding FilteredConversations}"
                             SelectedItem="{Binding SelectedConversation, Mode=OneWay}"
                             SelectionChanged="ConversationListBox_SelectionChanged"
                             IsEnabled="{Binding CanSwitchConversation}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotConversationRecord}">
                                <Border Padding="11,9"
                                        Style="{StaticResource CopilotInsetBorderStyle}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="{x:Static properties:Resources.Rename}"
                                                      Command="{Binding DataContext.RenameConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="{Binding PinMenuText}"
                                                      Command="{Binding DataContext.TogglePinConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="导出 Markdown"
                                                      Command="{Binding DataContext.ExportConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="{x:Static properties:Resources.Delete}"
                                                      Command="{Binding DataContext.DeleteConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock MaxWidth="138"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Text="{Binding Title}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="6,0,0,0"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           FontSize="11"
                                                           Opacity="0.48"
                                                           Text="{Binding PinLabel}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Border Margin="6,0,0,0"
                                                        Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource GlobalBorderBrush1}"
                                                        CornerRadius="6"
                                                        Visibility="{Binding HasAgentRunStatus, Converter={StaticResource bool2VisibilityConverter}}">
                                                    <TextBlock FontSize="9"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Opacity="0.72"
                                                               Text="{Binding AgentRunStatusLabel}" />
                                                </Border>
                                            </StackPanel>
                                        </DockPanel>

                                        <DockPanel Margin="0,4,0,0" LastChildFill="False">
                                            <TextBlock MaxWidth="118"
                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                       FontSize="11"
                                                       Opacity="0.72"
                                                       Text="{Binding ConversationListPreviewText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="8,0,0,0"
                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                       FontSize="11"
                                                       Opacity="0.5"
                                                       Text="{Binding UpdatedLabel}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="3"
                               Margin="16"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource GlobalTextBrush}"
                               IsHitTestVisible="False"
                               Opacity="0.48"
                               Text="没有匹配的会话"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasNoConversationSearchResults, Converter={StaticResource bool2VisibilityConverter}}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
