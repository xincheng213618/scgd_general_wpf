<UserControl x:Class="ColorVision.Copilot.CopilotChatPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.Copilot"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:CopilotChatViewModel}">
    <UserControl.Resources>
    </UserControl.Resources>

    <Grid Background="{DynamicResource GlobalBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="248" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MaxWidth="320"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Opacity="0.68"
                           Text="{Binding EmptyStateText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsConversationEmpty, Converter={StaticResource bool2VisibilityConverter}}" />

                <ScrollViewer x:Name="MessagesScrollViewer" VerticalScrollBarVisibility="Auto">
                    <ItemsControl Margin="14,12,14,12" ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotChatMessage}">
                                <Grid Margin="0,0,0,18">
                                    <Border x:Name="UserBubble"
                                            MaxWidth="560"
                                            Padding="14,12"
                                            HorizontalAlignment="Right"
                                            Background="#153B66"
                                            BorderBrush="#316BA8"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Content}" TextWrapping="Wrap" />
                                            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Right" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.48" Text="{Binding TimeLabel}" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel x:Name="AssistantPanel" Visibility="Collapsed">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource GlobalTextBrush}" Text="AI" />
                                            <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.48" Text="{Binding TimeLabel}" />
                                        </DockPanel>

                                        <Expander Margin="0,0,0,8"
                                                  Foreground="{DynamicResource GlobalTextBrush}"
                                                  Header="{Binding ReasoningHeader}"
                                                  IsExpanded="{Binding IsReasoningExpanded, Mode=TwoWay}"
                                                  Visibility="{Binding HasReasoning, Converter={StaticResource bool2VisibilityConverter}}">
                                            <Border Margin="0,6,0,0" Padding="10,8" Background="#11161D" BorderBrush="#273141" BorderThickness="1" CornerRadius="8">
                                                <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.88" Text="{Binding ReasoningContent}" TextWrapping="Wrap" />
                                            </Border>
                                        </Expander>

                                        <local:CopilotMarkdownView Markdown="{Binding Content}" />
                                    </StackPanel>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter TargetName="UserBubble" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsUser}" Value="False">
                                        <Setter TargetName="AssistantPanel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="1"
                    Margin="12,0,12,12"
                    Padding="12,10"
                    Background="#10151B"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel DockPanel.Dock="Left" Margin="0,0,12,0" Orientation="Horizontal">
                            <Button Padding="8,2" Command="{Binding AddFileAttachmentCommand}" Content="+ 文件" />
                            <Button Margin="6,0,0,0" Padding="8,2" Command="{Binding AddContextAttachmentCommand}" Content="+ 上下文" />
                        </StackPanel>

                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.48"
                                   Text="未挂载文件或上下文"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>

                            <ItemsControl ItemsSource="{Binding Attachments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:CopilotAttachmentItem}">
                                        <Border Margin="0,0,8,0"
                                                Padding="8,4"
                                                Background="#171B22"
                                                BorderBrush="#273141"
                                                BorderThickness="1"
                                                CornerRadius="999"
                                                ToolTip="{Binding TooltipText}">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.52" Text="{Binding BadgeText}" />
                                                <TextBlock Margin="8,0,0,0"
                                                           MaxWidth="180"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Text="{Binding DisplayLabel}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Button Margin="8,0,0,0"
                                                        Padding="0"
                                                        Command="{Binding DataContext.RemoveAttachmentCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="x"
                                                        Width="16"
                                                        Height="16" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0" Background="Transparent" BorderThickness="0"
                                  VerticalAlignment="Bottom"
                                  ItemsSource="{Binding Profiles}"
                                  DisplayMemberPath="DisplayLabel"
                                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                  IsEnabled="{Binding CanSelectProfile}" />

                        <TextBox x:Name="PromptTextBox"
                                 Grid.Column="2"
                                 MinHeight="40"
                                 MaxHeight="150"
                                 Padding="0,7,0,7"
                                 AcceptsReturn="True"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource GlobalTextBrush}"
                                 PreviewKeyDown="PromptTextBox_PreviewKeyDown"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Center"
                                 VerticalScrollBarVisibility="Auto" />

                        <Button Grid.Column="4"
                                Width="40"
                                Height="40"
                                Padding="0" Background="Transparent" BorderThickness="0"
                                  VerticalAlignment="Bottom"
                                Command="{Binding PrimaryActionCommand}"
                                Content="{Binding PrimaryActionGlyph}"
                                FontSize="16"
                                ToolTip="{Binding PrimaryActionToolTip}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1" Background="#10151B" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="8,8,8,6" Orientation="Horizontal">
                    <Button Width="34" Margin="0,0,6,0" Padding="0" Command="{Binding NewChatCommand}" Content="+" />
                    <Button Padding="10,4" Command="{Binding OpenSettingsCommand}" Content="配置" IsEnabled="{Binding CanSwitchConversation}" />
                </StackPanel>

                <ListBox Grid.Row="1"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemsSource="{Binding Conversations}"
                         SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                         IsEnabled="{Binding CanSwitchConversation}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:CopilotConversationRecord}">
                            <Border Padding="10,8">
                                <Border.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="重命名"
                                                  Command="{Binding DataContext.RenameConversationCommand, Source={x:Reference Root}}"
                                                  CommandParameter="{Binding}" />
                                        <MenuItem Header="{Binding PinMenuText}"
                                                  Command="{Binding DataContext.TogglePinConversationCommand, Source={x:Reference Root}}"
                                                  CommandParameter="{Binding}" />
                                        <Separator />
                                        <MenuItem Header="删除"
                                                  Command="{Binding DataContext.DeleteConversationCommand, Source={x:Reference Root}}"
                                                  CommandParameter="{Binding}" />
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <StackPanel>
                                    <DockPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="6,0,0,0"
                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                       FontSize="11"
                                                       Opacity="0.48"
                                                       Text="{Binding PinLabel}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.55" Text="{Binding UpdatedLabel}" />
                                    </DockPanel>
                                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.62" Text="{Binding ProfileDisplayName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.78" Text="{Binding PreviewText}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>