<UserControl x:Class="ColorVision.Copilot.CopilotChatPanel"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision.Copilot"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:CopilotChatViewModel}" d:Height="500" d:Width="600">
    <UserControl.Resources>
        <Style x:Key="AssistantPlainTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
            <Setter Property="Opacity" Value="0.94" />
        </Style>
        <Style x:Key="ReadOnlyMessageTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
        <Style x:Key="MessageActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Opacity" Value="0.54" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.84" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.28" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ComposerComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="UserMessageTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ReadOnlyMessageTextBoxStyle}">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style x:Key="UserMessageMetaTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style x:Key="UserMessageActionButtonStyle" TargetType="Button" BasedOn="{StaticResource MessageActionButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>
        <Style x:Key="CopilotSurfaceBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style x:Key="CopilotInsetBorderStyle" TargetType="Border" BasedOn="{StaticResource CopilotSurfaceBorderStyle}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="SidebarColumnDefinition" Width="184" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

                <Border Grid.Row="0"
                    Margin="12,12,12,0"
                    Padding="2,0,2,10"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="False">
                    <Button x:Name="TitleBarConversationButton"
                        DockPanel.Dock="Right"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="8,0,0,0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Click="ToggleConversationSidebarButton_Click"
                        ToolTip="展开会话列表"
                        Visibility="Collapsed">
                    <Grid Width="18" Height="16">
                        <Border Width="10"
                            Height="6"
                            Margin="8,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#2E3A49"
                            BorderBrush="#445063"
                            BorderThickness="1"
                            CornerRadius="2"
                            Opacity="0.38" />
                        <Border Width="10"
                            Height="6"
                            Margin="4,4,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#354150"
                            BorderBrush="#4C5A71"
                            BorderThickness="1"
                            CornerRadius="2"
                            Opacity="0.7" />
                        <Border Width="10"
                            Height="6"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#4A5A73"
                            BorderBrush="#6E80A0"
                            BorderThickness="1"
                            CornerRadius="2" />
                    </Grid>
                    </Button>

                    <TextBlock MaxWidth="520"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Text="{Binding SelectedConversation.Title, FallbackValue=新会话, TargetNullValue=新会话}"
                           TextTrimming="CharacterEllipsis" />
                </DockPanel>
                </Border>

            <Grid Grid.Row="1">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MaxWidth="320"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Opacity="0.68"
                           Text="{Binding EmptyStateText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsConversationEmpty, Converter={StaticResource bool2VisibilityConverter}}" />

                <ScrollViewer x:Name="MessagesScrollViewer" VerticalScrollBarVisibility="Auto">
                    <ItemsControl Margin="14,12,14,12" ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotChatMessage}">
                                <Grid Margin="0,0,0,18">
                                    <Border x:Name="UserBubble"
                                            MaxWidth="560"
                                            Padding="14,12"
                                            HorizontalAlignment="Right"
                                            Background="{DynamicResource PrimaryBrush}"
                                            BorderBrush="{DynamicResource PrimaryBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBox Style="{StaticResource UserMessageTextBoxStyle}"
                                                     Text="{Binding Content, Mode=OneWay}" />
                                            <TextBlock Margin="0,8,0,0"
                                                       HorizontalAlignment="Right"
                                                       FontSize="11"
                                                       Style="{StaticResource UserMessageMetaTextStyle}"
                                                       Text="{Binding TimeLabel}" />
                                            <StackPanel Margin="0,8,0,0"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Style="{StaticResource UserMessageActionButtonStyle}"
                                                        Command="{Binding DataContext.CopyMessageCommand, Source={x:Reference Root}}"
                                                        CommandParameter="{Binding}"
                                                        Content="复制"
                                                        ToolTip="复制当前消息" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel x:Name="AssistantPanel" Visibility="Collapsed">
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock MaxWidth="320"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                       Text="{Binding Header}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock DockPanel.Dock="Right" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.48" Text="{Binding TimeLabel}" />
                                        </DockPanel>

                                        <Expander Margin="0,0,0,8"
                                                  Foreground="{DynamicResource GlobalTextBrush}"
                                                  Header="{Binding ExecutionHeader}"
                                                  IsExpanded="{Binding IsExecutionExpanded, Mode=TwoWay}"
                                                  Visibility="{Binding HasExecutionTrace, Converter={StaticResource bool2VisibilityConverter}}">
                                            <Border Margin="0,6,0,0"
                                                    Padding="10,8"
                                                    Style="{StaticResource CopilotSurfaceBorderStyle}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <TextBox Style="{StaticResource ReadOnlyMessageTextBoxStyle}"
                                                         Opacity="0.9"
                                                         Text="{Binding ExecutionContent, Mode=OneWay}" />
                                            </Border>
                                        </Expander>

                                        <Expander Margin="0,0,0,8"
                                                  Foreground="{DynamicResource GlobalTextBrush}"
                                                  Header="{Binding ReasoningHeader}"
                                                  IsExpanded="{Binding IsReasoningExpanded, Mode=TwoWay}"
                                                  Visibility="{Binding HasReasoning, Converter={StaticResource bool2VisibilityConverter}}">
                                            <Border Margin="0,6,0,0"
                                                    Padding="10,8"
                                                    Style="{StaticResource CopilotSurfaceBorderStyle}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <TextBox Style="{StaticResource ReadOnlyMessageTextBoxStyle}"
                                                         Opacity="0.88"
                                                         Text="{Binding ReasoningContent, Mode=OneWay}" />
                                            </Border>
                                        </Expander>

                                        <TextBox Style="{StaticResource ReadOnlyMessageTextBoxStyle}"
                                                 Opacity="0.94"
                                                 Text="{Binding Content, Mode=OneWay}" />

                    <StackPanel Margin="0,10,0,0"
                            Orientation="Horizontal">
                        <Button Style="{StaticResource MessageActionButtonStyle}"
                            Command="{Binding DataContext.CopyMessageCommand, Source={x:Reference Root}}"
                            CommandParameter="{Binding}"
                            Content="复制"
                            ToolTip="复制当前消息" />
                        <Button Style="{StaticResource MessageActionButtonStyle}"
                            Command="{Binding DataContext.RetryMessageCommand, Source={x:Reference Root}}"
                            CommandParameter="{Binding}"
                            Content="重试"
                            ToolTip="重新生成当前轮回答" />
                        <Button Style="{StaticResource MessageActionButtonStyle}"
                            Margin="0"
                            Command="{Binding DataContext.RefreshMessageCommand, Source={x:Reference Root}}"
                            CommandParameter="{Binding}"
                            Content="刷新"
                            ToolTip="重新抓取网页上下文并生成回答" />
                    </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter TargetName="UserBubble" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsUser}" Value="False">
                                        <Setter TargetName="AssistantPanel" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

                <Border Grid.Row="2"
                    Margin="5,0,5,5"
                    Padding="5,5"
                    Style="{StaticResource CopilotSurfaceBorderStyle}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Foreground="{DynamicResource GlobalTextBrush}"
                                   Opacity="0.48"
                                   Text="未挂载文件、图片、网页或上下文"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ScrollViewer x:Name="AttachmentScrollViewer"
                                      MaxHeight="104"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>

                            <ItemsControl Width="{Binding ViewportWidth, ElementName=AttachmentScrollViewer}"
                                          ItemsSource="{Binding Attachments}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:CopilotAttachmentItem}">
                                        <Grid Margin="0,0,8,0">
                                            <Border x:Name="AttachmentChip"
                                                    Padding="8,4"
                                                    Style="{StaticResource CopilotSurfaceBorderStyle}"
                                                    BorderThickness="1"
                                                    CornerRadius="999"
                                                    ToolTip="{Binding TooltipText}"
                                                    Visibility="Collapsed">
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.52" Text="{Binding BadgeText}" />
                                                    <TextBlock Margin="8,0,0,0"
                                                               MaxWidth="180"
                                                               Foreground="{DynamicResource GlobalTextBrush}"
                                                               Text="{Binding DisplayLabel}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <Button Margin="8,0,0,0"
                                                            Width="16"
                                                            Height="16"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            Command="{Binding DataContext.RemoveAttachmentCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Foreground="{DynamicResource GlobalTextBrush}"
                                                            Content="×" />
                                                </DockPanel>
                                            </Border>

                                            <Border x:Name="ImageAttachmentCard"
                                                    Padding="6"
                                                        Style="{StaticResource CopilotSurfaceBorderStyle}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    ToolTip="{Binding TooltipText}"
                                                    Visibility="Collapsed">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="36"
                                                            Height="36"
                                                            Style="{StaticResource CopilotInsetBorderStyle}"
                                                            CornerRadius="10"
                                                            ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" />
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Margin="4"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                                       Opacity="0.52"
                                                                       Text="{Binding ImageFallbackText}"
                                                                       TextAlignment="Center"
                                                                       TextWrapping="Wrap" />
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                                Margin="8,0,0,0"
                                                                VerticalAlignment="Center">
                                                        <TextBlock MaxWidth="76"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Text="{Binding DisplayLabel}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock MaxWidth="76"
                                                                   Margin="0,1,0,0"
                                                                   FontSize="10"
                                                                   Foreground="{DynamicResource GlobalTextBrush}"
                                                                   Opacity="0.5"
                                                                   Text="{Binding ImageMetaText}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <Button Grid.Column="2"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="8,0,0,0"
                                                            Padding="0"
                                                            VerticalAlignment="Center"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            Command="{Binding DataContext.RemoveAttachmentCommand, Source={x:Reference Root}}"
                                                            CommandParameter="{Binding}"
                                                            Content="×"
                                                            Foreground="{DynamicResource GlobalTextBrush}" />
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                <Setter TargetName="ImageAttachmentCard" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsImage}" Value="False">
                                                <Setter TargetName="AttachmentChip" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <TextBox x:Name="PromptTextBox"
                             Grid.Row="1"
                             MinHeight="20"
                             MaxHeight="68"
                             Padding="0,4,0,4"
                             AcceptsReturn="True"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource GlobalTextBrush}"
                             PreviewKeyDown="PromptTextBox_PreviewKeyDown"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto" />

                    <DockPanel Grid.Row="2" Margin="0,0,0,0">
                        <Button DockPanel.Dock="Right" Grid.Column="6"
                                Width="40"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Command="{Binding PrimaryActionCommand}"
                                Content="{Binding PrimaryActionGlyph}"
                                FontSize="16"
                                Foreground="{DynamicResource GlobalTextBrush}"
                                ToolTip="{Binding PrimaryActionToolTip}" />
                        <Button x:Name="AttachMenuButton"
                                Grid.Column="0"  Width="36"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Click="AttachMenuButton_Click"
                            ToolTip="挂载文件、图片或上下文">
                            <Button.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="粘贴图片" Command="{Binding PasteImageAttachmentCommand}" />
                                    <MenuItem Header="指定网页" Command="{Binding AddWebPageAttachmentCommand}" />
                                    <Separator />
                                    <MenuItem Header="添加文件" Command="{Binding AddFileAttachmentCommand}" />
                                    <MenuItem Header="添加上下文" Command="{Binding AddContextAttachmentCommand}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="✚" />
                        </Button>

                            <ComboBox Width="76"
                                    Margin="6,0,8,0"
                                    Style="{StaticResource ComposerComboBoxStyle}"
                                    VerticalAlignment="Center"
                                    ItemsSource="{Binding AgentModes}"
                                    DisplayMemberPath="Label"
                                    SelectedValuePath="Mode"
                                    SelectedValue="{Binding SelectedAgentMode, Mode=TwoWay}"
                                    IsEnabled="{Binding CanSelectAgentMode}"
                                    ToolTip="{Binding SelectedAgentModeDescription}" />

                        <ComboBox Grid.Column="2"
                                    Margin="0,0,6,0"
                                  Style="{StaticResource ComposerComboBoxStyle}"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding Profiles}"
                                  DisplayMemberPath="DisplayLabel"
                                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                  IsEnabled="{Binding CanSelectProfile}" />

                        <Button Grid.Column="4"
                            Width="28"
                            Height="28"
                            Margin="6,0,8,0"
                            Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Left"
                                Command="{Binding OpenSettingsCommand}"
                                Foreground="{DynamicResource GlobalTextBrush}"
                            IsEnabled="{Binding CanSwitchConversation}"
                            ToolTip="配置">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="16"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   Text="&#xE713;" />
                        </Button>


                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1">
            <Border x:Name="ConversationSidebarBorder" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="8,8,8,6" LastChildFill="False">
                        <Button x:Name="CompactSidebarToggleButton"
                                Width="28"
                                Height="28"
                                Margin="0,0,6,0"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Click="ToggleConversationSidebarButton_Click"
                                ToolTip="收起会话列表"
                                Visibility="Collapsed">
                            <Grid Width="18" Height="16">
                                <Border Width="10"
                                        Height="6"
                                        Margin="8,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#2E3A49"
                                        BorderBrush="#445063"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Opacity="0.38" />
                                <Border Width="10"
                                        Height="6"
                                        Margin="4,4,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#354150"
                                        BorderBrush="#4C5A71"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Opacity="0.7" />
                                <Border Width="10"
                                        Height="6"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Background="#4A5A73"
                                        BorderBrush="#6E80A0"
                                        BorderThickness="1"
                                        CornerRadius="2" />
                            </Grid>
                        </Button>

                        <Button Width="34"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Command="{Binding NewChatCommand}"
                                DockPanel.Dock="Right"
                                ToolTip="新建会话">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="✚" />
                        </Button>
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemsSource="{Binding Conversations}"
                             SelectedItem="{Binding SelectedConversation, Mode=TwoWay}"
                             IsEnabled="{Binding CanSwitchConversation}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotConversationRecord}">
                                <Border Padding="10,8">
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="重命名"
                                                      Command="{Binding DataContext.RenameConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="{Binding PinMenuText}"
                                                      Command="{Binding DataContext.TogglePinConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="删除"
                                                      Command="{Binding DataContext.DeleteConversationCommand, Source={x:Reference Root}}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Margin="6,0,0,0"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           FontSize="11"
                                                           Opacity="0.48"
                                                           Text="{Binding PinLabel}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>

                                        <DockPanel Margin="0,4,0,0" LastChildFill="False">
                                            <TextBlock MaxWidth="104"
                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                       FontSize="11"
                                                       Opacity="0.72"
                                                       Text="{Binding PreviewText}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="8,0,0,0"
                                                       Foreground="{DynamicResource GlobalTextBrush}"
                                                       FontSize="11"
                                                       Opacity="0.5"
                                                       Text="{Binding UpdatedLabel}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
