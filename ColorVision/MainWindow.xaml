<Window x:Class="ColorVision.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:input="clr-namespace:System.Windows.Input;assembly=netstandard"
        xmlns:local="clr-namespace:ColorVision"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Properties"
        xmlns:search="clr-namespace:ColorVision.UI.Serach;assembly=ColorVision.UI"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:MainWindowConfig}"
        Title="" Width="1280" Height="720"
        Background="{DynamicResource GlobalBackground}"
        Initialized="Window_Initialized">
    <Window.Resources>
        <DataTemplate x:Key="DocumentHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource GlobalBackground}" BorderBrush="{DynamicResource BorderBrush}" WindowChrome.IsHitTestVisibleInChrome="True">
            <DockPanel>
                <StackPanel x:Name="RightMenuItemPanel" DockPanel.Dock="Right" Orientation="Horizontal" />

                <Menu x:Name="Menu1" Padding="2" HorizontalAlignment="Left" Background="Transparent" />
                <search:SearchControl x:Name="SearchControl1" Margin="10,1" HorizontalAlignment="Left" VerticalAlignment="Center" />

            </DockPanel>
        </Border>

        <xcad:DockingManager x:Name="DockingManager1" Grid.Row="1" Margin="-6,-6" Padding="0" Background="Transparent" BorderThickness="0" DocumentHeaderTemplate="{StaticResource DocumentHeaderTemplate}">
            <xcad:LayoutRoot x:Name="_layoutRoot">
                <xcad:LayoutPanel Orientation="Horizontal">
                    <xcad:LayoutAnchorablePaneGroup x:Name="LeftPaneGroup" DockWidth="303">
                        <xcad:LayoutAnchorablePane x:Name="LeftPane">
                            <xcad:LayoutAnchorable Title="{x:Static properties:Resources.SolutionExplorer}" CanAutoHide="True" CanClose="True" CanFloat="True" ContentId="ProjectPanel">
                                <Grid x:Name="ProjectPanelGrid" />
                            </xcad:LayoutAnchorable>
                            <xcad:LayoutAnchorable Title="{x:Static properties:Resources.DeviceControl}" CanAutoHide="True" CanClose="True" CanFloat="True" ContentId="AcquirePanel">
                                <ScrollViewer Background="{DynamicResource GlobalBorderBrush1}" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="StackPanelSPD" Margin="-2,5,0,0" />
                                </ScrollViewer>
                            </xcad:LayoutAnchorable>
                        </xcad:LayoutAnchorablePane>
                    </xcad:LayoutAnchorablePaneGroup>
                    <xcad:LayoutPanel Orientation="Vertical">
                        <xcad:LayoutDocumentPaneGroup>
                            <xcad:LayoutDocumentPane x:Name="LayoutDocumentPane" />
                        </xcad:LayoutDocumentPaneGroup>

                    </xcad:LayoutPanel>
                </xcad:LayoutPanel>
            </xcad:LayoutRoot>
        </xcad:DockingManager>
        <Grid x:Name="StatusBarGrid" Grid.Row="2" Visibility="{Binding IsOpenStatusBar, Converter={StaticResource bool2VisibilityConverter}}" />

    </Grid>
</Window>
