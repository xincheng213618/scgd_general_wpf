<UserControl x:Class="ColorVision.FloatingBall.DesktopPetSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <UserControl.Resources>
        <Style x:Key="DesktopPetToolbarButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="14,4" />
        </Style>

    </UserControl.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Text="宠物" />
                <TextBlock Margin="0,7,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="选择桌面伙伴。它会管理 Copilot 状态，并把需要关注的事情带到桌面。"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                <Button Click="CreatePetButton_Click"
                        Content="创建"
                        Style="{StaticResource DesktopPetToolbarButtonStyle}" />
                <Button x:Name="RefreshButton"
                        Click="RefreshButton_Click"
                        Content="刷新"
                        Style="{StaticResource DesktopPetToolbarButtonStyle}" />
                <Button x:Name="WakePetButton"
                        Click="WakePetButton_Click"
                        Content="唤醒宠物"
                        Style="{StaticResource DesktopPetToolbarButtonStyle}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,18,0,12"
                Padding="12,9"
                Background="{DynamicResource LayoutBackground}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="7">
            <TextBlock x:Name="StatusText"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="正在查找可用素材…"
                       TextWrapping="Wrap" />
        </Border>

        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{DynamicResource LayoutBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="9">
                    <ItemsControl ItemsSource="{Binding Assets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,7"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="58" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="46"
                                                Height="46"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource GlobalBackground}"
                                                BorderBrush="{DynamicResource ButtonBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="7">
                                            <Image Margin="3"
                                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                   Source="{Binding Thumbnail}"
                                                   Stretch="Uniform" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    Margin="10,0,14,0"
                                                    VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource GlobalTextBrush}"
                                                           Text="{Binding DisplayName}" />
                                                <Border Margin="8,0,0,0"
                                                        Padding="5,0"
                                                        Background="{DynamicResource GlobalBackground}"
                                                        BorderBrush="{DynamicResource ButtonBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                    <TextBlock FontSize="9"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               Text="{Binding SourceLabel}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Margin="0,3,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="{Binding Description}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,2,0,0"
                                                       FontSize="9"
                                                       Foreground="#D99000"
                                                       Text="{Binding Diagnostic}"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Diagnostic}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                MinWidth="70"
                                                Height="28"
                                                Padding="11,2"
                                                VerticalAlignment="Center"
                                                Click="SelectPetButton_Click"
                                                Content="{Binding SelectButtonText}"
                                                IsEnabled="{Binding CanSelect}"
                                                Tag="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="14,10"
                        Background="{DynamicResource LayoutBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="自定义宠物" />
                            <TextBlock Margin="0,3,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="打开 ColorVision 素材目录，管理 pet.json 素材包。"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                MinWidth="96"
                                Height="30"
                                Margin="16,0,0,0"
                                Padding="12,3"
                                VerticalAlignment="Center"
                                Click="OpenPetFolderButton_Click"
                                Content="打开目录" />
                    </Grid>
                </Border>

                <Border Margin="0,10,0,0"
                        Padding="14,10"
                        Background="{DynamicResource LayoutBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource GlobalTextBrush}"
                                       Text="外观" />
                            <TextBlock Margin="0,3,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="调整桌面宠物大小" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Margin="18,0,0,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <TextBlock Width="46"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="{Binding Config.PetScale, StringFormat={}{0:P0}}" />
                            <Slider Width="190"
                                    Minimum="0.65"
                                    Maximum="1.45"
                                    SmallChange="0.05"
                                    LargeChange="0.1"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding Config.PetScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,10,0,0"
                        Padding="14,10"
                        Background="{DynamicResource LayoutBackground}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <CheckBox Content="跟随 Copilot 任务状态"
                                      IsChecked="{Binding Config.EnableCopilotIntegration}" />
                            <CheckBox Margin="0,7,0,0"
                                      Content="显示等待确认、完成和失败提醒"
                                      IsEnabled="{Binding Config.EnableCopilotIntegration}"
                                      IsChecked="{Binding Config.ShowCopilotNotifications}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                MinWidth="96"
                                Height="32"
                                Padding="14,4"
                                VerticalAlignment="Center"
                                Click="AdvancedButton_Click"
                                Content="高级设置" />
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
