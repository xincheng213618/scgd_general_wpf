<base:BaseWindow x:Class="ColorVision.AboutMsgWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:base="clr-namespace:ColorVision.Themes.Controls;assembly=ColorVision.Themes"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:graphics="clr-namespace:ColorVision.UI.Graphics;assembly=ColorVision.UI"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:properties="clr-namespace:ColorVision.Properties"
                 mc:Ignorable="d" Width="510" Height="410" Background="Transparent" Initialized="Window_Initialized"
                 IsBlurEnabled="True" PreviewKeyDown="BaseWindow_PreviewKeyDown" ResizeMode="NoResize"
                 ShowInTaskbar="False">
    <base:BaseWindow.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
        </Style>
    </base:BaseWindow.Resources>
    <Grid Margin="0,-30,0,0">
        <Grid x:Name="Grid1" Background="#FFFFFF" Opacity="0.04" />
        <Grid Margin="20,30,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <StackPanel>
                <Image x:Name="ImageLogo" Width="200" Margin="20" PreviewMouseDown="Image_PreviewMouseDown" Source="Assets/Image/ColorVision.png" />
                <TextBlock x:Name="LogoText" Margin="5,15,5,20" HorizontalAlignment="Center" FontWeight="Bold" Text="" />
                <Button x:Name="CloseButton" HorizontalAlignment="Center" Background="Transparent" BorderThickness="0" Click="Button_Click_1" MouseEnter="CloseButton_MouseEnter" MouseLeave="CloseButton_MouseLeave">
                    <Button.Content>
                        <Viewbox Width="200">
                            <Border Width="400" Height="80" Background="Transparent" BorderThickness="4" CornerRadius="10">
                                <Border.BorderBrush>
                                    <LinearGradientBrush Opacity="0.8" StartPoint="1,1" EndPoint="0.0,0">
                                        <LinearGradientBrush.RelativeTransform>
                                            <RotateTransform x:Name="GradientRotateTransform" Angle="0" CenterX="0.5" CenterY="0.5" />
                                        </LinearGradientBrush.RelativeTransform>
                                        <GradientStop Offset="0" Color="#3684F1" />
                                        <GradientStop x:Name="GradientStop1" Offset="0.45" Color="#FBDBB8" />
                                        <GradientStop x:Name="GradientStop2" Offset="0.55" Color="#FBDBB8" />
                                        <GradientStop Offset="1" Color="#3684F1" />
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <BeginStoryboard.Storyboard>
                                                <Storyboard>
                                                    <DoubleAnimation RepeatBehavior="Forever" Storyboard.TargetName="GradientRotateTransform" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1" />
                                                    <DoubleAnimation AutoReverse="True" RepeatBehavior="Forever" Storyboard.TargetName="GradientStop1" Storyboard.TargetProperty="Offset" From="0.6" To="0.1" Duration="0:0:2" />
                                                    <DoubleAnimation AutoReverse="True" RepeatBehavior="Forever" Storyboard.TargetName="GradientStop2" Storyboard.TargetProperty="Offset" From="0.4" To="0.9" Duration="0:0:1" />
                                                </Storyboard>
                                            </BeginStoryboard.Storyboard>

                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <graphics:TextShape x:Name="TextSharp1" VerticalAlignment="Center" Fill="{StaticResource GlobalTextBrush}" FontSize="50" StrokeThickness="2" Text="确定">
                                        <graphics:TextShape.Stroke>
                                            <LinearGradientBrush Opacity="0.8" StartPoint="1,1" EndPoint="0.0,0">
                                                <LinearGradientBrush.RelativeTransform>
                                                    <RotateTransform x:Name="GradientRotateTransform2" Angle="0" CenterX="0.5" CenterY="0.5" />
                                                </LinearGradientBrush.RelativeTransform>
                                                <GradientStop Offset="0.0" Color="Red" />
                                                <GradientStop Offset="0.142" Color="Orange" />
                                                <GradientStop Offset="0.285" Color="Yellow" />
                                                <GradientStop Offset="0.428" Color="Green" />
                                                <GradientStop Offset="0.571" Color="Blue" />
                                                <GradientStop Offset="0.714" Color="Indigo" />
                                                <GradientStop Offset="0.857" Color="Violet" />
                                            </LinearGradientBrush>
                                        </graphics:TextShape.Stroke>
                                    </graphics:TextShape>

                                </StackPanel>
                            </Border>
                        </Viewbox>
                    </Button.Content>

                </Button>
            </StackPanel>


            <StackPanel Grid.Row="1" Margin="5" VerticalAlignment="Bottom">
                <TextBlock x:Name="TextBlockVision" HorizontalAlignment="Center" Text="ColorVision (64位) -  1.0.0.0" TextAlignment="Center" TextWrapping="Wrap" />
                <TextBlock x:Name="TextCUDAVision" VerticalAlignment="Center" Text="CUDA" TextAlignment="Center" Visibility="Collapsed" />
                <TextBlock VerticalAlignment="Center" Text="CopyRight © 2024-2026 ColorVision All Rigths Reserved" TextAlignment="Center" />
            </StackPanel>



        </Grid>


    </Grid>

</base:BaseWindow>
