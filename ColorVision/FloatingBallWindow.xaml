<Window x:Class="ColorVision.FloatingBall.FloatingBallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ColorVision.FloatingBall"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:DesktopPetConfig}"
        Title="ColorVision Desktop Pet"
        Width="300"
        Height="360"
        AllowsTransparency="True"
        Background="Transparent"
        Initialized="Window_Initialized"
        Loaded="Window_Loaded"
        LocationChanged="Window_LocationChanged"
        Closed="Window_Closed"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="{Binding AlwaysOnTop}"
        WindowStyle="None"
        ResizeMode="NoResize">
    <Grid x:Name="Root"
          RenderTransformOrigin="0.5,1"
          Opacity="{Binding PetOpacity}">
        <Grid.RenderTransform>
            <ScaleTransform ScaleX="{Binding PetScale}" ScaleY="{Binding PetScale}" />
        </Grid.RenderTransform>

        <Popup x:Name="CopilotApprovalPopup"
               AllowsTransparency="True"
               Focusable="False"
               HorizontalOffset="0"
               Placement="Top"
               PlacementTarget="{Binding ElementName=PetHost}"
               PopupAnimation="Fade"
               StaysOpen="True"
               VerticalOffset="-8">
            <Grid Width="278">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="9" />
                </Grid.RowDefinitions>
                <Border x:Name="CopilotApprovalBorder"
                        Padding="13,11"
                        Background="#FAFFFFFF"
                        BorderBrush="#5CD99000"
                        BorderThickness="1"
                        CornerRadius="13">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22"
                                          Opacity="0.22"
                                          ShadowDepth="4"
                                          Color="#000000" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ConfirmationTitle"
                                       Margin="0,1,8,0"
                                       Foreground="#202A3A"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="1"
                                    Padding="7,2"
                                    Background="#18D99000"
                                    CornerRadius="8">
                                <TextBlock x:Name="ConfirmationCountText"
                                           Foreground="#8B5D00"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Text="需确认" />
                            </Border>
                        </Grid>

                        <TextBlock x:Name="ConfirmationDescription"
                                   Grid.Row="1"
                                   MaxHeight="38"
                                   Margin="0,7,0,0"
                                   Foreground="#344154"
                                   FontSize="11.5"
                                   LineHeight="16"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap" />

                        <TextBlock x:Name="ConfirmationToolText"
                                   Grid.Row="2"
                                   Margin="0,7,0,0"
                                   Foreground="#5D6878"
                                   FontFamily="Consolas"
                                   FontSize="10.5"
                                   TextTrimming="CharacterEllipsis" />

                        <TextBlock x:Name="ConfirmationExpiryText"
                                   Grid.Row="3"
                                   Margin="0,3,0,0"
                                   Foreground="#7A8492"
                                   FontSize="10.5"
                                   TextTrimming="CharacterEllipsis" />

                        <Grid Grid.Row="4"
                              Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ConfirmationStatusText"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"
                                       Foreground="#7A8492"
                                       FontSize="10.5"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="Collapsed" />
                            <Button Grid.Column="1"
                                    MinWidth="52"
                                    Height="29"
                                    Padding="9,3"
                                    Click="OpenConfirmationButton_Click"
                                    Content="查看" />
                            <Button x:Name="RejectConfirmationButton"
                                    Grid.Column="2"
                                    MinWidth="52"
                                    Height="29"
                                    Margin="7,0,0,0"
                                    Padding="9,3"
                                    Click="RejectConfirmationButton_Click"
                                    Content="拒绝" />
                            <Button x:Name="ApproveConfirmationButton"
                                    Grid.Column="3"
                                    MinWidth="58"
                                    Height="29"
                                    Margin="7,0,0,0"
                                    Padding="9,3"
                                    Background="#2F5BFF"
                                    BorderBrush="#2F5BFF"
                                    Foreground="White"
                                    Click="ApproveConfirmationButton_Click"
                                    Content="批准" />
                        </Grid>
                    </Grid>
                </Border>
                <Path Grid.Row="1"
                      Width="18"
                      Height="9"
                      HorizontalAlignment="Center"
                      Data="M 0 0 L 18 0 L 9 9 Z"
                      Fill="#FAFFFFFF"
                      Stroke="#5CD99000"
                      StrokeThickness="1" />
            </Grid>
        </Popup>

        <Grid x:Name="MessageBubble"
              Width="246"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Opacity="0"
              Visibility="Collapsed"
              RenderTransformOrigin="0.5,1">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="MessageBubbleTransform" Y="8" />
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
            </Grid.RowDefinitions>
            <Border x:Name="MessageBubbleBorder"
                    Grid.Row="0"
                    Background="#F7FFFFFF"
                    BorderBrush="#3B2F5BFF"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12,9">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      Opacity="0.18"
                                      ShadowDepth="3"
                                      Color="#000000" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="MessageTitle"
                               Foreground="#233047"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="MessageText"
                               Margin="0,4,0,0"
                               Foreground="#344154"
                               FontSize="12"
                               LineHeight="17"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Path Grid.Row="1"
                  Width="18"
                  Height="10"
                  HorizontalAlignment="Center"
                  Data="M 0 0 L 18 0 L 9 10 Z"
                  Fill="#F7FFFFFF"
                  Stroke="#3B2F5BFF"
                  StrokeThickness="1" />
        </Grid>

        <Grid x:Name="PetHost"
              Width="240"
              Height="260"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Margin="0,0,0,6"
              Cursor="Hand">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="PetFloatTransform" />
            </Grid.RenderTransform>

            <Grid x:Name="NativePet"
                  RenderTransformOrigin="0.5,0.72">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <RotateTransform x:Name="PetTiltTransform" Angle="0" />
                        <ScaleTransform x:Name="PetTapScaleTransform" ScaleX="1" ScaleY="1" />
                    </TransformGroup>
                </Grid.RenderTransform>

                <Ellipse x:Name="ActivityGlow"
                         Width="184"
                         Height="184"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Fill="#443C6DF0"
                         Opacity="0.18">
                    <Ellipse.Effect>
                        <BlurEffect Radius="24" />
                    </Ellipse.Effect>
                </Ellipse>

                <Image x:Name="DefaultPetImage"
                       Margin="6"
                       Source="/ColorVision;component/Assets/Pets/xiaocai.png"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />

                <Image x:Name="SpritePetImage"
                       Margin="6"
                       Stretch="Uniform"
                       Visibility="Collapsed"
                       RenderOptions.BitmapScalingMode="NearestNeighbor" />

                <Border x:Name="ActivityBadge"
                        Width="34"
                        Height="24"
                        Margin="0,0,22,16"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="#E62F5BFF"
                        BorderBrush="#E6FFFFFF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ActivityBadgeText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="Bold"
                               Text="AI" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
