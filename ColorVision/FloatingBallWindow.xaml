<Window x:Class="ColorVision.FloatingBall.FloatingBallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ColorVision.FloatingBall"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" Title="FloatingBallWindow" Width="125"
        Height="35" AllowDrop="True" AllowsTransparency="True"
        Background="Transparent" Initialized="Window_Initialized" ShowInTaskbar="False"
        Topmost="True" WindowStyle="None">
    <Grid>
        <Border Background="White" BorderBrush="#AF000000" BorderThickness="1"
                CornerRadius="10" Opacity="0.8" />
        <StackPanel Margin="10" VerticalAlignment="Center">
            <TextBlock Text="" />
        </StackPanel>

    </Grid>
</Window>
