<UserControl x:Class="ColorVision.CopilotChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ColorVision"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=local:CopilotChatViewModel}">
    <Grid Background="{DynamicResource GlobalBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="10,10,10,0" Padding="12" Background="#10151B" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource GlobalTextBrush}" Text="ColorVision AI Demo" />
                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="右侧停靠面板，支持 OpenAI / Anthropic 兼容接口。" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Margin="0,0,6,0" Padding="10,4" Command="{Binding ToggleSettingsCommand}" Content="配置" />
                    <Button Margin="0,0,6,0" Padding="10,4" Command="{Binding NewChatCommand}" Content="新会话" />
                    <Button Padding="10,4" Command="{Binding CancelCommand}" Content="停止" IsEnabled="{Binding IsBusy}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="10,8,10,0"
                Padding="12"
                Background="#10151B"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="{Binding IsSettingsOpen, Converter={StaticResource bool2VisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6,10,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="协议" />
                <ComboBox Grid.Row="0"
                          Grid.Column="1"
                          Margin="0,0,0,8"
                          ItemsSource="{Binding ProviderOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding SelectedProviderType}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,10,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="Base URL" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Text="{Binding EditableBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,10,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="API Key" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" Text="{Binding EditableApiKey, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,10,0" VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Text="模型" />
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" Text="{Binding EditableModel, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,10,0" VerticalAlignment="Top" Foreground="{DynamicResource GlobalTextBrush}" Text="提示词" />
                <TextBox Grid.Row="4" Grid.Column="1" Height="74" Margin="0,0,0,8" AcceptsReturn="True" Text="{Binding EditableSystemPrompt, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                <Grid Grid.Row="5" Grid.Column="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource GlobalTextBrush}" Text="最大 Token" />
                        <TextBox Text="{Binding EditableMaxTokens, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource GlobalTextBrush}" Text="温度" />
                        <TextBox Text="{Binding EditableTemperature, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="6" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="{Binding ConnectionSummary}" TextWrapping="Wrap" />
                    <Button Grid.Column="1" Padding="14,6" Command="{Binding SaveSettingsCommand}" Content="保存配置" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="10,8,10,0" Padding="10,8" Background="#10151B" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
            <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding StatusText}" TextWrapping="Wrap" />
        </Border>

        <Border Grid.Row="3" Margin="10,8,10,8" Padding="0" Background="#00FFFFFF">
            <Grid>
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MaxWidth="260"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Opacity="0.68"
                           Text="先在上方配置 API，再开始和 AI 对话。按 Enter 发送，按 Shift+Enter 换行。"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsConversationEmpty, Converter={StaticResource bool2VisibilityConverter}}" />

                <ScrollViewer x:Name="MessagesScrollViewer" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:CopilotChatMessage}">
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource GlobalTextBrush}" Opacity="0.72" Text="{Binding Header}" />

                                    <Border MaxWidth="320" Padding="12,10" BorderThickness="1" CornerRadius="10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Setter Property="Background" Value="#171B22" />
                                                <Setter Property="BorderBrush" Value="#273141" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                        <Setter Property="Background" Value="#153B66" />
                                                        <Setter Property="BorderBrush" Value="#316BA8" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Content}" TextWrapping="Wrap" />
                                    </Border>

                                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.45" Text="{Binding TimeLabel}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="4" Margin="10,0,10,10" Padding="10" Background="#10151B" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="PromptTextBox"
                         MinHeight="72"
                         MaxHeight="160"
                         AcceptsReturn="True"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource GlobalTextBrush}"
                         PreviewKeyDown="PromptTextBox_PreviewKeyDown"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto" />

                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Bottom">
                    <Button MinWidth="76" Padding="14,6" Command="{Binding SendCommand}" Content="发送" />
                    <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource GlobalTextBrush}" FontSize="11" Opacity="0.55" Text="Enter 发送" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>