<Window x:Class="ColorVision.ServiceHost.ServiceHostManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ColorVision Service Host"
        Width="980"
        Height="680"
        MinWidth="820"
        MinHeight="560"
        Background="{DynamicResource GlobalBackground}"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="Margin" Value="0,3,12,3" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="Margin" Value="0,3,0,3" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="12,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="16" TextElement.Foreground="{DynamicResource GlobalTextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                <TextBlock Text="ColorVision Service Host" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="SummaryText" Margin="0,6,0,0" Text="Checking..." />
            </StackPanel>
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Content="Refresh"
                    MinWidth="96"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="RefreshButton_Click" />
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.45*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Status" Style="{StaticResource SectionTitleStyle}" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Service" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ServiceNameText" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="State" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StateText" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Package" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PackageVersionText" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Installed" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="InstalledVersionText" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Running" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="RunningVersionText" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Action" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ActionHintText" Style="{StaticResource ValueTextStyle}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Paths" Style="{StaticResource SectionTitleStyle}" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Package" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PackagePathText" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Installed" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InstalledPathText" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Process" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="RunningProcessText" Style="{StaticResource ValueTextStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Log" Style="{StaticResource LabelTextStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LogPathText" Style="{StaticResource ValueTextStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Service Host" Style="{StaticResource SectionTitleStyle}" />
                            <WrapPanel>
                                <Button x:Name="InstallButton" Content="Install / Update" Style="{StaticResource ActionButtonStyle}" Click="InstallButton_Click" />
                                <Button x:Name="SelfUpdateButton" Content="Self Update" Style="{StaticResource ActionButtonStyle}" Click="SelfUpdateButton_Click" />
                                <Button x:Name="StartButton" Content="Start" Style="{StaticResource ActionButtonStyle}" Click="StartButton_Click" />
                                <Button x:Name="StopButton" Content="Stop" Style="{StaticResource ActionButtonStyle}" Click="StopButton_Click" />
                                <Button x:Name="UninstallButton" Content="Uninstall" Style="{StaticResource ActionButtonStyle}" Click="UninstallButton_Click" />
                                <Button x:Name="PingButton" Content="Ping" Style="{StaticResource ActionButtonStyle}" Click="PingButton_Click" />
                                <Button x:Name="StatusButton" Content="Status" Style="{StaticResource ActionButtonStyle}" Click="StatusButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Maintenance" Style="{StaticResource SectionTitleStyle}" />
                            <WrapPanel>
                                <Button x:Name="FileAssociationButton" Content="File Association" Style="{StaticResource ActionButtonStyle}" Click="FileAssociationButton_Click" />
                                <Button x:Name="RegisterThumbnailButton" Content="Register Thumbnail" Style="{StaticResource ActionButtonStyle}" Click="RegisterThumbnailButton_Click" />
                                <Button x:Name="UnregisterThumbnailButton" Content="Unregister Thumbnail" Style="{StaticResource ActionButtonStyle}" Click="UnregisterThumbnailButton_Click" />
                                <Button x:Name="WriteMarkerButton" Content="Write Marker" Style="{StaticResource ActionButtonStyle}" Click="WriteMarkerButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Diagnostics" Style="{StaticResource SectionTitleStyle}" />
                            <WrapPanel>
                                <Button x:Name="OpenPackageButton" Content="Open Package" Style="{StaticResource ActionButtonStyle}" Click="OpenPackageButton_Click" />
                                <Button x:Name="OpenInstalledButton" Content="Open Installed" Style="{StaticResource ActionButtonStyle}" Click="OpenInstalledButton_Click" />
                                <Button x:Name="OpenLogButton" Content="Open Log" Style="{StaticResource ActionButtonStyle}" Click="OpenLogButton_Click" />
                                <Button x:Name="CopyStatusButton" Content="Copy Status" Style="{StaticResource ActionButtonStyle}" Click="CopyStatusButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2" Style="{StaticResource SectionBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Operation Log" Style="{StaticResource SectionTitleStyle}" />
                    <TextBox x:Name="LogBox"
                             Grid.Row="1"
                             Background="{DynamicResource TerminalBackgroundBrush}"
                             BorderBrush="{DynamicResource ButtonBorderBrush}"
                             Foreground="{DynamicResource TerminalForegroundBrush}"
                             FontFamily="Consolas"
                             FontSize="12"
                             IsReadOnly="True"
                             Padding="8"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
