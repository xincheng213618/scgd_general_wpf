<Window x:Class="ColorVision.Update.ApplicationSnapshotsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Properties"
        Title="{x:Static properties:Resources.UpdatePreviewApplicationSnapshotsLink}"
        Width="860"
        Height="520"
        MinWidth="760"
        MinHeight="440"
        Background="{DynamicResource GlobalBackground}"
        mc:Ignorable="d">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Text="{x:Static properties:Resources.UpdatePreviewApplicationSnapshotsLink}" />
                <TextBlock Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource GlobalTextBrush}"
                           Opacity="0.72"
                           Text="{Binding SnapshotDirectory}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Top">
                <CheckBox Margin="0,0,0,10"
                          HorizontalAlignment="Right"
                          Content="{x:Static properties:Resources.CreateSnapshotBeforeUpdate}"
                          IsChecked="{Binding CreateSnapshotBeforeUpdate, Mode=TwoWay}"
                          ToolTip="{x:Static properties:Resources.CreateSnapshotBeforeUpdateDescription}" />
                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button Margin="0,0,8,0"
                            Click="CreateSnapshot_Click"
                            Content="创建快照"
                            IsEnabled="{Binding CanRunCommand}" />
                    <Button Margin="0,0,8,0"
                            Click="RebuildDefault_Click"
                            Content="重建默认"
                            IsEnabled="{Binding CanRunCommand}" />
                    <Button Click="OpenFolder_Click"
                            Content="打开目录" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,16,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{DynamicResource GlobalTextBrush}"
                       Opacity="0.72"
                       Text="程序目录" />
            <TextBlock Grid.Column="1"
                       Margin="10,0,24,0"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{DynamicResource GlobalTextBrush}"
                       Opacity="0.72"
                       Text="{Binding ProgramDirectory}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{DynamicResource GlobalTextBrush}"
                       Opacity="0.72"
                       Text="{Binding CurrentVersion}" />
        </Grid>

        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  Background="Transparent"
                  BorderBrush="{DynamicResource GlobalBorderBrush}"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  ItemsSource="{Binding Snapshots}"
                  SelectedItem="{Binding SelectedSnapshot, Mode=TwoWay}"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Width="110"
                                    Binding="{Binding SnapshotTypeText}"
                                    Header="类型" />
                <DataGridTextColumn Width="155"
                                    Binding="{Binding CreatedAtText}"
                                    Header="时间" />
                <DataGridTextColumn Width="180"
                                    Binding="{Binding VersionText}"
                                    Header="版本" />
                <DataGridTextColumn Width="90"
                                    Binding="{Binding SizeText}"
                                    Header="大小" />
                <DataGridTextColumn Width="*"
                                    Binding="{Binding FileName}"
                                    Header="文件" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{DynamicResource GlobalTextBrush}"
                       Opacity="0.72"
                       Text="{Binding StatusText}"
                       TextTrimming="CharacterEllipsis" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Click="Refresh_Click"
                        Content="刷新"
                        IsEnabled="{Binding CanRunCommand}" />
                <Button Margin="0,0,8,0"
                        Click="RestoreSnapshot_Click"
                        Content="还原"
                        IsEnabled="{Binding CanUseSelected}" />
                <Button Click="DeleteSnapshot_Click"
                        Content="删除"
                        IsEnabled="{Binding CanUseSelected}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
