<base:BaseWindow x:Class="ColorVision.Update.UpdatePreviewWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:base="clr-namespace:ColorVision.Themes.Controls;assembly=ColorVision.Themes"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:local="clr-namespace:ColorVision.Update"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 Width="948"
                 Height="620"
                 MinWidth="860"
                 MinHeight="520"
                 Title="ColorVision"
                 ShowTitle="True"
                 ShowIcon="False"
                 Background="{DynamicResource UpdateDialog.Background}"
                 BorderBrush="{DynamicResource UpdateDialog.Border}"
                 BorderThickness="1"
                 mc:Ignorable="d">
    <base:BaseWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="UpdateDialogTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </base:BaseWindow.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,14"
                Padding="18,16"
                Background="{DynamicResource UpdateDialog.SurfaceAlt}"
                BorderBrush="{DynamicResource UpdateDialog.WeakBorder}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26"
                               FontWeight="Bold"
                               Foreground="{DynamicResource UpdateDialog.TextPrimary}"
                               Text="{Binding Heading}"
                               TextTrimming="None"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               MaxWidth="620"
                               Foreground="{DynamicResource UpdateDialog.TextSecondary}"
                               Opacity="0.72"
                               Text="{Binding Summary}"
                               TextTrimming="None"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="16,0,0,0"
                        Padding="12,8"
                        VerticalAlignment="Top"
                        Background="{DynamicResource UpdateDialog.TagBackground}"
                        BorderBrush="{DynamicResource UpdateDialog.WeakBorder}"
                        BorderThickness="1"
                        CornerRadius="999">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource UpdateDialog.TagForeground}"
                               Text="{Binding HostVersionText}"
                               TextTrimming="None"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border Style="{StaticResource UpdateDialogCardStyle}"
                    Margin="0"
                    MinWidth="360"
                    MaxWidth="440"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding CheckingVisibility}">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="52"
                            Height="52"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource UpdateDialog.Background}"
                            BorderBrush="{DynamicResource UpdateDialog.Border}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="22"
                                   Foreground="{DynamicResource UpdateDialog.Accent}"
                                   Text="{Binding StateGlyph}" />
                    </Border>
                    <TextBlock Margin="0,18,0,0"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource UpdateDialog.TextPrimary}"
                               Text="{Binding CheckingTitle}" />
                    <TextBlock Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource UpdateDialog.TextSecondary}"
                               Opacity="0.72"
                               Text="{Binding CheckingSummary}"
                               TextAlignment="Center"
                               TextTrimming="None"
                               TextWrapping="Wrap" />
                    <ProgressBar Width="220"
                                 Height="6"
                                 Margin="0,18,0,0"
                                 IsIndeterminate="True"
                                 Background="{DynamicResource UpdateDialog.Background}"
                                 Foreground="{DynamicResource UpdateDialog.Accent}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource UpdateDialogCardStyle}"
                    Margin="0"
                    MinWidth="360"
                    MaxWidth="460"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding EmptyStateCenteredVisibility}">
                <StackPanel HorizontalAlignment="Center">
                    <Border Width="52"
                            Height="52"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource UpdateDialog.Background}"
                            BorderBrush="{DynamicResource UpdateDialog.Border}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="22"
                                   Foreground="{DynamicResource UpdateDialog.Accent}"
                                   Text="{Binding StateGlyph}" />
                    </Border>
                    <TextBlock Margin="0,18,0,0"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource UpdateDialog.TextPrimary}"
                               Text="{Binding EmptyStateTitle}" />
                    <TextBlock Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource UpdateDialog.TextSecondary}"
                               Opacity="0.72"
                               Text="{Binding EmptyStateMessage}"
                               TextAlignment="Center"
                               TextTrimming="None"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <ScrollViewer MaxHeight="{Binding ItemsViewportMaxHeight}"
                          VerticalAlignment="Top"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding ItemsListVisibility}">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:UpdatePreviewItem}">
                            <Border Style="{StaticResource UpdateDialogCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <CheckBox Margin="0,2,12,0"
                                                  VerticalAlignment="Top"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Visibility="{Binding SelectionVisibility}" />

                                        <Border Margin="0,0,12,0"
                                                VerticalAlignment="Top"
                                                Visibility="{Binding RequiredTagVisibility}"
                                                Style="{StaticResource UpdateDialogTagBorderStyle}">
                                            <TextBlock FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource UpdateDialog.TagForeground}"
                                                       Text="必选" />
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="17"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource UpdateDialog.TextPrimary}"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                            <TextBlock Margin="0,3,0,0"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource UpdateDialog.TextSecondary}"
                                                       Opacity="0.72"
                                                       Text="{Binding SecondaryLabel}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       Visibility="{Binding SecondaryLabelVisibility}" />
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Margin="14,0,0,0"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource UpdateDialogTagBorderStyle}">
                                            <TextBlock FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource UpdateDialog.TagForeground}"
                                                       Text="{Binding Category}" />
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="1" Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource UpdateDialog.TextPrimary}"
                                                   Text="{Binding VersionTransitionText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap" />

                                        <TextBlock Grid.Column="1"
                                                   Margin="16,0,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource UpdateDialog.TextSecondary}"
                                                   Opacity="0.78"
                                                   Text="{Binding HostRequirementText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   Visibility="{Binding HostRequirementVisibility}" />
                                    </Grid>

                                    <TextBlock Grid.Row="2"
                                               Margin="0,10,0,0"
                                               Foreground="{DynamicResource UpdateDialog.TextSecondary}"
                                               Opacity="0.86"
                                               Text="{Binding Summary}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="Wrap"
                                               MaxHeight="40" />

                                    <StackPanel Grid.Row="3"
                                                Margin="0,12,0,0"
                                                Visibility="{Binding ProgressVisibility}">
                                        <ProgressBar Height="6"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding ProgressValue}"
                                                     Background="{DynamicResource UpdateDialog.Background}"
                                                     Foreground="{DynamicResource UpdateDialog.Accent}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource UpdateDialog.TextSecondary}"
                                                   Opacity="0.72"
                                                   Text="{Binding ProgressText}"
                                                   TextTrimming="None"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,16,0,0"
                Padding="0,16,0,0"
                BorderBrush="{DynamicResource UpdateDialog.WeakBorder}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                               Foreground="{DynamicResource UpdateDialog.TextSecondary}"
                               Opacity="0.72"
                               Text="{Binding SelectionSummary}"
                               Visibility="{Binding FooterInfoVisibility}" />
                    <Button Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Click="SecondaryButton_Click"
                            Content="{Binding SecondaryButtonText}"
                            Style="{StaticResource UpdateDialogTextButtonStyle}"
                            Visibility="{Binding SecondaryButtonVisibility}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Margin="0,0,10,0"
                            Click="CancelButton_Click"
                            Content="{Binding CancelButtonText}"
                            IsEnabled="{Binding CanCancel}"
                            Style="{StaticResource UpdateDialogSecondaryButtonStyle}" />
                    <Button Click="ConfirmButton_Click"
                            Content="{Binding ConfirmButtonText}"
                            IsEnabled="{Binding CanConfirm}"
                            Visibility="{Binding ConfirmButtonVisibility}"
                            Style="{StaticResource UpdateDialogPrimaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</base:BaseWindow>