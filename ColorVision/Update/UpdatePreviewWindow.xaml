<Window x:Class="ColorVision.Update.UpdatePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ColorVision.Update"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Width="960"
        Height="580"
        MinWidth="820"
        MinHeight="480"
        Background="{StaticResource GlobalBackground}"
        mc:Ignorable="d">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="22"
                       FontWeight="Bold"
                       Text="{Binding Heading}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,10,0,0"
                       Opacity="0.88"
                       Text="{Binding Summary}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{DynamicResource defaultgreyColor}"
                    BorderThickness="1"
                    CornerRadius="6">
                <ListView ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:UpdatePreviewItem}">
                            <Border Margin="6" Padding="10" BorderBrush="{DynamicResource defaultgreyColor}" BorderThickness="1" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Opacity="0.72"
                                               Text="{Binding Category}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Opacity="0.88"
                                               Text="{Binding VersionSummary}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Opacity="0.78"
                                               Text="{Binding Summary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource defaultgreyColor}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,12"
                               FontSize="16"
                               FontWeight="Bold"
                               Text="{Binding SelectedItemTitle}" />
                    <TextBox Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource GlobalTextBrush}"
                             IsReadOnly="True"
                             Text="{Binding SelectedDetailText}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </DockPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Margin="0,0,8,0"
                    Padding="14,6"
                    Click="SecondaryButton_Click"
                    Content="{Binding SecondaryButtonText}"
                    Visibility="{Binding SecondaryButtonVisibility}" />
            <Button Margin="0,0,8,0"
                    Padding="14,6"
                    Click="CancelButton_Click"
                    Content="{Binding CancelButtonText}" />
            <Button Padding="16,6"
                    Click="ConfirmButton_Click"
                    Content="{Binding ConfirmButtonText}" />
        </StackPanel>
    </Grid>
</Window>