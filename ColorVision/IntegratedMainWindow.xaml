<Window x:Class="ColorVision.IntegratedMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:input="clr-namespace:System.Windows.Input;assembly=netstandard"
        xmlns:local="clr-namespace:ColorVision"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:ColorVision.Properties"
        xmlns:search="clr-namespace:ColorVision.UI.Serach;assembly=ColorVision.UI"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:xcad="https://github.com/Dirkster99/AvalonDock"
        xmlns:xcadctrl="clr-namespace:AvalonDock.Controls;assembly=AvalonDock"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:MainWindowConfig}"
        Title="" Width="1280" Height="720"
        Icon="pack://application:,,,/ColorVision.Themes;component/Assets/Image/ColorVision.ico"
        Background="{DynamicResource GlobalBackground}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Initialized="Window_Initialized">
    <Window.Resources>
        <Style x:Key="TopChromeButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource GlobalTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource ButtonBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TopChromeCaptionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource CaptionButtonForeground}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}"
                                       TextOptions.TextFormattingMode="Display"
                                       TextOptions.TextRenderingMode="Aliased" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonBorderBrush}" />
                </Trigger>
                <Trigger Property="Tag" Value="ChromeHover">
                    <Setter Property="Background" Value="{DynamicResource ButtonBorderBrush}" />
                </Trigger>
                <Trigger Property="Tag" Value="ChromePressed">
                    <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush1}" />
                    <Setter Property="Opacity" Value="0.72" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TopChromeCloseButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TopChromeCaptionButtonStyle}">
            <Setter Property="Width" Value="52" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#9D1D12" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="MainWindowFrameBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="WorkspaceShellBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource GlobalBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GlobalBorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style TargetType="{x:Type xcadctrl:LayoutGridResizerControl}">
            <Setter Property="Background" Value="{DynamicResource GlobalBorderBrush}" />
        </Style>
        <DataTemplate x:Key="DocumentHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="{DynamicResource GlobalTextBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Border x:Name="WindowFrameBorder" Style="{StaticResource MainWindowFrameBorderStyle}">
        <Grid x:Name="Root">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>
            <Border x:Name="TopChromeBar"
                    Grid.Row="0"
                    Background="{DynamicResource GlobalBackground}"
                    BorderBrush="{DynamicResource GlobalBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="0" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ApplicationIconButton"
                            Grid.Column="0"
                            Margin="6,0,4,0"
                            Click="ApplicationIconButton_Click"
                            Style="{StaticResource TopChromeButtonStyle}"
                            ToolTip="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                        <Image Width="16" Height="16" Source="{Binding Icon, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                    </Button>

                    <Menu x:Name="Menu1"
                          Grid.Column="1"
                          Padding="2,0"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Background="Transparent"
                          Foreground="{DynamicResource GlobalTextBrush}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True" />

                      <Grid x:Name="SearchHostGrid"
                          Grid.Column="2"
                          Margin="18,0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center">
                        <TextBlock x:Name="WindowTitleTextBlock"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource GlobalTextBrush}"
                                   IsHitTestVisible="False"
                                   Opacity="0.62"
                                   Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                   TextTrimming="CharacterEllipsis" />
                        <search:SearchControl x:Name="SearchControl1"
                                              Margin="0"
                                              MinWidth="260"
                                              MaxWidth="360"
                                              SearchBoxHeight="30"
                                              Width="{Binding ActualWidth, ElementName=SearchHostGrid}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    </Grid>

                    <StackPanel x:Name="RightMenuItemPanel"
                                Grid.Column="3"
                                Margin="8,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True" />

                    <StackPanel x:Name="WindowCommandButtonsPanel"
                                Grid.Column="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                Orientation="Horizontal"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinimizeButton"
                                Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                Content="&#xE949;"
                                Style="{StaticResource TopChromeCaptionButtonStyle}"
                                ToolTip="Minimize" />
                        <Grid>
                            <Button x:Name="MaximizeButton"
                                    Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                                    Content="&#xE739;"
                                    Style="{StaticResource TopChromeCaptionButtonStyle}"
                                    ToolTip="Maximize" />
                            <Button x:Name="RestoreButton"
                                    Command="{x:Static SystemCommands.RestoreWindowCommand}"
                                    Content="&#xE923;"
                                    Style="{StaticResource TopChromeCaptionButtonStyle}"
                                    ToolTip="Restore"
                                    Visibility="Collapsed" />
                        </Grid>
                        <Button x:Name="CloseButton"
                                Command="{x:Static SystemCommands.CloseWindowCommand}"
                                Content="&#xE8BB;"
                                Style="{StaticResource TopChromeCloseButtonStyle}"
                                ToolTip="Close" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="WorkspaceShell"
                    Grid.Row="1"
                    Style="{StaticResource WorkspaceShellBorderStyle}">
                <xcad:DockingManager x:Name="DockingManager1"
                                     Margin="0"
                                     Padding="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     DocumentHeaderTemplate="{StaticResource DocumentHeaderTemplate}">
                    <xcad:LayoutRoot x:Name="_layoutRoot">
                        <xcad:LayoutPanel Orientation="Horizontal">
                            <xcad:LayoutAnchorablePaneGroup x:Name="LeftPaneGroup" DockWidth="303">
                                <xcad:LayoutAnchorablePane x:Name="LeftPane">
                                    <xcad:LayoutAnchorable Title="{x:Static properties:Resources.SolutionExplorer}" CanAutoHide="True" CanClose="True" CanFloat="True" ContentId="ProjectPanel">
                                        <Grid x:Name="ProjectPanelGrid" />
                                    </xcad:LayoutAnchorable>
                                    <xcad:LayoutAnchorable Title="{x:Static properties:Resources.DeviceControl}" CanAutoHide="True" CanClose="True" CanFloat="True" ContentId="AcquirePanel">
                                        <ScrollViewer x:Name="ScrollViewerDisplay"
                                                      Background="{DynamicResource GlobalBorderBrush1}"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <StackPanel x:Name="StackPanelSPD"
                                                        Width="{Binding ViewportWidth, ElementName=ScrollViewerDisplay}"
                                                        Margin="-2,5,0,0" />
                                        </ScrollViewer>
                                    </xcad:LayoutAnchorable>
                                </xcad:LayoutAnchorablePane>
                            </xcad:LayoutAnchorablePaneGroup>
                            <xcad:LayoutPanel Orientation="Vertical">
                                <xcad:LayoutDocumentPaneGroup>
                                    <xcad:LayoutDocumentPane x:Name="LayoutDocumentPane" />
                                </xcad:LayoutDocumentPaneGroup>
                            </xcad:LayoutPanel>
                        </xcad:LayoutPanel>
                    </xcad:LayoutRoot>
                </xcad:DockingManager>
            </Border>

            <Grid x:Name="StatusBarGrid"
                  Grid.Row="2"
                  Visibility="{Binding IsOpenStatusBar, Converter={StaticResource bool2VisibilityConverter}}" />
        </Grid>
    </Border>
</Window>